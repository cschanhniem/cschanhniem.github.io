{
  "comment_text": {
    "dhp159:1": "Accept Pali reading of <i lang='pi' translate='no'>attānaṁ</i> as accusative, but note the Prakrit variant <i lang='pi' translate='no'>attanā</i> in instrumental. ",
    "dhp159:3": "Read <i lang='pi' translate='no'>dametha</i> as third singular optative reflexive. "
  },
