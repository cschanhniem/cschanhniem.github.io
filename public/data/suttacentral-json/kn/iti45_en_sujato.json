  "root_text": {
    "iti45:0.1": "Itivuttaka 45 ",
    "iti45:0.2": "Dukanipāta ",
    "iti45:0.3": "Dutiyavagga ",
    "iti45:0.4": "Paṭisallānasutta ",
    "iti45:1.1": "Vuttañhetaṁ bhagavatā vuttamarahatāti me sutaṁ: ",
    "iti45:2.1": "“Paṭisallānārāmā, bhikkhave, viharatha paṭisallānaratā, ajjhattaṁ cetosamathamanuyuttā, anirākatajjhānā, vipassanāya samannāgatā, brūhetāro suññāgārānaṁ. ",
    "iti45:2.2": "Paṭisallānārāmānaṁ, bhikkhave, viharataṁ paṭisallānaratānaṁ ajjhattaṁ cetosamathamanuyuttānaṁ anirākatajjhānānaṁ vipassanāya samannāgatānaṁ brūhetānaṁ suññāgārānaṁ dvinnaṁ phalānaṁ aññataraṁ phalaṁ pāṭikaṅkhaṁ—",
    "iti45:2.3": "diṭṭheva dhamme aññā, sati vā upādisese anāgāmitā”ti. ",
    "iti45:2.4": "Etamatthaṁ bhagavā avoca. ",
    "iti45:2.5": "Tatthetaṁ iti vuccati: ",
    "iti45:3.1": "“Ye santacittā nipakā, ",
    "iti45:3.2": "satimanto ca jhāyino; ",
    "iti45:3.3": "Sammā dhammaṁ vipassanti, ",
    "iti45:3.4": "kāmesu anapekkhino. ",
    "iti45:4.1": "Appamādaratā santā, ",
    "iti45:4.2": "pamāde bhayadassino; ",
    "iti45:4.3": "Abhabbā parihānāya, ",
    "iti45:4.4": "nibbānasseva santike”ti. ",
    "iti45:5.1": "Ayampi attho vutto bhagavatā, iti me sutanti. ",
    "iti45:5.2": "Aṭṭhamaṁ. "
  },
  "translation_text": {
    "iti45:0.1": "So It Was Said 45 ",
    "iti45:0.2": "The Book of the Twos ",
    "iti45:0.3": "Chapter Two ",
    "iti45:0.4": "Retreat ",
    "iti45:1.1": "This was said by the Buddha, the Perfected One: that is what I heard. ",
    "iti45:2.1": "“Enjoy retreat, mendicants, love retreat. Be committed to inner serenity of the heart, don’t neglect absorption, be endowed with discernment, and frequent empty huts. ",
    "iti45:2.2": "A mendicant who enjoys retreat can expect one of two results: ",
    "iti45:2.3": "enlightenment in this very life, or if there’s something left over, non-return.” ",
    "iti45:2.4": "The Buddha spoke this matter. ",
    "iti45:2.5": "On this it is said: ",
    "iti45:3.1": "“With minds at peace, alert, ",
    "iti45:3.2": "mindful and meditative, ",
    "iti45:3.3": "they rightly discern the Dhamma, ",
    "iti45:3.4": "unconcerned for sensual pleasures. ",
    "iti45:4.1": "Delighting in diligence, peaceful, ",
    "iti45:4.2": "seeing fear in negligence, ",
    "iti45:4.3": "such a one can’t decline, ",
    "iti45:4.4": "and has drawn near to extinguishment.” ",
    "iti45:5.1": "This too is a matter that was spoken by the Blessed One: that is what I heard. "
  },
  "variant_text": {
    "iti45:2.1": "Paṭisallānārāmā → paṭisallāṇārāmā (mr) ",
    "iti45:3.2": "satimanto ca → satimantova (bj, mr) "
  },
