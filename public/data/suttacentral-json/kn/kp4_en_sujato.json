  "root_text": {
    "kp4:0.1": "Khuddakapāṭha 4 ",
    "kp4:0.2": "Kumārapañhā ",
    "kp4:1.1": "Ekaṁ nāma kiṁ? ",
    "kp4:1.2": "Sabbe sattā āhāraṭṭhitikā. ",
    "kp4:2.1": "Dve nāma kiṁ? ",
    "kp4:2.2": "Nāmañca rūpañca. ",
    "kp4:3.1": "Tīṇi nāma kiṁ? ",
    "kp4:3.2": "Tisso vedanā. ",
    "kp4:4.1": "Cattāri nāma kiṁ? ",
    "kp4:4.2": "Cattāri ariyasaccāni. ",
    "kp4:5.1": "Pañca nāma kiṁ? ",
    "kp4:5.2": "Pañcupādānakkhandhā. ",
    "kp4:6.1": "Cha nāma kiṁ? ",
    "kp4:6.2": "Cha ajjhattikāni āyatanāni. ",
    "kp4:7.1": "Satta nāma kiṁ? ",
    "kp4:7.2": "Satta bojjhaṅgā. ",
    "kp4:8.1": "Aṭṭha nāma kiṁ? ",
    "kp4:8.2": "Ariyo aṭṭhaṅgiko maggo. ",
    "kp4:9.1": "Nava nāma kiṁ? ",
    "kp4:9.2": "Nava sattāvāsā. ",
    "kp4:10.1": "Dasa nāma kiṁ? ",
    "kp4:10.2": "Dasahaṅgehi samannāgato “arahā”ti vuccatīti. ",
    "kp4:11.1": "Kumārapañhā. "
  },
  "translation_text": {
    "kp4:0.1": "Basic Passages 4 ",
    "kp4:0.2": "The Boy’s Questions ",
    "kp4:1.1": "What is the one? ",
    "kp4:1.2": "All sentient beings are sustained by food. ",
    "kp4:2.1": "What is the two? ",
    "kp4:2.2": "Name and form. ",
    "kp4:3.1": "What is the three? ",
    "kp4:3.2": "Three feelings. ",
    "kp4:4.1": "What is the four? ",
    "kp4:4.2": "Four noble truths. ",
    "kp4:5.1": "What is the five? ",
    "kp4:5.2": "Five grasping aggregates. ",
    "kp4:6.1": "What is the six? ",
    "kp4:6.2": "Six interior sense fields. ",
    "kp4:7.1": "What is the seven? ",
    "kp4:7.2": "Seven awakening factors. ",
    "kp4:8.1": "What is the eight? ",
    "kp4:8.2": "The noble eightfold path. ",
    "kp4:9.1": "What is the nine? ",
    "kp4:9.2": "Nine abodes of sentient beings. ",
    "kp4:10.1": "What is the ten? ",
    "kp4:10.2": "One endowed with ten factors is called “perfected”. "
  },
