  "root_text": {
    "dhp167:0.1": "Khuddakanikāya ",
    "dhp167:0.2": "Dhammapada ",
    "dhp167:0.3": "Lokavagga ",
    "dhp167:0.4": "Daharabhikkhuvatthu ",
    "dhp167:1": "Hīnaṁ dhammaṁ na seveyya, ",
    "dhp167:2": "pamādena na saṁvase; ",
    "dhp167:3": "Micchādiṭṭhiṁ na seveyya, ",
    "dhp167:4": "na siyā lokavaḍḍhano. ",
    "dhp168:0": "Suddhodanavatthu ",
    "dhp168:1": "Uttiṭṭhe nappamajjeyya, ",
    "dhp168:2": "dhammaṁ sucaritaṁ care; ",
    "dhp168:3": "Dhammacārī sukhaṁ seti, ",
    "dhp168:4": "asmiṁ loke paramhi ca. ",
    "dhp169:1": "Dhammaṁ care sucaritaṁ, ",
    "dhp169:2": "na naṁ duccaritaṁ care; ",
    "dhp169:3": "Dhammacārī sukhaṁ seti, ",
    "dhp169:4": "asmiṁ loke paramhi ca. ",
    "dhp170:0": "Pañcasatavipassakabhikkhuvatthu ",
    "dhp170:1": "Yathā pubbuḷakaṁ passe, ",
    "dhp170:2": "yathā passe marīcikaṁ; ",
    "dhp170:3": "Evaṁ lokaṁ avekkhantaṁ, ",
    "dhp170:4": "maccurājā na passati. ",
    "dhp171:0": "Abhayarājakumāravatthu ",
    "dhp171:1": "Etha passathimaṁ lokaṁ, ",
    "dhp171:2": "cittaṁ rājarathūpamaṁ; ",
    "dhp171:3": "Yattha bālā visīdanti, ",
    "dhp171:4": "natthi saṅgo vijānataṁ. ",
    "dhp172:0": "Sammajjanattheravatthu ",
    "dhp172:1": "Yo ca pubbe pamajjitvā, ",
    "dhp172:2": "pacchā so nappamajjati; ",
    "dhp172:3": "Somaṁ lokaṁ pabhāseti, ",
    "dhp172:4": "abbhā muttova candimā. ",
    "dhp173:0": "Aṅgulimālattheravatthu ",
    "dhp173:1": "Yassa pāpaṁ kataṁ kammaṁ, ",
    "dhp173:2": "kusalena pidhīyati; ",
    "dhp173:3": "Somaṁ lokaṁ pabhāseti, ",
    "dhp173:4": "abbhā muttova candimā. ",
    "dhp174:0": "Pesakāradhītāvatthu ",
    "dhp174:1": "Andhabhūto ayaṁ loko, ",
    "dhp174:2": "tanukettha vipassati; ",
    "dhp174:3": "Sakuṇo jālamuttova, ",
    "dhp174:4": "appo saggāya gacchati. ",
    "dhp175:0": "Tiṁsabhikkhuvatthu ",
    "dhp175:1": "Haṁsādiccapathe yanti, ",
    "dhp175:2": "ākāse yanti iddhiyā; ",
    "dhp175:3": "Nīyanti dhīrā lokamhā, ",
    "dhp175:4": "jetvā māraṁ savāhiniṁ. ",
    "dhp176:0": "Ciñcamāṇavikāvatthu ",
    "dhp176:1": "Ekaṁ dhammaṁ atītassa, ",
    "dhp176:2": "musāvādissa jantuno; ",
    "dhp176:3": "Vitiṇṇaparalokassa, ",
    "dhp176:4": "natthi pāpaṁ akāriyaṁ. ",
    "dhp177:0": "Asadisadānavatthu ",
    "dhp177:1": "Na ve kadariyā devalokaṁ vajanti, ",
    "dhp177:2": "Bālā have nappasaṁsanti dānaṁ; ",
    "dhp177:3": "Dhīro ca dānaṁ anumodamāno, ",
    "dhp177:4": "Teneva so hoti sukhī parattha. ",
    "dhp178:0": "Anāthapiṇḍikaputtakālavatthu ",
    "dhp178:1": "Pathabyā ekarajjena, ",
    "dhp178:2": "saggassa gamanena vā; ",
    "dhp178:3": "Sabbalokādhipaccena, ",
    "dhp178:4": "sotāpattiphalaṁ varaṁ. ",
    "dhp178:5": "Lokavaggo terasamo. "
  },
  "translation_text": {
    "dhp167:0.1": "Minor Collection ",
    "dhp167:0.2": "Sayings of the Dhamma 167–178 ",
    "dhp167:0.3": "13. The World ",
    "dhp167:0.4": "",
    "dhp167:1": "Don’t resort to lowly things, ",
    "dhp167:2": "don’t abide in negligence, ",
    "dhp167:3": "don’t resort to wrong views, ",
    "dhp167:4": "don’t perpetuate the world. ",
    "dhp168:0": "",
    "dhp168:1": "Get up, don’t be heedless, ",
    "dhp168:2": "live by principle, with good conduct. ",
    "dhp168:3": "For one of good conduct sleeps at ease, ",
    "dhp168:4": "in this world and the next. ",
    "dhp169:1": "Live by principle, with good conduct, ",
    "dhp169:2": "don’t conduct yourself badly. ",
    "dhp169:3": "For one of good conduct sleeps at ease, ",
    "dhp169:4": "in this world and the next. ",
    "dhp170:0": "",
    "dhp170:1": "Look upon the world ",
    "dhp170:2": "as a bubble ",
    "dhp170:3": "or a mirage, ",
    "dhp170:4": "then the King of Death won’t see you. ",
    "dhp171:0": "",
    "dhp171:1": "Come, see this world decked out ",
    "dhp171:2": "like a fancy royal chariot. ",
    "dhp171:3": "Here fools founder, ",
    "dhp171:4": "but the discerning are not chained. ",
    "dhp172:0": "",
    "dhp172:1": "He who once was heedless, ",
    "dhp172:2": "but turned to heedfulness, ",
    "dhp172:3": "lights up the world ",
    "dhp172:4": "like the moon freed from clouds. ",
    "dhp173:0": "",
    "dhp173:1": "Someone whose bad deed ",
    "dhp173:2": "is supplanted by the good, ",
    "dhp173:3": "lights up the world, ",
    "dhp173:4": "like the moon freed from clouds. ",
    "dhp174:0": "",
    "dhp174:1": "Blind is the world, ",
    "dhp174:2": "few are those who clearly see. ",
    "dhp174:3": "Only a handful go to heaven, ",
    "dhp174:4": "like a bird freed from a net. ",
    "dhp175:0": "",
    "dhp175:1": "Swans fly by the sun’s path, ",
    "dhp175:2": "psychic sages fly through space. ",
    "dhp175:3": "The attentive leave the world, ",
    "dhp175:4": "having vanquished Māra with his legions. ",
    "dhp176:0": "",
    "dhp176:1": "When a personage, spurning the hereafter, ",
    "dhp176:2": "transgresses in just one thing—",
    "dhp176:3": "lying—",
    "dhp176:4": "there is no evil they would not do. ",
    "dhp177:0": "",
    "dhp177:1": "The miserly don’t ascend to heaven, ",
    "dhp177:2": "it takes a fool to not praise giving. ",
    "dhp177:3": "The attentive celebrate giving, ",
    "dhp177:4": "and so find happiness in the hereafter. ",
    "dhp178:0": "",
    "dhp178:1": "The fruit of stream-entry is better ",
    "dhp178:2": "than being the one king of the earth, ",
    "dhp178:3": "than going to heaven, ",
    "dhp178:4": "than lordship over all the world. ",
    "dhp178:5": ""
  },
  "variant_text": {
    "dhp170:1": "pubbuḷakaṁ → bubbulakaṁ (bj, pts2ed); bubbuḷakaṁ (pts1ed) ",
    "dhp173:2": "pidhīyati → pithīyati (bj, sya-all, pts2ed); piṭhīyati (pts1ed) ",
    "dhp174:1": "Andhabhūto → andhībhūto (mr) ",
    "dhp175:4": "savāhiniṁ → savāhanaṁ (sya-all, pts1ed, pts2ed, mr) "
  },
