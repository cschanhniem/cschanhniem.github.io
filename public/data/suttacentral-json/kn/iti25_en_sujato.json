  "root_text": {
    "iti25:0.1": "Itivuttaka 25 ",
    "iti25:0.2": "Ekakanipāta ",
    "iti25:0.3": "Tatiyavagga ",
    "iti25:0.4": "Musāvādasutta ",
    "iti25:1.1": "Vuttañhetaṁ bhagavatā vuttamarahatāti me sutaṁ: ",
    "iti25:2.1": "“Ekadhammaṁ atītassa, bhikkhave, purisapuggalassa nāhaṁ tassa kiñci pāpakammaṁ akaraṇīyanti vadāmi. ",
    "iti25:2.2": "Katamaṁ ekadhammaṁ? ",
    "iti25:2.3": "Yadidaṁ, bhikkhave, sampajānamusāvādo”ti. ",
    "iti25:2.4": "Etamatthaṁ bhagavā avoca. ",
    "iti25:2.5": "Tatthetaṁ iti vuccati: ",
    "iti25:3.1": "“Ekadhammaṁ atītassa, ",
    "iti25:3.2": "musāvādissa jantuno; ",
    "iti25:3.3": "Vitiṇṇaparalokassa, ",
    "iti25:3.4": "natthi pāpaṁ akāriyan”ti. ",
    "iti25:4.1": "Ayampi attho vutto bhagavatā, iti me sutanti. ",
    "iti25:4.2": "Pañcamaṁ. "
  },
  "translation_text": {
    "iti25:0.1": "So It Was Said 25 ",
    "iti25:0.2": "The Book of the Ones ",
    "iti25:0.3": "Chapter Three ",
    "iti25:0.4": "Lying ",
    "iti25:1.1": "This was said by the Buddha, the Perfected One: that is what I heard. ",
    "iti25:2.1": "“Mendicants, for an individual person who transgresses in one thing, there is no bad deed they would not do, I say. ",
    "iti25:2.2": "What one thing? ",
    "iti25:2.3": "It is this: telling a deliberate lie.” ",
    "iti25:2.4": "The Buddha spoke this matter. ",
    "iti25:2.5": "On this it is said: ",
    "iti25:3.1": "“When a personage, spurning the hereafter, ",
    "iti25:3.2": "transgresses in just one thing—",
    "iti25:3.3": "lying—",
    "iti25:3.4": "there is no evil they would not do.” ",
    "iti25:4.1": "This too is a matter that was spoken by the Blessed One: that is what I heard. "
  },
  "variant_text": {
    "iti25:2.1": "Ekadhammaṁ → ekaṁ dhammaṁ (bj) ",
    "iti25:2.3": "Yadidaṁ → yathayidaṁ (bj, sya-all, pts-vp-pli1, mr) "
  },
