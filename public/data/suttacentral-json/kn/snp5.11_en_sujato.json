  "root_text": {
    "snp5.11:0.1": "Sutta Nipāta 5.11 ",
    "snp5.11:0.2": "Kappamāṇavapucchā ",
    "snp5.11:1.1": "“Majjhe sarasmiṁ tiṭṭhataṁ, ",
    "snp5.11:1.2": "(iccāyasmā kappo) ",
    "snp5.11:1.3": "Oghe jāte mahabbhaye; ",
    "snp5.11:1.4": "Jarāmaccuparetānaṁ, ",
    "snp5.11:1.5": "Dīpaṁ pabrūhi mārisa; ",
    "snp5.11:1.6": "Tvañca me dīpamakkhāhi, ",
    "snp5.11:1.7": "Yathāyidaṁ nāparaṁ siyā”. ",
    "snp5.11:2.1": "“Majjhe sarasmiṁ tiṭṭhataṁ, ",
    "snp5.11:2.2": "(kappāti bhagavā) ",
    "snp5.11:2.3": "Oghe jāte mahabbhaye; ",
    "snp5.11:2.4": "Jarāmaccuparetānaṁ, ",
    "snp5.11:2.5": "Dīpaṁ pabrūmi kappa te. ",
    "snp5.11:3.1": "Akiñcanaṁ anādānaṁ, ",
    "snp5.11:3.2": "etaṁ dīpaṁ anāparaṁ; ",
    "snp5.11:3.3": "Nibbānaṁ iti naṁ brūmi, ",
    "snp5.11:3.4": "jarāmaccuparikkhayaṁ. ",
    "snp5.11:4.1": "Etadaññāya ye satā, ",
    "snp5.11:4.2": "Diṭṭhadhammābhinibbutā; ",
    "snp5.11:4.3": "Na te māravasānugā, ",
    "snp5.11:4.4": "Na te mārassa paddhagū”ti. ",
    "snp5.11:4.5": "Kappamāṇavapucchā dasamā. "
  },
  "translation_text": {
    "snp5.11:0.1": "Anthology of Discourses 5.11 ",
    "snp5.11:0.2": "The Questions of Kappa ",
    "snp5.11:1.1": "“For those overwhelmed by old age and death,” ",
    "snp5.11:1.2": "said Venerable Kappa, ",
    "snp5.11:1.3": "“stuck mid-stream ",
    "snp5.11:1.4": "as the terrifying flood arises, ",
    "snp5.11:1.5": "tell me an island, good fellow. ",
    "snp5.11:1.6": "Explain to me an island ",
    "snp5.11:1.7": "so this may occur no further.” ",
    "snp5.11:2.1": "“For those overwhelmed by old age and death,” ",
    "snp5.11:2.2": "replied the Buddha, ",
    "snp5.11:2.3": "“stuck mid-stream ",
    "snp5.11:2.4": "as the terrifying flood arises, ",
    "snp5.11:2.5": "I shall tell you an island, Kappa. ",
    "snp5.11:3.1": "Having nothing, taking nothing: ",
    "snp5.11:3.2": "this is the island with nothing further. ",
    "snp5.11:3.3": "I call it extinguishment, ",
    "snp5.11:3.4": "the ending of old age and death. ",
    "snp5.11:4.1": "Those who have fully understood this, mindful, ",
    "snp5.11:4.2": "are quenched in this very life. ",
    "snp5.11:4.3": "They don’t fall under Māra’s sway, ",
    "snp5.11:4.4": "nor are they his footmen.” "
  },
  "variant_text": {
    "snp5.11:3.3": "Nibbānaṁ iti → nibbānamiti (bj) ",
    "snp5.11:4.4": "paddhagū”ti → paṭṭhagūti (sya-all, mr) "
  },
