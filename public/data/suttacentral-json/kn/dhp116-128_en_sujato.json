  "root_text": {
    "dhp116:0.1": "Khuddakanikāya ",
    "dhp116:0.2": "Dhammapada ",
    "dhp116:0.3": "Pāpavagga ",
    "dhp116:0.4": "Cūḷekasāṭakabrāhmaṇavatthu ",
    "dhp116:1": "Abhittharetha kalyāṇe, ",
    "dhp116:2": "pāpā cittaṁ nivāraye; ",
    "dhp116:3": "Dandhañhi karoto puññaṁ, ",
    "dhp116:4": "pāpasmiṁ ramatī mano. ",
    "dhp117:0": "Seyyasakattheravatthu ",
    "dhp117:1": "Pāpañce puriso kayirā, ",
    "dhp117:2": "Na naṁ kayirā punappunaṁ; ",
    "dhp117:3": "Na tamhi chandaṁ kayirātha, ",
    "dhp117:4": "Dukkho pāpassa uccayo. ",
    "dhp118:0": "Lājadevadhītāvatthu ",
    "dhp118:1": "Puññañce puriso kayirā, ",
    "dhp118:2": "kayirā naṁ punappunaṁ; ",
    "dhp118:3": "Tamhi chandaṁ kayirātha, ",
    "dhp118:4": "sukho puññassa uccayo. ",
    "dhp119:0": "Anāthapiṇḍikaseṭṭhivatthu ",
    "dhp119:1": "Pāpopi passati bhadraṁ, ",
    "dhp119:2": "Yāva pāpaṁ na paccati; ",
    "dhp119:3": "Yadā ca paccati pāpaṁ, ",
    "dhp119:4": "Atha pāpo pāpāni passati. ",
    "dhp120:1": "Bhadropi passati pāpaṁ, ",
    "dhp120:2": "Yāva bhadraṁ na paccati; ",
    "dhp120:3": "Yadā ca paccati bhadraṁ, ",
    "dhp120:4": "Atha bhadro bhadrāni passati. ",
    "dhp121:0": "Asaññataparikkhāravatthu ",
    "dhp121:1": "Māvamaññetha pāpassa, ",
    "dhp121:2": "na mantaṁ āgamissati; ",
    "dhp121:3": "Udabindunipātena, ",
    "dhp121:4": "udakumbhopi pūrati; ",
    "dhp121:5": "Bālo pūrati pāpassa, ",
    "dhp121:6": "thokaṁ thokampi ācinaṁ. ",
    "dhp122:0": "Biḷālapādakaseṭṭhivatthu ",
    "dhp122:1": "Māvamaññetha puññassa, ",
    "dhp122:2": "na mandaṁ āgamissati; ",
    "dhp122:3": "Udabindunipātena, ",
    "dhp122:4": "udakumbhopi pūrati; ",
    "dhp122:5": "Dhīro pūrati puññassa, ",
    "dhp122:6": "thokaṁ thokampi ācinaṁ. ",
    "dhp123:0": "Mahādhanavāṇijavatthu ",
    "dhp123:1": "Vāṇijova bhayaṁ maggaṁ, ",
    "dhp123:2": "appasattho mahaddhano; ",
    "dhp123:3": "Visaṁ jīvitukāmova, ",
    "dhp123:4": "pāpāni parivajjaye. ",
    "dhp124:0": "Kukkuṭamittanesādavatthu ",
    "dhp124:1": "Pāṇimhi ce vaṇo nāssa, ",
    "dhp124:2": "hareyya pāṇinā visaṁ; ",
    "dhp124:3": "Nābbaṇaṁ visamanveti, ",
    "dhp124:4": "natthi pāpaṁ akubbato. ",
    "dhp125:0": "Kokasunakhaluddakavatthu ",
    "dhp125:1": "Yo appaduṭṭhassa narassa dussati, ",
    "dhp125:2": "Suddhassa posassa anaṅgaṇassa; ",
    "dhp125:3": "Tameva bālaṁ pacceti pāpaṁ, ",
    "dhp125:4": "Sukhumo rajo paṭivātaṁva khitto. ",
    "dhp126:0": "Maṇikārakulūpakatissattheravatthu ",
    "dhp126:1": "Gabbhameke uppajjanti, ",
    "dhp126:2": "nirayaṁ pāpakammino; ",
    "dhp126:3": "Saggaṁ sugatino yanti, ",
    "dhp126:4": "parinibbanti anāsavā. ",
    "dhp127:0": "Tayojanavatthu ",
    "dhp127:1": "Na antalikkhe na samuddamajjhe, ",
    "dhp127:2": "Na pabbatānaṁ vivaraṁ pavissa; ",
    "dhp127:3": "Na vijjatī so jagatippadeso, ",
    "dhp127:4": "Yatthaṭṭhito mucceyya pāpakammā. ",
    "dhp128:0": "Suppabuddhasakyavatthu ",
    "dhp128:1": "Na antalikkhe na samuddamajjhe, ",
    "dhp128:2": "Na pabbatānaṁ vivaraṁ pavissa; ",
    "dhp128:3": "Na vijjatī so jagatippadeso, ",
    "dhp128:4": "Yatthaṭṭhitaṁ nappasaheyya maccu. ",
    "dhp128:5": "Pāpavaggo navamo. "
  },
  "translation_text": {
    "dhp116:0.1": "Minor Collection ",
    "dhp116:0.2": "Sayings of the Dhamma 116–128 ",
    "dhp116:0.3": "9. Wickedness ",
    "dhp116:1": "Rush to do good, ",
    "dhp116:2": "shield your mind from evil; ",
    "dhp116:3": "for when you’re slow to do good, ",
    "dhp116:4": "your thoughts delight in wickedness. ",
    "dhp117:1": "If you do something bad, ",
    "dhp117:2": "don’t do it again and again, ",
    "dhp117:3": "don’t set your heart on it, ",
    "dhp117:4": "for piling up evil is suffering. ",
    "dhp118:1": "If you do something good, ",
    "dhp118:2": "do it again and again, ",
    "dhp118:3": "set your heart on it, ",
    "dhp118:4": "for piling up goodness is joyful. ",
    "dhp119:1": "Even the wicked see good things, ",
    "dhp119:2": "so long as their wickedness has not ripened. ",
    "dhp119:3": "But as soon as that wickedness ripens, ",
    "dhp119:4": "then the wicked see wicked things. ",
    "dhp120:1": "Even the good see wicked things, ",
    "dhp120:2": "so long as their goodness has not ripened. ",
    "dhp120:3": "But as soon as that goodness ripens, ",
    "dhp120:4": "then the good see good things. ",
    "dhp121:1": "Think not lightly of evil, ",
    "dhp121:2": "that it won’t come back to you. ",
    "dhp121:3": "The pot is filled with water ",
    "dhp121:4": "falling drop by drop; ",
    "dhp121:5": "the fool is filled with wickedness ",
    "dhp121:6": "piled up bit by bit. ",
    "dhp122:1": "Think not lightly of goodness, ",
    "dhp122:2": "that it won’t come back to you. ",
    "dhp122:3": "The pot is filled with water ",
    "dhp122:4": "falling drop by drop; ",
    "dhp122:5": "the attentive one is filled with goodness ",
    "dhp122:6": "piled up bit by bit. ",
    "dhp123:1": "Avoid wickedness, ",
    "dhp123:2": "as a merchant with rich cargo and small escort ",
    "dhp123:3": "would avoid a dangerous road, ",
    "dhp123:4": "or one who loves life would avoid drinking poison. ",
    "dhp124:1": "You can carry poison in your hand ",
    "dhp124:2": "if it has no wound, ",
    "dhp124:3": "for poison does not infect without a wound; ",
    "dhp124:4": "nothing bad happens unless you do bad. ",
    "dhp125:1": "Whoever wrongs a man who has done no wrong, ",
    "dhp125:2": "a pure man who has not a blemish, ",
    "dhp125:3": "the evil backfires on the fool, ",
    "dhp125:4": "like fine dust thrown upwind. ",
    "dhp126:1": "Some are born in a womb; ",
    "dhp126:2": "evil-doers go to hell; ",
    "dhp126:3": "the virtuous go to heaven; ",
    "dhp126:4": "the undefiled are fully extinguished. ",
    "dhp127:1": "Not in midair, nor mid-ocean, ",
    "dhp127:2": "nor hiding in a mountain cleft; ",
    "dhp127:3": "you’ll find no place on the planet ",
    "dhp127:4": "to escape your wicked deeds. ",
    "dhp128:1": "Not in midair, nor mid-ocean, ",
    "dhp128:2": "nor hiding in a mountain cleft; ",
    "dhp128:3": "you’ll find no place on the planet ",
    "dhp128:4": "where you won’t be vanquished by death. "
  },
  "variant_text": {
    "dhp117:2": "Na naṁ → na taṁ (bj, pts1ed, pts2ed) ",
    "dhp118:2": "kayirā naṁ → kayirāthetaṁ (bj); kayirāthenaṁ (sya-all, pts1ed, pts2ed) ",
    "dhp119:4": "Atha pāpo pāpāni → atha pāpāni (?) ",
    "dhp120:4": "bhadro bhadrāni → atha bhadrāni (?) ",
    "dhp121:1": "Māvamaññetha → māpamaññetha (bj); māppamaññetha (pts1ed, pts2ed) ",
    "dhp121:2": "na mantaṁ → na mattaṁ (sya-all) ",
    "dhp121:4": "pūrati → pūrati bālo (bj, mr); āpūrati bālo (sya-all) ",
    "dhp121:6": "thokaṁ thokampi → thokathokampi (bj, pts1ed, pts2ed) ",
    "dhp127:2": "pavissa → pavīsaṁ (sya-all) ",
    "dhp127:3": "Na vijjatī → na vijjati (bj, mr) ",
    "dhp127:4": "Yatthaṭṭhito → yatraṭṭhito (sya-all) ",
    "dhp128:4": "Yatthaṭṭhitaṁ → yatraṭṭhitaṁ (sya-all) "
  },
