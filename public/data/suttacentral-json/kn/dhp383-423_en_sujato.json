  "root_text": {
    "dhp383:0.1": "Khuddakanikāya ",
    "dhp383:0.2": "Dhammapada ",
    "dhp383:0.3": "Brāhmaṇavagga ",
    "dhp383:0.4": "Pasādabahulabrāhmaṇavatthu ",
    "dhp383:1": "Chinda sotaṁ parakkamma, ",
    "dhp383:2": "kāme panuda brāhmaṇa; ",
    "dhp383:3": "Saṅkhārānaṁ khayaṁ ñatvā, ",
    "dhp383:4": "akataññūsi brāhmaṇa. ",
    "dhp384:0": "Sambahulabhikkhuvatthu ",
    "dhp384:1": "Yadā dvayesu dhammesu, ",
    "dhp384:2": "pāragū hoti brāhmaṇo; ",
    "dhp384:3": "Athassa sabbe saṁyogā, ",
    "dhp384:4": "atthaṁ gacchanti jānato. ",
    "dhp385:0": "Māravatthu ",
    "dhp385:1": "Yassa pāraṁ apāraṁ vā, ",
    "dhp385:2": "pārāpāraṁ na vijjati; ",
    "dhp385:3": "Vītaddaraṁ visaṁyuttaṁ, ",
    "dhp385:4": "tamahaṁ brūmi brāhmaṇaṁ. ",
    "dhp386:0": "Aññatarabrāhmaṇavatthu ",
    "dhp386:1": "Jhāyiṁ virajamāsīnaṁ, ",
    "dhp386:2": "katakiccamanāsavaṁ; ",
    "dhp386:3": "Uttamatthamanuppattaṁ, ",
    "dhp386:4": "tamahaṁ brūmi brāhmaṇaṁ. ",
    "dhp387:0": "Ānandattheravatthu ",
    "dhp387:1": "Divā tapati ādicco, ",
    "dhp387:2": "rattimābhāti candimā; ",
    "dhp387:3": "Sannaddho khattiyo tapati, ",
    "dhp387:4": "jhāyī tapati brāhmaṇo; ",
    "dhp387:5": "Atha sabbamahorattiṁ, ",
    "dhp387:6": "buddho tapati tejasā. ",
    "dhp388:0": "Aññatarabrāhmaṇapabbajitavatthu ",
    "dhp388:1": "Bāhitapāpoti brāhmaṇo, ",
    "dhp388:2": "Samacariyā samaṇoti vuccati; ",
    "dhp388:3": "Pabbājayamattano malaṁ, ",
    "dhp388:4": "Tasmā “pabbajito”ti vuccati. ",
    "dhp389:0": "Sāriputtattheravatthu ",
    "dhp389:1": "Na brāhmaṇassa pahareyya, ",
    "dhp389:2": "nāssa muñcetha brāhmaṇo; ",
    "dhp389:3": "Dhī brāhmaṇassa hantāraṁ, ",
    "dhp389:4": "tato dhī yassa muñcati. ",
    "dhp390:1": "Na brāhmaṇassetadakiñci seyyo, ",
    "dhp390:2": "Yadā nisedho manaso piyehi; ",
    "dhp390:3": "Yato yato hiṁsamano nivattati, ",
    "dhp390:4": "Tato tato sammatimeva dukkhaṁ. ",
    "dhp391:0": "Mahāpajāpatigotamīvatthu ",
    "dhp391:1": "Yassa kāyena vācāya, ",
    "dhp391:2": "manasā natthi dukkaṭaṁ; ",
    "dhp391:3": "Saṁvutaṁ tīhi ṭhānehi, ",
    "dhp391:4": "tamahaṁ brūmi brāhmaṇaṁ. ",
    "dhp392:0": "Sāriputtattheravatthu ",
    "dhp392:1": "Yamhā dhammaṁ vijāneyya, ",
    "dhp392:2": "sammāsambuddhadesitaṁ; ",
    "dhp392:3": "Sakkaccaṁ taṁ namasseyya, ",
    "dhp392:4": "aggihuttaṁva brāhmaṇo. ",
    "dhp393:0": "Jaṭilabrāhmaṇavatthu ",
    "dhp393:1": "Na jaṭāhi na gottena, ",
    "dhp393:2": "na jaccā hoti brāhmaṇo; ",
    "dhp393:3": "Yamhi saccañca dhammo ca, ",
    "dhp393:4": "so sucī so ca brāhmaṇo. ",
    "dhp394:0": "Kuhakabrāhmaṇavatthu ",
    "dhp394:1": "Kiṁ te jaṭāhi dummedha, ",
    "dhp394:2": "kiṁ te ajinasāṭiyā; ",
    "dhp394:3": "Abbhantaraṁ te gahanaṁ, ",
    "dhp394:4": "bāhiraṁ parimajjasi. ",
    "dhp395:0": "Kisāgotamīvatthu ",
    "dhp395:1": "Paṁsukūladharaṁ jantuṁ, ",
    "dhp395:2": "kisaṁ dhamanisanthataṁ; ",
    "dhp395:3": "Ekaṁ vanasmiṁ jhāyantaṁ, ",
    "dhp395:4": "tamahaṁ brūmi brāhmaṇaṁ. ",
    "dhp396:0": "Ekabrāhmaṇavatthu ",
    "dhp396:1": "Na cāhaṁ brāhmaṇaṁ brūmi, ",
    "dhp396:2": "yonijaṁ mattisambhavaṁ; ",
    "dhp396:3": "Bhovādi nāma so hoti, ",
    "dhp396:4": "sace hoti sakiñcano; ",
    "dhp396:5": "Akiñcanaṁ anādānaṁ, ",
    "dhp396:6": "tamahaṁ brūmi brāhmaṇaṁ. ",
    "dhp397:0": "Uggasenaseṭṭhiputtavatthu ",
    "dhp397:1": "Sabbasaṁyojanaṁ chetvā, ",
    "dhp397:2": "yo ve na paritassati; ",
    "dhp397:3": "Saṅgātigaṁ visaṁyuttaṁ, ",
    "dhp397:4": "tamahaṁ brūmi brāhmaṇaṁ. ",
    "dhp398:0": "Dvebrāhmaṇavatthu ",
    "dhp398:1": "Chetvā naddhiṁ varattañca, ",
    "dhp398:2": "sandānaṁ sahanukkamaṁ; ",
    "dhp398:3": "Ukkhittapalighaṁ buddhaṁ, ",
    "dhp398:4": "tamahaṁ brūmi brāhmaṇaṁ. ",
    "dhp399:0": "Akkosakabhāradvājavatthu ",
    "dhp399:1": "Akkosaṁ vadhabandhañca, ",
    "dhp399:2": "aduṭṭho yo titikkhati; ",
    "dhp399:3": "Khantībalaṁ balānīkaṁ, ",
    "dhp399:4": "tamahaṁ brūmi brāhmaṇaṁ. ",
    "dhp400:0": "Sāriputtattheravatthu ",
    "dhp400:1": "Akkodhanaṁ vatavantaṁ, ",
    "dhp400:2": "sīlavantaṁ anussadaṁ; ",
    "dhp400:3": "Dantaṁ antimasārīraṁ, ",
    "dhp400:4": "tamahaṁ brūmi brāhmaṇaṁ. ",
    "dhp401:0": "Uppalavaṇṇāttherīvatthu ",
    "dhp401:1": "Vāri pokkharapatteva, ",
    "dhp401:2": "āraggeriva sāsapo; ",
    "dhp401:3": "Yo na limpati kāmesu, ",
    "dhp401:4": "tamahaṁ brūmi brāhmaṇaṁ. ",
    "dhp402:0": "Aññatarabrāhmaṇavatthu ",
    "dhp402:1": "Yo dukkhassa pajānāti, ",
    "dhp402:2": "idheva khayamattano; ",
    "dhp402:3": "Pannabhāraṁ visaṁyuttaṁ, ",
    "dhp402:4": "tamahaṁ brūmi brāhmaṇaṁ. ",
    "dhp403:0": "Khemābhikkhunīvatthu ",
    "dhp403:1": "Gambhīrapaññaṁ medhāviṁ, ",
    "dhp403:2": "maggāmaggassa kovidaṁ; ",
    "dhp403:3": "Uttamatthamanuppattaṁ, ",
    "dhp403:4": "tamahaṁ brūmi brāhmaṇaṁ. ",
    "dhp404:0": "Pabbhāravāsitissattheravatthu ",
    "dhp404:1": "Asaṁsaṭṭhaṁ gahaṭṭhehi, ",
    "dhp404:2": "anāgārehi cūbhayaṁ; ",
    "dhp404:3": "Anokasārimappicchaṁ, ",
    "dhp404:4": "tamahaṁ brūmi brāhmaṇaṁ. ",
    "dhp405:0": "Aññatarabhikkhuvatthu ",
    "dhp405:1": "Nidhāya daṇḍaṁ bhūtesu, ",
    "dhp405:2": "tasesu thāvaresu ca; ",
    "dhp405:3": "Yo na hanti na ghāteti, ",
    "dhp405:4": "tamahaṁ brūmi brāhmaṇaṁ. ",
    "dhp406:0": "Sāmaṇerānaṁvatthu ",
    "dhp406:1": "Aviruddhaṁ viruddhesu, ",
    "dhp406:2": "attadaṇḍesu nibbutaṁ; ",
    "dhp406:3": "Sādānesu anādānaṁ, ",
    "dhp406:4": "tamahaṁ brūmi brāhmaṇaṁ. ",
    "dhp407:0": "Mahāpanthakattheravatthu ",
    "dhp407:1": "Yassa rāgo ca doso ca, ",
    "dhp407:2": "māno makkho ca pātito; ",
    "dhp407:3": "Sāsaporiva āraggā, ",
    "dhp407:4": "tamahaṁ brūmi brāhmaṇaṁ. ",
    "dhp408:0": "Pilindavacchattheravatthu ",
    "dhp408:1": "Akakkasaṁ viññāpaniṁ, ",
    "dhp408:2": "giraṁ saccamudīraye; ",
    "dhp408:3": "Yāya nābhisaje kañci, ",
    "dhp408:4": "tamahaṁ brūmi brāhmaṇaṁ. ",
    "dhp409:0": "Aññatarattheravatthu ",
    "dhp409:1": "Yodha dīghaṁ va rassaṁ vā, ",
    "dhp409:2": "aṇuṁ thūlaṁ subhāsubhaṁ; ",
    "dhp409:3": "Loke adinnaṁ nādiyati, ",
    "dhp409:4": "tamahaṁ brūmi brāhmaṇaṁ. ",
    "dhp410:0": "Sāriputtattheravatthu ",
    "dhp410:1": "Āsā yassa na vijjanti, ",
    "dhp410:2": "asmiṁ loke paramhi ca; ",
    "dhp410:3": "Nirāsāsaṁ visaṁyuttaṁ, ",
    "dhp410:4": "tamahaṁ brūmi brāhmaṇaṁ. ",
    "dhp411:0": "Mahāmoggallānattheravatthu ",
    "dhp411:1": "Yassālayā na vijjanti, ",
    "dhp411:2": "aññāya akathaṅkathī; ",
    "dhp411:3": "Amatogadhamanuppattaṁ, ",
    "dhp411:4": "tamahaṁ brūmi brāhmaṇaṁ. ",
    "dhp412:0": "Revatattheravatthu ",
    "dhp412:1": "Yodha puññañca pāpañca, ",
    "dhp412:2": "ubho saṅgamupaccagā; ",
    "dhp412:3": "Asokaṁ virajaṁ suddhaṁ, ",
    "dhp412:4": "tamahaṁ brūmi brāhmaṇaṁ. ",
    "dhp413:0": "Candābhattheravatthu ",
    "dhp413:1": "Candaṁva vimalaṁ suddhaṁ, ",
    "dhp413:2": "vippasannamanāvilaṁ; ",
    "dhp413:3": "Nandībhavaparikkhīṇaṁ, ",
    "dhp413:4": "tamahaṁ brūmi brāhmaṇaṁ. ",
    "dhp414:0": "Sīvalittheravatthu ",
    "dhp414:1": "Yomaṁ palipathaṁ duggaṁ, ",
    "dhp414:2": "saṁsāraṁ mohamaccagā; ",
    "dhp414:3": "Tiṇṇo pāraṅgato jhāyī, ",
    "dhp414:4": "anejo akathaṅkathī; ",
    "dhp414:5": "Anupādāya nibbuto, ",
    "dhp414:6": "tamahaṁ brūmi brāhmaṇaṁ. ",
    "dhp415:0": "Sundarasamuddattheravatthu ",
    "dhp415:1": "Yodha kāme pahantvāna, ",
    "dhp415:2": "anāgāro paribbaje; ",
    "dhp415:3": "Kāmabhavaparikkhīṇaṁ, ",
    "dhp415:4": "tamahaṁ brūmi brāhmaṇaṁ. ",
    "dhp416:0": "Jaṭilattheravatthu ",
    "dhp416:1": "Yodha taṇhaṁ pahantvāna, ",
    "dhp416:2": "anāgāro paribbaje; ",
    "dhp416:3": "Taṇhābhavaparikkhīṇaṁ, ",
    "dhp416:4": "tamahaṁ brūmi brāhmaṇaṁ. ",
    "dhp416:5.0": "Jotikattheravatthu ",
    "dhp416:5.1": "Yodha taṇhaṁ pahantvāna, ",
    "dhp416:6": "anāgāro paribbaje; ",
    "dhp416:7": "Taṇhābhavaparikkhīṇaṁ, ",
    "dhp416:8": "tamahaṁ brūmi brāhmaṇaṁ. ",
    "dhp417:0": "Naṭaputtakattheravatthu ",
    "dhp417:1": "Hitvā mānusakaṁ yogaṁ, ",
    "dhp417:2": "dibbaṁ yogaṁ upaccagā; ",
    "dhp417:3": "Sabbayogavisaṁyuttaṁ, ",
    "dhp417:4": "tamahaṁ brūmi brāhmaṇaṁ. ",
    "dhp418:0": "Naṭaputtakattheravatthu ",
    "dhp418:1": "Hitvā ratiñca aratiñca, ",
    "dhp418:2": "sītibhūtaṁ nirūpadhiṁ; ",
    "dhp418:3": "Sabbalokābhibhuṁ vīraṁ, ",
    "dhp418:4": "tamahaṁ brūmi brāhmaṇaṁ. ",
    "dhp419:0": "Vaṅgīsattheravatthu ",
    "dhp419:1": "Cutiṁ yo vedi sattānaṁ, ",
    "dhp419:2": "upapattiñca sabbaso; ",
    "dhp419:3": "Asattaṁ sugataṁ buddhaṁ, ",
    "dhp419:4": "tamahaṁ brūmi brāhmaṇaṁ. ",
    "dhp420:1": "Yassa gatiṁ na jānanti, ",
    "dhp420:2": "devā gandhabbamānusā; ",
    "dhp420:3": "Khīṇāsavaṁ arahantaṁ, ",
    "dhp420:4": "tamahaṁ brūmi brāhmaṇaṁ. ",
    "dhp421:0": "Dhammadinnāttherīvatthu ",
    "dhp421:1": "Yassa pure ca pacchā ca, ",
    "dhp421:2": "majjhe ca natthi kiñcanaṁ; ",
    "dhp421:3": "Akiñcanaṁ anādānaṁ, ",
    "dhp421:4": "tamahaṁ brūmi brāhmaṇaṁ. ",
    "dhp422:0": "Aṅgulimālattheravatthu ",
    "dhp422:1": "Usabhaṁ pavaraṁ vīraṁ, ",
    "dhp422:2": "mahesiṁ vijitāvinaṁ; ",
    "dhp422:3": "Anejaṁ nhātakaṁ buddhaṁ, ",
    "dhp422:4": "tamahaṁ brūmi brāhmaṇaṁ. ",
    "dhp423:0": "Devahitabrāhmaṇavatthu ",
    "dhp423:1": "Pubbenivāsaṁ yo vedi, ",
    "dhp423:2": "saggāpāyañca passati; ",
    "dhp423:3": "Atho jātikkhayaṁ patto, ",
    "dhp423:4": "abhiññāvosito muni; ",
    "dhp423:5": "Sabbavositavosānaṁ, ",
    "dhp423:6": "tamahaṁ brūmi brāhmaṇaṁ. ",
    "dhp423:7": "Brāhmaṇavaggo chabbīsatimo. ",
    "dhp423:8": "Ettāvatā sabbapaṭhame yamakavagge cuddasa vatthūni, appamādavagge nava, cittavagge nava, pupphavagge dvādasa, bālavagge pannarasa, paṇḍitavagge ekādasa, arahantavagge dasa, sahassavagge cuddasa, pāpavagge dvādasa, daṇḍavagge ekādasa, jarāvagge nava, attavagge dasa, lokavagge ekādasa, buddhavagge nava, sukhavagge aṭṭha, piyavagge nava, kodhavagge aṭṭha, malavagge dvādasa, dhammaṭṭhavagge dasa, maggavagge dvādasa, pakiṇṇakavagge nava, nirayavagge nava, nāgavagge aṭṭha, taṇhāvagge dvādasa, bhikkhuvagge dvādasa, brāhmaṇavagge cattālīsāti pañcādhikāni tīṇi vatthusatāni. ",
    "dhp423:9": "Satevīsacatussatā, ",
    "dhp423:10": "catusaccavibhāvinā; ",
    "dhp423:11": "Satattayañca vatthūnaṁ, ",
    "dhp423:12": "pañcādhikaṁ samuṭṭhitāti. ",
    "dhp423:13": "Dhammapade vaggānamuddānaṁ ",
    "dhp423:14": "Yamakappamādo cittaṁ, ",
    "dhp423:15": "pupphaṁ bālena paṇḍito; ",
    "dhp423:16": "Arahanto sahassañca, ",
    "dhp423:17": "pāpaṁ daṇḍena te dasa. ",
    "dhp423:18": "Jarā attā ca loko ca, ",
    "dhp423:19": "buddho sukhaṁ piyena ca; ",
    "dhp423:20": "Kodho malañca dhammaṭṭho, ",
    "dhp423:21": "maggavaggena vīsati. ",
    "dhp423:22": "Pakiṇṇaṁ nirayo nāgo, ",
    "dhp423:23": "taṇhā bhikkhu ca brāhmaṇo; ",
    "dhp423:24": "Ete chabbīsati vaggā, ",
    "dhp423:25": "desitādiccabandhunā. ",
    "dhp423:26": "Gāthānamuddānaṁ ",
    "dhp423:27": "Yamake vīsati gāthā, ",
    "dhp423:28": "appamādamhi dvādasa; ",
    "dhp423:29": "Ekādasa cittavagge, ",
    "dhp423:30": "pupphavaggamhi soḷasa. ",
    "dhp423:31": "Bāle ca soḷasa gāthā, ",
    "dhp423:32": "paṇḍitamhi catuddasa; ",
    "dhp423:33": "Arahante dasa gāthā, ",
    "dhp423:34": "sahasse honti soḷasa. ",
    "dhp423:35": "Terasa pāpavaggamhi, ",
    "dhp423:36": "daṇḍamhi dasa satta ca; ",
    "dhp423:37": "Ekādasa jarā vagge, ",
    "dhp423:38": "attavaggamhi tā dasa. ",
    "dhp423:39": "Dvādasa lokavaggamhi, ",
    "dhp423:40": "buddhavaggamhi ṭhārasa; ",
    "dhp423:41": "Sukhe ca piyavagge ca, ",
    "dhp423:42": "gāthāyo honti dvādasa. ",
    "dhp423:43": "Cuddasa kodhavaggamhi, ",
    "dhp423:44": "malavaggekavīsati; ",
    "dhp423:45": "Sattarasa ca dhammaṭṭhe, ",
    "dhp423:46": "maggavagge sattarasa. ",
    "dhp423:47": "Pakiṇṇe soḷasa gāthā, ",
    "dhp423:48": "niraye nāge ca cuddasa; ",
    "dhp423:49": "Chabbīsa taṇhāvaggamhi, ",
    "dhp423:50": "tevīsa bhikkhuvaggikā. ",
    "dhp423:51": "Ekatālīsagāthāyo, ",
    "dhp423:52": "brāhmaṇe vaggamuttame; ",
    "dhp423:53": "Gāthāsatāni cattāri, ",
    "dhp423:54": "tevīsa ca punāpare; ",
    "dhp423:55": "Dhammapade nipātamhi, ",
    "dhp423:56": "desitādiccabandhunāti. ",
    "dhp423:57": "Dhammapadapāḷi samattā. "
  },
  "translation_text": {
    "dhp383:0.1": "Minor Collection ",
    "dhp383:0.2": "Sayings of the Dhamma 383–423 ",
    "dhp383:0.3": "26. Brahmins ",
    "dhp383:1": "Cut the stream, striving! ",
    "dhp383:2": "Cast aside sensual pleasures, brahmin. ",
    "dhp383:3": "Knowing the ending of conditions, ",
    "dhp383:4": "know the uncreated, brahmin. ",
    "dhp384:1": "When a brahmin has gone beyond ",
    "dhp384:2": "dualistic phenomena, ",
    "dhp384:3": "then they consciously ",
    "dhp384:4": "make an end of all fetters. ",
    "dhp385:1": "One for whom there is no crossing over ",
    "dhp385:2": "or crossing back, or crossing over and back; ",
    "dhp385:3": "stress-free, detached, ",
    "dhp385:4": "that’s who I declare a brahmin. ",
    "dhp386:1": "Absorbed, rid of hopes, ",
    "dhp386:2": "their task completed, without defilements, ",
    "dhp386:3": "arrived at the highest goal: ",
    "dhp386:4": "that’s who I declare a brahmin. ",
    "dhp387:1": "The sun blazes by day, ",
    "dhp387:2": "the moon radiates at night, ",
    "dhp387:3": "the aristocrat shines in armor, ",
    "dhp387:4": "and the brahmin shines in absorption. ",
    "dhp387:5": "But all day and all night, ",
    "dhp387:6": "the Buddha blazes with glory. ",
    "dhp388:1": "A brahmin’s so-called <j>since they’ve banished evil, ",
    "dhp388:2": "an ascetic’s so-called <j>since they live a serene life. ",
    "dhp388:3": "One who has renounced all stains ",
    "dhp388:4": "is said to be a “renunciant”. ",
    "dhp389:1": "One should never strike a brahmin, ",
    "dhp389:2": "nor should a brahmin retaliate. ",
    "dhp389:3": "Woe to the one who hurts a brahmin, ",
    "dhp389:4": "and woe for the one who retaliates. ",
    "dhp390:1": "Nothing is better for a brahmin ",
    "dhp390:2": "than to hold their mind back from attachment. ",
    "dhp390:3": "From wherever a cruel wish recoils, ",
    "dhp390:4": "right there suffering subsides. ",
    "dhp391:1": "Who does nothing wrong ",
    "dhp391:2": "by body, speech or mind, ",
    "dhp391:3": "restrained in these three respects, ",
    "dhp391:4": "that’s who I declare a brahmin. ",
    "dhp392:1": "You should graciously honor ",
    "dhp392:2": "the one from whom you learn the Dhamma ",
    "dhp392:3": "taught by the awakened Buddha, ",
    "dhp392:4": "as a brahmin honors the sacred flame. ",
    "dhp393:1": "Not by matted hair or family, ",
    "dhp393:2": "or birth is one a brahmin. ",
    "dhp393:3": "Those who are  truthful and principled: ",
    "dhp393:4": "they are pure, they are brahmins. ",
    "dhp394:1": "Why the matted hair, you simpleton, ",
    "dhp394:2": "and why the skin of deer? ",
    "dhp394:3": "The tangle is inside you, ",
    "dhp394:4": "yet you polish up your outsides. ",
    "dhp395:1": "A personage who wears robes of rags, ",
    "dhp395:2": "lean, their limbs showing veins, ",
    "dhp395:3": "meditating alone in the forest, ",
    "dhp395:4": "that’s who I declare a brahmin. ",
    "dhp396:1": "I don’t call someone a brahmin ",
    "dhp396:2": "after the mother’s womb they’re born from. ",
    "dhp396:3": "If they still have attachments, ",
    "dhp396:4": "they’re just someone who says “worthy”. ",
    "dhp396:5": "Having nothing, taking nothing: ",
    "dhp396:6": "that’s who I declare a brahmin. ",
    "dhp397:1": "Having cut off all fetters ",
    "dhp397:2": "they have no anxiety. ",
    "dhp397:3": "They’ve slipped their chains and are detached: ",
    "dhp397:4": "that’s who I declare a brahmin. ",
    "dhp398:1": "They’ve cut the strap and harness, ",
    "dhp398:2": "the halter and bridle too, ",
    "dhp398:3": "with cross-bar lifted, they’re awakened: ",
    "dhp398:4": "that’s who I declare a brahmin. ",
    "dhp399:1": "Abuse, killing, caging: ",
    "dhp399:2": "they endure these without anger. ",
    "dhp399:3": "Patience is their powerful army: ",
    "dhp399:4": "that’s who I declare a brahmin. ",
    "dhp400:1": "Not irritable or pretentious, ",
    "dhp400:2": "dutiful in precepts and observances, ",
    "dhp400:3": "tamed, bearing their final body: ",
    "dhp400:4": "that’s who I declare a brahmin. ",
    "dhp401:1": "Like water from a lotus leaf, ",
    "dhp401:2": "like a mustard seed off a pin-point, ",
    "dhp401:3": "sensual pleasures slip off them: ",
    "dhp401:4": "that’s who I declare a brahmin. ",
    "dhp402:1": "They understand for themselves ",
    "dhp402:2": "the end of suffering in this life; ",
    "dhp402:3": "with burden put down, detached: ",
    "dhp402:4": "that’s who I declare a brahmin. ",
    "dhp403:1": "Deep in wisdom, intelligent, ",
    "dhp403:2": "expert in the path and what is not the path; ",
    "dhp403:3": "arrived at the highest goal: ",
    "dhp403:4": "that’s who I declare a brahmin. ",
    "dhp404:1": "Mixing with neither ",
    "dhp404:2": "householders nor the homeless; ",
    "dhp404:3": "a migrant with no bastion, few in wishes: ",
    "dhp404:4": "that’s who I declare a brahmin. ",
    "dhp405:1": "They’ve laid aside violence ",
    "dhp405:2": "against creatures firm and frail; ",
    "dhp405:3": "not killing or making others kill: ",
    "dhp405:4": "that’s who I declare a brahmin. ",
    "dhp406:1": "Not fighting among those who fight, ",
    "dhp406:2": "quenched among those who have taken up arms, ",
    "dhp406:3": "not grasping among those who grasp: ",
    "dhp406:4": "that’s who I declare a brahmin. ",
    "dhp407:1": "They’ve discarded greed and hate, ",
    "dhp407:2": "along with conceit and contempt, ",
    "dhp407:3": "like a mustard seed off the point of a pin: ",
    "dhp407:4": "that’s who I declare a brahmin. ",
    "dhp408:1": "The words they utter ",
    "dhp408:2": "are polished, informative, and true, ",
    "dhp408:3": "and don’t offend anyone: ",
    "dhp408:4": "that’s who I declare a brahmin. ",
    "dhp409:1": "They don’t steal anything in the world, ",
    "dhp409:2": "long or short, ",
    "dhp409:3": "fine or coarse, beautiful or ugly: ",
    "dhp409:4": "that’s who I declare a brahmin. ",
    "dhp410:1": "They have no hope ",
    "dhp410:2": "in this world or the next; ",
    "dhp410:3": "with no need for hope, detached: ",
    "dhp410:4": "that’s who I declare a brahmin. ",
    "dhp411:1": "They have no clinging, ",
    "dhp411:2": "knowledge has freed them of indecision, ",
    "dhp411:3": "they’ve arrived at the objective, freedom from death: ",
    "dhp411:4": "that’s who I declare a brahmin. ",
    "dhp412:1": "They’ve escaped clinging ",
    "dhp412:2": "to both good and bad deeds; ",
    "dhp412:3": "sorrowless, stainless, pure: ",
    "dhp412:4": "that’s who I declare a brahmin. ",
    "dhp413:1": "Pure as the spotless moon, ",
    "dhp413:2": "clear and undisturbed, ",
    "dhp413:3": "they’ve ended relish for rebirth: ",
    "dhp413:4": "that’s who I declare a brahmin. ",
    "dhp414:1": "They’ve got past this grueling swamp ",
    "dhp414:2": "of delusion, transmigration. ",
    "dhp414:3": "Meditating in stillness, free of indecision, ",
    "dhp414:4": "they have crossed over to the far shore. ",
    "dhp414:5": "They’re quenched by not grasping: ",
    "dhp414:6": "that’s who I declare a brahmin. ",
    "dhp415:1": "They’ve given up sensual stimulations, ",
    "dhp415:2": "and have gone forth from lay life; ",
    "dhp415:3": "they’ve ended rebirth in the sensual realm: ",
    "dhp415:4": "that’s who I declare a brahmin. ",
    "dhp416:1": "They’ve given up craving, ",
    "dhp416:2": "and have gone forth from lay life; ",
    "dhp416:3": "they’ve ended craving to be reborn: ",
    "dhp416:4": "that’s who I declare a brahmin. ",
    "dhp416:5.1": "They’ve given up craving, ",
    "dhp416:6": "and have gone forth from lay life; ",
    "dhp416:7": "they’ve ended craving to be reborn: ",
    "dhp416:8": "that’s who I declare a brahmin. ",
    "dhp417:1": "They’ve thrown off the human yoke, ",
    "dhp417:2": "and slipped out of the heavenly yoke; ",
    "dhp417:3": "unyoked from all yokes: ",
    "dhp417:4": "that’s who I declare a brahmin. ",
    "dhp418:1": "Giving up desire and discontent, ",
    "dhp418:2": "they’re cooled and free of attachments; ",
    "dhp418:3": "a hero, master of the whole world: ",
    "dhp418:4": "that’s who I declare a brahmin. ",
    "dhp419:1": "They know the passing away ",
    "dhp419:2": "and rebirth of all beings; ",
    "dhp419:3": "unattached, holy, awakened: ",
    "dhp419:4": "that’s who I declare a brahmin. ",
    "dhp420:1": "Gods, centaurs, and humans ",
    "dhp420:2": "don’t know their destiny; ",
    "dhp420:3": "the perfected ones with defilements ended: ",
    "dhp420:4": "that’s who I declare a brahmin. ",
    "dhp421:1": "They have nothing before or after, ",
    "dhp421:2": "or even in between. ",
    "dhp421:3": "Having nothing, taking nothing: ",
    "dhp421:4": "that’s who I declare a brahmin. ",
    "dhp422:1": "Captain of the herd, excellent hero, ",
    "dhp422:2": "great seer and victor; ",
    "dhp422:3": "unstirred, washed, awakened: ",
    "dhp422:4": "that’s who I declare a brahmin. ",
    "dhp423:1": "One who knows their past lives, ",
    "dhp423:2": "sees heaven and places of loss, ",
    "dhp423:3": "and has attained the end of rebirth; ",
    "dhp423:4": "a sage of perfect insight ",
    "dhp423:5": "at the summit of spiritual perfection: ",
    "dhp423:6": "that’s who I declare a brahmin. ",
    "dhp423:55": "",
    "dhp423:57": "The Sayings of the Dhamma are completed. "
  },
