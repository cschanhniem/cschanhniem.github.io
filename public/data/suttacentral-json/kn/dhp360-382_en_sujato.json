  "root_text": {
    "dhp360:0.1": "Khuddakanikāya ",
    "dhp360:0.2": "Dhammapada ",
    "dhp360:0.3": "Bhikkhuvagga ",
    "dhp360:0.4": "Pañcabhikkhuvatthu ",
    "dhp360:1": "Cakkhunā saṁvaro sādhu, ",
    "dhp360:2": "sādhu sotena saṁvaro; ",
    "dhp360:3": "Ghānena saṁvaro sādhu, ",
    "dhp360:4": "sādhu jivhāya saṁvaro. ",
    "dhp361:1": "Kāyena saṁvaro sādhu, ",
    "dhp361:2": "sādhu vācāya saṁvaro; ",
    "dhp361:3": "Manasā saṁvaro sādhu, ",
    "dhp361:4": "sādhu sabbattha saṁvaro; ",
    "dhp361:5": "Sabbattha saṁvuto bhikkhu, ",
    "dhp361:6": "sabbadukkhā pamuccati. ",
    "dhp362:0": "Haṁsaghātakabhikkhuvatthu ",
    "dhp362:1": "Hatthasaṁyato pādasaṁyato, ",
    "dhp362:2": "Vācāsaṁyato saṁyatuttamo; ",
    "dhp362:3": "Ajjhattarato samāhito, ",
    "dhp362:4": "Eko santusito tamāhu bhikkhuṁ. ",
    "dhp363:0": "Kokālikavatthu ",
    "dhp363:1": "Yo mukhasaṁyato bhikkhu, ",
    "dhp363:2": "mantabhāṇī anuddhato; ",
    "dhp363:3": "Atthaṁ dhammañca dīpeti, ",
    "dhp363:4": "madhuraṁ tassa bhāsitaṁ. ",
    "dhp364:0": "Dhammārāmattheravatthu ",
    "dhp364:1": "Dhammārāmo dhammarato, ",
    "dhp364:2": "dhammaṁ anuvicintayaṁ; ",
    "dhp364:3": "Dhammaṁ anussaraṁ bhikkhu, ",
    "dhp364:4": "saddhammā na parihāyati. ",
    "dhp365:0": "Vipakkhasevakabhikkhuvatthu ",
    "dhp365:1": "Salābhaṁ nātimaññeyya, ",
    "dhp365:2": "nāññesaṁ pihayaṁ care; ",
    "dhp365:3": "Aññesaṁ pihayaṁ bhikkhu, ",
    "dhp365:4": "samādhiṁ nādhigacchati. ",
    "dhp366:1": "Appalābhopi ce bhikkhu, ",
    "dhp366:2": "salābhaṁ nātimaññati; ",
    "dhp366:3": "Taṁ ve devā pasaṁsanti, ",
    "dhp366:4": "suddhājīviṁ atanditaṁ. ",
    "dhp367:0": "Pañcaggadāyakabrāhmaṇavatthu ",
    "dhp367:1": "Sabbaso nāmarūpasmiṁ, ",
    "dhp367:2": "yassa natthi mamāyitaṁ; ",
    "dhp367:3": "Asatā ca na socati, ",
    "dhp367:4": "sa ve “bhikkhū”ti vuccati. ",
    "dhp368:0": "Sambahulabhikkhuvatthu ",
    "dhp368:1": "Mettāvihārī yo bhikkhu, ",
    "dhp368:2": "pasanno buddhasāsane; ",
    "dhp368:3": "Adhigacche padaṁ santaṁ, ",
    "dhp368:4": "saṅkhārūpasamaṁ sukhaṁ. ",
    "dhp369:1": "Siñca bhikkhu imaṁ nāvaṁ, ",
    "dhp369:2": "sittā te lahumessati; ",
    "dhp369:3": "Chetvā rāgañca dosañca, ",
    "dhp369:4": "tato nibbānamehisi. ",
    "dhp370:1": "Pañca chinde pañca jahe, ",
    "dhp370:2": "pañca cuttari bhāvaye; ",
    "dhp370:3": "Pañca saṅgātigo bhikkhu, ",
    "dhp370:4": "“oghatiṇṇo”ti vuccati. ",
    "dhp371:1": "Jhāya bhikkhu mā pamādo, ",
    "dhp371:2": "Mā te kāmaguṇe ramessu cittaṁ; ",
    "dhp371:3": "Mā lohaguḷaṁ gilī pamatto, ",
    "dhp371:4": "Mā kandi “dukkhamidan”ti dayhamāno. ",
    "dhp372:1": "Natthi jhānaṁ apaññassa, ",
    "dhp372:2": "paññā natthi ajhāyato; ",
    "dhp372:3": "Yamhi jhānañca paññā ca, ",
    "dhp372:4": "sa ve nibbānasantike. ",
    "dhp373:1": "Suññāgāraṁ paviṭṭhassa, ",
    "dhp373:2": "santacittassa bhikkhuno; ",
    "dhp373:3": "Amānusī rati hoti, ",
    "dhp373:4": "sammā dhammaṁ vipassato. ",
    "dhp374:1": "Yato yato sammasati, ",
    "dhp374:2": "khandhānaṁ udayabbayaṁ; ",
    "dhp374:3": "Labhatī pītipāmojjaṁ, ",
    "dhp374:4": "amataṁ taṁ vijānataṁ. ",
    "dhp375:1": "Tatrāyamādi bhavati, ",
    "dhp375:2": "idha paññassa bhikkhuno; ",
    "dhp375:3": "Indriyagutti santuṭṭhi, ",
    "dhp375:4": "pātimokkhe ca saṁvaro. ",
    "dhp376:1": "Mitte bhajassu kalyāṇe, ",
    "dhp376:2": "suddhājīve atandite; ",
    "dhp376:3": "Paṭisanthāravutyassa, ",
    "dhp376:4": "ācārakusalo siyā; ",
    "dhp376:5": "Tato pāmojjabahulo, ",
    "dhp376:6": "dukkhassantaṁ karissati. ",
    "dhp377:0": "Pañcasatabhikkhuvatthu ",
    "dhp377:1": "Vassikā viya pupphāni, ",
    "dhp377:2": "maddavāni pamuñcati; ",
    "dhp377:3": "Evaṁ rāgañca dosañca, ",
    "dhp377:4": "vippamuñcetha bhikkhavo. ",
    "dhp378:0": "Santakāyattheravatthu ",
    "dhp378:1": "Santakāyo santavāco, ",
    "dhp378:2": "santavā susamāhito; ",
    "dhp378:3": "Vantalokāmiso bhikkhu, ",
    "dhp378:4": "“upasanto”ti vuccati. ",
    "dhp379:0": "Naṅgalakulattheravatthu ",
    "dhp379:1": "Attanā codayattānaṁ, ",
    "dhp379:2": "paṭimaṁsetha attanā; ",
    "dhp379:3": "So attagutto satimā, ",
    "dhp379:4": "sukhaṁ bhikkhu vihāhisi. ",
    "dhp380:1": "Attā hi attano nātho, ",
    "dhp380:2": "ko hi nātho paro siyā; ",
    "dhp380:3": "Attā hi attano gati, ",
    "dhp380:4": "tasmā saṁyamamattānaṁ; ",
    "dhp380:5": "Assaṁ bhadraṁva vāṇijo. ",
    "dhp381:0": "Vakkalittheravatthu ",
    "dhp381:1": "Pāmojjabahulo bhikkhu, ",
    "dhp381:2": "pasanno buddhasāsane; ",
    "dhp381:3": "Adhigacche padaṁ santaṁ, ",
    "dhp381:4": "saṅkhārūpasamaṁ sukhaṁ. ",
    "dhp382:0": "Sumanasāmaṇeravatthu ",
    "dhp382:1": "Yo have daharo bhikkhu, ",
    "dhp382:2": "yuñjati buddhasāsane; ",
    "dhp382:3": "Somaṁ lokaṁ pabhāseti, ",
    "dhp382:4": "abbhā muttova candimā. ",
    "dhp382:5": "Bhikkhuvaggo pañcavīsatimo. "
  },
  "translation_text": {
    "dhp360:0.1": "Minor Collection ",
    "dhp360:0.2": "Sayings of the Dhamma 360–382 ",
    "dhp360:0.3": "25. Mendicants ",
    "dhp360:1": "Restraint of the eye is good; ",
    "dhp360:2": "good is restraint of the ear; ",
    "dhp360:3": "restraint of the nose is good; ",
    "dhp360:4": "good is restraint of the tongue. ",
    "dhp361:1": "Restraint of the body is good; ",
    "dhp361:2": "good is restraint of speech; ",
    "dhp361:3": "restraint of mind is good; ",
    "dhp361:4": "everywhere, restraint is good. ",
    "dhp361:5": "The mendicant restrained everywhere ",
    "dhp361:6": "is released from all suffering. ",
    "dhp362:1": "One restrained in hand and foot, ",
    "dhp362:2": "and in speech, the supreme restraint; ",
    "dhp362:3": "happy inside, serene, ",
    "dhp362:4": "solitary, content, I call a mendicant. ",
    "dhp363:1": "When a mendicant of restrained mouth, ",
    "dhp363:2": "thoughtful in counsel, not restless, ",
    "dhp363:3": "explains the text and its meaning, ",
    "dhp363:4": "their words are sweet. ",
    "dhp364:1": "Delighting in the teaching, enjoying the teaching, ",
    "dhp364:2": "contemplating the teaching, ",
    "dhp364:3": "a mendicant who recollects the teaching ",
    "dhp364:4": "doesn’t fall away from the true teaching. ",
    "dhp365:1": "A well-off mendicant ought not look down ",
    "dhp365:2": "on others, nor should they be envious. ",
    "dhp365:3": "A mendicant who envies others ",
    "dhp365:4": "does not achieve immersion. ",
    "dhp366:1": "If a mendicant is poor in offerings, ",
    "dhp366:2": "the well-to-do ought not look down on them. ",
    "dhp366:3": "For the gods indeed praise them, ",
    "dhp366:4": "who are tireless and pure of livelihood. ",
    "dhp367:1": "One who has no sense of ownership ",
    "dhp367:2": "in the whole realm of name and form, ",
    "dhp367:3": "who does not grieve for that which is not, ",
    "dhp367:4": "is said to be a mendicant. ",
    "dhp368:1": "A mendicant who meditates on love, ",
    "dhp368:2": "devoted to the Buddha’s teaching, ",
    "dhp368:3": "would realize the peaceful state, ",
    "dhp368:4": "the blissful stilling of conditions. ",
    "dhp369:1": "Bail out this boat, mendicant! ",
    "dhp369:2": "When bailed out it will float lightly. ",
    "dhp369:3": "Having cut off desire and hate, ",
    "dhp369:4": "you shall reach extinguishment. ",
    "dhp370:1": "Five to cut, five to drop, ",
    "dhp370:2": "and five more to develop. ",
    "dhp370:3": "When a mendicant slips five chains ",
    "dhp370:4": "they’re said to have crossed the flood. ",
    "dhp371:1": "Practice absorption, don’t be negligent! ",
    "dhp371:2": "Don’t let the mind delight in the senses! ",
    "dhp371:3": "Don’t heedlessly swallow a hot iron ball! ",
    "dhp371:4": "And when it burns, don’t cry, “Oh, the pain!” ",
    "dhp372:1": "No absorption for one without wisdom, ",
    "dhp372:2": "no wisdom for one without absorption. ",
    "dhp372:3": "But one with absorption and wisdom—",
    "dhp372:4": "they have truly drawn near to extinguishment. ",
    "dhp373:1": "A mendicant who enters an empty hut ",
    "dhp373:2": "with mind at peace ",
    "dhp373:3": "finds a superhuman delight ",
    "dhp373:4": "as they rightly discern the Dhamma. ",
    "dhp374:1": "Whenever they are mindful ",
    "dhp374:2": "of the rise and fall of the aggregates, ",
    "dhp374:3": "they feel rapture and joy: ",
    "dhp374:4": "that is freedom from death for one who knows. ",
    "dhp375:1": "This is the very start of the path ",
    "dhp375:2": "for a wise mendicant: ",
    "dhp375:3": "guarding the senses, contentment, ",
    "dhp375:4": "and restraint in the monastic code. ",
    "dhp376:1": "Mix with spiritual friends, ",
    "dhp376:2": "who are tireless and pure of livelihood. ",
    "dhp376:3": "Share what you have with others, ",
    "dhp376:4": "being skillful in your conduct. ",
    "dhp376:5": "And when you’re full of joy, ",
    "dhp376:6": "you’ll make an end to suffering. ",
    "dhp377:1": "As a jasmine sheds ",
    "dhp377:2": "its withered flowers, ",
    "dhp377:3": "O mendicants, ",
    "dhp377:4": "shed greed and hate. ",
    "dhp378:1": "Calm in body, calm in speech, ",
    "dhp378:2": "peaceful and serene; ",
    "dhp378:3": "a mendicant who’s spat out the world’s bait ",
    "dhp378:4": "is said to be one at peace. ",
    "dhp379:1": "Urge yourself on, ",
    "dhp379:2": "reflect on yourself. ",
    "dhp379:3": "A mendicant self-controlled and mindful ",
    "dhp379:4": "will always dwell in happiness. ",
    "dhp380:1": "Self is indeed the lord of self, ",
    "dhp380:2": "for who else would be one’s lord? ",
    "dhp380:3": "Self is indeed the home of self, ",
    "dhp380:4": "so restrain yourself, ",
    "dhp380:5": "as a merchant his thoroughbred steed. ",
    "dhp381:1": "A monk full of joy ",
    "dhp381:2": "trusting in the Buddha’s teaching, ",
    "dhp381:3": "would realize the peaceful state, ",
    "dhp381:4": "the blissful stilling of conditions. ",
    "dhp382:1": "A young mendicant ",
    "dhp382:2": "devoted to the Buddha’s teaching, ",
    "dhp382:3": "lights up the world, ",
    "dhp382:4": "like the moon freed from clouds. "
  },
  "variant_text": {
    "dhp371:1": "Jhāya bhikkhu → jhāya tuvaṁ bhikkhu (?) | pamādo → mā ca pamādo (bj, sya-all, pts1ed); mā ca pāmado (pts2ed) ",
    "dhp371:2": "ramessu → bhamassu (bj, sya2ed, pts1ed, pts2ed); bhavassu (cck, sya1ed); ramassu (mr) ",
    "dhp372:2": "ajhāyato → ajjhāyato (pts1ed); ajhāyino (mr) ",
    "dhp374:3": "Labhatī → labhati (bj); labhate (mr) ",
    "dhp376:3": "Paṭisanthāravutyassa → paṭisanthāravuttyassa (sya-all); paṭisanthāravutt'assa (pts1ed, pts2ed); paṭisandhāravutyassa (mr) ",
    "dhp377:2": "maddavāni → majjavāni (mr ṭīkā); paccavāni (mr aṭṭha.) ",
    "dhp378:2": "santavā susamāhito → santamano susamāhito (sya-all); santamano samāhito (mr) ",
    "dhp379:2": "paṭimaṁsetha attanā → paṭimāsettamattanā (bj, cck, pts1ed); paṭimaṁsetamattanā (sya1ed, sya2ed); paṭimāse attamattanā (pts2ed) ",
    "dhp380:2": "ko hi nātho paro siyā → etthantare pāṭho videsapotthakesu ",
    "dhp380:4": "saṁyamamattānaṁ → saññamaya'ttānaṁ (bj, cck); saññama attānaṁ (sya1ed, sya2ed); aññamay'attānaṁ (pts1ed); saññāmay'attānaṁ (pts2ed) ",
    "dhp382:3": "Somaṁ → so imaṁ (bj, sya-all, km, pts1ed) "
