{
  "comment_text": {
    "dhp380:3": "<i lang='pi' translate='no'>Gati</i> is glossed by the commentary as <i lang='pi' translate='no'>saraṇa</i> (“refuge”), which agrees with the Sanskrit Udānavarga’s <i lang='pi' translate='no'>śaraṇa</i>. "
  },
