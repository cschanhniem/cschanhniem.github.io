  "root_text": {
    "snp2.10:0.1": "Sutta Nipāta 2.10 ",
    "snp2.10:0.2": "Uṭṭhānasutta ",
    "snp2.10:1.1": "Uṭṭhahatha nisīdatha, ",
    "snp2.10:1.2": "ko attho supitena vo; ",
    "snp2.10:1.3": "Āturānañhi kā niddā, ",
    "snp2.10:1.4": "sallaviddhāna ruppataṁ. ",
    "snp2.10:2.1": "Uṭṭhahatha nisīdatha, ",
    "snp2.10:2.2": "Daḷhaṁ sikkhatha santiyā; ",
    "snp2.10:2.3": "Mā vo pamatte viññāya, ",
    "snp2.10:2.4": "Maccurājā amohayittha vasānuge. ",
    "snp2.10:3.1": "Yāya devā manussā ca, ",
    "snp2.10:3.2": "sitā tiṭṭhanti atthikā; ",
    "snp2.10:3.3": "Tarathetaṁ visattikaṁ, ",
    "snp2.10:3.4": "khaṇo vo mā upaccagā; ",
    "snp2.10:3.5": "Khaṇātītā hi socanti, ",
    "snp2.10:3.6": "nirayamhi samappitā. ",
    "snp2.10:4.1": "Pamādo rajo pamādo, ",
    "snp2.10:4.2": "Pamādānupatito rajo; ",
    "snp2.10:4.3": "Appamādena vijjāya, ",
    "snp2.10:4.4": "Abbahe sallamattanoti. ",
    "snp2.10:4.5": "Uṭṭhānasuttaṁ dasamaṁ. "
  },
  "translation_text": {
    "snp2.10:0.1": "Anthology of Discourses 2.10 ",
    "snp2.10:0.2": "Get Up! ",
    "snp2.10:1.1": "Get up and meditate! ",
    "snp2.10:1.2": "What’s the point in your sleeping? ",
    "snp2.10:1.3": "How can the afflicted slumber ",
    "snp2.10:1.4": "when inflicted by an arrow strike? ",
    "snp2.10:2.1": "Get up and meditate! ",
    "snp2.10:2.2": "Train hard for peace! ",
    "snp2.10:2.3": "The King of Death has caught you heedless—",
    "snp2.10:2.4": "don’t let him fool you under his sway. ",
    "snp2.10:3.1": "Needy gods and humans ",
    "snp2.10:3.2": "are held back by clinging: ",
    "snp2.10:3.3": "get over it. ",
    "snp2.10:3.4": "Don’t let the moment pass you by. ",
    "snp2.10:3.5": "For if you miss your moment ",
    "snp2.10:3.6": "you’ll grieve when sent to hell. ",
    "snp2.10:4.1": "Negligence is always dust; ",
    "snp2.10:4.2": "dust follows right behind negligence. ",
    "snp2.10:4.3": "Through diligence and knowledge, ",
    "snp2.10:4.4": "pluck out the dart from yourself. "
  },
  "variant_text": {
    "snp2.10:3.4": "khaṇo vo → khaṇo ve (pts-vp-pli1, mr) ",
    "snp2.10:4.4": "Abbahe → abbūḷhe (sya-all); abbuhe (mr aṭṭha.) "
  },
