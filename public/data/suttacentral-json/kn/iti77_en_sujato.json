  "root_text": {
    "iti77:0.1": "Itivuttaka 77 ",
    "iti77:0.2": "Tikanipāta ",
    "iti77:0.3": "Tatiyavagga ",
    "iti77:0.4": "Bhidurasutta ",
    "iti77:1.1": "Vuttañhetaṁ bhagavatā vuttamarahatāti me sutaṁ: ",
    "iti77:2.1": "“Bhidurāyaṁ, bhikkhave, kāyo, viññāṇaṁ virāgadhammaṁ, sabbe upadhī aniccā dukkhā vipariṇāmadhammā”ti. ",
    "iti77:2.2": "Etamatthaṁ bhagavā avoca. ",
    "iti77:2.3": "Tatthetaṁ iti vuccati: ",
    "iti77:3.1": "“Kāyañca bhiduraṁ ñatvā, ",
    "iti77:3.2": "Viññāṇañca virāgunaṁ; ",
    "iti77:3.3": "Upadhīsu bhayaṁ disvā, ",
    "iti77:3.4": "Jātimaraṇamaccagā; ",
    "iti77:3.5": "Sampatvā paramaṁ santiṁ, ",
    "iti77:3.6": "Kālaṁ kaṅkhati bhāvitatto”ti. ",
    "iti77:4.1": "Ayampi attho vutto bhagavatā, iti me sutanti. ",
    "iti77:4.2": "Aṭṭhamaṁ. "
  },
  "translation_text": {
    "iti77:0.1": "So It Was Said 77 ",
    "iti77:0.2": "The Book of the Threes ",
    "iti77:0.3": "Chapter Three ",
    "iti77:0.4": "Fragile ",
    "iti77:1.1": "This was said by the Buddha, the Perfected One: that is what I heard. ",
    "iti77:2.1": "“This body is fragile, mendicants, consciousness is liable to fade away, and all attachments are impermanent, suffering, and perishable.” ",
    "iti77:2.2": "The Buddha spoke this matter. ",
    "iti77:2.3": "On this it is said: ",
    "iti77:3.1": "“Knowing that the body is fragile, ",
    "iti77:3.2": "that consciousness is faded, ",
    "iti77:3.3": "and seeing the danger in attachments, ",
    "iti77:3.4": "they go beyond birth and death. ",
    "iti77:3.5": "Having attained ultimate peace, ",
    "iti77:3.6": "evolved, they await their time.” ",
    "iti77:4.1": "This too is a matter that was spoken by the Blessed One: that is what I heard. "
  },
  "variant_text": {
    "iti77:2.1": "Bhidurāyaṁ → bhindantāyaṁ (sya-all, pts-vp-pli1, mr) ",
    "iti77:3.1": "bhiduraṁ → bhindantaṁ (sya-all, pts-vp-pli1, mr) ",
    "iti77:3.2": "virāgunaṁ → pabhaṅguraṁ (bj); virāgikaṁ (si, pts-vp-pli1); pabhaṅguṇaṁ (sya-all) "
  },
