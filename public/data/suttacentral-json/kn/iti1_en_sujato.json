  "root_text": {
    "iti1:0.1": "Itivuttaka 1 ",
    "iti1:0.2": "Ekakanipāta ",
    "iti1:0.3": "Paṭhamavagga ",
    "iti1:0.4": "Lobhasutta ",
    "iti1:1.1": "Vuttañhetaṁ bhagavatā vuttamarahatāti me sutaṁ: ",
    "iti1:2.1": "“Ekadhammaṁ, bhikkhave, pajahatha; ",
    "iti1:2.2": "ahaṁ vo pāṭibhogo anāgāmitāya. ",
    "iti1:2.3": "Katamaṁ ekadhammaṁ? ",
    "iti1:2.4": "Lobhaṁ, bhikkhave, ekadhammaṁ pajahatha; ",
    "iti1:2.5": "ahaṁ vo pāṭibhogo anāgāmitāyā”ti. ",
    "iti1:2.6": "Etamatthaṁ bhagavā avoca. ",
    "iti1:2.7": "Tatthetaṁ iti vuccati: ",
    "iti1:3.1": "“Yena lobhena luddhāse, ",
    "iti1:3.2": "sattā gacchanti duggatiṁ; ",
    "iti1:3.3": "Taṁ lobhaṁ sammadaññāya, ",
    "iti1:3.4": "pajahanti vipassino; ",
    "iti1:3.5": "Pahāya na punāyanti, ",
    "iti1:3.6": "imaṁ lokaṁ kudācanan”ti. ",
    "iti1:4.1": "Ayampi attho vutto bhagavatā, iti me sutanti. ",
    "iti1:4.2": "Paṭhamaṁ. "
  },
  "translation_text": {
    "iti1:0.1": "So It Was Said 1 ",
    "iti1:0.2": "The Book of the Ones ",
    "iti1:0.3": "Chapter One ",
    "iti1:0.4": "Greed ",
    "iti1:1.1": "This was said by the Buddha, the Perfected One: that is what I heard. ",
    "iti1:2.1": "“Mendicants, give up one thing ",
    "iti1:2.2": "and I guarantee you non-return. ",
    "iti1:2.3": "What one thing? ",
    "iti1:2.4": "Greed is the one thing. Give it up, ",
    "iti1:2.5": "and I guarantee you non-return.” ",
    "iti1:2.6": "The Buddha spoke this matter. ",
    "iti1:2.7": "On this it is said: ",
    "iti1:3.1": "“When overcome by greed ",
    "iti1:3.2": "beings go to a bad place. ",
    "iti1:3.3": "Having rightly understood that greed, ",
    "iti1:3.4": "the discerning give it up. ",
    "iti1:3.5": "Once they’ve given it up, ",
    "iti1:3.6": "they never return to this world.” ",
    "iti1:4.1": "This too is a matter that was spoken by the Blessed One: that is what I heard. "
  },
