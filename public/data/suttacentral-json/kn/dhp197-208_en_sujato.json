  "root_text": {
    "dhp197:0.1": "Khuddakanikāya ",
    "dhp197:0.2": "Dhammapada ",
    "dhp197:0.3": "Sukhavagga ",
    "dhp197:0.4": "Ñātikalahavūpasamanavatthu ",
    "dhp197:1": "Susukhaṁ vata jīvāma, ",
    "dhp197:2": "verinesu averino; ",
    "dhp197:3": "Verinesu manussesu, ",
    "dhp197:4": "viharāma averino. ",
    "dhp198:1": "Susukhaṁ vata jīvāma, ",
    "dhp198:2": "āturesu anāturā; ",
    "dhp198:3": "Āturesu manussesu, ",
    "dhp198:4": "viharāma anāturā. ",
    "dhp199:1": "Susukhaṁ vata jīvāma, ",
    "dhp199:2": "ussukesu anussukā; ",
    "dhp199:3": "Ussukesu manussesu, ",
    "dhp199:4": "viharāma anussukā. ",
    "dhp200:0": "Māravatthu ",
    "dhp200:1": "Susukhaṁ vata jīvāma, ",
    "dhp200:2": "yesaṁ no natthi kiñcanaṁ; ",
    "dhp200:3": "Pītibhakkhā bhavissāma, ",
    "dhp200:4": "devā ābhassarā yathā. ",
    "dhp201:0": "Kosalaraññoparājayavatthu ",
    "dhp201:1": "Jayaṁ veraṁ pasavati, ",
    "dhp201:2": "dukkhaṁ seti parājito; ",
    "dhp201:3": "Upasanto sukhaṁ seti, ",
    "dhp201:4": "hitvā jayaparājayaṁ. ",
    "dhp202:0": "Aññatarakuladārikāvatthu ",
    "dhp202:1": "Natthi rāgasamo aggi, ",
    "dhp202:2": "Natthi dosasamo kali; ",
    "dhp202:3": "Natthi khandhasamā dukkhā, ",
    "dhp202:4": "Natthi santiparaṁ sukhaṁ. ",
    "dhp203:0": "Ekaupāsakavatthu ",
    "dhp203:1": "Jighacchāparamā rogā, ",
    "dhp203:2": "saṅkhāraparamā dukhā; ",
    "dhp203:3": "Etaṁ ñatvā yathābhūtaṁ, ",
    "dhp203:4": "nibbānaṁ paramaṁ sukhaṁ. ",
    "dhp204:0": "Pasenadikosalavatthu ",
    "dhp204:1": "Ārogyaparamā lābhā, ",
    "dhp204:2": "Santuṭṭhiparamaṁ dhanaṁ; ",
    "dhp204:3": "Vissāsaparamā ñāti, ",
    "dhp204:4": "Nibbānaṁ paramaṁ sukhaṁ. ",
    "dhp205:0": "Tissattheravatthu ",
    "dhp205:1": "Pavivekarasaṁ pitvā, ",
    "dhp205:2": "rasaṁ upasamassa ca; ",
    "dhp205:3": "Niddaro hoti nippāpo, ",
    "dhp205:4": "dhammapītirasaṁ pivaṁ. ",
    "dhp206:0": "Sakkavatthu ",
    "dhp206:1": "Sāhu dassanamariyānaṁ, ",
    "dhp206:2": "sannivāso sadā sukho; ",
    "dhp206:3": "Adassanena bālānaṁ, ",
    "dhp206:4": "niccameva sukhī siyā. ",
    "dhp207:1": "Bālasaṅgatacārī hi, ",
    "dhp207:2": "dīghamaddhāna socati; ",
    "dhp207:3": "Dukkho bālehi saṁvāso, ",
    "dhp207:4": "amitteneva sabbadā; ",
    "dhp207:5": "Dhīro ca sukhasaṁvāso, ",
    "dhp207:6": "ñātīnaṁva samāgamo. ",
    "dhp208:1": "Tasmā hi—",
    "dhp208:2": "Dhīrañca paññañca bahussutañca, ",
    "dhp208:3": "Dhorayhasīlaṁ vatavantamariyaṁ; ",
    "dhp208:4": "Taṁ tādisaṁ sappurisaṁ sumedhaṁ, ",
    "dhp208:5": "Bhajetha nakkhattapathaṁva candimā. ",
    "dhp208:6": "Sukhavaggo pannarasamo. "
  },
  "translation_text": {
    "dhp197:0.1": "Minor Collection ",
    "dhp197:0.2": "Sayings of the Dhamma 197–208 ",
    "dhp197:0.3": "15. Happiness ",
    "dhp197:1": "Let us live so very happily, ",
    "dhp197:2": "loving among the hostile. ",
    "dhp197:3": "Among hostile humans, ",
    "dhp197:4": "let us live with love. ",
    "dhp198:1": "Let us live so very happily, ",
    "dhp198:2": "healthy among the ailing. ",
    "dhp198:3": "Among ailing humans ",
    "dhp198:4": "let us live healthily. ",
    "dhp199:1": "Let us live so very happily, ",
    "dhp199:2": "content among the greedy. ",
    "dhp199:3": "Among greedy humans, ",
    "dhp199:4": "let us live content. ",
    "dhp200:1": "Let us live so very happily, ",
    "dhp200:2": "we who have nothing. ",
    "dhp200:3": "We shall feed on rapture, ",
    "dhp200:4": "like the gods of streaming radiance. ",
    "dhp201:1": "Victory breeds enmity; ",
    "dhp201:2": "the defeated sleep badly. ",
    "dhp201:3": "The peaceful sleep at ease, ",
    "dhp201:4": "having left victory and defeat behind. ",
    "dhp202:1": "There is no fire like greed, ",
    "dhp202:2": "no crime like hate, ",
    "dhp202:3": "no suffering like the aggregates, ",
    "dhp202:4": "no bliss beyond peace. ",
    "dhp203:1": "Hunger is the worst illness, ",
    "dhp203:2": "conditions are the worst suffering. ",
    "dhp203:3": "For one who truly knows this, ",
    "dhp203:4": "extinguishment is the ultimate happiness. ",
    "dhp204:1": "Health is the ultimate blessing; ",
    "dhp204:2": "contentment, the ultimate wealth; ",
    "dhp204:3": "trust is the ultimate family; ",
    "dhp204:4": "extinguishment, the ultimate happiness. ",
    "dhp205:1": "Having drunk the nectar of seclusion ",
    "dhp205:2": "and the nectar of peace—",
    "dhp205:3": "free of stress, free of evil, ",
    "dhp205:4": "drink the joyous nectar of truth. ",
    "dhp206:1": "It’s good to see the noble ones, ",
    "dhp206:2": "staying with them is always good. ",
    "dhp206:3": "Were you not to see fools, ",
    "dhp206:4": "you’d always be happy. ",
    "dhp207:1": "For one who consorts with fools ",
    "dhp207:2": "grieves long. ",
    "dhp207:3": "Painful is living with fools, ",
    "dhp207:4": "like being stuck with your enemy. ",
    "dhp207:5": "Happy is living with an attentive one, ",
    "dhp207:6": "like meeting with your kin. ",
    "dhp208:1": "Therefore: ",
    "dhp208:2": "An attentive one, wise and learned, ",
    "dhp208:3": "a behemoth of virtue, true to their vows, noble: ",
    "dhp208:4": "follow a true and intelligent person such as this, ",
    "dhp208:5": "as the moon tracks the path of the stars. "
  },
  "variant_text": {
    "dhp202:3": "khandhasamā → khandhādisā (sya-all, pts1ed, pts2ed rūpasiddhiyā sameti) ",
    "dhp203:2": "saṅkhāraparamā → saṅkhārā paramā (bahūsu) ",
    "dhp204:3": "Vissāsaparamā ñāti → vissāsaparamā ñātī (bj, pts2ed); vissāsaparamo ñāti (bj); vissāsā paramā ñāti (mr) ",
    "dhp204:4": "Nibbānaṁ paramaṁ → nibbāṇaparamaṁ (bj) ",
    "dhp205:1": "pitvā → pītvā (bj, km, pts1ed, pts2ed) ",
    "dhp207:1": "Bālasaṅgatacārī → bālasaṅgaticārī (mr) "
  },
