  "root_text": {
    "dhp235:0.1": "Khuddakanikāya ",
    "dhp235:0.2": "Dhammapada ",
    "dhp235:0.3": "Malavagga ",
    "dhp235:0.4": "Goghātakaputtavatthu ",
    "dhp235:1": "Paṇḍupalāsova dānisi, ",
    "dhp235:2": "Yamapurisāpi ca te upaṭṭhitā; ",
    "dhp235:3": "Uyyogamukhe ca tiṭṭhasi, ",
    "dhp235:4": "Pātheyyampi ca te na vijjati. ",
    "dhp236:1": "So karohi dīpamattano, ",
    "dhp236:2": "Khippaṁ vāyama paṇḍito bhava; ",
    "dhp236:3": "Niddhantamalo anaṅgaṇo, ",
    "dhp236:4": "Dibbaṁ ariyabhūmiṁ upehisi. ",
    "dhp237:1": "Upanītavayo ca dānisi, ",
    "dhp237:2": "Sampayātosi yamassa santikaṁ; ",
    "dhp237:3": "Vāso te natthi antarā, ",
    "dhp237:4": "Pātheyyampi ca te na vijjati. ",
    "dhp238:1": "So karohi dīpamattano, ",
    "dhp238:2": "Khippaṁ vāyama paṇḍito bhava; ",
    "dhp238:3": "Niddhantamalo anaṅgaṇo, ",
    "dhp238:4": "Na punaṁ jātijaraṁ upehisi. ",
    "dhp239:0": "Aññatarabrāhmaṇavatthu ",
    "dhp239:1": "Anupubbena medhāvī, ",
    "dhp239:2": "thokaṁ thokaṁ khaṇe khaṇe; ",
    "dhp239:3": "Kammāro rajatasseva, ",
    "dhp239:4": "niddhame malamattano. ",
    "dhp240:0": "Tissattheravatthu ",
    "dhp240:1": "Ayasāva malaṁ samuṭṭhitaṁ, ",
    "dhp240:2": "Tatuṭṭhāya tameva khādati; ",
    "dhp240:3": "Evaṁ atidhonacārinaṁ, ",
    "dhp240:4": "Sāni kammāni nayanti duggatiṁ. ",
    "dhp241:0": "Lāḷudāyīvatthu ",
    "dhp241:1": "Asajjhāyamalā mantā, ",
    "dhp241:2": "anuṭṭhānamalā gharā; ",
    "dhp241:3": "Malaṁ vaṇṇassa kosajjaṁ, ",
    "dhp241:4": "pamādo rakkhato malaṁ. ",
    "dhp242:0": "Aññatarakulaputtavatthu ",
    "dhp242:1": "Malitthiyā duccaritaṁ, ",
    "dhp242:2": "maccheraṁ dadato malaṁ; ",
    "dhp242:3": "Malā ve pāpakā dhammā, ",
    "dhp242:4": "asmiṁ loke paramhi ca. ",
    "dhp243:1": "Tato malā malataraṁ, ",
    "dhp243:2": "avijjā paramaṁ malaṁ; ",
    "dhp243:3": "Etaṁ malaṁ pahantvāna, ",
    "dhp243:4": "nimmalā hotha bhikkhavo. ",
    "dhp244:0": "Cūḷasāribhikkhuvatthu ",
    "dhp244:1": "Sujīvaṁ ahirikena, ",
    "dhp244:2": "kākasūrena dhaṁsinā; ",
    "dhp244:3": "Pakkhandinā pagabbhena, ",
    "dhp244:4": "saṅkiliṭṭhena jīvitaṁ. ",
    "dhp245:1": "Hirīmatā ca dujjīvaṁ, ",
    "dhp245:2": "niccaṁ sucigavesinā; ",
    "dhp245:3": "Alīnenāppagabbhena, ",
    "dhp245:4": "suddhājīvena passatā. ",
    "dhp246:0": "Pañcaupāsakavatthu ",
    "dhp246:1": "Yo pāṇamatipāteti, ",
    "dhp246:2": "musāvādañca bhāsati; ",
    "dhp246:3": "Loke adinnamādiyati, ",
    "dhp246:4": "paradārañca gacchati. ",
    "dhp247:1": "Surāmerayapānañca, ",
    "dhp247:2": "yo naro anuyuñjati; ",
    "dhp247:3": "Idheva meso lokasmiṁ, ",
    "dhp247:4": "mūlaṁ khaṇati attano. ",
    "dhp248:1": "Evaṁ bho purisa jānāhi, ",
    "dhp248:2": "pāpadhammā asaññatā; ",
    "dhp248:3": "Mā taṁ lobho adhammo ca, ",
    "dhp248:4": "ciraṁ dukkhāya randhayuṁ. ",
    "dhp249:0": "Tissadaharavatthu ",
    "dhp249:1": "Dadāti ve yathāsaddhaṁ, ",
    "dhp249:2": "yathāpasādanaṁ jano; ",
    "dhp249:3": "Tattha yo ca maṅku bhavati, ",
    "dhp249:4": "paresaṁ pānabhojane; ",
    "dhp249:5": "Na so divā vā rattiṁ vā, ",
    "dhp249:6": "samādhimadhigacchati. ",
    "dhp250:1": "Yassa cetaṁ samucchinnaṁ, ",
    "dhp250:2": "mūlaghaccaṁ samūhataṁ; ",
    "dhp250:3": "Sa ve divā vā rattiṁ vā, ",
    "dhp250:4": "samādhimadhigacchati. ",
    "dhp251:0": "Pañcaupāsakavatthu ",
    "dhp251:1": "Natthi rāgasamo aggi, ",
    "dhp251:2": "natthi dosasamo gaho; ",
    "dhp251:3": "Natthi mohasamaṁ jālaṁ, ",
    "dhp251:4": "natthi taṇhāsamā nadī. ",
    "dhp252:0": "Meṇḍakaseṭṭhivatthu ",
    "dhp252:1": "Sudassaṁ vajjamaññesaṁ, ",
    "dhp252:2": "attano pana duddasaṁ; ",
    "dhp252:3": "Paresaṁ hi so vajjāni, ",
    "dhp252:4": "opunāti yathā bhusaṁ; ",
    "dhp252:5": "Attano pana chādeti, ",
    "dhp252:6": "kaliṁva kitavā saṭho. ",
    "dhp253:0": "Ujjhānasaññittheravatthu ",
    "dhp253:1": "Paravajjānupassissa, ",
    "dhp253:2": "niccaṁ ujjhānasaññino; ",
    "dhp253:3": "Āsavā tassa vaḍḍhanti, ",
    "dhp253:4": "ārā so āsavakkhayā. ",
    "dhp254:0": "Subhaddaparibbājakavatthu ",
    "dhp254:1": "Ākāseva padaṁ natthi, ",
    "dhp254:2": "samaṇo natthi bāhire; ",
    "dhp254:3": "Papañcābhiratā pajā, ",
    "dhp254:4": "nippapañcā tathāgatā. ",
    "dhp255:1": "Ākāseva padaṁ natthi, ",
    "dhp255:2": "samaṇo natthi bāhire; ",
    "dhp255:3": "Saṅkhārā sassatā natthi, ",
    "dhp255:4": "natthi buddhānamiñjitaṁ. ",
    "dhp255:5": "Malavaggo aṭṭhārasamo. "
  },
  "translation_text": {
    "dhp235:0.1": "Minor Collection ",
    "dhp235:0.2": "Sayings of the Dhamma 235–255 ",
    "dhp235:0.3": "18. Stains ",
    "dhp235:0.4": "",
    "dhp235:1": "Today you’re like a withered leaf, ",
    "dhp235:2": "Yama’s men await you. ",
    "dhp235:3": "You stand at the departure gates, ",
    "dhp235:4": "yet you have no supplies for the road. ",
    "dhp236:1": "Make an island of yourself! ",
    "dhp236:2": "Swiftly strive, learn to be wise! ",
    "dhp236:3": "Purged of stains, flawless, ",
    "dhp236:4": "you’ll go to the heavenly realm of the noble ones. ",
    "dhp237:1": "You’ve journeyed the stages of life, ",
    "dhp237:2": "and now you set out to meet Yama. ",
    "dhp237:3": "Along the way there’s nowhere to stay, ",
    "dhp237:4": "yet you have no supplies for the road. ",
    "dhp238:1": "Make an island of yourself! ",
    "dhp238:2": "Swiftly strive, learn to be wise! ",
    "dhp238:3": "Purged of stains, flawless, ",
    "dhp238:4": "you’ll not come again to rebirth and old age. ",
    "dhp239:0": "",
    "dhp239:1": "A smart person would purge ",
    "dhp239:2": "their own stains gradually, ",
    "dhp239:3": "bit by bit, moment by moment, ",
    "dhp239:4": "like a smith smelting silver. ",
    "dhp240:0": "",
    "dhp240:1": "It is the rust born on the iron ",
    "dhp240:2": "that eats away the place it arose. ",
    "dhp240:3": "And so it is their own deeds ",
    "dhp240:4": "that lead the overly-ascetic to a bad place. ",
    "dhp241:0": "",
    "dhp241:1": "Not rehearsing is the stain of hymns. ",
    "dhp241:2": "The stain of houses is neglect. ",
    "dhp241:3": "Laziness is the stain of beauty. ",
    "dhp241:4": "A guard’s stain is negligence. ",
    "dhp242:0": "",
    "dhp242:1": "Misconduct is a woman’s stain. ",
    "dhp242:2": "A giver’s stain is stinginess. ",
    "dhp242:3": "Bad qualities are a stain ",
    "dhp242:4": "in this world and the next. ",
    "dhp243:1": "But a worse stain than these ",
    "dhp243:2": "is ignorance, the worst stain of all. ",
    "dhp243:3": "Having given up that stain, ",
    "dhp243:4": "be without stains, mendicants! ",
    "dhp244:0": "",
    "dhp244:1": "Life is easy for the shameless. ",
    "dhp244:2": "With all the rude courage of a crow, ",
    "dhp244:3": "they live pushy, ",
    "dhp244:4": "rude, and corrupt. ",
    "dhp245:1": "Life is hard for the conscientious, ",
    "dhp245:2": "always seeking purity, ",
    "dhp245:3": "neither clinging nor rude, ",
    "dhp245:4": "pure of livelihood and discerning. ",
    "dhp246:0": "",
    "dhp246:1": "Take anyone in this world ",
    "dhp246:2": "who kills living creatures, ",
    "dhp246:3": "speaks falsely, steals, ",
    "dhp246:4": "commits adultery, ",
    "dhp247:1": "and indulges in drinking ",
    "dhp247:2": "beer and wine. ",
    "dhp247:3": "Right here they dig up ",
    "dhp247:4": "the root of their own self. ",
    "dhp248:1": "Know this, my friend: ",
    "dhp248:2": "they are unrestrained and wicked. ",
    "dhp248:3": "Don’t let that greed and unrighteousness ",
    "dhp248:4": "inflict pain on you for long. ",
    "dhp249:0": "",
    "dhp249:1": "The people give according to their faith, ",
    "dhp249:2": "according to their confidence. ",
    "dhp249:3": "If you get upset over that, ",
    "dhp249:4": "over other’s food and drink, ",
    "dhp249:5": "you’ll not, by day or by night, ",
    "dhp249:6": "become immersed in samādhi. ",
    "dhp250:1": "Those who have cut that out, ",
    "dhp250:2": "dug it up at the root, eradicated it, ",
    "dhp250:3": "they will, by day or by night, ",
    "dhp250:4": "become immersed in samādhi. ",
    "dhp251:0": "",
    "dhp251:1": "There is no fire like greed, ",
    "dhp251:2": "no crime like hate, ",
    "dhp251:3": "no net like delusion, ",
    "dhp251:4": "no river like craving. ",
    "dhp252:0": "",
    "dhp252:1": "It’s easy to see the faults of others, ",
    "dhp252:2": "hard to see one’s own. ",
    "dhp252:3": "For the faults of others ",
    "dhp252:4": "are tossed high like hay, ",
    "dhp252:5": "while one’s own are hidden, ",
    "dhp252:6": "as a cheat hides a bad hand. ",
    "dhp253:0": "",
    "dhp253:1": "When you look for the flaws of others, ",
    "dhp253:2": "always finding fault, ",
    "dhp253:3": "your defilements only grow, ",
    "dhp253:4": "you’re far from ending defilements. ",
    "dhp254:0": "",
    "dhp254:1": "In the atmosphere there is no track, ",
    "dhp254:2": "there’s no true ascetic outside here. ",
    "dhp254:3": "People enjoy proliferation, ",
    "dhp254:4": "the Realized Ones are free of proliferation. ",
    "dhp255:1": "In the atmosphere there is no track, ",
    "dhp255:2": "there’s no true ascetic outside here. ",
    "dhp255:3": "No conditions last forever, ",
    "dhp255:4": "the Awakened Ones are not shaken. ",
    "dhp255:5": ""
  },
  "variant_text": {
    "dhp235:2": "te → taṁ (bj, sya-all, km, pts1ed, pts2ed) ",
    "dhp236:4": "Dibbaṁ ariyabhūmiṁ upehisi → dibbaṁ ariyabhūmimehisi (bj, sya-all, pts1ed, pts2ed); dibbamariyabhūmiṁ upehisi (?) ",
    "dhp237:3": "Vāso → vāsopi ca (bahūsu) ",
    "dhp238:4": "Na punaṁ jātijaraṁ → na puna jātijaraṁ (bj, sya-all); na puna jātijjaraṁ (mr) ",
    "dhp240:1": "samuṭṭhitaṁ → samuṭṭhāya (mr) ",
    "dhp240:2": "Tatuṭṭhāya → taduṭṭhāya (bj, sya-all, pts1ed, pts2ed) ",
    "dhp240:4": "kammāni → sakakammāni (bj, pts2ed) ",
    "dhp249:2": "yathāpasādanaṁ → yattha pasādanaṁ (katthaci) ",
    "dhp249:3": "Tattha yo ca maṅku bhavati → tattha ce maṅku yo hoti (bj); tattha yo maṅkuto hoti (sya-all); tattha yo maṅku hoti (pts1ed); tattha yo maṅku bhavati (pts2ed) ",
    "dhp250:2": "mūlaghaccaṁ → mulaghaccaṁ (sya-all); mūlaghacchaṁ (mr) ",
    "dhp252:4": "opunāti → opuṇāti (bj, pts1ed); ophunāti (mr) "
  },
  "reference_text": {
    "dhp235:1": "vnp235, vns235, cck25.39, mc0.58, ms18Dh_255, pts-vp-pli1ed35, pts-vp-pli2ed67",
    "dhp236:1": "vnp236, vns236, csp1ed18.48, csp2ed18.48, ms18Dh_256",
    "dhp237:1": "vnp237, vns237, dr25.63, ms18Dh_257, sya25.47",
    "dhp238:1": "vnp238, vns238, ms18Dh_258, pts-vp-pli2ed68",
