  "root_text": {
    "snp2.3:0.1": "Sutta Nipāta 2.3 ",
    "snp2.3:0.2": "Hirisutta ",
    "snp2.3:1.1": "Hiriṁ tarantaṁ vijigucchamānaṁ, ",
    "snp2.3:1.2": "Tavāhamasmi iti bhāsamānaṁ; ",
    "snp2.3:1.3": "Sayhāni kammāni anādiyantaṁ, ",
    "snp2.3:1.4": "Neso mamanti iti naṁ vijaññā. ",
    "snp2.3:2.1": "Ananvayaṁ piyaṁ vācaṁ, ",
    "snp2.3:2.2": "yo mittesu pakubbati; ",
    "snp2.3:2.3": "Akarontaṁ bhāsamānaṁ, ",
    "snp2.3:2.4": "parijānanti paṇḍitā. ",
    "snp2.3:3.1": "Na so mitto yo sadā appamatto, ",
    "snp2.3:3.2": "Bhedāsaṅkī randhamevānupassī; ",
    "snp2.3:3.3": "Yasmiñca seti urasīva putto, ",
    "snp2.3:3.4": "Sa ve mitto yo parehi abhejjo. ",
    "snp2.3:4.1": "Pāmujjakaraṇaṁ ṭhānaṁ, ",
    "snp2.3:4.2": "pasaṁsāvahanaṁ sukhaṁ; ",
    "snp2.3:4.3": "Phalānisaṁso bhāveti, ",
    "snp2.3:4.4": "vahanto porisaṁ dhuraṁ. ",
    "snp2.3:5.1": "Pavivekarasaṁ pitvā, ",
    "snp2.3:5.2": "Rasaṁ upasamassa ca; ",
    "snp2.3:5.3": "Niddaro hoti nippāpo, ",
    "snp2.3:5.4": "Dhammapītirasaṁ pivanti. ",
    "snp2.3:5.5": "Hirisuttaṁ tatiyaṁ. "
  },
  "translation_text": {
    "snp2.3:0.1": "Anthology of Discourses 2.3 ",
    "snp2.3:0.2": "Conscientious Companionship ",
    "snp2.3:1.1": "Flouting conscience, loathing it, ",
    "snp2.3:1.2": "saying “I’m on your side”, ",
    "snp2.3:1.3": "but not following up in deeds—",
    "snp2.3:1.4": "know they’re not on your side. ",
    "snp2.3:2.1": "Some say nice things to their friends ",
    "snp2.3:2.2": "without following it up. ",
    "snp2.3:2.3": "The wise will recognize ",
    "snp2.3:2.4": "one who talks without doing. ",
    "snp2.3:3.1": "No true friend relentlessly ",
    "snp2.3:3.2": "suspects betrayal, looking for fault. ",
    "snp2.3:3.3": "One on whom you rest, like a child on the breast, ",
    "snp2.3:3.4": "is a true friend, not split from you by others. ",
    "snp2.3:4.1": "One whose reward is the fruit ",
    "snp2.3:4.2": "of bearing the burden of service ",
    "snp2.3:4.3": "develops a happy state, ",
    "snp2.3:4.4": "producing joy and attracting praise. ",
    "snp2.3:5.1": "One who has drunk the nectar of seclusion ",
    "snp2.3:5.2": "and the nectar of peace, ",
    "snp2.3:5.3": "free of stress, free of evil, ",
    "snp2.3:5.4": "drinks the joyous nectar of Dhamma. "
  },
  "variant_text": {
