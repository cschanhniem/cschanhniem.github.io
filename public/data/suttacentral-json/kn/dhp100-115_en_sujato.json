  "root_text": {
    "dhp100:0.1": "Khuddakanikāya ",
    "dhp100:0.2": "Dhammapada ",
    "dhp100:0.3": "Sahassavagga ",
    "dhp100:0.4": "Tambadāṭhikacoraghātakavatthu ",
    "dhp100:1": "Sahassamapi ce vācā, ",
    "dhp100:2": "anatthapadasaṁhitā; ",
    "dhp100:3": "Ekaṁ atthapadaṁ seyyo, ",
    "dhp100:4": "yaṁ sutvā upasammati. ",
    "dhp101:0": "Bāhiyadārucīriyattheravatthu ",
    "dhp101:1": "Sahassamapi ce gāthā, ",
    "dhp101:2": "anatthapadasaṁhitā; ",
    "dhp101:3": "Ekaṁ gāthāpadaṁ seyyo, ",
    "dhp101:4": "yaṁ sutvā upasammati. ",
    "dhp102:0": "Kuṇḍalakesitherīvatthu ",
    "dhp102:1": "Yo ca gāthā sataṁ bhāse, ",
    "dhp102:2": "anatthapadasaṁhitā; ",
    "dhp102:3": "Ekaṁ dhammapadaṁ seyyo, ",
    "dhp102:4": "yaṁ sutvā upasammati. ",
    "dhp103:1": "Yo sahassaṁ sahassena, ",
    "dhp103:2": "saṅgāme mānuse jine; ",
    "dhp103:3": "Ekañca jeyyamattānaṁ, ",
    "dhp103:4": "sa ve saṅgāmajuttamo. ",
    "dhp104:0": "Anatthapucchakabrāhmaṇavatthu ",
    "dhp104:1": "Attā have jitaṁ seyyo, ",
    "dhp104:2": "yā cāyaṁ itarā pajā; ",
    "dhp104:3": "Attadantassa posassa, ",
    "dhp104:4": "niccaṁ saññatacārino. ",
    "dhp105:1": "Neva devo na gandhabbo, ",
    "dhp105:2": "na māro saha brahmunā; ",
    "dhp105:3": "Jitaṁ apajitaṁ kayirā, ",
    "dhp105:4": "tathārūpassa jantuno. ",
    "dhp106:0": "Sāriputtattherassa mātulabrāhmaṇavatthu ",
    "dhp106:1": "Māse māse sahassena, ",
    "dhp106:2": "yo yajetha sataṁ samaṁ; ",
    "dhp106:3": "Ekañca bhāvitattānaṁ, ",
    "dhp106:4": "muhuttamapi pūjaye; ",
    "dhp106:5": "Sāyeva pūjanā seyyo, ",
    "dhp106:6": "yañce vassasataṁ hutaṁ. ",
    "dhp107:0": "Sāriputtattherassa bhāgineyyavatthu ",
    "dhp107:1": "Yo ca vassasataṁ jantu, ",
    "dhp107:2": "aggiṁ paricare vane; ",
    "dhp107:3": "Ekañca bhāvitattānaṁ, ",
    "dhp107:4": "muhuttamapi pūjaye; ",
    "dhp107:5": "Sāyeva pūjanā seyyo, ",
    "dhp107:6": "yañce vassasataṁ hutaṁ. ",
    "dhp108:0": "Sāriputtatherassa sahāyakabrāhmaṇavatthu ",
    "dhp108:1": "Yaṁ kiñci yiṭṭhaṁ va hutaṁ va loke, ",
    "dhp108:2": "Saṁvaccharaṁ yajetha puññapekkho; ",
    "dhp108:3": "Sabbampi taṁ na catubhāgameti, ",
    "dhp108:4": "Abhivādanā ujjugatesu seyyo. ",
    "dhp109:0": "Āyuvaḍḍhanakumāravatthu ",
    "dhp109:1": "Abhivādanasīlissa, ",
    "dhp109:2": "niccaṁ vuḍḍhāpacāyino; ",
    "dhp109:3": "Cattāro dhammā vaḍḍhanti, ",
    "dhp109:4": "āyu vaṇṇo sukhaṁ balaṁ. ",
    "dhp110:0": "Saṅkiccasāmaṇeravatthu ",
    "dhp110:1": "Yo ca vassasataṁ jīve, ",
    "dhp110:2": "dussīlo asamāhito; ",
    "dhp110:3": "Ekāhaṁ jīvitaṁ seyyo, ",
    "dhp110:4": "sīlavantassa jhāyino. ",
    "dhp111:0": "Khāṇukoṇḍaññattheravatthu ",
    "dhp111:1": "Yo ca vassasataṁ jīve, ",
    "dhp111:2": "duppañño asamāhito; ",
    "dhp111:3": "Ekāhaṁ jīvitaṁ seyyo, ",
    "dhp111:4": "paññavantassa jhāyino. ",
    "dhp112:0": "Sabbadāsattheravatthu ",
    "dhp112:1": "Yo ca vassasataṁ jīve, ",
    "dhp112:2": "kusīto hīnavīriyo; ",
    "dhp112:3": "Ekāhaṁ jīvitaṁ seyyo, ",
    "dhp112:4": "vīriyamārabhato daḷhaṁ. ",
    "dhp113:0": "Paṭācārātherīvatthu ",
    "dhp113:1": "Yo ca vassasataṁ jīve, ",
    "dhp113:2": "apassaṁ udayabbayaṁ; ",
    "dhp113:3": "Ekāhaṁ jīvitaṁ seyyo, ",
    "dhp113:4": "passato udayabbayaṁ. ",
    "dhp114:0": "Kisāgotamīvatthu ",
    "dhp114:1": "Yo ca vassasataṁ jīve, ",
    "dhp114:2": "apassaṁ amataṁ padaṁ; ",
    "dhp114:3": "Ekāhaṁ jīvitaṁ seyyo, ",
    "dhp114:4": "passato amataṁ padaṁ. ",
    "dhp115:0": "Bahuputtikattherīvatthu ",
    "dhp115:1": "Yo ca vassasataṁ jīve, ",
    "dhp115:2": "apassaṁ dhammamuttamaṁ; ",
    "dhp115:3": "Ekāhaṁ jīvitaṁ seyyo, ",
    "dhp115:4": "passato dhammamuttamaṁ. ",
    "dhp115:5": "Sahassavaggo aṭṭhamo. "
  },
  "translation_text": {
    "dhp100:0.1": "Minor Collection ",
    "dhp100:0.2": "Sayings of the Dhamma 100–115 ",
    "dhp100:0.3": "8. The Thousands ",
    "dhp100:0.4": "",
    "dhp100:1": "Better than a thousand ",
    "dhp100:2": "meaningless sayings ",
    "dhp100:3": "is a single meaningful saying, ",
    "dhp100:4": "hearing which brings you peace. ",
    "dhp101:0": "",
    "dhp101:1": "Better than a thousand ",
    "dhp101:2": "meaningless verses ",
    "dhp101:3": "is a single meaningful verse, ",
    "dhp101:4": "hearing which brings you peace. ",
    "dhp102:0": "",
    "dhp102:1": "Better than reciting ",
    "dhp102:2": "a hundred meaningless verses ",
    "dhp102:3": "is a single saying of Dhamma, ",
    "dhp102:4": "hearing which brings you peace. ",
    "dhp103:1": "The supreme conqueror is ",
    "dhp103:2": "not he who conquers a million men in battle, ",
    "dhp103:3": "but he who conquers a single man: ",
    "dhp103:4": "himself. ",
    "dhp104:0": "",
    "dhp104:1": "It is surely better to conquer oneself ",
    "dhp104:2": "than all those other folk. ",
    "dhp104:3": "When a person has tamed themselves, ",
    "dhp104:4": "always living restrained, ",
    "dhp105:1": "no god nor centaur, ",
    "dhp105:2": "nor Māra nor divinity, ",
    "dhp105:3": "can undo the victory ",
    "dhp105:4": "of such a personage. ",
    "dhp106:0": "",
    "dhp106:1": "Rather than a thousandfold sacrifice, ",
    "dhp106:2": "every month for a full century, ",
    "dhp106:3": "it’s better to honor for a single hour ",
    "dhp106:4": "one who has developed themselves. ",
    "dhp106:5": "That offering is better ",
    "dhp106:6": "than the hundred year sacrifice. ",
    "dhp107:0": "",
    "dhp107:1": "Rather than serve the sacred flame ",
    "dhp107:2": "in the forest for a hundred years, ",
    "dhp107:3": "it’s better to honor for a single hour ",
    "dhp107:4": "a personage who has developed themselves. ",
    "dhp107:5": "That offering is better ",
    "dhp107:6": "than the hundred year sacrifice. ",
    "dhp108:0": "",
    "dhp108:1": "Whatever sacrifice or offering in the world ",
    "dhp108:2": "a seeker of merit may make for a year, ",
    "dhp108:3": "none of it is worth a quarter ",
    "dhp108:4": "of bowing to the sincere. ",
    "dhp109:0": "",
    "dhp109:1": "For one in the habit of bowing, ",
    "dhp109:2": "always honoring the elders, ",
    "dhp109:3": "four blessings grow: ",
    "dhp109:4": "lifespan, beauty, happiness, and strength. ",
    "dhp110:0": "",
    "dhp110:1": "Better to live a single day ",
    "dhp110:2": "ethical and absorbed in meditation ",
    "dhp110:3": "than to live a hundred years ",
    "dhp110:4": "unethical and lacking immersion. ",
    "dhp111:0": "",
    "dhp111:1": "Better to live a single day ",
    "dhp111:2": "wise and absorbed in meditation ",
    "dhp111:3": "than to live a hundred years ",
    "dhp111:4": "witless and lacking immersion. ",
    "dhp112:0": "",
    "dhp112:1": "Better to live a single day ",
    "dhp112:2": "energetic and strong, ",
    "dhp112:3": "than to live a hundred years ",
    "dhp112:4": "lazy and lacking energy. ",
    "dhp113:0": "",
    "dhp113:1": "Better to live a single day ",
    "dhp113:2": "seeing rise and fall ",
    "dhp113:3": "than to live a hundred years ",
    "dhp113:4": "blind to rise and fall. ",
    "dhp114:0": "",
    "dhp114:1": "Better to live a single day ",
    "dhp114:2": "seeing the state free of death ",
    "dhp114:3": "than to live a hundred years ",
    "dhp114:4": "blind to the state free of death. ",
    "dhp115:0": "",
    "dhp115:1": "Better to live a single day ",
    "dhp115:2": "seeing the supreme teaching ",
    "dhp115:3": "than to live a hundred years ",
    "dhp115:4": "blind to the supreme teaching. ",
    "dhp115:5": ""
  },
  "variant_text": {
    "dhp102:2": "anatthapadasaṁhitā → anatthapadasañhitaṁ (bj, mr) ",
    "dhp103:3": "jeyyamattānaṁ → jeyya attānaṁ (bj) ",
    "dhp108:1": "yiṭṭhaṁ va hutaṁ va → yiṭṭhañca hutañca (pts1ed, mr) ",
    "dhp109:2": "vuḍḍhāpacāyino → vaddhāpacāyino (bj, pts1ed, pts2ed) "
  },
