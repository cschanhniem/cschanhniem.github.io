  "root_text": {
    "dhp90:0.1": "Khuddakanikāya ",
    "dhp90:0.2": "Dhammapada ",
    "dhp90:0.3": "Arahantavagga ",
    "dhp90:0.4": "Jīvakapañhavatthu ",
    "dhp90:1": "Gataddhino visokassa, ",
    "dhp90:2": "vippamuttassa sabbadhi; ",
    "dhp90:3": "Sabbaganthappahīnassa, ",
    "dhp90:4": "pariḷāho na vijjati. ",
    "dhp91:0": "Mahākassapattheravatthu ",
    "dhp91:1": "Uyyuñjanti satīmanto, ",
    "dhp91:2": "na nikete ramanti te; ",
    "dhp91:3": "Haṁsāva pallalaṁ hitvā, ",
    "dhp91:4": "okamokaṁ jahanti te. ",
    "dhp92:0": "Belaṭṭhasīsattheravatthu ",
    "dhp92:1": "Yesaṁ sannicayo natthi, ",
    "dhp92:2": "ye pariññātabhojanā; ",
    "dhp92:3": "Suññato animitto ca, ",
    "dhp92:4": "vimokkho yesaṁ gocaro; ",
    "dhp92:5": "Ākāseva sakuntānaṁ, ",
    "dhp92:6": "gati tesaṁ durannayā. ",
    "dhp93:0": "Anuruddhattheravatthu ",
    "dhp93:1": "Yassāsavā parikkhīṇā, ",
    "dhp93:2": "āhāre ca anissito; ",
    "dhp93:3": "Suññato animitto ca, ",
    "dhp93:4": "vimokkho yassa gocaro; ",
    "dhp93:5": "Ākāseva sakuntānaṁ, ",
    "dhp93:6": "padaṁ tassa durannayaṁ. ",
    "dhp94:0": "Mahākaccāyanattheravatthu ",
    "dhp94:1": "Yassindriyāni samathaṅgatāni, ",
    "dhp94:2": "Assā yathā sārathinā sudantā; ",
    "dhp94:3": "Pahīnamānassa anāsavassa, ",
    "dhp94:4": "Devāpi tassa pihayanti tādino. ",
    "dhp95:0": "Sāriputtattheravatthu ",
    "dhp95:1": "Pathavisamo no virujjhati, ",
    "dhp95:2": "Indakhilupamo tādi subbato; ",
    "dhp95:3": "Rahadova apetakaddamo, ",
    "dhp95:4": "Saṁsārā na bhavanti tādino. ",
    "dhp96:0": "Kosambivāsitissattherasāmaṇeravatthu ",
    "dhp96:1": "Santaṁ tassa manaṁ hoti, ",
    "dhp96:2": "santā vācā ca kamma ca; ",
    "dhp96:3": "Sammadaññāvimuttassa, ",
    "dhp96:4": "upasantassa tādino. ",
    "dhp97:0": "Sāriputtattheravatthu ",
    "dhp97:1": "Assaddho akataññū ca, ",
    "dhp97:2": "sandhicchedo ca yo naro; ",
    "dhp97:3": "Hatāvakāso vantāso, ",
    "dhp97:4": "sa ve uttamaporiso. ",
    "dhp98:0": "Khadiravaniyarevatattheravatthu ",
    "dhp98:1": "Gāme vā yadi vāraññe, ",
    "dhp98:2": "Ninne vā yadi vā thale; ",
    "dhp98:3": "Yattha arahanto viharanti, ",
    "dhp98:4": "Taṁ bhūmirāmaṇeyyakaṁ. ",
    "dhp99:0": "Aññataraitthivatthu ",
    "dhp99:1": "Ramaṇīyāni araññāni, ",
    "dhp99:2": "yattha na ramatī jano; ",
    "dhp99:3": "Vītarāgā ramissanti, ",
    "dhp99:4": "na te kāmagavesino. ",
    "dhp99:5": "Arahantavaggo sattamo. "
  },
  "translation_text": {
    "dhp90:0.1": "Minor Collection ",
    "dhp90:0.2": "Sayings of the Dhamma 90–99 ",
    "dhp90:0.3": "7. The Perfected Ones ",
    "dhp90:1": "At journey’s end, rid of sorrow; ",
    "dhp90:2": "everywhere free, ",
    "dhp90:3": "all ties given up, ",
    "dhp90:4": "no fever is found in them. ",
    "dhp91:1": "The mindful apply themselves; ",
    "dhp91:2": "they delight in no abode. ",
    "dhp91:3": "Like a swan gone from the marsh, ",
    "dhp91:4": "they leave home after home behind. ",
    "dhp92:1": "Those with nothing stored up, ",
    "dhp92:2": "who have understood their food, ",
    "dhp92:3": "whose domain is the liberation ",
    "dhp92:4": "of the signless and the empty: ",
    "dhp92:5": "their path is hard to trace, ",
    "dhp92:6": "like birds in the sky. ",
    "dhp93:1": "One whose defilements have ended; ",
    "dhp93:2": "who’s not attached to food; ",
    "dhp93:3": "whose domain is the liberation ",
    "dhp93:4": "of the signless and the empty: ",
    "dhp93:5": "their track is hard to trace, ",
    "dhp93:6": "like birds in the sky. ",
    "dhp94:1": "Whose faculties have become serene, ",
    "dhp94:2": "like horses tamed by a charioteer, ",
    "dhp94:3": "who has abandoned conceit and defilements; ",
    "dhp94:4": "the unaffected one is envied by even the gods. ",
    "dhp95:1": "Undisturbed like the earth, ",
    "dhp95:2": "true to their vows, steady as Indra’s pillar, ",
    "dhp95:3": "like a lake clear of mud; ",
    "dhp95:4": "such a one does not transmigrate. ",
    "dhp96:1": "Their mind is peaceful, ",
    "dhp96:2": "peaceful are their speech and deeds. ",
    "dhp96:3": "Such a one is at peace, ",
    "dhp96:4": "rightly freed through enlightenment. ",
    "dhp97:1": "Lacking faith, a house-breaker, ",
    "dhp97:2": "one who acknowledges nothing, ",
    "dhp97:3": "purged of hope, they’ve wasted their chance: ",
    "dhp97:4": "that is indeed the supreme person! ",
    "dhp98:1": "Whether in village or wilderness, ",
    "dhp98:2": "in a valley or the uplands, ",
    "dhp98:3": "wherever the perfected ones live ",
    "dhp98:4": "is a delightful place. ",
    "dhp99:1": "Delightful are the wildernesses ",
    "dhp99:2": "where no people delight. ",
    "dhp99:3": "Those free of greed will delight there, ",
    "dhp99:4": "not those who seek sensual pleasures. "
  },
  "variant_text": {
    "dhp92:5": "sakuntānaṁ → sakuṇānaṁ (mr) ",
    "dhp94:1": "Yassindriyāni → kassindriyāni (thag2.43:1 [Brahmālittheragāthā]) | samathaṅgatāni → samathaṁ gatāni (bj, pts1ed, pts2ed) ",
    "dhp95:2": "Indakhilupamo → indakhīlūpamo (bj, sya-all, pts1ed, pts2ed) "
  },
