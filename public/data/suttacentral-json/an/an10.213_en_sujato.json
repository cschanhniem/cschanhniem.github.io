  "root_text": {
    "an10.213:0.1": "Aṅguttara Nikāya 10.213 ",
    "an10.213:0.2": "21. Karajakāyavagga ",
    "an10.213:0.3": "Mātugāmasutta ",
    "an10.213:1.1": "“Dasahi, bhikkhave, dhammehi samannāgato mātugāmo yathābhataṁ nikkhitto evaṁ niraye. ",
    "an10.213:1.2": "Katamehi dasahi? ",
    "an10.213:1.3": "Pāṇātipātī hoti …pe… ",
    "an10.213:1.4": "adinnādāyī hoti … ",
    "an10.213:1.5": "kāmesumicchācārī hoti … ",
    "an10.213:1.6": "musāvādī hoti … ",
    "an10.213:1.7": "pisuṇavāco hoti … ",
    "an10.213:1.8": "pharusavāco hoti … ",
    "an10.213:1.9": "samphappalāpī hoti … ",
    "an10.213:1.10": "abhijjhālu hoti … ",
    "an10.213:1.11": "byāpannacitto hoti … ",
    "an10.213:1.12": "micchādiṭṭhiko hoti …. ",
    "an10.213:1.13": "Imehi kho, bhikkhave, dasahi dhammehi samannāgato mātugāmo yathābhataṁ nikkhitto evaṁ niraye. ",
    "an10.213:2.1": "Dasahi, bhikkhave, dhammehi samannāgato mātugāmo yathābhataṁ nikkhitto evaṁ sagge. ",
    "an10.213:2.2": "Katamehi dasahi? ",
    "an10.213:2.3": "Pāṇātipātā paṭivirato hoti …pe… ",
    "an10.213:2.4": "adinnādānā paṭivirato hoti … ",
    "an10.213:2.5": "kāmesumicchācārā paṭivirato hoti … ",
    "an10.213:2.6": "musāvādā paṭivirato hoti … ",
    "an10.213:2.7": "pisuṇāya vācāya paṭivirato hoti … ",
    "an10.213:2.8": "pharusāya vācāya paṭivirato hoti … ",
    "an10.213:2.9": "samphappalāpā paṭivirato hoti … ",
    "an10.213:2.10": "anabhijjhālu hoti … ",
    "an10.213:2.11": "abyāpannacitto hoti … ",
    "an10.213:2.12": "sammādiṭṭhiko hoti …. ",
    "an10.213:2.13": "Imehi kho, bhikkhave, dasahi dhammehi samannāgato mātugāmo yathābhataṁ nikkhitto evaṁ sagge”ti. ",
    "an10.213:2.14": "Tatiyaṁ. "
  },
  "translation_text": {
    "an10.213:0.1": "Numbered Discourses 10.213 ",
    "an10.213:0.2": "21. The Body Born of Deeds ",
    "an10.213:0.3": "A Female ",
    "an10.213:1.1": "“A lady with ten qualities is placed in hell as if delivered there. ",
    "an10.213:1.2": "What ten? ",
    "an10.213:1.3": "She kills living creatures. … ",
    "an10.213:1.4": "She steals. … ",
    "an10.213:1.5": "She commits sexual misconduct. … ",
    "an10.213:1.6": "She lies. … ",
    "an10.213:1.7": "She speaks divisively. … ",
    "an10.213:1.8": "She speaks harshly. … ",
    "an10.213:1.9": "She indulges in talking nonsense. … ",
    "an10.213:1.10": "She’s covetous. … ",
    "an10.213:1.11": "She has cruel intentions. … ",
    "an10.213:1.12": "She has wrong view. … ",
    "an10.213:1.13": "A lady with these ten qualities is placed in hell as if delivered there. ",
    "an10.213:2.1": "A lady with ten qualities is placed in heaven as if delivered there. ",
    "an10.213:2.2": "What ten? ",
    "an10.213:2.3": "She doesn’t kill living creatures. … ",
    "an10.213:2.4": "She doesn’t steal. … ",
    "an10.213:2.5": "She doesn’t commit sexual misconduct. … ",
    "an10.213:2.6": "She doesn’t lie. … ",
    "an10.213:2.7": "She doesn’t speak divisively. … ",
    "an10.213:2.8": "She doesn’t speak harshly. … ",
    "an10.213:2.9": "She doesn’t indulge in talking nonsense. … ",
    "an10.213:2.10": "She’s content. … ",
    "an10.213:2.11": "She’s kind hearted. … ",
    "an10.213:2.12": "She has right view. … ",
    "an10.213:2.13": "A lady with these ten qualities is placed in heaven as if delivered there.” "
  },
