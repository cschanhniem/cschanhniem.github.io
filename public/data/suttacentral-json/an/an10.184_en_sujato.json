  "root_text": {
    "an10.184:0.1": "Aṅguttara Nikāya 10.184 ",
    "an10.184:0.2": "18. Sādhuvagga ",
    "an10.184:0.3": "Vajjasutta ",
    "an10.184:1.1": "“Sāvajjañca vo, bhikkhave, dhammaṁ desessāmi anavajjañca. ",
    "an10.184:1.2": "Taṁ suṇātha …pe… ",
    "an10.184:1.3": "katamo ca, bhikkhave, sāvajjo dhammo? ",
    "an10.184:1.4": "Pāṇātipāto …pe… ",
    "an10.184:1.5": "micchādiṭṭhi—",
    "an10.184:1.6": "ayaṁ vuccati, bhikkhave, sāvajjo dhammo. ",
    "an10.184:2.1": "Katamo ca, bhikkhave, anavajjo dhammo? ",
    "an10.184:2.2": "Pāṇātipātā veramaṇī …pe… ",
    "an10.184:2.3": "sammādiṭṭhi—",
    "an10.184:2.4": "ayaṁ vuccati, bhikkhave, anavajjo dhammo”ti. ",
    "an10.184:2.5": "Sattamaṁ. "
  },
  "translation_text": {
    "an10.184:0.1": "Numbered Discourses 10.184 ",
    "an10.184:0.2": "18. Good ",
    "an10.184:0.3": "Blameworthy ",
    "an10.184:1.1": "“I will teach you the blameworthy principle and the blameless. … ",
    "an10.184:1.2": "",
    "an10.184:1.3": "And what is the blameworthy principle? ",
    "an10.184:1.4": "Killing living creatures … ",
    "an10.184:1.5": "wrong view. ",
    "an10.184:1.6": "This is called the blameworthy principle. ",
    "an10.184:2.1": "And what is the blameless principle? ",
    "an10.184:2.2": "Not killing living creatures … ",
    "an10.184:2.3": "right view. ",
    "an10.184:2.4": "This is called the blameless principle.” "
  },
  "variant_text": {
    "an10.184:0.3": "Vajjasutta → sāvajjasuttaṁ (bj) "
  },
