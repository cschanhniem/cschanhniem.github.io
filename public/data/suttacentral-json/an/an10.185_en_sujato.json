  "root_text": {
    "an10.185:0.1": "Aṅguttara Nikāya 10.185 ",
    "an10.185:0.2": "18. Sādhuvagga ",
    "an10.185:0.3": "Tapanīyasutta ",
    "an10.185:1.1": "“Tapanīyañca vo, bhikkhave, dhammaṁ desessāmi atapanīyañca. ",
    "an10.185:1.2": "Taṁ suṇātha …pe… ",
    "an10.185:1.3": "katamo ca, bhikkhave, tapanīyo dhammo? ",
    "an10.185:1.4": "Pāṇātipāto …pe… ",
    "an10.185:1.5": "micchādiṭṭhi—",
    "an10.185:1.6": "ayaṁ vuccati, bhikkhave, tapanīyo dhammo. ",
    "an10.185:2.1": "Katamo ca, bhikkhave, atapanīyo dhammo? ",
    "an10.185:2.2": "Pāṇātipātā veramaṇī …pe… ",
    "an10.185:2.3": "sammādiṭṭhi—",
    "an10.185:2.4": "ayaṁ vuccati, bhikkhave, atapanīyo dhammo”ti. ",
    "an10.185:2.5": "Aṭṭhamaṁ. "
  },
  "translation_text": {
    "an10.185:0.1": "Numbered Discourses 10.185 ",
    "an10.185:0.2": "18. Good ",
    "an10.185:0.3": "Mortifying ",
    "an10.185:1.1": "“I will teach you the mortifying principle and the unmortifying. … ",
    "an10.185:1.2": "",
    "an10.185:1.3": "And what is the mortifying principle? ",
    "an10.185:1.4": "Killing living creatures … ",
    "an10.185:1.5": "wrong view. ",
    "an10.185:1.6": "This is called the mortifying principle. ",
    "an10.185:2.1": "And what is the unmortifying principle? ",
    "an10.185:2.2": "Not killing living creatures … ",
    "an10.185:2.3": "right view. ",
    "an10.185:2.4": "This is called the unmortifying principle.” "
  },
