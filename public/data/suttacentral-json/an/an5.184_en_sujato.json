  "root_text": {
    "an5.184:0.1": "Aṅguttara Nikāya 5.184 ",
    "an5.184:0.2": "19. Araññavagga ",
    "an5.184:0.3": "Sosānikasutta ",
    "an5.184:1.1": "“Pañcime, bhikkhave, sosānikā. ",
    "an5.184:1.2": "Katame pañca? ",
    "an5.184:1.3": "Mandattā momūhattā sosāniko hoti …pe… idamatthitaṁyeva nissāya sosāniko hoti. ",
    "an5.184:1.4": "Ime kho, bhikkhave, pañca sosānikā”ti. ",
    "an5.184:1.5": "Catutthaṁ. "
  },
  "translation_text": {
    "an5.184:0.1": "Numbered Discourses 5.184 ",
    "an5.184:0.2": "19. Wilderness Dwellers ",
    "an5.184:0.3": "Charnel Ground Dwellers ",
    "an5.184:1.1": "“Mendicants, these five dwell in a charnel ground. ",
    "an5.184:1.2": "What five? ",
    "an5.184:1.3": "One may dwell in a charnel ground because of stupidity … corrupt wishes … madness … because it is praised by the Buddhas … or for the sake of having few wishes … ",
    "an5.184:1.4": "These are the five who dwell in a charnel ground.” "
  },
