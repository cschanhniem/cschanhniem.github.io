  "root_text": {
    "an8.85:0.1": "Aṅguttara Nikāya 8.85 ",
    "an8.85:0.2": "9. Sativagga ",
    "an8.85:0.3": "Samaṇasutta ",
    "an8.85:1.1": "“‘Samaṇo’ti, bhikkhave, tathāgatassetaṁ adhivacanaṁ arahato sammāsambuddhassa. ",
    "an8.85:1.2": "‘Brāhmaṇo’ti, bhikkhave, tathāgatassetaṁ adhivacanaṁ arahato sammāsambuddhassa. ",
    "an8.85:1.3": "‘Vedagū’ti, bhikkhave, tathāgatassetaṁ adhivacanaṁ arahato sammāsambuddhassa. ",
    "an8.85:1.4": "‘Bhisakko’ti, bhikkhave, tathāgatassetaṁ adhivacanaṁ arahato sammāsambuddhassa. ",
    "an8.85:1.5": "‘Nimmalo’ti, bhikkhave, tathāgatassetaṁ adhivacanaṁ arahato sammāsambuddhassa. ",
    "an8.85:1.6": "‘Vimalo’ti, bhikkhave, tathāgatassetaṁ adhivacanaṁ arahato sammāsambuddhassa. ",
    "an8.85:1.7": "‘Ñāṇī’ti, bhikkhave, tathāgatassetaṁ adhivacanaṁ arahato sammāsambuddhassa. ",
    "an8.85:1.8": "‘Vimutto’ti, bhikkhave, tathāgatassetaṁ adhivacanaṁ arahato sammāsambuddhassāti. ",
    "an8.85:2.1": "Yaṁ samaṇena pattabbaṁ, ",
    "an8.85:2.2": "brāhmaṇena vusīmatā; ",
    "an8.85:2.3": "Yaṁ vedagunā pattabbaṁ, ",
    "an8.85:2.4": "bhisakkena anuttaraṁ. ",
    "an8.85:3.1": "Yaṁ nimmalena pattabbaṁ, ",
    "an8.85:3.2": "vimalena sucīmatā; ",
    "an8.85:3.3": "Yaṁ ñāṇinā ca pattabbaṁ, ",
    "an8.85:3.4": "vimuttena anuttaraṁ. ",
    "an8.85:4.1": "Sohaṁ vijitasaṅgāmo, ",
    "an8.85:4.2": "mutto mocemi bandhanā; ",
    "an8.85:4.3": "Nāgomhi paramadanto, ",
    "an8.85:4.4": "asekho parinibbuto”ti. ",
    "an8.85:4.5": "Pañcamaṁ. "
  },
  "translation_text": {
    "an8.85:0.1": "Numbered Discourses 8.85 ",
    "an8.85:0.2": "9. Mindfulness ",
    "an8.85:0.3": "Terms for the Realized One ",
    "an8.85:1.1": "“‘Ascetic’ is a term for the Realized One, the perfected one, the fully awakened Buddha. ",
    "an8.85:1.2": "‘Brahmin’, ",
    "an8.85:1.3": "‘Knowledge Master’, ",
    "an8.85:1.4": "‘Healer’, ",
    "an8.85:1.5": "‘Unstained’, ",
    "an8.85:1.6": "‘Immaculate’, ",
    "an8.85:1.7": "‘Knower’, ",
    "an8.85:1.8": "and ‘Freed’ are terms for the Realized One, the perfected one, the fully awakened Buddha. ",
    "an8.85:2.1": "The supreme should be attained by an ascetic, ",
    "an8.85:2.2": "a brahmin who has lived the life; ",
    "an8.85:2.3": "it should be attained by a knowledge master, ",
    "an8.85:2.4": "a healer. ",
    "an8.85:3.1": "The supreme should be attained by the unstained, ",
    "an8.85:3.2": "stainless and pure; ",
    "an8.85:3.3": "it should be attained by a knower, ",
    "an8.85:3.4": "who is free. ",
    "an8.85:4.1": "I am victorious in battle! ",
    "an8.85:4.2": "Released, I release others from their chains. ",
    "an8.85:4.3": "I am a dragon completely tamed, ",
    "an8.85:4.4": "an adept, I am quenched.” "
  },
  "variant_text": {
    "an8.85:0.3": "Samaṇasutta → tathāgatādhivacanasuttaṁ (bj) "
  },
