  "root_text": {
    "an10.182:0.1": "Aṅguttara Nikāya 10.182 ",
    "an10.182:0.2": "18. Sādhuvagga ",
    "an10.182:0.3": "Dhammasutta ",
    "an10.182:1.1": "“Dhammañca vo, bhikkhave, desessāmi adhammañca. ",
    "an10.182:1.2": "Taṁ suṇātha …pe… ",
    "an10.182:1.3": "katamo ca, bhikkhave, adhammo? ",
    "an10.182:1.4": "Pāṇātipāto …pe… ",
    "an10.182:1.5": "micchādiṭṭhi—",
    "an10.182:1.6": "ayaṁ vuccati, bhikkhave, adhammo. ",
    "an10.182:2.1": "Katamo ca, bhikkhave, dhammo? ",
    "an10.182:2.2": "Pāṇātipātā veramaṇī …pe… ",
    "an10.182:2.3": "sammādiṭṭhi—",
    "an10.182:2.4": "ayaṁ vuccati, bhikkhave, dhammo”ti. ",
    "an10.182:2.5": "Pañcamaṁ. "
  },
  "translation_text": {
    "an10.182:0.1": "Numbered Discourses 10.182 ",
    "an10.182:0.2": "18. Good ",
    "an10.182:0.3": "The Teaching ",
    "an10.182:1.1": "“I will teach you what is the teaching and what is not the teaching. … ",
    "an10.182:1.2": "",
    "an10.182:1.3": "And what is not the teaching? ",
    "an10.182:1.4": "Killing living creatures … ",
    "an10.182:1.5": "wrong view. ",
    "an10.182:1.6": "This is called what is not the teaching. ",
    "an10.182:2.1": "And what is the teaching? ",
    "an10.182:2.2": "Not killing living creatures … ",
    "an10.182:2.3": "right view. ",
    "an10.182:2.4": "This is called the teaching.” "
  },
