  "root_text": {
    "an7.91:0.1": "Aṅguttara Nikāya 7.91 ",
    "an7.91:0.2": "9. Samaṇavagga ",
    "an7.91:0.3": "Ariyasutta ",
    "an7.91:1.1": "“… Ārakattā ariyo hoti …pe…. ",
    "an7.91:1.2": "Sattamaṁ. "
  },
  "translation_text": {
    "an7.91:0.1": "Numbered Discourses 7.91 ",
    "an7.91:0.2": "9. An Ascetic ",
    "an7.91:0.3": "A Noble One ",
    "an7.91:1.1": "“Mendicants, it’s because seven foes have been nobbled that you become a noble one …” "
  },
