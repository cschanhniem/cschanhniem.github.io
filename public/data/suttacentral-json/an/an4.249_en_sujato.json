  "root_text": {
    "an4.249:0.1": "Aṅguttara Nikāya 4.249 ",
    "an4.249:0.2": "25. Āpattibhayavagga ",
    "an4.249:0.3": "Bahukārasutta ",
    "an4.249:1.1": "“Cattārome, bhikkhave, dhammā manussabhūtassa bahukārā honti. ",
    "an4.249:1.2": "Katame cattāro? ",
    "an4.249:1.3": "Sappurisasaṁsevo, saddhammasavanaṁ, yonisomanasikāro, dhammānudhammappaṭipatti—",
    "an4.249:1.4": "Ime kho, bhikkhave, cattāro dhammā manussabhūtassa bahukārā hontī”ti. ",
    "an4.249:1.5": "Sattamaṁ. "
  },
  "translation_text": {
    "an4.249:0.1": "Numbered Discourses 4.249 ",
    "an4.249:0.2": "25. Perils of Offenses ",
    "an4.249:0.3": "Very Helpful ",
    "an4.249:1.1": "“Mendicants, these four things are very helpful to a human being. ",
    "an4.249:1.2": "What four? ",
    "an4.249:1.3": "Associating with true persons, listening to the true teaching, rational application of mind, and practicing in line with the teaching. ",
    "an4.249:1.4": "These four things are very helpful to a human being.” "
  },
