  "root_text": {
    "an5.207:0.1": "Aṅguttara Nikāya 5.207 ",
    "an5.207:0.2": "21. Kimilavagga ",
    "an5.207:0.3": "Yāgusutta ",
    "an5.207:1.1": "“Pañcime, bhikkhave, ānisaṁsā yāguyā. ",
    "an5.207:1.2": "Katame pañca? ",
    "an5.207:1.3": "Khuddaṁ paṭihanati, pipāsaṁ paṭivineti, vātaṁ anulometi, vatthiṁ sodheti, āmāvasesaṁ pāceti. ",
    "an5.207:1.4": "Ime kho, bhikkhave, pañca ānisaṁsā yāguyā”ti. ",
    "an5.207:1.5": "Sattamaṁ. "
  },
  "translation_text": {
    "an5.207:0.1": "Numbered Discourses 5.207 ",
    "an5.207:0.2": "21. With Kimbila ",
    "an5.207:0.3": "Porridge ",
    "an5.207:1.1": "“Mendicants, there are these five benefits of porridge. ",
    "an5.207:1.2": "What five? ",
    "an5.207:1.3": "It wards off hunger, quenches thirst, settles the wind, cleans the bladder, and helps digestion. ",
    "an5.207:1.4": "These are the five benefits of porridge.” "
  },
  "variant_text": {
    "an5.207:1.3": "Khuddaṁ → khudaṁ (bj, pts1ed) "
  },
