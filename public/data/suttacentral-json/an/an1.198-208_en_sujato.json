  "root_text": {
    "an1.198:0.1": "Aṅguttara Nikāya 1 ",
    "an1.198:0.2": "15. Dutiyavagga ",
    "an1.198:1.1": "“Etadaggaṁ, bhikkhave, mama sāvakānaṁ bhikkhūnaṁ manomayaṁ kāyaṁ abhinimminantānaṁ yadidaṁ cūḷapanthako. ",
    "an1.199:1.1": "… Cetovivaṭṭakusalānaṁ yadidaṁ cūḷapanthako. ",
    "an1.200:1.1": "… Saññāvivaṭṭakusalānaṁ yadidaṁ mahāpanthako. ",
    "an1.201:1.1": "… Araṇavihārīnaṁ yadidaṁ subhūti. ",
    "an1.202:1.1": "… Dakkhiṇeyyānaṁ yadidaṁ subhūti. ",
    "an1.203:1.1": "… Āraññakānaṁ yadidaṁ revato khadiravaniyo. ",
    "an1.204:1.1": "… Jhāyīnaṁ yadidaṁ kaṅkhārevato. ",
    "an1.205:1.1": "… Āraddhavīriyānaṁ yadidaṁ soṇo koḷiviso. ",
    "an1.206:1.1": "… Kalyāṇavākkaraṇānaṁ yadidaṁ soṇo kuṭikaṇṇo. ",
    "an1.207:1.1": "… Lābhīnaṁ yadidaṁ sīvali. ",
    "an1.208:1.1": "… Saddhādhimuttānaṁ yadidaṁ vakkalī”ti. ",
    "an1.208:1.2": "Vaggo dutiyo. "
  },
  "translation_text": {
    "an1.198:0.1": "Numbered Discourses 1 ",
    "an1.198:0.2": "Chapter Two ",
    "an1.198:1.1": "“The foremost of my monk disciples in creating a mind-made body is Cūḷapanthaka. ",
    "an1.199:1.1": "… who are skilled in the evolution of consciousness is Cūḷapanthaka. ",
    "an1.200:1.1": "… who are skilled in the evolution of perception is Mahāpanthaka. ",
    "an1.201:1.1": "… who live without strife is Subhūti. ",
    "an1.202:1.1": "… who are worthy of a religious donation is Subhūti. ",
    "an1.203:1.1": "… who stay in the wilderness is Revata of the Acacia Wood. ",
    "an1.204:1.1": "… who practice absorption is Revata the Doubter. ",
    "an1.205:1.1": "… who are energetic is Soṇa Koḷivisa. ",
    "an1.206:1.1": "… who enunciate well is Soṇa of the Sharp Ears. ",
    "an1.207:1.1": "… who receive many possessions is Sīvali. ",
    "an1.208:1.1": "… who are committed to faith is Vakkalī.” "
  },
  "variant_text": {
    "an1.198:1.1": "cūḷapanthako → cullapanthako (bj, sya-all, km, pts1ed) "
  },
