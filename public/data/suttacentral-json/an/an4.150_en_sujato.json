  "root_text": {
    "an4.150:0.1": "Aṅguttara Nikāya 4.150 ",
    "an4.150:0.2": "15. Ābhāvagga ",
    "an4.150:0.3": "Sārasutta ",
    "an4.150:1.1": "“Cattārome, bhikkhave, sārā. ",
    "an4.150:1.2": "Katame cattāro? ",
    "an4.150:1.3": "Sīlasāro, samādhisāro, paññāsāro, vimuttisāro—",
    "an4.150:1.4": "Ime kho, bhikkhave, cattāro sārā”ti. ",
    "an4.150:1.5": "Dasamaṁ. ",
    "an4.150:1.6": "Ābhāvaggo pañcamo. ",
    "an4.150:2.0": "Tassuddānaṁ ",
    "an4.150:2.1": "Ābhā pabhā ca ālokā, ",
    "an4.150:2.2": "obhāsā ceva pajjotā; ",
    "an4.150:2.3": "Dve kālā caritā dve ca, ",
    "an4.150:2.4": "honti sārena te dasāti. ",
    "an4.150:2.5": "Tatiyo paṇṇāsako samatto. "
  },
  "translation_text": {
    "an4.150:0.1": "Numbered Discourses 4.150 ",
    "an4.150:0.2": "15. Brightness ",
    "an4.150:0.3": "Essentials ",
    "an4.150:1.1": "“Mendicants, there are these four essentials. ",
    "an4.150:1.2": "What four? ",
    "an4.150:1.3": "Ethics, immersion, wisdom, and freedom are essentials. ",
    "an4.150:1.4": "These are the four essentials.” ",
