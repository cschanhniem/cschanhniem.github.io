  "root_text": {
    "an4.242:0.1": "Aṅguttara Nikāya 4.242 ",
    "an4.242:0.2": "24. Kammavagga ",
    "an4.242:0.3": "Sappurisānisaṁsasutta ",
    "an4.242:1.1": "“Sappurisaṁ, bhikkhave, nissāya cattāro ānisaṁsā pāṭikaṅkhā. ",
    "an4.242:1.2": "Katame cattāro? ",
    "an4.242:1.3": "Ariyena sīlena vaḍḍhati, ariyena samādhinā vaḍḍhati, ariyāya paññāya vaḍḍhati, ariyāya vimuttiyā vaḍḍhati—",
    "an4.242:1.4": "sappurisaṁ, bhikkhave, nissāya ime cattāro ānisaṁsā pāṭikaṅkhā”ti. ",
    "an4.242:1.5": "Ekādasamaṁ. ",
    "an4.242:1.6": "Kammavaggo catuttho. ",
    "an4.242:2.0": "Tassuddānaṁ ",
    "an4.242:2.1": "Saṅkhitta vitthāra soṇakāyana, ",
    "an4.242:2.2": "Sikkhāpadaṁ ariyamaggo bojjhaṅgaṁ; ",
    "an4.242:2.3": "Sāvajjañceva abyābajjhaṁ, ",
    "an4.242:2.4": "Samaṇo ca sappurisānisaṁsoti. "
  },
  "translation_text": {
    "an4.242:0.1": "Numbered Discourses 4.242 ",
    "an4.242:0.2": "24. Deeds ",
    "an4.242:0.3": "Benefits of Relying on a True Person ",
    "an4.242:1.1": "“Mendicants, you can expect four benefits from relying on a true person. ",
    "an4.242:1.2": "What four? ",
    "an4.242:1.3": "Growth in noble ethics, immersion, wisdom, and freedom. ",
    "an4.242:1.4": "You can expect these four benefits from relying on a true person.” ",
