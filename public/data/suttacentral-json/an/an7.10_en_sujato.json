  "root_text": {
    "an7.10:0.1": "Aṅguttara Nikāya 7.10 ",
    "an7.10:0.2": "1. Dhanavagga ",
    "an7.10:0.3": "Macchariyasutta ",
    "an7.10:1.1": "“Sattimāni, bhikkhave, saṁyojanāni. ",
    "an7.10:1.2": "Katamāni satta? ",
    "an7.10:1.3": "Anunayasaṁyojanaṁ, paṭighasaṁyojanaṁ, diṭṭhisaṁyojanaṁ, vicikicchāsaṁyojanaṁ, mānasaṁyojanaṁ, issāsaṁyojanaṁ, macchariyasaṁyojanaṁ. ",
    "an7.10:1.4": "Imāni kho, bhikkhave, satta saṁyojanānī”ti. ",
    "an7.10:1.5": "Dasamaṁ. ",
    "an7.10:1.6": "Dhanavaggo paṭhamo. ",
    "an7.10:2.0": "Tassuddānaṁ ",
    "an7.10:2.1": "Dve piyāni balaṁ dhanaṁ, ",
    "an7.10:2.2": "Saṅkhittañceva vitthataṁ; ",
    "an7.10:2.3": "Uggaṁ saṁyojanañceva, ",
    "an7.10:2.4": "Pahānaṁ macchariyena cāti. "
  },
  "translation_text": {
    "an7.10:0.1": "Numbered Discourses 7.10 ",
    "an7.10:0.2": "1. Wealth ",
    "an7.10:0.3": "Stinginess ",
    "an7.10:1.1": "“Mendicants, there are these seven fetters. ",
    "an7.10:1.2": "What seven? ",
    "an7.10:1.3": "The fetters of attraction, repulsion, views, doubt, conceit, jealousy, and stinginess. ",
    "an7.10:1.4": "These are the seven fetters.” ",
