  "root_text": {
    "an4.74:0.1": "Aṅguttara Nikāya 4.74 ",
    "an4.74:0.2": "8. Apaṇṇakavagga ",
    "an4.74:0.3": "Paṭhamaaggasutta ",
    "an4.74:1.1": "“Cattārimāni, bhikkhave, aggāni. ",
    "an4.74:1.2": "Katamāni cattāri? ",
    "an4.74:1.3": "Sīlaggaṁ, samādhiggaṁ, paññāggaṁ, vimuttaggaṁ—",
    "an4.74:1.4": "Imāni kho, bhikkhave, cattāri aggānī”ti. ",
    "an4.74:1.5": "Catutthaṁ. "
  },
  "translation_text": {
    "an4.74:0.1": "Numbered Discourses 4.74 ",
    "an4.74:0.2": "8.  Sure Bet ",
    "an4.74:0.3": "Best (1st) ",
    "an4.74:1.1": "“Mendicants, these four things are the best. ",
    "an4.74:1.2": "What four? ",
    "an4.74:1.3": "The best ethics, immersion, wisdom, and freedom. ",
    "an4.74:1.4": "These are the four things that are the best.” "
  },
  "variant_text": {
    "an4.74:1.3": "samādhiggaṁ → samādhaggaṁ (bj, cck, sya2ed, km, pts1ed); samadhaggaṁ (sya1ed) "
  },
