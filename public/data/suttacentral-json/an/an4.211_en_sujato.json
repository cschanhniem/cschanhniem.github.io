  "root_text": {
    "an4.211:0.1": "Aṅguttara Nikāya 4.211 ",
    "an4.211:0.2": "22. Parisāvagga ",
    "an4.211:0.3": "Parisāsutta ",
    "an4.211:1.1": "“Cattārome, bhikkhave, parisadūsanā. ",
    "an4.211:1.2": "Katame cattāro? ",
    "an4.211:1.3": "Bhikkhu, bhikkhave, dussīlo pāpadhammo parisadūsano; ",
    "an4.211:1.4": "bhikkhunī, bhikkhave, dussīlā pāpadhammā parisadūsanā; ",
    "an4.211:1.5": "upāsako, bhikkhave, dussīlo pāpadhammo parisadūsano; ",
    "an4.211:1.6": "upāsikā, bhikkhave, dussīlā pāpadhammā parisadūsanā. ",
    "an4.211:1.7": "Ime kho, bhikkhave, cattāro parisadūsanā. ",
    "an4.211:2.1": "Cattārome, bhikkhave, parisasobhanā. ",
    "an4.211:2.2": "Katame cattāro? ",
    "an4.211:2.3": "Bhikkhu, bhikkhave, sīlavā kalyāṇadhammo parisasobhano; ",
    "an4.211:2.4": "bhikkhunī, bhikkhave, sīlavatī kalyāṇadhammā parisasobhanā; ",
    "an4.211:2.5": "upāsako, bhikkhave, sīlavā kalyāṇadhammo parisasobhano; ",
    "an4.211:2.6": "upāsikā, bhikkhave, sīlavatī kalyāṇadhammā parisasobhanā. ",
    "an4.211:2.7": "Ime kho, bhikkhave, cattāro parisasobhanā”ti. ",
    "an4.211:2.8": "Paṭhamaṁ. "
  },
  "translation_text": {
    "an4.211:0.1": "Numbered Discourses 4.211 ",
    "an4.211:0.2": "22. Assembly ",
    "an4.211:0.3": "Assembly ",
    "an4.211:1.1": "“Mendicants, these four corrupt an assembly. ",
    "an4.211:1.2": "What four? ",
    "an4.211:1.3": "A monk, nun, layman, or laywoman who is unethical, of bad character. ",
    "an4.211:1.4": "",
    "an4.211:1.5": "",
    "an4.211:1.6": "",
    "an4.211:1.7": "These are the four that corrupt an assembly. ",
    "an4.211:2.1": "Mendicants, these four grace an assembly. ",
    "an4.211:2.2": "What four? ",
    "an4.211:2.3": "A monk, nun, layman, or laywoman who is ethical, of good character. ",
    "an4.211:2.4": "",
    "an4.211:2.5": "",
    "an4.211:2.6": "",
    "an4.211:2.7": "These are the four that grace an assembly.” "
  },
  "variant_text": {
    "an4.211:0.2": "Parisāvagga → parisasobhanavaggo (bj) ",
    "an4.211:0.3": "Parisāsutta → parisasobhanasuttaṁ (bj) ",
    "an4.211:1.3": "Bhikkhu, bhikkhave → idha bhikkhave bhikkhu (pts1ed, mr) "
  },
