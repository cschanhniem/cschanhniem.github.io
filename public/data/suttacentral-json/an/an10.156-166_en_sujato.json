  "root_text": {
    "an10.156-166:0.1": "Aṅguttara Nikāya 10.156–166 ",
    "an10.156-166:0.2": "16. Puggalavagga ",
    "an10.156-166:0.3": "Bhajitabbādisutta ",
    "an10.156-166:1.1": "“Dasahi, bhikkhave, dhammehi samannāgato puggalo na bhajitabbo …pe… ",
    "an10.156-166:1.2": "bhajitabbo …pe… ",
    "an10.156-166:1.3": "na payirupāsitabbo … ",
    "an10.156-166:1.4": "payirupāsitabbo …pe… ",
    "an10.156-166:1.5": "na pujjo hoti … ",
    "an10.156-166:1.6": "pujjo hoti …pe… ",
    "an10.156-166:1.7": "na pāsaṁso hoti … ",
    "an10.156-166:1.8": "pāsaṁso hoti …pe… ",
    "an10.156-166:1.9": "agāravo hoti … ",
    "an10.156-166:1.10": "sagāravo hoti …pe… ",
    "an10.156-166:1.11": "appatisso hoti … ",
    "an10.156-166:1.12": "sappatisso hoti …pe… ",
    "an10.156-166:1.13": "na ārādhako hoti … ",
    "an10.156-166:1.14": "ārādhako hoti …pe… ",
    "an10.156-166:1.15": "na visujjhati … ",
    "an10.156-166:1.16": "visujjhati …pe… ",
    "an10.156-166:1.17": "mānaṁ nādhibhoti … ",
    "an10.156-166:1.18": "mānaṁ adhibhoti …pe… ",
    "an10.156-166:1.19": "paññāya na vaḍḍhati … ",
    "an10.156-166:1.20": "paññāya vaḍḍhati …pe…. ",
    "an10.156-166:2.1": "Bahuṁ apuññaṁ pasavati … ",
    "an10.156-166:2.2": "bahuṁ puññaṁ pasavati. ",
    "an10.156-166:2.3": "Katamehi dasahi? ",
    "an10.156-166:2.4": "Sammādiṭṭhiko hoti, sammāsaṅkappo hoti, sammāvāco hoti, sammākammanto hoti, sammāājīvo hoti, sammāvāyāmo hoti, sammāsati hoti, sammāsamādhi hoti, sammāñāṇī hoti, sammāvimutti hoti—",
    "an10.156-166:2.5": "imehi kho, bhikkhave, dasahi dhammehi samannāgato puggalo bahuṁ puññaṁ pasavatī”ti. ",
    "an10.156-166:2.6": "Puggalavaggo paṭhamo. "
  },
  "translation_text": {
    "an10.156-166:0.1": "Numbered Discourses 10.156–166 ",
    "an10.156-166:0.2": "16. Individuals ",
    "an10.156-166:0.3": "Frequenting, Etc. ",
    "an10.156-166:1.1": "“Mendicants, you should not frequent an individual who has ten qualities. … ",
    "an10.156-166:1.2": "you should frequent … ",
    "an10.156-166:1.3": "you should not pay homage … ",
    "an10.156-166:1.4": "you should pay homage … ",
    "an10.156-166:1.5": "you should not venerate … ",
    "an10.156-166:1.6": "you should venerate … ",
    "an10.156-166:1.7": "you should not praise … ",
    "an10.156-166:1.8": "you should praise … ",
    "an10.156-166:1.9": "you should not respect … ",
    "an10.156-166:1.10": "you should respect … ",
    "an10.156-166:1.11": "you should not revere … ",
    "an10.156-166:1.12": "you should revere … ",
    "an10.156-166:1.13": "is not a success … ",
    "an10.156-166:1.14": "is a success … ",
    "an10.156-166:1.15": "is not pure … ",
    "an10.156-166:1.16": "is pure … ",
    "an10.156-166:1.17": "does not win over conceit … ",
    "an10.156-166:1.18": "wins over conceit … ",
    "an10.156-166:1.19": "does not grow in wisdom … ",
    "an10.156-166:1.20": "grows in wisdom … ",
    "an10.156-166:2.1": "brims with much wickedness … ",
    "an10.156-166:2.2": "brims with much merit. ",
    "an10.156-166:2.3": "What ten? ",
    "an10.156-166:2.4": "Right view, right thought, right speech, right action, right livelihood, right effort, right mindfulness, right immersion, right knowledge, and right freedom. ",
    "an10.156-166:2.5": "An individual who has these ten qualities creates much merit.” "
  },
