  "root_text": {
    "an4.17:0.1": "Aṅguttara Nikāya 4.17 ",
    "an4.17:0.2": "2. Caravagga ",
    "an4.17:0.3": "Paṭhamaagatisutta ",
    "an4.17:1.1": "“Cattārimāni, bhikkhave, agatigamanāni. ",
    "an4.17:1.2": "Katamāni cattāri? ",
    "an4.17:1.3": "Chandāgatiṁ gacchati, dosāgatiṁ gacchati, mohāgatiṁ gacchati, bhayāgatiṁ gacchati—",
    "an4.17:1.4": "Imāni kho, bhikkhave, cattāri agatigamanānīti. ",
    "an4.17:2.1": "Chandā dosā bhayā mohā, ",
    "an4.17:2.2": "yo dhammaṁ ativattati; ",
    "an4.17:2.3": "Nihīyati tassa yaso, ",
    "an4.17:2.4": "kāḷapakkheva candimā”ti. ",
    "an4.17:2.5": "Sattamaṁ. "
  },
  "translation_text": {
    "an4.17:0.1": "Numbered Discourses 4.17 ",
    "an4.17:0.2": "2. Walking ",
    "an4.17:0.3": "Prejudice (1st) ",
    "an4.17:1.1": "“Mendicants, there are these four ways of making prejudiced decisions. ",
    "an4.17:1.2": "What four? ",
    "an4.17:1.3": "Making decisions prejudiced by favoritism, hostility, stupidity, and cowardice. ",
    "an4.17:1.4": "These are the four ways of making prejudiced decisions. ",
    "an4.17:2.1": "If you act against the teaching ",
    "an4.17:2.2": "out of favoritism, hostility, cowardice, or stupidity, ",
    "an4.17:2.3": "your fame fades away, ",
    "an4.17:2.4": "like the moon in the waning fortnight.” "
  },
  "variant_text": {
    "an4.17:0.3": "Paṭhamaagatisutta → agatisuttaṁ (bj) "
  },
