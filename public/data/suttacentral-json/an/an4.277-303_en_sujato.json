  "root_text": {
    "an4.277-303:0.1": "Aṅguttara Nikāya 4.277–303 ",
    "an4.277-303:0.2": "28. Rāgapeyyāla ",
    "an4.277-303:0.3": "Pariññādisutta ",
    "an4.277-303:1.1": "“Rāgassa, bhikkhave, pariññāya …pe… parikkhayāya … pahānāya … khayāya … vayāya … virāgāya … nirodhāya … cāgāya … paṭinissaggāya cattāro dhammā bhāvetabbā …pe…. ",
    "an4.277-303:1.2": "Tiṁsatimaṁ. "
  },
  "translation_text": {
    "an4.277-303:0.1": "Numbered Discourses 4.277–303 ",
    "an4.277-303:0.2": "28. Abbreviated Texts Beginning with Greed ",
    "an4.277-303:0.3": "Complete Understanding, Etc. ",
    "an4.277-303:1.1": "“For the complete understanding … finishing … giving up … ending … vanishing … fading away … cessation … giving away … letting go of greed, four things should be developed.” "
  },
