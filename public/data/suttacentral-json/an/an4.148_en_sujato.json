  "root_text": {
    "an4.148:0.1": "Aṅguttara Nikāya 4.148 ",
    "an4.148:0.2": "15. Ābhāvagga ",
    "an4.148:0.3": "Duccaritasutta ",
    "an4.148:1.1": "“Cattārimāni, bhikkhave, vacīduccaritāni. ",
    "an4.148:1.2": "Katamāni cattāri? ",
    "an4.148:1.3": "Musāvādo, pisuṇā vācā, pharusā vācā, samphappalāpo—",
    "an4.148:1.4": "Imāni kho, bhikkhave, cattāri vacīduccaritānī”ti. ",
    "an4.148:1.5": "Aṭṭhamaṁ. "
  },
  "translation_text": {
    "an4.148:0.1": "Numbered Discourses 4.148 ",
    "an4.148:0.2": "15. Brightness ",
    "an4.148:0.3": "Bad Conduct ",
    "an4.148:1.1": "“Mendicants, there are these four kinds of bad conduct by way of speech. ",
    "an4.148:1.2": "What four? ",
    "an4.148:1.3": "Speech that’s false, divisive, harsh, or nonsensical. ",
    "an4.148:1.4": "These are the four kinds of bad conduct by way of speech.” "
  },
  "variant_text": {
    "an4.148:0.3": "Duccaritasutta → vacīduccaritasuttaṁ (bj) "
  },
