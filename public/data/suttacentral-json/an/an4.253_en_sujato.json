  "root_text": {
    "an4.253:0.1": "Aṅguttara Nikāya 4.253 ",
    "an4.253:0.2": "25. Āpattibhayavagga ",
    "an4.253:0.3": "Catutthavohārasutta ",
    "an4.253:1.1": "“Cattārome, bhikkhave, ariyavohārā. ",
    "an4.253:1.2": "Katame cattāro? ",
    "an4.253:1.3": "Diṭṭhe diṭṭhavāditā, sute sutavāditā, mute mutavāditā, viññāte viññātavāditā—",
    "an4.253:1.4": "Ime kho, bhikkhave, cattāro ariyavohārā”ti. ",
    "an4.253:1.5": "Ekādasamaṁ. ",
    "an4.253:1.6": "Āpattibhayavaggo pañcamo. ",
    "an4.253:2.0": "Tassuddānaṁ ",
    "an4.253:2.1": "Bhedaāpatti sikkhā ca, ",
    "an4.253:2.2": "seyyā thūpārahena ca; ",
    "an4.253:2.3": "Paññāvuddhi bahukārā, ",
    "an4.253:2.4": "vohārā caturo ṭhitāti. ",
    "an4.253:2.5": "Pañcamo paṇṇāsako samatto. "
  },
  "translation_text": {
    "an4.253:0.1": "Numbered Discourses 4.253 ",
    "an4.253:0.2": "25. Perils of Offenses ",
    "an4.253:0.3": "Expressions (4th) ",
    "an4.253:1.1": "“Mendicants, there are these four noble expressions. ",
    "an4.253:1.2": "What four? ",
    "an4.253:1.3": "Saying you’ve seen, heard, thought, or known something, and you have. ",
    "an4.253:1.4": "These are the four noble expressions.” ",
