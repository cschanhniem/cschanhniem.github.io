  "root_text": {
    "an8.17:0.1": "Aṅguttara Nikāya 8.17 ",
    "an8.17:0.2": "2. Mahāvagga ",
    "an8.17:0.3": "Paṭhamabandhanasutta ",
    "an8.17:1.1": "“Aṭṭhahi, bhikkhave, ākārehi itthī purisaṁ bandhati. ",
    "an8.17:1.2": "Katamehi aṭṭhahi? ",
    "an8.17:1.3": "Ruṇṇena, bhikkhave, itthī purisaṁ bandhati; ",
    "an8.17:1.4": "hasitena, bhikkhave, itthī purisaṁ bandhati; ",
    "an8.17:1.5": "bhaṇitena, bhikkhave, itthī purisaṁ bandhati; ",
    "an8.17:1.6": "ākappena, bhikkhave, itthī purisaṁ bandhati; ",
    "an8.17:1.7": "vanabhaṅgena, bhikkhave, itthī purisaṁ bandhati; ",
    "an8.17:1.8": "gandhena, bhikkhave, itthī purisaṁ bandhati; ",
    "an8.17:1.9": "rasena, bhikkhave, itthī purisaṁ bandhati; ",
    "an8.17:1.10": "phassena, bhikkhave, itthī purisaṁ bandhati. ",
    "an8.17:1.11": "Imehi kho, bhikkhave, aṭṭhahākārehi itthī purisaṁ bandhati. ",
    "an8.17:1.12": "Te, bhikkhave, sattā subaddhā, ye phassena baddhā”ti. ",
    "an8.17:1.13": "Sattamaṁ. "
  },
  "translation_text": {
    "an8.17:0.1": "Numbered Discourses 8.17 ",
    "an8.17:0.2": "2. The Great Chapter ",
    "an8.17:0.3": "Catching (1st) ",
    "an8.17:1.1": "“Mendicants, a woman catches a man using eight features. ",
    "an8.17:1.2": "What eight? ",
    "an8.17:1.3": "With weeping, ",
    "an8.17:1.4": "laughing, ",
    "an8.17:1.5": "speaking, ",
    "an8.17:1.6": "appearance, ",
    "an8.17:1.7": "gifts of wildflowers, ",
    "an8.17:1.8": "scents, ",
    "an8.17:1.9": "tastes, ",
    "an8.17:1.10": "and touches. ",
    "an8.17:1.11": "A woman catches a man using these eight features. ",
    "an8.17:1.12": "But those beings who are caught by touch are well and truly caught.” "
  },
  "variant_text": {
    "an8.17:0.3": "Paṭhamabandhanasutta → purisabandhanasuttaṁ (bj) ",
    "an8.17:1.12": "subaddhā → subandhā (si, sya-all, mr) | ye → yeva (sya-all, pts1ed, mr) | baddhā”ti → bandhāti (bj, sya-all, mr) "
  },
