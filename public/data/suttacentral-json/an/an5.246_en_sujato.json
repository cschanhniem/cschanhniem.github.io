    "an5.246:0.1": "Aṅguttara Nikāya 5.246 ",
    "an5.246:0.2": "25. Duccaritavagga ",
    "an5.246:0.3": "Dutiyakāyaduccaritasutta ",
    "an5.246:1.1": "“Pañcime, bhikkhave, ādīnavā kāyaduccarite …pe… ānisaṁsā kāyasucarite …pe…. ",
    "an5.246:1.2": "Chaṭṭhaṁ. "
  },
  "translation_text": {
