  "root_text": {
    "an5.244:0.1": "Aṅguttara Nikāya 5.244 ",
    "an5.244:0.2": "25. Duccaritavagga ",
    "an5.244:0.3": "Paṭhamamanoduccaritasutta ",
    "an5.244:1.1": "“Pañcime, bhikkhave, ādīnavā manoduccarite …pe… ānisaṁsā manosucarite. ",
    "an5.244:1.2": "Katame pañca? ",
    "an5.244:1.3": "Attāpi attānaṁ na upavadati; ",
    "an5.244:1.4": "anuvicca viññū pasaṁsanti; ",
    "an5.244:1.5": "kalyāṇo kittisaddo abbhuggacchati; ",
    "an5.244:1.6": "asammūḷho kālaṁ karoti; ",
    "an5.244:1.7": "kāyassa bhedā paraṁ maraṇā sugatiṁ saggaṁ lokaṁ upapajjati. ",
    "an5.244:1.8": "Ime kho, bhikkhave, pañca ānisaṁsā manosucarite”ti. ",
    "an5.244:1.9": "Catutthaṁ. "
  },
  "translation_text": {
