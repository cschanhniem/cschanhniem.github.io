  "root_text": {
    "an10.181:0.1": "Aṅguttara Nikāya 10.181 ",
    "an10.181:0.2": "18. Sādhuvagga ",
    "an10.181:0.3": "Atthasutta ",
    "an10.181:1.1": "“Atthañca vo, bhikkhave, desessāmi anatthañca. ",
    "an10.181:1.2": "Taṁ suṇātha …pe… ",
    "an10.181:1.3": "katamo ca, bhikkhave, anattho? ",
    "an10.181:1.4": "Pāṇātipāto …pe… ",
    "an10.181:1.5": "micchādiṭṭhi—",
    "an10.181:1.6": "ayaṁ vuccati, bhikkhave, anattho. ",
    "an10.181:2.1": "Katamo ca, bhikkhave, attho? ",
    "an10.181:2.2": "Pāṇātipātā veramaṇī …pe… ",
    "an10.181:2.3": "sammādiṭṭhi—",
    "an10.181:2.4": "ayaṁ vuccati, bhikkhave, attho”ti. ",
    "an10.181:2.5": "Catutthaṁ. "
  },
  "translation_text": {
    "an10.181:0.1": "Numbered Discourses 10.181 ",
    "an10.181:0.2": "18. Good ",
    "an10.181:0.3": "Beneficial ",
    "an10.181:1.1": "“I will teach you the beneficial and the harmful. … ",
    "an10.181:1.2": "",
    "an10.181:1.3": "And what is the harmful? ",
    "an10.181:1.4": "Killing living creatures … ",
    "an10.181:1.5": "wrong view. ",
    "an10.181:1.6": "This is called the harmful. ",
    "an10.181:2.1": "And what is the beneficial? ",
    "an10.181:2.2": "Not killing living creatures … ",
    "an10.181:2.3": "right view. ",
    "an10.181:2.4": "This is called the beneficial.” "
  },
