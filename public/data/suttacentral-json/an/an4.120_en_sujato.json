  "root_text": {
    "an4.120:0.1": "Aṅguttara Nikāya 4.120 ",
    "an4.120:0.2": "12. Kesivagga ",
    "an4.120:0.3": "Dutiyabhayasutta ",
    "an4.120:1.1": "“Cattārimāni, bhikkhave, bhayāni. ",
    "an4.120:1.2": "Katamāni cattāri? ",
    "an4.120:1.3": "Aggibhayaṁ, udakabhayaṁ, rājabhayaṁ, corabhayaṁ—",
    "an4.120:1.4": "Imāni kho, bhikkhave, cattāri bhayānī”ti. ",
    "an4.120:1.5": "Dasamaṁ. ",
    "an4.120:1.6": "Kesivaggo dutiyo. ",
    "an4.120:2.0": "Tassuddānaṁ ",
    "an4.120:2.1": "Kesi javo patodo ca, ",
    "an4.120:2.2": "Nāgo ṭhānena pañcamaṁ; ",
    "an4.120:2.3": "Appamādo ca ārakkho, ",
    "an4.120:2.4": "Saṁvejanīyañca dve bhayāti. "
  },
  "translation_text": {
    "an4.120:0.1": "Numbered Discourses 4.120 ",
    "an4.120:0.2": "12. With Kesi ",
    "an4.120:0.3": "Perils (2nd) ",
    "an4.120:1.1": "“Mendicants, there are these four perils. ",
    "an4.120:1.2": "What four? ",
    "an4.120:1.3": "The perils of fire, water, kings, and bandits. ",
    "an4.120:1.4": "These are the four perils.” ",
