  "root_text": {
    "an3.108:0.1": "Aṅguttara Nikāya 3.108 ",
    "an3.108:0.2": "11. Sambodhavagga ",
    "an3.108:0.3": "Atittisutta ",
    "an3.108:1.1": "“Tiṇṇaṁ, bhikkhave, paṭisevanāya natthi titti. ",
    "an3.108:1.2": "Katamesaṁ tiṇṇaṁ? ",
    "an3.108:1.3": "Soppassa, bhikkhave, paṭisevanāya natthi titti. ",
    "an3.108:1.4": "Surāmerayapānassa, bhikkhave, paṭisevanāya natthi titti. ",
    "an3.108:1.5": "Methunadhammasamāpattiyā, bhikkhave, paṭisevanāya natthi titti. ",
    "an3.108:1.6": "Imesaṁ, bhikkhave, tiṇṇaṁ paṭisevanāya natthi tittī”ti. ",
    "an3.108:1.7": "Chaṭṭhaṁ. "
  },
  "translation_text": {
    "an3.108:0.1": "Numbered Discourses 3.108 ",
    "an3.108:0.2": "11. Awakening ",
    "an3.108:0.3": "Satisfaction ",
    "an3.108:1.1": "“Mendicants, there are three indulgences that never satisfy. ",
    "an3.108:1.2": "What three? ",
    "an3.108:1.3": "Sleep, ",
    "an3.108:1.4": "drinking beer and wine, ",
    "an3.108:1.5": "and sexual intercourse. ",
    "an3.108:1.6": "These are the three indulgences that never satisfy.” "
  },
