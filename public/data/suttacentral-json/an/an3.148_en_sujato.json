  "root_text": {
    "an3.148:0.1": "Aṅguttara Nikāya 3.148 ",
    "an3.148:0.2": "15. Maṅgalavagga ",
    "an3.148:0.3": "Visamasutta ",
    "an3.148:1.1": "“Tīhi, bhikkhave …pe… ",
    "an3.148:1.2": "visamena kāyakammena, visamena vacīkammena, visamena manokammena—",
    "an3.148:1.3": "imehi kho …pe… evaṁ niraye. ",
    "an3.148:2.1": "Tīhi, bhikkhave, dhammehi …pe… ",
    "an3.148:2.2": "samena kāyakammena, samena vacīkammena, samena manokammena—",
    "an3.148:2.3": "imehi kho …pe… evaṁ sagge”ti. ",
    "an3.148:2.4": "Tatiyaṁ. "
  },
  "translation_text": {
    "an3.148:0.1": "Numbered Discourses 3.148 ",
    "an3.148:0.2": "15. Good Fortune ",
    "an3.148:0.3": "Unethical ",
    "an3.148:1.1": "“Someone with three qualities is placed in hell as if delivered there. … ",
    "an3.148:1.2": "Unethical deeds by way of body, speech, and mind. … ",
    "an3.148:1.3": "",
    "an3.148:2.1": "Someone with three qualities is placed in heaven as if delivered there. … ",
    "an3.148:2.2": "Ethical deeds by way of body, speech, and mind. …” ",
    "an3.148:2.3": ""
  },
