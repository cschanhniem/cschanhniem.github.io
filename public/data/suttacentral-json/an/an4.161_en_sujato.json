  "root_text": {
    "an4.161:0.1": "Aṅguttara Nikāya 4.161 ",
    "an4.161:0.2": "17. Paṭipadāvagga ",
    "an4.161:0.3": "Saṅkhittasutta ",
    "an4.161:1.1": "“Catasso imā, bhikkhave, paṭipadā. ",
    "an4.161:1.2": "Katamā catasso? ",
    "an4.161:1.3": "Dukkhā paṭipadā dandhābhiññā, ",
    "an4.161:1.4": "dukkhā paṭipadā khippābhiññā, ",
    "an4.161:1.5": "sukhā paṭipadā dandhābhiññā, ",
    "an4.161:1.6": "sukhā paṭipadā khippābhiññā—",
    "an4.161:1.7": "imā kho, bhikkhave, catasso paṭipadā”ti. ",
    "an4.161:1.8": "Paṭhamaṁ. "
  },
  "translation_text": {
    "an4.161:0.1": "Numbered Discourses 4.161 ",
    "an4.161:0.2": "17. Practice ",
    "an4.161:0.3": "In Brief ",
    "an4.161:1.1": "“Mendicants, there are four ways of practice. ",
    "an4.161:1.2": "What four? ",
    "an4.161:1.3": "Painful practice with slow insight, ",
    "an4.161:1.4": "painful practice with swift insight, ",
    "an4.161:1.5": "pleasant practice with slow insight, and ",
    "an4.161:1.6": "pleasant practice with swift insight. ",
    "an4.161:1.7": "These are the four ways of practice.” "
  },
  "variant_text": {
    "an4.161:0.3": "Saṅkhittasutta → paṭipadāsuttaṁ (bj) "
  },
