  "root_text": {
    "an7.30:0.1": "Aṅguttara Nikāya 7.30 ",
    "an7.30:0.2": "3. Vajjisattakavagga ",
    "an7.30:0.3": "Vipattisutta ",
    "an7.30:1.1": "Sattimā, bhikkhave, upāsakassa vipattiyo …pe… ",
    "an7.30:1.2": "sattimā, bhikkhave, upāsakassa sampadā …pe…. ",
    "an7.30:1.3": "Dasamaṁ. "
  },
  "translation_text": {
    "an7.30:0.1": "Numbered Discourses 7.30 ",
    "an7.30:0.2": "3. The Vajji Seven ",
    "an7.30:0.3": "Failures for a Lay Follower ",
    "an7.30:1.1": "“Mendicants, there are these seven failures for a lay follower … ",
    "an7.30:1.2": "There are these seven accomplishments for a lay follower …” "
  },
  "variant_text": {
    "an7.30:0.3": "Vipattisutta → upāsakavipattisuttaṁ (bj) "
  },
