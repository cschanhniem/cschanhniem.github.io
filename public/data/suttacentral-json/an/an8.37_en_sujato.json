  "root_text": {
    "an8.37:0.1": "Aṅguttara Nikāya 8.37 ",
    "an8.37:0.2": "4. Dānavagga ",
    "an8.37:0.3": "Sappurisadānasutta ",
    "an8.37:1.1": "“Aṭṭhimāni, bhikkhave, sappurisadānāni. ",
    "an8.37:1.2": "Katamāni aṭṭha? ",
    "an8.37:1.3": "Suciṁ deti, paṇītaṁ deti, kālena deti, kappiyaṁ deti, viceyya deti, abhiṇhaṁ deti, dadaṁ cittaṁ pasādeti, datvā attamano hoti. ",
    "an8.37:1.4": "Imāni kho, bhikkhave, aṭṭha sappurisadānānīti. ",
    "an8.37:2.1": "Suciṁ paṇītaṁ kālena, ",
    "an8.37:2.2": "kappiyaṁ pānabhojanaṁ; ",
    "an8.37:2.3": "Abhiṇhaṁ dadāti dānaṁ, ",
    "an8.37:2.4": "sukhettesu brahmacārisu. ",
    "an8.37:3.1": "Neva vippaṭisārissa, ",
    "an8.37:3.2": "cajitvā āmisaṁ bahuṁ; ",
    "an8.37:3.3": "Evaṁ dinnāni dānāni, ",
    "an8.37:3.4": "vaṇṇayanti vipassino. ",
    "an8.37:4.1": "Evaṁ yajitvā medhāvī, ",
    "an8.37:4.2": "saddho muttena cetasā; ",
    "an8.37:4.3": "Abyābajjhaṁ sukhaṁ lokaṁ, ",
    "an8.37:4.4": "paṇḍito upapajjatī”ti. ",
    "an8.37:4.5": "Sattamaṁ. "
  },
  "translation_text": {
    "an8.37:0.1": "Numbered Discourses 8.37 ",
    "an8.37:0.2": "4. Giving ",
    "an8.37:0.3": "Gifts of a True Person ",
    "an8.37:1.1": "“Mendicants, there are these eight gifts of a true person. ",
    "an8.37:1.2": "What eight? ",
    "an8.37:1.3": "Their gift is pure, good quality, timely, appropriate, intelligent, and regular. While giving their heart is confident, and afterwards they’re uplifted. ",
    "an8.37:1.4": "These are the eight gifts of a true person. ",
    "an8.37:2.1": "He gives pure, good quality, and timely gifts ",
    "an8.37:2.2": "of appropriate food and drinks ",
    "an8.37:2.3": "regularly to spiritual practitioners ",
    "an8.37:2.4": "who are fertile fields of merit. ",
    "an8.37:3.1": "They never regret ",
    "an8.37:3.2": "giving away many things of the flesh. ",
    "an8.37:3.3": "Discerning people praise ",
    "an8.37:3.4": "giving such gifts. ",
    "an8.37:4.1": "An intelligent person sacrifices like this, ",
    "an8.37:4.2": "faithful, with a mind of letting go. ",
    "an8.37:4.3": "Such an astute person is reborn ",
    "an8.37:4.4": "in a happy, pleasing world.” "
  },
  "variant_text": {
    "an8.37:2.4": "sukhettesu → sukhette (pts1ed) ",
    "an8.37:3.1": "Neva → na ca (bj, pts1ed) ",
    "an8.37:4.3": "Abyābajjhaṁ → abyāpajjhaṁ (bj, sya-all, mr); avyāpajjhaṁ (pts1ed) "
  },
