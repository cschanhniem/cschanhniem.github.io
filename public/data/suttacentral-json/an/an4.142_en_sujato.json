  "root_text": {
    "an4.142:0.1": "Aṅguttara Nikāya 4.142 ",
    "an4.142:0.2": "15. Ābhāvagga ",
    "an4.142:0.3": "Pabhāsutta ",
    "an4.142:1.1": "“Catasso imā, bhikkhave, pabhā. ",
    "an4.142:1.2": "Katamā catasso? ",
    "an4.142:1.3": "Candappabhā, sūriyappabhā, aggippabhā, paññāpabhā—",
    "an4.142:1.4": "imā kho, bhikkhave, catasso pabhā. ",
    "an4.142:1.5": "Etadaggaṁ, bhikkhave, imāsaṁ catunnaṁ pabhānaṁ yadidaṁ paññāpabhā”ti. ",
    "an4.142:1.6": "Dutiyaṁ. "
  },
  "translation_text": {
    "an4.142:0.1": "Numbered Discourses 4.142 ",
    "an4.142:0.2": "15. Brightness ",
    "an4.142:0.3": "Radiance ",
    "an4.142:1.1": "“Mendicants, there are these four kinds of radiance. ",
    "an4.142:1.2": "What four? ",
    "an4.142:1.3": "The radiance of the moon, sun, fire, and wisdom. ",
    "an4.142:1.4": "These are the four kinds of radiance. ",
    "an4.142:1.5": "The best of these four kinds of radiance is the radiance of wisdom.” "
  },
