  "root_text": {
    "an10.138:0.1": "Aṅguttara Nikāya 10.138 ",
    "an10.138:0.2": "14. Sādhuvagga ",
    "an10.138:0.3": "Dhammasutta ",
    "an10.138:1.1": "“Dhammañca vo, bhikkhave, desessāmi adhammañca. ",
    "an10.138:1.2": "Taṁ suṇātha …pe… ",
    "an10.138:1.3": "katamo ca, bhikkhave, adhammo? ",
    "an10.138:1.4": "Micchādiṭṭhi …pe… micchāvimutti—",
    "an10.138:1.5": "ayaṁ vuccati, bhikkhave, adhammo. ",
    "an10.138:1.6": "Katamo ca, bhikkhave, dhammo? ",
    "an10.138:1.7": "Sammādiṭṭhi …pe… sammāvimutti—",
    "an10.138:1.8": "ayaṁ vuccati, bhikkhave, dhammo”ti. ",
    "an10.138:1.9": "Pañcamaṁ. "
  },
  "translation_text": {
    "an10.138:0.1": "Numbered Discourses 10.138 ",
    "an10.138:0.2": "14. Good ",
    "an10.138:0.3": "The Teaching ",
    "an10.138:1.1": "“I will teach you what is the teaching and what is not the teaching. … ",
    "an10.138:1.2": "",
    "an10.138:1.3": "And what is not the teaching? ",
    "an10.138:1.4": "Wrong view, wrong thought, wrong speech, wrong action, wrong livelihood, wrong effort, wrong mindfulness, wrong immersion, wrong knowledge, and wrong freedom. ",
    "an10.138:1.5": "This is called what is not the teaching. ",
    "an10.138:1.6": "And what is the teaching? ",
    "an10.138:1.7": "Right view, right thought, right speech, right action, right livelihood, right effort, right mindfulness, right immersion, right knowledge, and right freedom. ",
    "an10.138:1.8": "This is called the teaching.” "
  },
