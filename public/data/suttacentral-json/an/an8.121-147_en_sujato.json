  "root_text": {
    "an8.121-147:0.1": "Aṅguttara Nikāya 8 ",
    "an8.121-147:0.2": "11. Rāgapeyyāla ",
    "an8.121-147:0.3": "~ ",
    "an8.121-147:1.1": "“Rāgassa, bhikkhave, pariññāya …pe… ",
    "an8.121-147:1.2": "parikkhayāya … ",
    "an8.121-147:1.3": "pahānāya … ",
    "an8.121-147:1.4": "khayāya … ",
    "an8.121-147:1.5": "vayāya … ",
    "an8.121-147:1.6": "virāgāya … ",
    "an8.121-147:1.7": "nirodhāya … ",
    "an8.121-147:1.8": "cāgāya … ",
    "an8.121-147:1.9": "paṭinissaggāya …pe… ",
    "an8.121-147:1.10": "ime aṭṭha dhammā bhāvetabbā”. "
  },
  "translation_text": {
    "an8.121-147:0.1": "Numbered Discourses 8 ",
    "an8.121-147:0.2": "11. Abbreviated Texts Beginning With Greed ",
    "an8.121-147:0.3": "Untitled Discourses on Greed ",
    "an8.121-147:1.1": "“For the complete understanding of greed … ",
    "an8.121-147:1.2": "complete ending … ",
    "an8.121-147:1.3": "giving up … ",
    "an8.121-147:1.4": "ending … ",
    "an8.121-147:1.5": "vanishing … ",
    "an8.121-147:1.6": "fading away … ",
    "an8.121-147:1.7": "cessation … ",
    "an8.121-147:1.8": "giving away … ",
    "an8.121-147:1.9": "letting go … ",
    "an8.121-147:1.10": "these eight things should be developed.” "
  },
