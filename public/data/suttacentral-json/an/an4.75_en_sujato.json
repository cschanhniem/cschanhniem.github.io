  "root_text": {
    "an4.75:0.1": "Aṅguttara Nikāya 4.75 ",
    "an4.75:0.2": "8. Apaṇṇakavagga ",
    "an4.75:0.3": "Dutiyaaggasutta ",
    "an4.75:1.1": "“Cattārimāni, bhikkhave, aggāni. ",
    "an4.75:1.2": "Katamāni cattāri? ",
    "an4.75:1.3": "Rūpaggaṁ, vedanāggaṁ, saññāggaṁ, bhavaggaṁ—",
    "an4.75:1.4": "Imāni kho, bhikkhave, cattāri aggānī”ti. ",
    "an4.75:1.5": "Pañcamaṁ. "
  },
  "translation_text": {
    "an4.75:0.1": "Numbered Discourses 4.75 ",
    "an4.75:0.2": "8.  Sure Bet ",
    "an4.75:0.3": "Best (2nd) ",
    "an4.75:1.1": "“Mendicants, these four things are the best. ",
    "an4.75:1.2": "What four? ",
    "an4.75:1.3": "The best form, feeling, perception, and existence. ",
    "an4.75:1.4": "These are the four things that are the best.” "
  },
