  "root_text": {
    "an4.133:0.1": "Aṅguttara Nikāya 4.133 ",
    "an4.133:0.2": "14. Puggalavagga ",
    "an4.133:0.3": "Ugghaṭitaññūsutta ",
    "an4.133:1.1": "“Cattārome, bhikkhave, puggalā santo saṁvijjamānā lokasmiṁ. ",
    "an4.133:1.2": "Katame cattāro? ",
    "an4.133:1.3": "Ugghaṭitaññū, vipañcitaññū, neyyo, padaparamo—",
    "an4.133:1.4": "Ime kho, bhikkhave, cattāro puggalā santo saṁvijjamānā lokasmin”ti. ",
    "an4.133:1.5": "Tatiyaṁ. "
  },
  "translation_text": {
    "an4.133:0.1": "Numbered Discourses 4.133 ",
    "an4.133:0.2": "14. Individuals ",
    "an4.133:0.3": "One Who Understands Immediately ",
    "an4.133:1.1": "“Mendicants, these four individuals are found in the world. ",
    "an4.133:1.2": "What four? ",
    "an4.133:1.3": "One who understands immediately, one who understands after detailed explanation, one who needs education, and one who merely learns by rote. ",
    "an4.133:1.4": "These are the four individuals found in the world.” "
  },
  "variant_text": {
    "an4.133:0.3": "Ugghaṭitaññūsutta → neyyapuggalasuttaṁ (bj) "
  },
