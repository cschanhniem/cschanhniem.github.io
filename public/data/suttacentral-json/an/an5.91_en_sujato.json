  "root_text": {
    "an5.91:0.1": "Aṅguttara Nikāya 5.91 ",
    "an5.91:0.2": "10. Kakudhavagga ",
    "an5.91:0.3": "Paṭhamasampadāsutta ",
    "an5.91:1.1": "“Pañcimā, bhikkhave, sampadā. ",
    "an5.91:1.2": "Katamā pañca? ",
    "an5.91:1.3": "Saddhāsampadā, sīlasampadā, sutasampadā, cāgasampadā, paññāsampadā—",
    "an5.91:1.4": "imā kho, bhikkhave, pañca sampadā”ti. ",
    "an5.91:1.5": "Paṭhamaṁ. "
  },
  "translation_text": {
    "an5.91:0.1": "Numbered Discourses 5.91 ",
    "an5.91:0.2": "10. With Kakudha ",
    "an5.91:0.3": "Accomplishments (1st) ",
    "an5.91:1.1": "“Mendicants, there are five accomplishments. ",
    "an5.91:1.2": "What five? ",
    "an5.91:1.3": "Accomplishment in faith, ethics, learning, generosity, and wisdom. ",
    "an5.91:1.4": "These are the five accomplishments.” "
  },
