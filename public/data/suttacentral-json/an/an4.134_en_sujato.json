  "root_text": {
    "an4.134:0.1": "Aṅguttara Nikāya 4.134 ",
    "an4.134:0.2": "14. Puggalavagga ",
    "an4.134:0.3": "Uṭṭhānaphalasutta ",
    "an4.134:1.1": "“Cattārome, bhikkhave, puggalā santo saṁvijjamānā lokasmiṁ. ",
    "an4.134:1.2": "Katame cattāro? ",
    "an4.134:1.3": "Uṭṭhānaphalūpajīvī na kammaphalūpajīvī, ",
    "an4.134:1.4": "kammaphalūpajīvī na uṭṭhānaphalūpajīvī, ",
    "an4.134:1.5": "uṭṭhānaphalūpajīvī ceva kammaphalūpajīvī ca, ",
    "an4.134:1.6": "neva uṭṭhānaphalūpajīvī na kammaphalūpajīvī—",
    "an4.134:1.7": "Ime kho, bhikkhave, cattāro puggalā santo saṁvijjamānā lokasmin”ti. ",
    "an4.134:1.8": "Catutthaṁ. "
  },
  "translation_text": {
    "an4.134:0.1": "Numbered Discourses 4.134 ",
    "an4.134:0.2": "14. Individuals ",
    "an4.134:0.3": "The Fruits of Initiative ",
    "an4.134:1.1": "“These four individuals are found in the world. ",
    "an4.134:1.2": "What four? ",
    "an4.134:1.3": "One who lives off the fruit of initiative, but not deeds; ",
    "an4.134:1.4": "one who lives off the fruit of deeds, but not initiative; ",
    "an4.134:1.5": "one who lives off the fruit of both deeds and initiative; ",
    "an4.134:1.6": "one who lives off the fruit of neither initiative nor deeds. ",
    "an4.134:1.7": "These are the four individuals found in the world.” "
  },
  "variant_text": {
    "an4.134:0.3": "Uṭṭhānaphalasutta → phalūpajīvīsuttaṁ (bj) "
  },
