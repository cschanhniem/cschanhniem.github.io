  "root_text": {
    "an4.146:0.1": "Aṅguttara Nikāya 4.146 ",
    "an4.146:0.2": "15. Ābhāvagga ",
    "an4.146:0.3": "Paṭhamakālasutta ",
    "an4.146:1.1": "“Cattārome, bhikkhave, kālā. ",
    "an4.146:1.2": "Katame cattāro? ",
    "an4.146:1.3": "Kālena dhammassavanaṁ, kālena dhammasākacchā, kālena sammasanā, kālena vipassanā—",
    "an4.146:1.4": "Ime kho, bhikkhave, cattāro kālā”ti. ",
    "an4.146:1.5": "Chaṭṭhaṁ. "
  },
  "translation_text": {
    "an4.146:0.1": "Numbered Discourses 4.146 ",
    "an4.146:0.2": "15. Brightness ",
    "an4.146:0.3": "Times (1st) ",
    "an4.146:1.1": "“Mendicants, there are these four times. ",
    "an4.146:1.2": "What four? ",
    "an4.146:1.3": "A time for listening to the teaching, a time for discussing the teaching, a time for serenity, and a time for discernment. ",
    "an4.146:1.4": "These are the four times.” "
  },
  "variant_text": {
    "an4.146:1.3": "kālena sammasanā → kālena samatho (bj, cck, sya2ed, km, pts1ed); kāle samatho (sya1ed) "
  },
