  "root_text": {
    "an10.136:0.1": "Aṅguttara Nikāya 10.136 ",
    "an10.136:0.2": "14. Sādhuvagga ",
    "an10.136:0.3": "Akusalasutta ",
    "an10.136:1.1": "“Akusalañca vo, bhikkhave, desessāmi kusalañca. ",
    "an10.136:1.2": "Taṁ suṇātha …pe… ",
    "an10.136:1.3": "katamañca, bhikkhave, akusalaṁ? ",
    "an10.136:1.4": "Micchādiṭṭhi …pe… micchāvimutti—",
    "an10.136:1.5": "idaṁ vuccati, bhikkhave, akusalaṁ. ",
    "an10.136:1.6": "Katamañca, bhikkhave, kusalaṁ? ",
    "an10.136:1.7": "Sammādiṭṭhi …pe… sammāvimutti—",
    "an10.136:1.8": "idaṁ vuccati, bhikkhave, kusalan”ti. ",
    "an10.136:1.9": "Tatiyaṁ. "
  },
  "translation_text": {
    "an10.136:0.1": "Numbered Discourses 10.136 ",
    "an10.136:0.2": "14. Good ",
    "an10.136:0.3": "Unskillful ",
    "an10.136:1.1": "“I will teach you the skillful and the unskillful … ",
    "an10.136:1.2": "",
    "an10.136:1.3": "And what is the unskillful? ",
    "an10.136:1.4": "Wrong view, wrong thought, wrong speech, wrong action, wrong livelihood, wrong effort, wrong mindfulness, wrong immersion, wrong knowledge, and wrong freedom. ",
    "an10.136:1.5": "This is called the unskillful. ",
    "an10.136:1.6": "And what is the skillful? ",
    "an10.136:1.7": "Right view, right thought, right speech, right action, right livelihood, right effort, right mindfulness, right immersion, right knowledge, and right freedom. ",
    "an10.136:1.8": "This is called the skillful.” "
  },
  "variant_text": {
    "an10.136:0.3": "Akusalasutta → kusalasuttaṁ (bj) "
  },
