  "root_text": {
    "an7.8:0.1": "Aṅguttara Nikāya 7.8 ",
    "an7.8:0.2": "1. Dhanavagga ",
    "an7.8:0.3": "Saṁyojanasutta ",
    "an7.8:1.1": "“Sattimāni, bhikkhave, saṁyojanāni. ",
    "an7.8:1.2": "Katamāni satta? ",
    "an7.8:1.3": "Anunayasaṁyojanaṁ, paṭighasaṁyojanaṁ, diṭṭhisaṁyojanaṁ, vicikicchāsaṁyojanaṁ, mānasaṁyojanaṁ, bhavarāgasaṁyojanaṁ, avijjāsaṁyojanaṁ. ",
    "an7.8:1.4": "Imāni kho, bhikkhave, satta saṁyojanānī”ti. ",
    "an7.8:1.5": "Aṭṭhamaṁ. "
  },
  "translation_text": {
    "an7.8:0.1": "Numbered Discourses 7.8 ",
    "an7.8:0.2": "1. Wealth ",
    "an7.8:0.3": "Fetters ",
    "an7.8:1.1": "“Mendicants, there are these seven fetters. ",
    "an7.8:1.2": "What seven? ",
    "an7.8:1.3": "The fetters of attraction, repulsion, views, doubt, conceit, desire for continued existence, and ignorance. ",
    "an7.8:1.4": "These are the seven fetters.” "
  },
  "variant_text": {
    "an7.8:0.3": "Saṁyojanasutta → sattasaññojanasuttaṁ (bj) "
  },
