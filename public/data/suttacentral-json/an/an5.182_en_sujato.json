  "root_text": {
    "an5.182:0.1": "Aṅguttara Nikāya 5.182 ",
    "an5.182:0.2": "19. Araññavagga ",
    "an5.182:0.3": "Cīvarasutta ",
    "an5.182:1.1": "“Pañcime, bhikkhave, paṁsukūlikā. ",
    "an5.182:1.2": "Katame pañca? ",
    "an5.182:1.3": "Mandattā momūhattā paṁsukūliko hoti …pe… idamatthitaṁyeva nissāya paṁsukūliko hoti. ",
    "an5.182:1.4": "Ime kho, bhikkhave, pañca paṁsukūlikā”ti. ",
    "an5.182:1.5": "Dutiyaṁ. "
  },
  "translation_text": {
    "an5.182:0.1": "Numbered Discourses 5.182 ",
    "an5.182:0.2": "19. Wilderness Dwellers ",
    "an5.182:0.3": "Robes ",
    "an5.182:1.1": "“Mendicants, these five wear rag robes. ",
    "an5.182:1.2": "What five? ",
    "an5.182:1.3": "One may wear rag robes because of stupidity … corrupt wishes … madness … because it is praised by the Buddhas … or for the sake of having few wishes … ",
    "an5.182:1.4": "These are the five who wear rag robes.” "
  },
  "variant_text": {
    "an5.182:0.3": "Cīvarasutta → paṁsukūlikasuttaṁ (bj) "
  },
