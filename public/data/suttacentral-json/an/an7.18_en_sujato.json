  "root_text": {
    "an7.18:0.1": "Aṅguttara Nikāya 7.18 ",
    "an7.18:0.2": "2. Anusayavagga ",
    "an7.18:0.3": "Anattānupassīsutta ",
    "an7.18:1.1": "Sabbesu dhammesu anattānupassī viharati …pe…. ",
    "an7.18:1.2": "Aṭṭhamaṁ. "
  },
  "translation_text": {
    "an7.18:0.1": "Numbered Discourses 7.18 ",
    "an7.18:0.2": "2. Tendencies ",
    "an7.18:0.3": "Observing Not-self ",
    "an7.18:1.1": "“First, take an individual who meditates observing not-self in all things. They perceive not-self and experience not-self. Constantly, continually, and without interruption, they apply the mind and fathom with wisdom. …” "
  },
