  "root_text": {
    "an10.112:0.1": "Aṅguttara Nikāya 10.112 ",
    "an10.112:0.2": "11. Samaṇasaññāvagga ",
    "an10.112:0.3": "Dutiyaasekhasutta ",
    "an10.112:1.1": "“Dasayime, bhikkhave, asekhiyā dhammā. ",
    "an10.112:1.2": "Katame dasa? ",
    "an10.112:1.3": "Asekhā sammādiṭṭhi, asekho sammāsaṅkappo, asekhā sammāvācā, asekho sammākammanto, asekho sammāājīvo, asekho sammāvāyāmo, asekhā sammāsati, asekho sammāsamādhi, asekhaṁ sammāñāṇaṁ, asekhā sammāvimutti—",
    "an10.112:1.4": "ime kho, bhikkhave, dasa asekhiyā dhammā”ti. ",
    "an10.112:1.5": "Dvādasamaṁ. ",
    "an10.112:1.6": "Samaṇasaññāvaggo paṭhamo. ",
    "an10.112:2.0": "Tassuddānaṁ ",
    "an10.112:2.1": "Saññā bojjhaṅgā micchattaṁ, ",
    "an10.112:2.2": "bījaṁ vijjāya nijjaraṁ; ",
    "an10.112:2.3": "Dhovanaṁ tikicchā vamanaṁ, ",
    "an10.112:2.4": "niddhamanaṁ dve asekhāti. "
  },
  "translation_text": {
    "an10.112:0.1": "Numbered Discourses 10.112 ",
    "an10.112:0.2": "11. Perceptions for Ascetics ",
    "an10.112:0.3": "An Adept (2nd) ",
    "an10.112:1.1": "“Mendicants, there are ten qualities of an adept. ",
    "an10.112:1.2": "What ten? ",
    "an10.112:1.3": "An adept’s right view, right thought, right speech, right action, right livelihood, right effort, right mindfulness, right immersion, right knowledge, and right freedom. ",
    "an10.112:1.4": "These are the ten qualities of an adept.” ",
