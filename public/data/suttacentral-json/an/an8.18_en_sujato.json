  "root_text": {
    "an8.18:0.1": "Aṅguttara Nikāya 8.18 ",
    "an8.18:0.2": "2. Mahāvagga ",
    "an8.18:0.3": "Dutiyabandhanasutta ",
    "an8.18:1.1": "“Aṭṭhahi, bhikkhave, ākārehi puriso itthiṁ bandhati. ",
    "an8.18:1.2": "Katamehi aṭṭhahi? ",
    "an8.18:1.3": "Ruṇṇena, bhikkhave, puriso itthiṁ bandhati; ",
    "an8.18:1.4": "hasitena, bhikkhave, puriso itthiṁ bandhati; ",
    "an8.18:1.5": "bhaṇitena, bhikkhave, puriso itthiṁ bandhati; ",
    "an8.18:1.6": "ākappena, bhikkhave, puriso itthiṁ bandhati; ",
    "an8.18:1.7": "vanabhaṅgena, bhikkhave, puriso itthiṁ bandhati; ",
    "an8.18:1.8": "gandhena, bhikkhave, puriso itthiṁ bandhati; ",
    "an8.18:1.9": "rasena, bhikkhave, puriso itthiṁ bandhati; ",
    "an8.18:1.10": "phassena, bhikkhave, puriso itthiṁ bandhati. ",
    "an8.18:1.11": "Imehi kho, bhikkhave, aṭṭhahākārehi puriso itthiṁ bandhati. ",
    "an8.18:1.12": "Te, bhikkhave, sattā subaddhā, ye phassena baddhā”ti. ",
    "an8.18:1.13": "Aṭṭhamaṁ. "
  },
  "translation_text": {
    "an8.18:0.1": "Numbered Discourses 8.18 ",
    "an8.18:0.2": "2. The Great Chapter ",
    "an8.18:0.3": "Catching (2nd) ",
    "an8.18:1.1": "“Mendicants, a man catches a woman using eight features. ",
    "an8.18:1.2": "What eight? ",
    "an8.18:1.3": "With weeping, ",
    "an8.18:1.4": "laughing, ",
    "an8.18:1.5": "speaking, ",
    "an8.18:1.6": "appearance, ",
    "an8.18:1.7": "gifts of wildflowers, ",
    "an8.18:1.8": "scents, ",
    "an8.18:1.9": "tastes, ",
    "an8.18:1.10": "and touches. ",
    "an8.18:1.11": "A man catches a woman using these eight features. ",
    "an8.18:1.12": "But those beings who are caught by touch are well and truly caught.” "
  },
  "variant_text": {
    "an8.18:0.3": "Dutiyabandhanasutta → itthibandhanasuttaṁ (bj) "
  },
