  "root_text": {
    "an4.116:0.1": "Aṅguttara Nikāya 4.116 ",
    "an4.116:0.2": "12. Kesivagga ",
    "an4.116:0.3": "Appamādasutta ",
    "an4.116:1.1": "“Catūhi, bhikkhave, ṭhānehi appamādo karaṇīyo. ",
    "an4.116:1.2": "Katamehi catūhi? ",
    "an4.116:1.3": "Kāyaduccaritaṁ, bhikkhave, pajahatha, kāyasucaritaṁ bhāvetha; ",
    "an4.116:1.4": "tattha ca mā pamādattha. ",
    "an4.116:1.5": "Vacīduccaritaṁ, bhikkhave, pajahatha, vacīsucaritaṁ bhāvetha; ",
    "an4.116:1.6": "tattha ca mā pamādattha. ",
    "an4.116:1.7": "Manoduccaritaṁ, bhikkhave, pajahatha, manosucaritaṁ bhāvetha; ",
    "an4.116:1.8": "tattha ca mā pamādattha. ",
    "an4.116:1.9": "Micchādiṭṭhiṁ, bhikkhave, pajahatha, sammādiṭṭhiṁ bhāvetha; ",
    "an4.116:1.10": "tattha ca mā pamādattha. ",
    "an4.116:2.1": "Yato kho, bhikkhave, bhikkhuno kāyaduccaritaṁ pahīnaṁ hoti kāyasucaritaṁ bhāvitaṁ, vacīduccaritaṁ pahīnaṁ hoti vacīsucaritaṁ bhāvitaṁ, manoduccaritaṁ pahīnaṁ hoti manosucaritaṁ bhāvitaṁ, micchādiṭṭhi pahīnā hoti sammādiṭṭhi bhāvitā, so na bhāyati samparāyikassa maraṇassā”ti. ",
    "an4.116:2.2": "Chaṭṭhaṁ. "
  },
  "translation_text": {
    "an4.116:0.1": "Numbered Discourses 4.116 ",
    "an4.116:0.2": "12. With Kesi ",
    "an4.116:0.3": "Diligence ",
    "an4.116:1.1": "“Mendicants, you should be diligent in four situations. ",
    "an4.116:1.2": "What four? ",
    "an4.116:1.3": "Give up bad conduct by way of body, speech, and mind; and develop good conduct by way of body, speech, and mind. ",
    "an4.116:1.4": "Don’t neglect these things. ",
    "an4.116:1.5": "",
    "an4.116:1.6": "",
    "an4.116:1.7": "",
    "an4.116:1.8": "",
    "an4.116:1.9": "Give up wrong view; and develop right view. ",
    "an4.116:1.10": "Don’t neglect this. ",
    "an4.116:2.1": "A mendicant who has done these things does not fear death in lives to come.” "
  },
