  "root_text": {
    "an5.46:0.1": "Aṅguttara Nikāya 5.46 ",
    "an5.46:0.2": "5. Muṇḍarājavagga ",
    "an5.46:0.3": "Sampadāsutta ",
    "an5.46:1.1": "“Pañcimā, bhikkhave, sampadā. ",
    "an5.46:1.2": "Katamā pañca? ",
    "an5.46:1.3": "Saddhāsampadā, sīlasampadā, sutasampadā, cāgasampadā, paññāsampadā—",
    "an5.46:1.4": "imā kho, bhikkhave, pañca sampadā”ti. ",
    "an5.46:1.5": "Chaṭṭhaṁ. "
  },
  "translation_text": {
    "an5.46:0.1": "Numbered Discourses 5.46 ",
    "an5.46:0.2": "5. With King Muṇḍa ",
    "an5.46:0.3": "Success ",
    "an5.46:1.1": "“Mendicants, there are five accomplishments. ",
    "an5.46:1.2": "What five? ",
    "an5.46:1.3": "Accomplishment in faith, ethics, learning, generosity, and wisdom. ",
    "an5.46:1.4": "These are the five accomplishments.” "
  },
  "variant_text": {
    "an5.46:0.3": "Sampadāsutta → pañcasampadāsuttaṁ (bj) "
  },
