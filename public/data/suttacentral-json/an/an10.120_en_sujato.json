  "root_text": {
    "an10.120:0.1": "Aṅguttara Nikāya 10.120 ",
    "an10.120:0.2": "12. Paccorohaṇivagga ",
    "an10.120:0.3": "Dutiyapaccorohaṇīsutta ",
    "an10.120:1.1": "“Ariyaṁ vo, bhikkhave, paccorohaṇiṁ desessāmi. ",
    "an10.120:1.2": "Taṁ suṇātha … ",
    "an10.120:1.3": "katamā ca, bhikkhave, ariyā paccorohaṇī? ",
    "an10.120:1.4": "Idha, bhikkhave, ariyasāvako iti paṭisañcikkhati: ",
    "an10.120:1.5": "‘micchādiṭṭhiyā kho pāpako vipāko—",
    "an10.120:1.6": "diṭṭhe ceva dhamme abhisamparāyañcā’ti. ",
    "an10.120:1.7": "So iti paṭisaṅkhāya micchādiṭṭhiṁ pajahati; ",
    "an10.120:1.8": "micchādiṭṭhiyā paccorohati. ",
    "an10.120:1.9": "Micchāsaṅkappassa kho pāpako vipāko … ",
    "an10.120:1.10": "micchāvācāya kho … ",
    "an10.120:1.11": "micchākammantassa kho … ",
    "an10.120:1.12": "micchāājīvassa kho … ",
    "an10.120:1.13": "micchāvāyāmassa kho … ",
    "an10.120:1.14": "micchāsatiyā kho … ",
    "an10.120:1.15": "micchāsamādhissa kho … ",
    "an10.120:1.16": "micchāñāṇassa kho … ",
    "an10.120:1.17": "micchāvimuttiyā kho pāpako vipāko—",
    "an10.120:1.18": "diṭṭhe ceva dhamme abhisamparāyañcāti. ",
    "an10.120:1.19": "So iti paṭisaṅkhāya micchāvimuttiṁ pajahati; ",
    "an10.120:1.20": "micchāvimuttiyā paccorohati. ",
    "an10.120:1.21": "Ayaṁ vuccati, bhikkhave, ariyā paccorohaṇī”ti. ",
    "an10.120:1.22": "Aṭṭhamaṁ. "
  },
  "translation_text": {
    "an10.120:0.1": "Numbered Discourses 10.120 ",
    "an10.120:0.2": "12. The Ceremony of Descent ",
    "an10.120:0.3": "The Ceremony of Descent (2nd) ",
    "an10.120:1.1": "“Mendicants, I will teach you the noble descent. ",
    "an10.120:1.2": "Listen and apply your mind well, I will speak. … ",
    "an10.120:1.3": "And what is the noble descent? ",
    "an10.120:1.4": "It’s when a noble disciple reflects: ",
    "an10.120:1.5": "‘Wrong view has a bad result ",
    "an10.120:1.6": "in both this life and the next.’ ",
    "an10.120:1.7": "Reflecting like this, they give up wrong view, ",
    "an10.120:1.8": "they descend from wrong view. ",
    "an10.120:1.9": "‘Wrong thought has a bad result …’ … ",
    "an10.120:1.10": "‘Wrong speech …’ … ",
    "an10.120:1.11": "‘Wrong action …’ … ",
    "an10.120:1.12": "‘Wrong livelihood …’ … ",
    "an10.120:1.13": "‘Wrong effort …’ … ",
    "an10.120:1.14": "‘Wrong mindfulness …’ … ",
    "an10.120:1.15": "‘Wrong immersion …’ … ",
    "an10.120:1.16": "‘Wrong knowledge …’ … ",
    "an10.120:1.17": "‘Wrong freedom has a bad result ",
    "an10.120:1.18": "in both this life and the next.’ ",
    "an10.120:1.19": "Reflecting like this, they give up wrong freedom, ",
    "an10.120:1.20": "they descend from wrong freedom. ",
    "an10.120:1.21": "This is called the noble descent.” "
  },
