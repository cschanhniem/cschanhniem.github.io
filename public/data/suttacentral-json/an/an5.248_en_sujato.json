  "root_text": {
    "an5.248:0.1": "Aṅguttara Nikāya 5.248 ",
    "an5.248:0.2": "25. Duccaritavagga ",
    "an5.248:0.3": "Dutiyamanoduccaritasutta ",
    "an5.248:1.1": "“Pañcime, bhikkhave, ādīnavā manoduccarite …pe… ānisaṁsā manosucarite. ",
    "an5.248:1.2": "Katame pañca? ",
    "an5.248:1.3": "Attāpi attānaṁ na upavadati; ",
    "an5.248:1.4": "anuvicca viññū pasaṁsanti; ",
    "an5.248:1.5": "kalyāṇo kittisaddo abbhuggacchati; ",
    "an5.248:1.6": "asaddhammā vuṭṭhāti; ",
    "an5.248:1.7": "saddhamme patiṭṭhāti. ",
    "an5.248:1.8": "Ime kho, bhikkhave, pañca ānisaṁsā manosucarite”ti. ",
    "an5.248:1.9": "Aṭṭhamaṁ. "
  },
  "translation_text": {
