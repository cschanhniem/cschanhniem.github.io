  "root_text": {
    "an10.183:0.1": "Aṅguttara Nikāya 10.183 ",
    "an10.183:0.2": "18. Sādhuvagga ",
    "an10.183:0.3": "Āsavasutta ",
    "an10.183:1.1": "“Sāsavañca vo, bhikkhave, dhammaṁ desessāmi anāsavañca. ",
    "an10.183:1.2": "Taṁ suṇātha …pe… ",
    "an10.183:1.3": "katamo ca, bhikkhave, sāsavo dhammo? ",
    "an10.183:1.4": "Pāṇātipāto …pe… ",
    "an10.183:1.5": "micchādiṭṭhi—",
    "an10.183:1.6": "ayaṁ vuccati, bhikkhave, sāsavo dhammo. ",
    "an10.183:2.1": "Katamo ca, bhikkhave, anāsavo dhammo? ",
    "an10.183:2.2": "Pāṇātipātā veramaṇī …pe… ",
    "an10.183:2.3": "sammādiṭṭhi—",
    "an10.183:2.4": "ayaṁ vuccati, bhikkhave, anāsavo dhammo”ti. ",
    "an10.183:2.5": "Chaṭṭhaṁ. "
  },
  "translation_text": {
    "an10.183:0.1": "Numbered Discourses 10.183 ",
    "an10.183:0.2": "18. Good ",
    "an10.183:0.3": "Defiled ",
    "an10.183:1.1": "“I will teach you the defiled principle and the undefiled. … ",
    "an10.183:1.2": "",
    "an10.183:1.3": "And what is the defiled principle? ",
    "an10.183:1.4": "Killing living creatures … ",
    "an10.183:1.5": "wrong view. ",
    "an10.183:1.6": "This is called the defiled principle. ",
    "an10.183:2.1": "And what is the undefiled principle? ",
    "an10.183:2.2": "Not killing living creatures … ",
    "an10.183:2.3": "right view. ",
    "an10.183:2.4": "This is called the undefiled principle.” "
  },
  "variant_text": {
    "an10.183:0.3": "Āsavasutta → sāsavadhammasuttaṁ (bj) "
  },
