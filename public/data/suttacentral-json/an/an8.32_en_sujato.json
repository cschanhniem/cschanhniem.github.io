  "root_text": {
    "an8.32:0.1": "Aṅguttara Nikāya 8.32 ",
    "an8.32:0.2": "4. Dānavagga ",
    "an8.32:0.3": "Dutiyadānasutta ",
    "an8.32:1.1": "“Saddhā hiriyaṁ kusalañca dānaṁ, ",
    "an8.32:1.2": "Dhammā ete sappurisānuyātā; ",
    "an8.32:1.3": "Etañhi maggaṁ diviyaṁ vadanti, ",
    "an8.32:1.4": "Etena hi gacchati devalokan”ti. ",
    "an8.32:1.5": "Dutiyaṁ. "
  },
  "translation_text": {
    "an8.32:0.1": "Numbered Discourses 8.32 ",
    "an8.32:0.2": "4. Giving ",
    "an8.32:0.3": "Giving (2nd) ",
    "an8.32:1.1": "“Faith, conscience, and skillful giving ",
    "an8.32:1.2": "are qualities true persons follow. ",
    "an8.32:1.3": "For this, they say, is the path of the gods, ",
    "an8.32:1.4": "which leads to the heavenly realm.” "
  },
