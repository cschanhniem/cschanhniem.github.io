  "root_text": {
    "an10.197:0.1": "Aṅguttara Nikāya 10.197 ",
    "an10.197:0.2": "19. Ariyamaggavagga ",
    "an10.197:0.3": "Anussaritabbasutta ",
    "an10.197:1.1": "“Anussaritabbañca vo, bhikkhave, dhammaṁ desessāmi nānussaritabbañca. ",
    "an10.197:1.2": "Taṁ suṇātha …pe… ",
    "an10.197:1.3": "katamo ca, bhikkhave, nānussaritabbo dhammo? ",
    "an10.197:1.4": "Pāṇātipāto …pe… ",
    "an10.197:1.5": "micchādiṭṭhi—",
    "an10.197:1.6": "ayaṁ vuccati, bhikkhave, nānussaritabbo dhammo. ",
    "an10.197:2.1": "Katamo ca, bhikkhave, anussaritabbo dhammo? ",
    "an10.197:2.2": "Pāṇātipātā veramaṇī …pe… ",
    "an10.197:2.3": "sammādiṭṭhi—",
    "an10.197:2.4": "ayaṁ vuccati, bhikkhave, anussaritabbo dhammo”ti. ",
    "an10.197:2.5": "Navamaṁ. "
  },
  "translation_text": {
    "an10.197:0.1": "Numbered Discourses 10.197 ",
    "an10.197:0.2": "19. The Noble Path ",
    "an10.197:0.3": "Should Be Recollected ",
    "an10.197:1.1": "“I will teach you the principle to recollect and the principle not to recollect. … ",
    "an10.197:1.2": "",
    "an10.197:1.3": "And what is the principle not to recollect? ",
    "an10.197:1.4": "Killing living creatures … ",
    "an10.197:1.5": "wrong view. ",
    "an10.197:1.6": "This is called the principle not to recollect. ",
    "an10.197:2.1": "And what is the principle to recollect? ",
    "an10.197:2.2": "Not killing living creatures … ",
    "an10.197:2.3": "right view. ",
    "an10.197:2.4": "This is called the principle to recollect.” "
  },
