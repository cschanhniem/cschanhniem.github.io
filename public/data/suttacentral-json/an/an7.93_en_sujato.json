  "root_text": {
    "an7.93:0.1": "Aṅguttara Nikāya 7.93 ",
    "an7.93:0.2": "9. Samaṇavagga ",
    "an7.93:0.3": "Asaddhammasutta ",
    "an7.93:1.1": "“Sattime, bhikkhave, asaddhammā. ",
    "an7.93:1.2": "Katame satta? ",
    "an7.93:1.3": "Assaddho hoti, ahiriko hoti, anottappī hoti, appassuto hoti, kusīto hoti, muṭṭhassati hoti, duppañño hoti. ",
    "an7.93:1.4": "Ime kho, bhikkhave, satta asaddhammā”ti. ",
    "an7.93:1.5": "Navamaṁ. "
  },
  "translation_text": {
    "an7.93:0.1": "Numbered Discourses 7.93 ",
    "an7.93:0.2": "9. An Ascetic ",
    "an7.93:0.3": "Bad Qualities ",
    "an7.93:1.1": "“Mendicants, there are these seven bad qualities. ",
    "an7.93:1.2": "What seven? ",
    "an7.93:1.3": "Someone is faithless, shameless, imprudent, unlearned, lazy, unmindful, and witless. ",
    "an7.93:1.4": "These are the seven bad qualities.” "
  },
