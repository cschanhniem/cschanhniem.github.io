  "root_text": {
    "an10.192:0.1": "Aṅguttara Nikāya 10.192 ",
    "an10.192:0.2": "19. Ariyamaggavagga ",
    "an10.192:0.3": "Sappurisadhammasutta ",
    "an10.192:1.1": "“Sappurisadhammañca vo, bhikkhave, desessāmi asappurisadhammañca. ",
    "an10.192:1.2": "Taṁ suṇātha …pe… ",
    "an10.192:1.3": "katamo ca, bhikkhave, asappurisadhammo? ",
    "an10.192:1.4": "Pāṇātipāto …pe… ",
    "an10.192:1.5": "micchādiṭṭhi—",
    "an10.192:1.6": "ayaṁ vuccati, bhikkhave, asappurisadhammo. ",
    "an10.192:2.1": "Katamo ca, bhikkhave, sappurisadhammo? ",
    "an10.192:2.2": "Pāṇātipātā veramaṇī …pe… ",
    "an10.192:2.3": "sammādiṭṭhi—",
    "an10.192:2.4": "ayaṁ vuccati, bhikkhave, sappurisadhammo”ti. ",
    "an10.192:2.5": "Catutthaṁ. "
  },
  "translation_text": {
    "an10.192:0.1": "Numbered Discourses 10.192 ",
    "an10.192:0.2": "19. The Noble Path ",
    "an10.192:0.3": "The Teaching of the True Persons ",
    "an10.192:1.1": "“Mendicants, I will teach you the teaching of the true persons and the teaching of the untrue persons. ",
    "an10.192:1.2": "",
    "an10.192:1.3": "And what is the teaching of the untrue persons? ",
    "an10.192:1.4": "Killing living creatures … ",
    "an10.192:1.5": "wrong view. ",
    "an10.192:1.6": "This is the teaching of the untrue persons. ",
    "an10.192:2.1": "And what is the teaching of the true persons? ",
    "an10.192:2.2": "Not killing living creatures … ",
    "an10.192:2.3": "right view. ",
    "an10.192:2.4": "This is the teaching of the true persons.” "
  },
