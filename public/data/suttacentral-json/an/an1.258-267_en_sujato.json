  "root_text": {
    "an1.258:0.1": "Aṅguttara Nikāya 1 ",
    "an1.258:0.2": "20. Sattamavagga ",
    "an1.258:1.1": "“Etadaggaṁ, bhikkhave, mama sāvikānaṁ upāsikānaṁ paṭhamaṁ saraṇaṁ gacchantīnaṁ yadidaṁ sujātā seniyadhītā. ",
    "an1.259:1.1": "… Dāyikānaṁ yadidaṁ visākhā migāramātā. ",
    "an1.260:1.1": "… Bahussutānaṁ yadidaṁ khujjuttarā. ",
    "an1.261:1.1": "… Mettāvihārīnaṁ yadidaṁ sāmāvatī. ",
    "an1.262:1.1": "… Jhāyīnaṁ yadidaṁ uttarānandamātā. ",
    "an1.263:1.1": "… Paṇītadāyikānaṁ yadidaṁ suppavāsā koliyadhītā. ",
    "an1.264:1.1": "… Gilānupaṭṭhākīnaṁ yadidaṁ suppiyā upāsikā. ",
    "an1.265:1.1": "… Aveccappasannānaṁ yadidaṁ kātiyānī. ",
    "an1.266:1.1": "… Vissāsikānaṁ yadidaṁ nakulamātā gahapatānī. ",
    "an1.267:1.1": "… Anussavappasannānaṁ yadidaṁ kāḷī upāsikā kuraragharikā”ti. ",
    "an1.267:1.2": "vaggo sattamo. ",
    "an1.267:1.3": "(Etadaggavaggo niṭṭhito.) "
  },
  "translation_text": {
    "an1.258:0.1": "Numbered Discourses 1 ",
    "an1.258:0.2": "Chapter Seven ",
    "an1.258:1.1": "“The foremost of my laywomen in first going for refuge is Sujātā the general’s daughter. ",
    "an1.259:1.1": "… as a donor is Visākhā, Migāra’s mother. ",
    "an1.260:1.1": "… who are very learned is Khujjuttarā. ",
    "an1.261:1.1": "… who dwell in love is Sāmāvatī. ",
    "an1.262:1.1": "… who practice absorption is Uttarā, Nanda’s mother. ",
    "an1.263:1.1": "… who give fine things is Suppavāsā the Koliyan. ",
    "an1.264:1.1": "… who care for the sick is the laywoman Suppiyā. ",
    "an1.265:1.1": "… who have experiential confidence is Kātiyānī. ",
    "an1.266:1.1": "… who are intimate is the householder Nakula’s mother. ",
    "an1.267:1.1": "… whose confidence is based on oral transmission is the laywoman Kāḷī of Kuraraghara.” "
  },
  "variant_text": {
    "an1.258:1.1": "seniyadhītā → senānīdhītā (bj); senānidhītā (sya-all, km, pts1ed) ",
    "an1.267:1.1": "kuraragharikā → kulagharikā (mr) "
  },
