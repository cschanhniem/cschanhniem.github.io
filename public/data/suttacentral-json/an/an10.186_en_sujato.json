  "root_text": {
    "an10.186:0.1": "Aṅguttara Nikāya 10.186 ",
    "an10.186:0.2": "18. Sādhuvagga ",
    "an10.186:0.3": "Ācayagāmisutta ",
    "an10.186:1.1": "“Ācayagāmiñca vo, bhikkhave, dhammaṁ desessāmi apacayagāmiñca. ",
    "an10.186:1.2": "Taṁ suṇātha …pe… ",
    "an10.186:1.3": "katamo ca, bhikkhave, ācayagāmī dhammo? ",
    "an10.186:1.4": "Pāṇātipāto …pe… ",
    "an10.186:1.5": "micchādiṭṭhi—",
    "an10.186:1.6": "ayaṁ vuccati, bhikkhave, ācayagāmī dhammo. ",
    "an10.186:2.1": "Katamo ca, bhikkhave, apacayagāmī dhammo? ",
    "an10.186:2.2": "Pāṇātipātā veramaṇī …pe… ",
    "an10.186:2.3": "sammādiṭṭhi—",
    "an10.186:2.4": "ayaṁ vuccati, bhikkhave, apacayagāmī dhammo”ti. ",
    "an10.186:2.5": "Navamaṁ. "
  },
  "translation_text": {
    "an10.186:0.1": "Numbered Discourses 10.186 ",
    "an10.186:0.2": "18. Good ",
    "an10.186:0.3": "Leading to Accumulation ",
    "an10.186:1.1": "“I will teach you the principle that leads to accumulation and that which leads to dispersal. … ",
    "an10.186:1.2": "",
    "an10.186:1.3": "And what is the principle that leads to accumulation? ",
    "an10.186:1.4": "Killing living creatures … ",
    "an10.186:1.5": "wrong view. ",
    "an10.186:1.6": "This is called the principle that leads to accumulation. ",
    "an10.186:2.1": "And what is the principle that leads to dispersal? ",
    "an10.186:2.2": "Not killing living creatures … ",
    "an10.186:2.3": "right view. ",
    "an10.186:2.4": "This is called the principle that leads to dispersal.” "
  },
  "variant_text": {
    "an10.186:0.3": "Ācayagāmisutta → ācayagāmīsuttaṁ (bj) "
  },
