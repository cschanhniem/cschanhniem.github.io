  "root_text": {
    "an10.196:0.1": "Aṅguttara Nikāya 10.196 ",
    "an10.196:0.2": "19. Ariyamaggavagga ",
    "an10.196:0.3": "Bahulīkātabbasutta ",
    "an10.196:1.1": "“Bahulīkātabbañca vo, bhikkhave, dhammaṁ desessāmi na bahulīkātabbañca. ",
    "an10.196:1.2": "Taṁ suṇātha …pe… ",
    "an10.196:1.3": "katamo ca, bhikkhave, na bahulīkātabbo dhammo? ",
    "an10.196:1.4": "Pāṇātipāto …pe… ",
    "an10.196:1.5": "micchādiṭṭhi—",
    "an10.196:1.6": "ayaṁ vuccati, bhikkhave, na bahulīkātabbo dhammo. ",
    "an10.196:2.1": "Katamo ca, bhikkhave, bahulīkātabbo dhammo? ",
    "an10.196:2.2": "Pāṇātipātā veramaṇī …pe… ",
    "an10.196:2.3": "sammādiṭṭhi—",
    "an10.196:2.4": "ayaṁ vuccati, bhikkhave, bahulīkātabbo dhammo”ti. ",
    "an10.196:2.5": "Aṭṭhamaṁ. "
  },
  "translation_text": {
    "an10.196:0.1": "Numbered Discourses 10.196 ",
    "an10.196:0.2": "19. The Noble Path ",
    "an10.196:0.3": "Principles That Should Be Made Much Of ",
    "an10.196:1.1": "“I will teach you the principle to make much of and the principle not to make much of. … ",
    "an10.196:1.2": "",
    "an10.196:1.3": "And what is the principle not to make much of? ",
    "an10.196:1.4": "Killing living creatures … ",
    "an10.196:1.5": "wrong view. ",
    "an10.196:1.6": "This is called the principle not to make much of. ",
    "an10.196:2.1": "And what is the principle to make much of? ",
    "an10.196:2.2": "Not killing living creatures … ",
    "an10.196:2.3": "right view. ",
    "an10.196:2.4": "This is called the principle to make much of.” "
  },
  "variant_text": {
    "an10.196:0.3": "Bahulīkātabbasutta → bahulīkātabbadhammasuttaṁ (bj) "
  },
