  "root_text": {
    "an6.9:0.1": "Aṅguttara Nikāya 6.9 ",
    "an6.9:0.2": "1. Āhuneyyavagga ",
    "an6.9:0.3": "Anussatiṭṭhānasutta ",
    "an6.9:1.1": "“Chayimāni, bhikkhave, anussatiṭṭhānāni. ",
    "an6.9:1.2": "Katamāni cha? ",
    "an6.9:1.3": "Buddhānussati, dhammānussati, saṅghānussati, sīlānussati, cāgānussati, devatānussati. ",
    "an6.9:1.4": "Imāni kho, bhikkhave, cha anussatiṭṭhānānī”ti. ",
    "an6.9:1.5": "Navamaṁ. "
  },
  "translation_text": {
    "an6.9:0.1": "Numbered Discourses 6.9 ",
    "an6.9:0.2": "1. Worthy of Offerings ",
    "an6.9:0.3": "Topics for Recollection ",
    "an6.9:1.1": "“Mendicants, there are these six topics for recollection. ",
    "an6.9:1.2": "What six? ",
    "an6.9:1.3": "The recollection of the Buddha, the teaching, the Saṅgha, ethics, generosity, and the deities. ",
    "an6.9:1.4": "These are the six topics for recollection.” "
  },
