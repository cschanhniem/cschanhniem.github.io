  "root_text": {
    "an4.64:0.1": "Aṅguttara Nikāya 4.64 ",
    "an4.64:0.2": "7. Pattakammavagga ",
    "an4.64:0.3": "Nirayasutta ",
    "an4.64:1.1": "“Catūhi, bhikkhave, dhammehi samannāgato yathābhataṁ nikkhitto evaṁ niraye. ",
    "an4.64:1.2": "Katamehi catūhi? ",
    "an4.64:1.3": "Pāṇātipātī hoti, adinnādāyī hoti, kāmesumicchācārī hoti, musāvādī hoti—",
    "an4.64:1.4": "imehi kho, bhikkhave, catūhi dhammehi samannāgato yathābhataṁ nikkhitto evaṁ nirayeti. ",
    "an4.64:2.1": "Pāṇātipāto adinnādānaṁ, ",
    "an4.64:2.2": "Musāvādo ca vuccati; ",
    "an4.64:2.3": "Paradāragamanañcāpi, ",
    "an4.64:2.4": "Nappasaṁsanti paṇḍitā”ti. ",
    "an4.64:2.5": "Catutthaṁ. "
  },
  "translation_text": {
    "an4.64:0.1": "Numbered Discourses 4.64 ",
    "an4.64:0.2": "7. Fitting Deeds ",
    "an4.64:0.3": "Hell ",
    "an4.64:1.1": "“Mendicants, someone with four qualities is placed in hell as if delivered there. ",
    "an4.64:1.2": "What four? ",
    "an4.64:1.3": "They kill living creatures, steal, commit sexual misconduct, and lie. ",
    "an4.64:1.4": "Someone with these four qualities is placed in hell as if delivered there. ",
    "an4.64:2.1": "Killing, stealing, ",
    "an4.64:2.2": "telling lies, ",
    "an4.64:2.3": "and visiting others’ wives: ",
    "an4.64:2.4": "astute people don’t praise these things.” "
  },
