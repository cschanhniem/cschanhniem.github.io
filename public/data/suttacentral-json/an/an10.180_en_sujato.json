  "root_text": {
    "an10.180:0.1": "Aṅguttara Nikāya 10.180 ",
    "an10.180:0.2": "18. Sādhuvagga ",
    "an10.180:0.3": "Kusalasutta ",
    "an10.180:1.1": "“Kusalañca vo, bhikkhave, desessāmi akusalañca. ",
    "an10.180:1.2": "Taṁ suṇātha …pe… ",
    "an10.180:1.3": "katamañca, bhikkhave, akusalaṁ? ",
    "an10.180:1.4": "Pāṇātipāto …pe… ",
    "an10.180:1.5": "micchādiṭṭhi—",
    "an10.180:1.6": "idaṁ vuccati, bhikkhave, akusalaṁ. ",
    "an10.180:2.1": "Katamañca, bhikkhave, kusalaṁ? ",
    "an10.180:2.2": "Pāṇātipātā veramaṇī …pe… ",
    "an10.180:2.3": "sammādiṭṭhi—",
    "an10.180:2.4": "idaṁ vuccati, bhikkhave, kusalan”ti. ",
    "an10.180:2.5": "Tatiyaṁ. "
  },
  "translation_text": {
    "an10.180:0.1": "Numbered Discourses 10.180 ",
    "an10.180:0.2": "18. Good ",
    "an10.180:0.3": "Skillful ",
    "an10.180:1.1": "“I will teach you the skillful and the unskillful … ",
    "an10.180:1.2": "",
    "an10.180:1.3": "And what is the unskillful? ",
    "an10.180:1.4": "Killing living creatures … ",
    "an10.180:1.5": "wrong view. ",
    "an10.180:1.6": "This is called the unskillful. ",
    "an10.180:2.1": "And what is the skillful? ",
    "an10.180:2.2": "Not killing living creatures … ",
    "an10.180:2.3": "right view. ",
    "an10.180:2.4": "This is called the skillful.” "
  },
