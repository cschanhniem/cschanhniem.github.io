  "root_text": {
    "an4.59:0.1": "Aṅguttara Nikāya 4.59 ",
    "an4.59:0.2": "6. Puññābhisandavagga ",
    "an4.59:0.3": "Bhojanasutta ",
    "an4.59:1.1": "“Bhojanaṁ, bhikkhave, dadamāno dāyako paṭiggāhakānaṁ cattāri ṭhānāni deti. ",
    "an4.59:1.2": "Katamāni cattāri? ",
    "an4.59:1.3": "Āyuṁ deti, vaṇṇaṁ deti, sukhaṁ deti, balaṁ deti. ",
    "an4.59:1.4": "Āyuṁ kho pana datvā āyussa bhāgī hoti dibbassa vā mānusassa vā. ",
    "an4.59:1.5": "Vaṇṇaṁ datvā … sukhaṁ datvā … balaṁ datvā balassa bhāgī hoti dibbassa vā mānusassa vā. ",
    "an4.59:1.6": "Bhojanaṁ, bhikkhave, dadamāno dāyako paṭiggāhakānaṁ imāni cattāri ṭhānāni detīti. ",
    "an4.59:2.1": "Yo saññatānaṁ paradattabhojinaṁ, ",
    "an4.59:2.2": "Kālena sakkacca dadāti bhojanaṁ; ",
    "an4.59:2.3": "Cattāri ṭhānāni anuppavecchati, ",
    "an4.59:2.4": "Āyuñca vaṇṇañca sukhaṁ balañca. ",
    "an4.59:3.1": "So āyudāyī vaṇṇadāyī, ",
    "an4.59:3.2": "sukhaṁ balaṁ dado naro; ",
    "an4.59:3.3": "Dīghāyu yasavā hoti, ",
    "an4.59:3.4": "yattha yatthūpapajjatī”ti. ",
    "an4.59:3.5": "Navamaṁ. "
  },
  "translation_text": {
    "an4.59:0.1": "Numbered Discourses 4.59 ",
    "an4.59:0.2": "6. Overflowing Merit ",
    "an4.59:0.3": "Food ",
    "an4.59:1.1": "“Mendicants, when a donor gives food, they give the recipients four things. ",
    "an4.59:1.2": "What four? ",
    "an4.59:1.3": "Long life, beauty, happiness, and strength. …” ",
