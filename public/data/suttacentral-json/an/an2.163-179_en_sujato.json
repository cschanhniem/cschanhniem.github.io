  "root_text": {
    "an2.163:0.1": "Aṅguttara Nikāya 2 ",
    "an2.163:0.2": "15. Samāpattivagga ",
    "an2.163:1.0": "163 ",
    "an2.163:1.1": "“Dveme, bhikkhave, dhammā. ",
    "an2.163:1.2": "Katame dve? ",
    "an2.163:1.3": "Samāpattikusalatā ca samāpattivuṭṭhānakusalatā ca. ",
    "an2.163:1.4": "Ime kho, bhikkhave, dve dhammā”ti. ",
    "an2.164:1.0": "164 ",
    "an2.164:1.1": "“Dveme, bhikkhave, dhammā. ",
    "an2.164:1.2": "Katame dve? ",
    "an2.164:1.3": "Ajjavañca maddavañca. ",
    "an2.164:1.4": "Ime kho, bhikkhave, dve dhammā”. ",
    "an2.165:1.0": "165 ",
    "an2.165:1.1": "“Dveme, bhikkhave, dhammā. ",
    "an2.165:1.2": "Katame dve? ",
    "an2.165:1.3": "Khanti ca soraccañca. ",
    "an2.165:1.4": "Ime kho, bhikkhave, dve dhammā”. ",
    "an2.166:1.0": "166 ",
    "an2.166:1.1": "“Dveme, bhikkhave, dhammā. ",
    "an2.166:1.2": "Katame dve? ",
    "an2.166:1.3": "Sākhalyañca paṭisanthāro ca. ",
    "an2.166:1.4": "Ime kho, bhikkhave, dve dhammā”. ",
    "an2.167:1.0": "167 ",
    "an2.167:1.1": "“Dveme, bhikkhave, dhammā. ",
    "an2.167:1.2": "Katame dve? ",
    "an2.167:1.3": "Avihiṁsā ca soceyyañca. ",
    "an2.167:1.4": "Ime kho, bhikkhave, dve dhammā”. ",
    "an2.168:1.0": "168 ",
    "an2.168:1.1": "“Dveme, bhikkhave, dhammā. ",
    "an2.168:1.2": "Katame dve? ",
    "an2.168:1.3": "Indriyesu aguttadvāratā ca bhojane amattaññutā ca. ",
    "an2.168:1.4": "Ime kho, bhikkhave, dve dhammā”. ",
    "an2.169:1.0": "169 ",
    "an2.169:1.1": "“Dveme, bhikkhave, dhammā. ",
    "an2.169:1.2": "Katame dve? ",
    "an2.169:1.3": "Indriyesu guttadvāratā ca bhojane mattaññutā ca. ",
    "an2.169:1.4": "Ime kho, bhikkhave, dve dhammā”. ",
    "an2.170:1.0": "170 ",
    "an2.170:1.1": "“Dveme, bhikkhave, dhammā. ",
    "an2.170:1.2": "Katame dve? ",
    "an2.170:1.3": "Paṭisaṅkhānabalañca bhāvanābalañca. ",
    "an2.170:1.4": "Ime kho, bhikkhave, dve dhammā”. ",
    "an2.171:1.0": "171 ",
    "an2.171:1.1": "“Dveme, bhikkhave, dhammā. ",
    "an2.171:1.2": "Katame dve? ",
    "an2.171:1.3": "Satibalañca samādhibalañca. ",
    "an2.171:1.4": "Ime kho, bhikkhave, dve dhammā”. ",
    "an2.172:1.0": "172 ",
    "an2.172:1.1": "“Dveme, bhikkhave, dhammā. ",
    "an2.172:1.2": "Katame dve? ",
    "an2.172:1.3": "Samatho ca vipassanā ca. ",
    "an2.172:1.4": "Ime kho, bhikkhave, dve dhammā”. ",
    "an2.173:1.0": "173 ",
    "an2.173:1.1": "“Dveme, bhikkhave, dhammā. ",
    "an2.173:1.2": "Katame dve? ",
    "an2.173:1.3": "Sīlavipatti ca diṭṭhivipatti ca. ",
    "an2.173:1.4": "Ime kho, bhikkhave, dve dhammā”. ",
    "an2.174:1.0": "174 ",
    "an2.174:1.1": "“Dveme, bhikkhave, dhammā. ",
    "an2.174:1.2": "Katame dve? ",
    "an2.174:1.3": "Sīlasampadā ca diṭṭhisampadā ca. ",
    "an2.174:1.4": "Ime kho, bhikkhave, dve dhammā”. ",
    "an2.175:1.0": "175 ",
    "an2.175:1.1": "“Dveme, bhikkhave, dhammā. ",
    "an2.175:1.2": "Katame dve? ",
    "an2.175:1.3": "Sīlavisuddhi ca diṭṭhivisuddhi ca. ",
    "an2.175:1.4": "Ime kho, bhikkhave, dve dhammā”. ",
    "an2.176:1.0": "176 ",
    "an2.176:1.1": "“Dveme, bhikkhave, dhammā. ",
    "an2.176:1.2": "Katame dve? ",
    "an2.176:1.3": "Diṭṭhivisuddhi ca yathādiṭṭhissa ca padhānaṁ. ",
    "an2.176:1.4": "Ime kho, bhikkhave, dve dhammā”. ",
    "an2.177:1.0": "177 ",
    "an2.177:1.1": "“Dveme, bhikkhave, dhammā. ",
    "an2.177:1.2": "Katame dve? ",
    "an2.177:1.3": "Asantuṭṭhitā ca kusalesu dhammesu, appaṭivānitā ca padhānasmiṁ. ",
    "an2.177:1.4": "Ime kho, bhikkhave, dve dhammā”. ",
    "an2.178:1.0": "178 ",
    "an2.178:1.1": "“Dveme, bhikkhave, dhammā. ",
    "an2.178:1.2": "Katame dve? ",
    "an2.178:1.3": "Muṭṭhassaccañca asampajaññañca. ",
    "an2.178:1.4": "Ime kho, bhikkhave, dve dhammā”. ",
    "an2.179:1.0": "179 ",
    "an2.179:1.1": "“Dveme, bhikkhave, dhammā. ",
    "an2.179:1.2": "Katame dve? ",
    "an2.179:1.3": "Sati ca sampajaññañca. ",
    "an2.179:1.4": "Ime kho, bhikkhave, dve dhammā”ti. ",
    "an2.179:1.5": "Samāpattivaggo pañcamo. ",
    "an2.179:1.6": "Tatiyo paṇṇāsako samatto. "
  },
  "translation_text": {
    "an2.163:0.1": "Numbered Discourses 2.163–179 ",
    "an2.163:0.2": "The Chapter on Attainment ",
    "an2.163:1.0": "163 ",
    "an2.163:1.1": "“There are these two things. ",
    "an2.163:1.2": "What two? ",
    "an2.163:1.3": "Skill in meditative attainments and skill in emerging from those attainments. ",
    "an2.163:1.4": "These are the two things.” ",
    "an2.164:1.0": "164 ",
    "an2.164:1.1": "“There are these two things. ",
    "an2.164:1.2": "What two? ",
    "an2.164:1.3": "Integrity and tenderness. ",
    "an2.164:1.4": "These are the two things.” ",
    "an2.165:1.0": "165 ",
    "an2.165:1.1": "“There are these two things. ",
    "an2.165:1.2": "What two? ",
    "an2.165:1.3": "Patience and gentleness. ",
    "an2.165:1.4": "These are the two things.” ",
    "an2.166:1.0": "166 ",
    "an2.166:1.1": "“There are these two things. ",
    "an2.166:1.2": "What two? ",
    "an2.166:1.3": "Camaraderie and hospitality. ",
    "an2.166:1.4": "These are the two things.” ",
    "an2.167:1.0": "167 ",
    "an2.167:1.1": "“There are these two things. ",
    "an2.167:1.2": "What two? ",
    "an2.167:1.3": "Harmlessness and purity. ",
    "an2.167:1.4": "These are the two things.” ",
    "an2.168:1.0": "168 ",
    "an2.168:1.1": "“There are these two things. ",
    "an2.168:1.2": "What two? ",
    "an2.168:1.3": "Not guarding the sense doors and eating too much. ",
    "an2.168:1.4": "These are the two things.” ",
    "an2.169:1.0": "169 ",
    "an2.169:1.1": "“There are these two things. ",
    "an2.169:1.2": "What two? ",
    "an2.169:1.3": "Guarding the sense doors and moderation in eating. ",
    "an2.169:1.4": "These are the two things.” ",
    "an2.170:1.0": "170 ",
    "an2.170:1.1": "“There are these two things. ",
    "an2.170:1.2": "What two? ",
    "an2.170:1.3": "The power of reflection and the power of development. ",
    "an2.170:1.4": "These are the two things.” ",
    "an2.171:1.0": "171 ",
    "an2.171:1.1": "“There are these two things. ",
    "an2.171:1.2": "What two? ",
    "an2.171:1.3": "The power of mindfulness and the power of immersion. ",
    "an2.171:1.4": "These are the two things.” ",
    "an2.172:1.0": "172 ",
    "an2.172:1.1": "“There are these two things. ",
    "an2.172:1.2": "What two? ",
    "an2.172:1.3": "Serenity and discernment. ",
    "an2.172:1.4": "These are the two things.” ",
    "an2.173:1.0": "173 ",
    "an2.173:1.1": "“There are these two things. ",
    "an2.173:1.2": "What two? ",
    "an2.173:1.3": "Failure in ethical conduct and failure in view. ",
    "an2.173:1.4": "These are the two things.” ",
    "an2.174:1.0": "174 ",
    "an2.174:1.1": "“There are these two things. ",
    "an2.174:1.2": "What two? ",
    "an2.174:1.3": "Accomplishment in ethical conduct and accomplishment in view. ",
    "an2.174:1.4": "These are the two things.” ",
    "an2.175:1.0": "175 ",
    "an2.175:1.1": "“There are these two things. ",
    "an2.175:1.2": "What two? ",
    "an2.175:1.3": "Purification of ethics and purification of view. ",
    "an2.175:1.4": "These are the two things.” ",
    "an2.176:1.0": "176 ",
    "an2.176:1.1": "“There are these two things. ",
    "an2.176:1.2": "What two? ",
    "an2.176:1.3": "Purification of view and making an effort in line with that view. ",
    "an2.176:1.4": "These are the two things.” ",
    "an2.177:1.0": "177 ",
    "an2.177:1.1": "“There are these two things. ",
    "an2.177:1.2": "What two? ",
    "an2.177:1.3": "To never be content with skillful qualities, and to never stop trying. ",
    "an2.177:1.4": "These are the two things.” ",
    "an2.178:1.0": "178 ",
    "an2.178:1.1": "“There are these two things. ",
    "an2.178:1.2": "What two? ",
    "an2.178:1.3": "Lack of mindfulness and lack of situational awareness. ",
    "an2.178:1.4": "These are the two things.” ",
    "an2.179:1.0": "179 ",
    "an2.179:1.1": "“There are these two things. ",
    "an2.179:1.2": "What two? ",
    "an2.179:1.3": "Mindfulness and situational awareness. ",
    "an2.179:1.4": "These are the two things.” "
  },
