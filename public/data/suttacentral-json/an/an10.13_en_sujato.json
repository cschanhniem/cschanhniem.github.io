  "root_text": {
    "an10.13:0.1": "Aṅguttara Nikāya 10.13 ",
    "an10.13:0.2": "2. Nāthavagga ",
    "an10.13:0.3": "Saṁyojanasutta ",
    "an10.13:1.1": "“Dasayimāni, bhikkhave, saṁyojanāni. ",
    "an10.13:1.2": "Katamāni dasa? ",
    "an10.13:1.3": "Pañcorambhāgiyāni saṁyojanāni, pañcuddhambhāgiyāni saṁyojanāni. ",
    "an10.13:1.4": "Katamāni pañcorambhāgiyāni saṁyojanāni? ",
    "an10.13:1.5": "Sakkāyadiṭṭhi, vicikicchā, sīlabbataparāmāso, kāmacchando, byāpādo—",
    "an10.13:1.6": "imāni pañcorambhāgiyāni saṁyojanāni. ",
    "an10.13:2.1": "Katamāni pañcuddhambhāgiyāni saṁyojanāni? ",
    "an10.13:2.2": "Rūparāgo, arūparāgo, māno, uddhaccaṁ, avijjā—",
    "an10.13:2.3": "imāni pañcuddhambhāgiyāni saṁyojanāni. ",
    "an10.13:2.4": "Imāni kho, bhikkhave, dasa saṁyojanānī”ti. ",
    "an10.13:2.5": "Tatiyaṁ. "
  },
  "translation_text": {
    "an10.13:0.1": "Numbered Discourses 10.13 ",
    "an10.13:0.2": "2. A Protector ",
    "an10.13:0.3": "Fetters ",
    "an10.13:1.1": "“Mendicants, there are ten fetters. ",
    "an10.13:1.2": "What ten? ",
    "an10.13:1.3": "The five lower fetters and the five higher fetters. ",
    "an10.13:1.4": "What are the five lower fetters? ",
    "an10.13:1.5": "Substantialist view, doubt, misapprehension of precepts and observances, sensual desire, and ill will. ",
    "an10.13:1.6": "These are the five lower fetters. ",
    "an10.13:2.1": "What are the five higher fetters? ",
    "an10.13:2.2": "Desire for rebirth in the realm of luminous form, desire for rebirth in the formless realm, conceit, restlessness, and ignorance. ",
    "an10.13:2.3": "These are the five higher fetters. ",
    "an10.13:2.4": "These are the ten fetters.” "
  },
