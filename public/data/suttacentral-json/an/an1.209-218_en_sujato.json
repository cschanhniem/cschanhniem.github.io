  "root_text": {
    "an1.209:0.1": "Aṅguttara Nikāya 1 ",
    "an1.209:0.2": "16. Tatiyavagga ",
    "an1.209:1.1": "“Etadaggaṁ, bhikkhave, mama sāvakānaṁ bhikkhūnaṁ sikkhākāmānaṁ yadidaṁ rāhulo. ",
    "an1.210:1.1": "… Saddhāpabbajitānaṁ yadidaṁ raṭṭhapālo. ",
    "an1.211:1.1": "… Paṭhamaṁ salākaṁ gaṇhantānaṁ yadidaṁ kuṇḍadhāno. ",
    "an1.212:1.1": "… Paṭibhānavantānaṁ yadidaṁ vaṅgīso. ",
    "an1.213:1.1": "… Samantapāsādikānaṁ yadidaṁ upaseno vaṅgantaputto. ",
    "an1.214:1.1": "… Senāsanapaññāpakānaṁ yadidaṁ dabbo mallaputto. ",
    "an1.215:1.1": "… devatānaṁ piyamanāpānaṁ yadidaṁ pilindavaccho. ",
    "an1.216:1.1": "… Khippābhiññānaṁ yadidaṁ bāhiyo dārucīriyo. ",
    "an1.217:1.1": "… Cittakathikānaṁ yadidaṁ kumārakassapo. ",
    "an1.218:1.1": "… Paṭisambhidāpattānaṁ yadidaṁ mahākoṭṭhito”ti. ",
    "an1.218:1.2": "Vaggo tatiyo. "
  },
  "translation_text": {
    "an1.209:0.1": "Numbered Discourses 1 ",
    "an1.209:0.2": "Chapter Three ",
    "an1.209:1.1": "“The foremost of my monk disciples who want to train is Rāhula. ",
    "an1.210:1.1": "… who went forth out of faith is Raṭṭhapāla. ",
    "an1.211:1.1": "… who are the first to pick up a ballot slip is Kuṇḍadhāna. ",
    "an1.212:1.1": "… who are eloquent poets is Vaṅgīsa. ",
    "an1.213:1.1": "… who are impressive all around is Upasena son of Vaṅgantā. ",
    "an1.214:1.1": "… who assign lodgings is Dabba Mallaputta. ",
    "an1.215:1.1": "… who are beloved of the deities is Pilindavaccha. ",
    "an1.216:1.1": "… with swift insight is Bāhiya of the Bark Cloth. ",
    "an1.217:1.1": "… with brilliant speech is Kassapa the Prince. ",
    "an1.218:1.1": "… who have attained the methods of textual analysis is Mahākoṭṭhita.” "
  },
  "variant_text": {
    "an1.218:1.1": "mahākoṭṭhito”ti → mahākoṭṭhikoti (aññesu suttesu marammapotthake) "
  },
