  "root_text": {
    "an4.143:0.1": "Aṅguttara Nikāya 4.143 ",
    "an4.143:0.2": "15. Ābhāvagga ",
    "an4.143:0.3": "Ālokasutta ",
    "an4.143:1.1": "“Cattārome, bhikkhave, ālokā. ",
    "an4.143:1.2": "Katame cattāro? ",
    "an4.143:1.3": "Candāloko, sūriyāloko, aggāloko, paññāloko—",
    "an4.143:1.4": "Ime kho, bhikkhave, cattāro ālokā. ",
    "an4.143:1.5": "Etadaggaṁ, bhikkhave, imesaṁ catunnaṁ ālokānaṁ yadidaṁ paññāloko”ti. ",
    "an4.143:1.6": "Tatiyaṁ. "
  },
  "translation_text": {
    "an4.143:0.1": "Numbered Discourses 4.143 ",
    "an4.143:0.2": "15. Brightness ",
    "an4.143:0.3": "Light ",
    "an4.143:1.1": "“Mendicants, there are these four lights. ",
    "an4.143:1.2": "What four? ",
    "an4.143:1.3": "The lights of the moon, sun, fire, and wisdom. ",
    "an4.143:1.4": "These are the four lights. ",
    "an4.143:1.5": "The best of these four lights is the light of wisdom.” "
  },
