  "root_text": {
    "an4.154:0.1": "Aṅguttara Nikāya 4.154 ",
    "an4.154:0.2": "16. Indriyavagga ",
    "an4.154:0.3": "Satibalasutta ",
    "an4.154:1.1": "“Cattārimāni, bhikkhave, balāni. ",
    "an4.154:1.2": "Katamāni cattāri? ",
    "an4.154:1.3": "Satibalaṁ, samādhibalaṁ, anavajjabalaṁ, saṅgahabalaṁ—",
    "an4.154:1.4": "Imāni kho, bhikkhave, cattāri balānī”ti. ",
    "an4.154:1.5": "Catutthaṁ. "
  },
  "translation_text": {
    "an4.154:0.1": "Numbered Discourses 4.154 ",
    "an4.154:0.2": "16. Faculties ",
    "an4.154:0.3": "The Power of Mindfulness ",
    "an4.154:1.1": "“Mendicants, there are these four powers. ",
    "an4.154:1.2": "What four? ",
    "an4.154:1.3": "The powers of mindfulness, immersion, blamelessness, and inclusiveness. ",
    "an4.154:1.4": "These are the four powers.” "
  },
  "variant_text": {
    "an4.154:0.3": "Satibalasutta → tatiyabalasuttaṁ (bj) "
  },
