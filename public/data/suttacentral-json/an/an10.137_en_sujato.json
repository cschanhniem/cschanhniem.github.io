  "root_text": {
    "an10.137:0.1": "Aṅguttara Nikāya 10.137 ",
    "an10.137:0.2": "14. Sādhuvagga ",
    "an10.137:0.3": "Atthasutta ",
    "an10.137:1.1": "“Atthañca vo, bhikkhave, desessāmi anatthañca. ",
    "an10.137:1.2": "Taṁ suṇātha …pe… ",
    "an10.137:1.3": "katamo ca, bhikkhave, anattho? ",
    "an10.137:1.4": "Micchādiṭṭhi …pe… micchāvimutti—",
    "an10.137:1.5": "ayaṁ vuccati, bhikkhave, anattho. ",
    "an10.137:1.6": "Katamo ca, bhikkhave, attho? ",
    "an10.137:1.7": "Sammādiṭṭhi …pe… sammāvimutti—",
    "an10.137:1.8": "ayaṁ vuccati, bhikkhave, attho”ti. ",
    "an10.137:1.9": "Catutthaṁ. "
  },
  "translation_text": {
    "an10.137:0.1": "Numbered Discourses 10.137 ",
    "an10.137:0.2": "14. Good ",
    "an10.137:0.3": "Beneficial ",
    "an10.137:1.1": "“I will teach you the beneficial and the harmful. … ",
    "an10.137:1.2": "",
    "an10.137:1.3": "And what is the harmful? ",
    "an10.137:1.4": "Wrong view, wrong thought, wrong speech, wrong action, wrong livelihood, wrong effort, wrong mindfulness, wrong immersion, wrong knowledge, and wrong freedom. ",
    "an10.137:1.5": "This is called the harmful. ",
    "an10.137:1.6": "And what is the beneficial? ",
    "an10.137:1.7": "Right view, right thought, right speech, right action, right livelihood, right effort, right mindfulness, right immersion, right knowledge, and right freedom. ",
    "an10.137:1.8": "This is called the beneficial.” "
  },
