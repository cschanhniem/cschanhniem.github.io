  "root_text": {
    "an4.231:0.1": "Aṅguttara Nikāya 4.231 ",
    "an4.231:0.2": "23. Duccaritavagga ",
    "an4.231:0.3": "Kavisutta ",
    "an4.231:1.1": "“Cattārome, bhikkhave, kavī. ",
    "an4.231:1.2": "Katame cattāro? ",
    "an4.231:1.3": "Cintākavi, sutakavi, atthakavi, paṭibhānakavi—",
    "an4.231:1.4": "Ime kho, bhikkhave, cattāro kavī”ti. ",
    "an4.231:1.5": "Ekādasamaṁ. ",
    "an4.231:1.6": "Duccaritavaggo tatiyo. ",
    "an4.231:2.0": "Tassuddānaṁ ",
    "an4.231:2.1": "Duccaritaṁ diṭṭhi akataññū ca, ",
    "an4.231:2.2": "Pāṇātipātāpi dve maggā; ",
    "an4.231:2.3": "Dve vohārapathā vuttā, ",
    "an4.231:2.4": "Ahirikaṁ duppaññakavinā cāti. "
  },
  "translation_text": {
    "an4.231:0.1": "Numbered Discourses 4.231 ",
    "an4.231:0.2": "23. Bad Conduct ",
    "an4.231:0.3": "Poets ",
    "an4.231:1.1": "“Mendicants, there are these four poets. ",
    "an4.231:1.2": "What four? ",
    "an4.231:1.3": "A poet who thoughtfully composes their own work, a poet who repeats the oral transmission, a poet who educates, and a poet who improvises. ",
    "an4.231:1.4": "These are the four poets.” ",
