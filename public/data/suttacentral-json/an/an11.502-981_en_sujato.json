  "root_text": {
    "an11.502-981:0.1": "Aṅguttara Nikāya 11 ",
    "an11.502-981:0.2": "Paṭhamapaṇṇāsaka ",
    "an11.502-981:0.3": "Sāmaññavagga ",
    "an11.502-981:0.4": "~ ",
    "an11.502-981:1.1": "Ekādasahi, bhikkhave, aṅgehi samannāgato gopālako bhabbo gogaṇaṁ pariharituṁ phātikātuṁ. ",
    "an11.502-981:1.2": "Katamehi ekādasahi? ",
    "an11.502-981:1.3": "Idha, bhikkhave, gopālako rūpaññū hoti… pe… ",
    "an11.502-981:2.1": "Evameva kho, bhikkhave, ekādasahi dhammehi samannāgato bhikkhu bhabbo cakkhusmiṁ aniccānupassī viharituṁ… ",
    "an11.502-981:2.2": "pe… ",
    "an11.502-981:2.3": "paṭinissaggānupassī viharitunti. "
  },
  "translation_text": {
    "an11.502-981:0.1": "Numbered Discourses 11.502–981 ",
    "an11.502-981:0.2": "The First Fifty ",
    "an11.502-981:0.3": "Similarity ",
    "an11.502-981:0.4": "Untitled Discourses on the Eye, Etc. ",
    "an11.502-981:1.1": "“Mendicants, a cowherd with eleven factors can maintain and expand a herd of cattle. ",
    "an11.502-981:1.2": "What eleven? ",
    "an11.502-981:1.3": "It’s when a cowherd knows form … ",
    "an11.502-981:2.1": "In the same way, a mendicant with eleven qualities can meditate observing impermanence in the eye … ",
    "an11.502-981:2.2": "",
    "an11.502-981:2.3": "meditate observing letting go. …” "
  },
