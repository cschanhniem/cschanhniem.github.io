  "root_text": {
    "an4.144:0.1": "Aṅguttara Nikāya 4.144 ",
    "an4.144:0.2": "15. Ābhāvagga ",
    "an4.144:0.3": "Obhāsasutta ",
    "an4.144:1.1": "“Cattārome, bhikkhave, obhāsā. ",
    "an4.144:1.2": "Katame cattāro? ",
    "an4.144:1.3": "Candobhāso, sūriyobhāso, aggobhāso, paññobhāso—",
    "an4.144:1.4": "Ime kho, bhikkhave, cattāro obhāsā. ",
    "an4.144:1.5": "Etadaggaṁ, bhikkhave, imesaṁ catunnaṁ obhāsānaṁ yadidaṁ paññobhāso”ti. ",
    "an4.144:1.6": "Catutthaṁ. "
  },
  "translation_text": {
    "an4.144:0.1": "Numbered Discourses 4.144 ",
    "an4.144:0.2": "15. Brightness ",
    "an4.144:0.3": "Shining ",
    "an4.144:1.1": "“Mendicants, there are four kinds of shining. ",
    "an4.144:1.2": "What four? ",
    "an4.144:1.3": "The shining of the moon, sun, fire, and wisdom. ",
    "an4.144:1.4": "These are the four kinds of shining. ",
    "an4.144:1.5": "The best of these four kinds of shining is the shining of wisdom.” "
  },
