  "root_text": {
    "an4.271:0.1": "Aṅguttara Nikāya 4.271 ",
    "an4.271:0.2": "27. Kammapathavagga ",
    "an4.271:0.3": "Abhijjhālusutta ",
    "an4.271:1.1": "…pe… Attanā ca abhijjhālu hoti, parañca abhijjhāya samādapeti, abhijjhāya ca samanuñño hoti, abhijjhāya ca vaṇṇaṁ bhāsati …pe…. ",
    "an4.271:2.1": "Attanā ca anabhijjhālu hoti, parañca anabhijjhāya samādapeti, anabhijjhāya ca samanuñño hoti, anabhijjhāya ca vaṇṇaṁ bhāsati—imehi kho …pe…. ",
    "an4.271:2.2": "Aṭṭhamaṁ. "
  },
  "translation_text": {
    "an4.271:0.1": "Numbered Discourses 4.271 ",
    "an4.271:0.2": "27. Ways of Performing Deeds ",
    "an4.271:0.3": "Covetousness ",
    "an4.271:1.1": "“… They themselves are covetous … ",
    "an4.271:2.1": "… They themselves are content …” "
  },
