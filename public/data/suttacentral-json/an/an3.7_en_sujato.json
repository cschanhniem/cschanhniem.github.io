  "root_text": {
    "an3.7:0.1": "Aṅguttara Nikāya 3.7 ",
    "an3.7:0.2": "1. Bālavagga ",
    "an3.7:0.3": "Sāvajjasutta ",
    "an3.7:1.1": "“Tīhi, bhikkhave, dhammehi samannāgato bālo veditabbo. ",
    "an3.7:1.2": "Katamehi tīhi? ",
    "an3.7:1.3": "Sāvajjena kāyakammena, sāvajjena vacīkammena, sāvajjena manokammena …pe… anavajjena kāyakammena, anavajjena vacīkammena, anavajjena manokammena …pe…. ",
    "an3.7:1.4": "Sattamaṁ. "
  },
  "translation_text": {
    "an3.7:0.1": "Numbered Discourses 3.7 ",
    "an3.7:0.2": "1. Fools ",
    "an3.7:0.3": "Blameworthy ",
    "an3.7:1.1": "“A fool is known by three things. ",
    "an3.7:1.2": "What three? ",
    "an3.7:1.3": "Blameworthy deeds by way of body, speech, and mind. … An astute person is known by blameless deeds by way of body, speech, and mind. …” "
  },
