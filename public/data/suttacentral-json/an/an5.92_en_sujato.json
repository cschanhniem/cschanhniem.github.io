  "root_text": {
    "an5.92:0.1": "Aṅguttara Nikāya 5.92 ",
    "an5.92:0.2": "10. Kakudhavagga ",
    "an5.92:0.3": "Dutiyasampadāsutta ",
    "an5.92:1.1": "“Pañcimā, bhikkhave, sampadā. ",
    "an5.92:1.2": "Katamā pañca? ",
    "an5.92:1.3": "Sīlasampadā, samādhisampadā, paññāsampadā, vimuttisampadā, vimuttiñāṇadassanasampadā—",
    "an5.92:1.4": "imā kho, bhikkhave, pañca sampadā”ti. ",
    "an5.92:1.5": "Dutiyaṁ. "
  },
  "translation_text": {
    "an5.92:0.1": "Numbered Discourses 5.92 ",
    "an5.92:0.2": "10. With Kakudha ",
    "an5.92:0.3": "Accomplishment (2nd) ",
    "an5.92:1.1": "“Mendicants, there are five accomplishments. ",
    "an5.92:1.2": "What five? ",
    "an5.92:1.3": "Accomplishment in ethics, immersion, wisdom, freedom, and the knowledge and vision of freedom. ",
    "an5.92:1.4": "These are the five accomplishments.” "
  },
