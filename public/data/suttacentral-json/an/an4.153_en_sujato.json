  "root_text": {
    "an4.153:0.1": "Aṅguttara Nikāya 4.153 ",
    "an4.153:0.2": "16. Indriyavagga ",
    "an4.153:0.3": "Paññābalasutta ",
    "an4.153:1.1": "“Cattārimāni, bhikkhave, balāni. ",
    "an4.153:1.2": "Katamāni cattāri? ",
    "an4.153:1.3": "Paññābalaṁ, vīriyabalaṁ, anavajjabalaṁ, saṅgahabalaṁ—",
    "an4.153:1.4": "Imāni kho, bhikkhave, cattāri balānī”ti. ",
    "an4.153:1.5": "Tatiyaṁ. "
  },
  "translation_text": {
    "an4.153:0.1": "Numbered Discourses 4.153 ",
    "an4.153:0.2": "16. Faculties ",
    "an4.153:0.3": "The Power of Wisdom ",
    "an4.153:1.1": "“Mendicants, there are these four powers. ",
    "an4.153:1.2": "What four? ",
    "an4.153:1.3": "The powers of wisdom, energy, blamelessness, and inclusiveness. ",
    "an4.153:1.4": "These are the four powers.” "
  },
  "variant_text": {
    "an4.153:0.3": "Paññābalasutta → dutiyabalasuttaṁ (bj) ",
    "an4.153:1.3": "saṅgahabalaṁ → saṅgāhabalaṁ (bj, pts1ed); saṅgāhakabalaṁ (sya-all, km) "
  },
