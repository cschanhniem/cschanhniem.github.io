  "root_text": {
    "an2.87:0.1": "Aṅguttara Nikāya 2 ",
    "an2.87:0.2": "9. Dhammavagga ",
    "an2.87:1.0": "87 ",
    "an2.87:1.1": "“Dveme, bhikkhave, dhammā. ",
    "an2.87:1.2": "Katame dve? ",
    "an2.87:1.3": "Cetovimutti ca paññāvimutti ca. ",
    "an2.87:1.4": "Ime kho, bhikkhave, dve dhammā”ti. ",
    "an2.88:1.0": "88 ",
    "an2.88:1.1": "“Dveme, bhikkhave, dhammā. ",
    "an2.88:1.2": "Katame dve? ",
    "an2.88:1.3": "Paggāho ca avikkhepo ca. ",
    "an2.88:1.4": "Ime kho, bhikkhave, dve dhammā”ti. ",
    "an2.89:1.0": "89 ",
    "an2.89:1.1": "“Dveme, bhikkhave, dhammā. ",
    "an2.89:1.2": "Katame dve? ",
    "an2.89:1.3": "Nāmañca rūpañca. ",
    "an2.89:1.4": "Ime kho, bhikkhave, dve dhammā”ti. ",
    "an2.90:1.0": "90 ",
    "an2.90:1.1": "“Dveme, bhikkhave, dhammā. ",
    "an2.90:1.2": "Katame dve? ",
    "an2.90:1.3": "Vijjā ca vimutti ca. ",
    "an2.90:1.4": "Ime kho, bhikkhave, dve dhammā”ti. ",
    "an2.91:1.0": "91 ",
    "an2.91:1.1": "“Dveme, bhikkhave, dhammā. ",
    "an2.91:1.2": "Katame dve? ",
    "an2.91:1.3": "Bhavadiṭṭhi ca vibhavadiṭṭhi ca. ",
    "an2.91:1.4": "Ime kho, bhikkhave, dve dhammā”ti. ",
    "an2.92:1.0": "92 ",
    "an2.92:1.1": "“Dveme, bhikkhave, dhammā. ",
    "an2.92:1.2": "Katame dve? ",
    "an2.92:1.3": "Ahirikañca anottappañca. ",
    "an2.92:1.4": "Ime kho, bhikkhave, dve dhammā”ti. ",
    "an2.93:1.0": "93 ",
    "an2.93:1.1": "“Dveme, bhikkhave, dhammā. ",
    "an2.93:1.2": "Katame dve? ",
    "an2.93:1.3": "Hirī ca ottappañca. ",
    "an2.93:1.4": "Ime kho, bhikkhave, dve dhammā”ti. ",
    "an2.94:1.0": "94 ",
    "an2.94:1.1": "“Dveme, bhikkhave, dhammā. ",
    "an2.94:1.2": "Katame dve? ",
    "an2.94:1.3": "Dovacassatā ca pāpamittatā ca. ",
    "an2.94:1.4": "Ime kho, bhikkhave, dve dhammā”ti. ",
    "an2.95:1.0": "95 ",
    "an2.95:1.1": "“Dveme, bhikkhave, dhammā. ",
    "an2.95:1.2": "Katame dve? ",
    "an2.95:1.3": "Sovacassatā ca kalyāṇamittatā ca. ",
    "an2.95:1.4": "Ime kho, bhikkhave, dve dhammā”ti. ",
    "an2.96:1.0": "96 ",
    "an2.96:1.1": "“Dveme, bhikkhave, dhammā. ",
    "an2.96:1.2": "Katame dve? ",
    "an2.96:1.3": "Dhātukusalatā ca manasikārakusalatā ca. ",
    "an2.96:1.4": "Ime kho, bhikkhave, dve dhammā”ti. ",
    "an2.97:1.0": "97 ",
    "an2.97:1.1": "“Dveme, bhikkhave, dhammā. ",
    "an2.97:1.2": "Katame dve? ",
    "an2.97:1.3": "Āpattikusalatā ca āpattivuṭṭhānakusalatā ca. ",
    "an2.97:1.4": "Ime kho, bhikkhave, dve dhammā”ti. ",
    "an2.97:1.5": "Dhammavaggo catuttho. "
  },
  "translation_text": {
    "an2.87:0.1": "Numbered Discourses 2.87–97 ",
    "an2.87:0.2": "The Chapter on Two Things ",
    "an2.87:1.0": "87 ",
    "an2.87:1.1": "“There are, mendicants, these two things. ",
    "an2.87:1.2": "What two? ",
    "an2.87:1.3": "Freedom of heart and freedom by wisdom. ",
    "an2.87:1.4": "These are the two things.” ",
    "an2.88:1.0": "88 ",
    "an2.88:1.1": "“There are, mendicants, these two things. ",
    "an2.88:1.2": "What two? ",
    "an2.88:1.3": "Exertion, and not being scattered. ",
    "an2.88:1.4": "These are the two things.” ",
    "an2.89:1.0": "89 ",
    "an2.89:1.1": "“There are, mendicants, these two things. ",
    "an2.89:1.2": "What two? ",
    "an2.89:1.3": "Name and form. ",
    "an2.89:1.4": "These are the two things.” ",
    "an2.90:1.0": "90 ",
    "an2.90:1.1": "“There are, mendicants, these two things. ",
    "an2.90:1.2": "What two? ",
    "an2.90:1.3": "Knowledge and freedom. ",
    "an2.90:1.4": "These are the two things.” ",
    "an2.91:1.0": "91 ",
    "an2.91:1.1": "“There are, mendicants, these two things. ",
    "an2.91:1.2": "What two? ",
    "an2.91:1.3": "Views favoring existence and views favoring nonexistence. ",
    "an2.91:1.4": "These are the two things.” ",
    "an2.92:1.0": "92 ",
    "an2.92:1.1": "“There are, mendicants, these two things. ",
    "an2.92:1.2": "What two? ",
    "an2.92:1.3": "Lack of conscience and prudence. ",
    "an2.92:1.4": "These are the two things.” ",
    "an2.93:1.0": "93 ",
    "an2.93:1.1": "“There are, mendicants, these two things. ",
    "an2.93:1.2": "What two? ",
    "an2.93:1.3": "Conscience and prudence. ",
    "an2.93:1.4": "These are the two things.” ",
    "an2.94:1.0": "94 ",
    "an2.94:1.1": "“There are, mendicants, these two things. ",
    "an2.94:1.2": "What two? ",
    "an2.94:1.3": "Being hard to admonish and having bad friends. ",
    "an2.94:1.4": "These are the two things.” ",
    "an2.95:1.0": "95 ",
    "an2.95:1.1": "“There are, mendicants, these two things. ",
    "an2.95:1.2": "What two? ",
    "an2.95:1.3": "Being easy to admonish and having good friends. ",
    "an2.95:1.4": "These are the two things.” ",
    "an2.96:1.0": "96 ",
    "an2.96:1.1": "“There are, mendicants, these two things. ",
    "an2.96:1.2": "What two? ",
    "an2.96:1.3": "Skill in the elements and skill in application of mind. ",
    "an2.96:1.4": "These are the two things.” ",
    "an2.97:1.0": "97 ",
    "an2.97:1.1": "“There are, mendicants, these two things. ",
    "an2.97:1.2": "What two? ",
    "an2.97:1.3": "Skill in offenses and skill in resolving offenses. ",
    "an2.97:1.4": "These are the two things.” "
  },
