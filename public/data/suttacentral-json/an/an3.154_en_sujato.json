  "root_text": {
    "an3.154:0.1": "Aṅguttara Nikāya 3.154 ",
    "an3.154:0.2": "15. Maṅgalavagga ",
    "an3.154:0.3": "Vandanāsutta ",
    "an3.154:1.1": "“Tisso imā, bhikkhave, vandanā. ",
    "an3.154:1.2": "Katamā tisso? ",
    "an3.154:1.3": "Kāyena, vācāya, manasā—",
    "an3.154:1.4": "imā kho, bhikkhave, tisso vandanā”ti. ",
    "an3.154:1.5": "Navamaṁ. "
  },
  "translation_text": {
    "an3.154:0.1": "Numbered Discourses 3.154 ",
    "an3.154:0.2": "15. Good Fortune ",
    "an3.154:0.3": "Homage ",
    "an3.154:1.1": "“Mendicants, there are three kinds of homage. ",
    "an3.154:1.2": "What three? ",
    "an3.154:1.3": "By way of body, speech, and mind. ",
    "an3.154:1.4": "These are the three kinds of homage.” "
  },
