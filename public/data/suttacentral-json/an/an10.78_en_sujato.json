  "root_text": {
    "an10.78:0.1": "Aṅguttara Nikāya 10.78 ",
    "an10.78:0.2": "8. Ākaṅkhavagga ",
    "an10.78:0.3": "Nigaṇṭhasutta ",
    "an10.78:1.1": "“Dasahi, bhikkhave, asaddhammehi samannāgatā nigaṇṭhā. ",
    "an10.78:1.2": "Katamehi dasahi? ",
    "an10.78:1.3": "Assaddhā, bhikkhave, nigaṇṭhā; ",
    "an10.78:1.4": "dussīlā, bhikkhave, nigaṇṭhā; ",
    "an10.78:1.5": "ahirikā, bhikkhave, nigaṇṭhā; ",
    "an10.78:1.6": "anottappino, bhikkhave, nigaṇṭhā; ",
    "an10.78:1.7": "asappurisasambhattino, bhikkhave, nigaṇṭhā; ",
    "an10.78:1.8": "attukkaṁsakaparavambhakā, bhikkhave, nigaṇṭhā; ",
    "an10.78:1.9": "sandiṭṭhiparāmāsā ādhānaggāhī duppaṭinissaggino, bhikkhave, nigaṇṭhā; ",
    "an10.78:1.10": "kuhakā, bhikkhave, nigaṇṭhā; ",
    "an10.78:1.11": "pāpicchā, bhikkhave, nigaṇṭhā; ",
    "an10.78:1.12": "pāpamittā, bhikkhave, nigaṇṭhā—",
    "an10.78:1.13": "imehi kho, bhikkhave, dasahi asaddhammehi samannāgatā nigaṇṭhā”ti. ",
    "an10.78:1.14": "Aṭṭhamaṁ. "
  },
  "translation_text": {
    "an10.78:0.1": "Numbered Discourses 10.78 ",
    "an10.78:0.2": "8. If You Want ",
    "an10.78:0.3": "Jains ",
    "an10.78:1.1": "“Mendicants, Jain ascetics have ten bad qualities. ",
    "an10.78:1.2": "What ten? ",
    "an10.78:1.3": "They’re faithless and ",
    "an10.78:1.4": "unethical, ",
    "an10.78:1.5": "without conscience ",
    "an10.78:1.6": "or prudence, ",
    "an10.78:1.7": "and devoted to untrue persons. ",
    "an10.78:1.8": "They glorify themselves and put others down. ",
    "an10.78:1.9": "They’re attached to their own views, holding them tight, and refusing to let go. ",
    "an10.78:1.10": "They’re deceptive, ",
    "an10.78:1.11": "with corrupt wishes ",
    "an10.78:1.12": "and bad friends. ",
    "an10.78:1.13": "Jain ascetics possess these ten bad qualities.” "
  },
