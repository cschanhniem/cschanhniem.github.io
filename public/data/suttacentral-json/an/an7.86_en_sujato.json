  "root_text": {
    "an7.86:0.1": "Aṅguttara Nikāya 7.86 ",
    "an7.86:0.2": "9. Samaṇavagga ",
    "an7.86:0.3": "Samaṇasutta ",
    "an7.86:1.1": "“Sattannaṁ, bhikkhave, dhammānaṁ samitattā samaṇo hoti …pe…. ",
    "an7.86:1.2": "Dutiyaṁ. "
  },
  "translation_text": {
    "an7.86:0.1": "Numbered Discourses 7.86 ",
    "an7.86:0.2": "9. An Ascetic ",
    "an7.86:0.3": "An Ascetic ",
    "an7.86:1.1": "“Mendicants, it’s because of quelling seven things that you become an ascetic …” "
