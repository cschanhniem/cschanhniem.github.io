  "root_text": {
    "an7.11:0.1": "Aṅguttara Nikāya 7.11 ",
    "an7.11:0.2": "2. Anusayavagga ",
    "an7.11:0.3": "Paṭhamaanusayasutta ",
    "an7.11:1.1": "“Sattime, bhikkhave, anusayā. ",
    "an7.11:1.2": "Katame satta? ",
    "an7.11:1.3": "Kāmarāgānusayo, paṭighānusayo, diṭṭhānusayo, vicikicchānusayo, mānānusayo, bhavarāgānusayo, avijjānusayo. ",
    "an7.11:1.4": "Ime kho, bhikkhave, satta anusayā”ti. ",
    "an7.11:1.5": "Paṭhamaṁ. "
  },
  "translation_text": {
    "an7.11:0.1": "Numbered Discourses 7.11 ",
    "an7.11:0.2": "2. Tendencies ",
    "an7.11:0.3": "Underlying Tendencies (1st) ",
    "an7.11:1.1": "“Mendicants, there are these seven underlying tendencies. ",
    "an7.11:1.2": "What seven? ",
    "an7.11:1.3": "The underlying tendencies of sensual desire, repulsion, views, doubt, conceit, desire for continued existence, and ignorance. ",
    "an7.11:1.4": "These are the seven underlying tendencies.” "
  },
