  "root_text": {
    "an5.160:0.1": "Aṅguttara Nikāya 5.160 ",
    "an5.160:0.2": "16. Saddhammavagga ",
    "an5.160:0.3": "Duppaṭivinodayasutta ",
    "an5.160:1.1": "“Pañcime, bhikkhave, uppannā duppaṭivinodayā. ",
    "an5.160:1.2": "Katame pañca? ",
    "an5.160:1.3": "Uppanno rāgo duppaṭivinodayo, uppanno doso duppaṭivinodayo, uppanno moho duppaṭivinodayo, uppannaṁ paṭibhānaṁ duppaṭivinodayaṁ, uppannaṁ gamikacittaṁ duppaṭivinodayaṁ. ",
    "an5.160:1.4": "Ime kho, bhikkhave, pañca uppannā duppaṭivinodayā”ti. ",
    "an5.160:1.5": "Dasamaṁ. ",
    "an5.160:1.6": "Saddhammavaggo paṭhamo. ",
    "an5.160:2.0": "Tassuddānaṁ ",
    "an5.160:2.1": "Tayo sammattaniyāmā, ",
    "an5.160:2.2": "tayo saddhammasammosā; ",
    "an5.160:2.3": "Dukkathā ceva sārajjaṁ, ",
    "an5.160:2.4": "udāyidubbinodayāti. "
  },
  "translation_text": {
    "an5.160:0.1": "Numbered Discourses 5.160 ",
    "an5.160:0.2": "16. The True Teaching ",
    "an5.160:0.3": "Hard to Get Rid Of ",
    "an5.160:1.1": "“Mendicants, these five things are hard to get rid of once they’ve arisen. ",
    "an5.160:1.2": "What five? ",
    "an5.160:1.3": "Greed, hate, delusion, the feeling of being inspired to speak out, and thoughts of traveling. ",
    "an5.160:1.4": "These five things are hard to get rid of once they’ve arisen.” ",
