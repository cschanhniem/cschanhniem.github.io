    "an5.247:0.1": "Aṅguttara Nikāya 5.247 ",
    "an5.247:0.2": "25. Duccaritavagga ",
    "an5.247:0.3": "Dutiyavacīduccaritasutta ",
    "an5.247:1.1": "“Pañcime, bhikkhave, ādīnavā vacīduccarite …pe… ānisaṁsā vacīsucarite …pe…. ",
    "an5.247:1.2": "Sattamaṁ. "
  },
