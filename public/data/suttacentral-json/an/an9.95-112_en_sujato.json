    "an9.95-112:0.1": "Aṅguttara Nikāya 9 ",
    "an9.95-112:0.2": "10. Rāgapeyyāla ",
    "an9.95-112:0.3": "~ ",
    "an9.95-112:1.1": "“Rāgassa, bhikkhave, pariññāya …pe… ",
    "an9.95-112:1.2": "parikkhayāya …pe… ",
    "an9.95-112:1.3": "pahānāya …pe… ",
    "an9.95-112:1.4": "khayāya …pe… ",
    "an9.95-112:1.5": "vayāya …pe… ",
    "an9.95-112:1.6": "virāgāya …pe… ",
    "an9.95-112:1.7": "nirodhāya …pe… ",
    "an9.95-112:1.8": "cāgāya …pe… ",
    "an9.95-112:1.9": "paṭinissaggāya …pe… ",
    "an9.95-112:1.10": "ime nava dhammā bhāvetabbā”. "
  },
  "translation_text": {
    "an9.95-112:0.1": "Numbered Discourses 9 ",
    "an9.95-112:0.2": "10. Abbreviated Texts Beginning with Greed ",
    "an9.95-112:0.3": "Untitled Discourses on Greed ",
    "an9.95-112:1.1": "“For the complete understanding of greed … ",
    "an9.95-112:1.2": "complete ending … ",
    "an9.95-112:1.3": "giving up … ",
    "an9.95-112:1.4": "ending … ",
    "an9.95-112:1.5": "vanishing … ",
    "an9.95-112:1.6": "fading away … ",
    "an9.95-112:1.7": "cessation … ",
    "an9.95-112:1.8": "giving away … ",
    "an9.95-112:1.9": "letting go of greed … ",
    "an9.95-112:1.10": "these nine things should be developed.” "
  },
