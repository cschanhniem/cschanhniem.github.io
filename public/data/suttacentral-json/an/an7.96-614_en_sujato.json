  "root_text": {
    "an7.96-614:0.1": "Aṅguttara Nikāya 7 ",
    "an7.96-614:0.2": "10. Āhuneyyavagga ",
    "an7.96-614:0.3": "~ ",
    "an7.96-614:1.1": "“Sattime, bhikkhave, puggalā āhuneyyā pāhuneyyā …pe… anuttaraṁ puññakkhettaṁ lokassa. ",
    "an7.96-614:1.2": "Katame satta? ",
    "an7.96-614:1.3": "Idha, bhikkhave, ekacco puggalo cakkhusmiṁ dukkhānupassī viharati …pe… ",
    "an7.96-614:1.4": "cakkhusmiṁ anattānupassī viharati …pe… ",
    "an7.96-614:1.5": "cakkhusmiṁ khayānupassī viharati …pe… ",
    "an7.96-614:1.6": "cakkhusmiṁ vayānupassī viharati …pe… ",
