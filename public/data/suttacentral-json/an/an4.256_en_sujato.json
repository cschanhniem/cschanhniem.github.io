  "root_text": {
    "an4.256:0.1": "Aṅguttara Nikāya 4.256 ",
    "an4.256:0.2": "26. Abhiññāvagga ",
    "an4.256:0.3": "Saṅgahavatthusutta ",
    "an4.256:1.1": "“Cattārimāni, bhikkhave, saṅgahavatthūni. ",
    "an4.256:1.2": "Katamāni cattāri? ",
    "an4.256:1.3": "Dānaṁ, peyyavajjaṁ, atthacariyā, samānattatā—",
    "an4.256:1.4": "Imāni kho, bhikkhave, cattāri saṅgahavatthūnī”ti. ",
    "an4.256:1.5": "Tatiyaṁ. "
  },
  "translation_text": {
    "an4.256:0.1": "Numbered Discourses 4.256 ",
    "an4.256:0.2": "26. Insight ",
    "an4.256:0.3": "Ways of Being Inclusive ",
    "an4.256:1.1": "“Mendicants, there are these four ways of being inclusive. ",
    "an4.256:1.2": "What four? ",
    "an4.256:1.3": "Giving, kindly words, taking care, and equality. ",
    "an4.256:1.4": "These are the four ways of being inclusive.” "
  },
  "variant_text": {
    "an4.256:1.3": "peyyavajjaṁ → piyavācā (mr) "
  },
