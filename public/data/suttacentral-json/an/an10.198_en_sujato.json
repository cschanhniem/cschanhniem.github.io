  "root_text": {
    "an10.198:0.1": "Aṅguttara Nikāya 10.198 ",
    "an10.198:0.2": "19. Ariyamaggavagga ",
    "an10.198:0.3": "Sacchikātabbasutta ",
    "an10.198:1.1": "“Sacchikātabbañca vo, bhikkhave, dhammaṁ desessāmi na sacchikātabbañca. ",
    "an10.198:1.2": "Taṁ suṇātha …pe… ",
    "an10.198:1.3": "katamo ca, bhikkhave, na sacchikātabbo dhammo? ",
    "an10.198:1.4": "Pāṇātipāto …pe… ",
    "an10.198:1.5": "micchādiṭṭhi—",
    "an10.198:1.6": "ayaṁ vuccati, bhikkhave, na sacchikātabbo dhammo. ",
    "an10.198:2.1": "Katamo ca, bhikkhave, sacchikātabbo dhammo? ",
    "an10.198:2.2": "Pāṇātipātā veramaṇī …pe… ",
    "an10.198:2.3": "sammādiṭṭhi—",
    "an10.198:2.4": "ayaṁ vuccati, bhikkhave, sacchikātabbo dhammo”ti. ",
    "an10.198:2.5": "Dasamaṁ. ",
    "an10.198:2.6": "Ariyamaggavaggo catuttho. "
  },
  "translation_text": {
    "an10.198:0.1": "Numbered Discourses 10.198 ",
    "an10.198:0.2": "19. The Noble Path ",
    "an10.198:0.3": "Should Be Realized ",
    "an10.198:1.1": "“I will teach you the principle to realize and the principle not to realize. … ",
    "an10.198:1.2": "",
    "an10.198:1.3": "And what is the principle not to realize? ",
    "an10.198:1.4": "Killing living creatures … ",
    "an10.198:1.5": "wrong view. ",
    "an10.198:1.6": "This is called the principle not to realize. ",
    "an10.198:2.1": "And what is the principle to realize? ",
    "an10.198:2.2": "Not killing living creatures … ",
    "an10.198:2.3": "right view. ",
    "an10.198:2.4": "This is called the principle to realize.” ",
    "an10.198:2.5": ""
  },
