  "root_text": {
    "an5.240:0.1": "Aṅguttara Nikāya 5.240 ",
    "an5.240:0.2": "24. Āvāsikavagga ",
    "an5.240:0.3": "Dutiyamacchariyasutta ",
    "an5.240:1.1": "“Pañcahi, bhikkhave, dhammehi samannāgato āvāsiko bhikkhu yathābhataṁ nikkhitto evaṁ niraye. ",
    "an5.240:1.2": "Katamehi pañcahi? ",
    "an5.240:1.3": "Āvāsamaccharī hoti; ",
    "an5.240:1.4": "kulamaccharī hoti; ",
    "an5.240:1.5": "lābhamaccharī hoti; ",
    "an5.240:1.6": "vaṇṇamaccharī hoti; ",
    "an5.240:1.7": "dhammamaccharī hoti. ",
    "an5.240:1.8": "Imehi kho, bhikkhave, pañcahi dhammehi samannāgato āvāsiko bhikkhu yathābhataṁ nikkhitto evaṁ niraye. ",
    "an5.240:2.1": "Pañcahi, bhikkhave, dhammehi samannāgato āvāsiko bhikkhu yathābhataṁ nikkhitto evaṁ sagge. ",
    "an5.240:2.2": "Katamehi pañcahi? ",
    "an5.240:2.3": "Na āvāsamaccharī hoti; ",
    "an5.240:2.4": "na kulamaccharī hoti; ",
    "an5.240:2.5": "na lābhamaccharī hoti; ",
    "an5.240:2.6": "na vaṇṇamaccharī hoti; ",
    "an5.240:2.7": "na dhammamaccharī hoti. ",
    "an5.240:2.8": "Imehi kho, bhikkhave, pañcahi dhammehi samannāgato āvāsiko bhikkhu yathābhataṁ nikkhitto evaṁ sagge”ti. ",
    "an5.240:2.9": "Dasamaṁ. ",
    "an5.240:2.10": "Āvāsikavaggo catuttho. ",
    "an5.240:3.0": "Tassuddānaṁ ",
    "an5.240:3.1": "Āvāsiko piyo ca sobhano, ",
    "an5.240:3.2": "Bahūpakāro anukampako ca; ",
    "an5.240:3.3": "Tayo avaṇṇārahā ceva, ",
    "an5.240:3.4": "Macchariyā duvepi cāti. "
  },
  "translation_text": {
    "an5.240:0.1": "Numbered Discourses 5.240 ",
    "an5.240:0.2": "24. A Resident Mendicant ",
    "an5.240:0.3": "Stinginess (2nd) ",
    "an5.240:1.1": "“Mendicants, a resident mendicant with five qualities is placed in hell as if delivered there. ",
    "an5.240:1.2": "What five? ",
    "an5.240:1.3": "They’re stingy regarding monasteries, ",
    "an5.240:1.4": "families, ",
    "an5.240:1.5": "material things, ",
    "an5.240:1.6": "praise, ",
    "an5.240:1.7": "and the teachings. ",
    "an5.240:1.8": "A resident mendicant with these five qualities is placed in hell as if delivered there. ",
    "an5.240:2.1": "A resident mendicant with five qualities is placed in heaven as if delivered there. ",
    "an5.240:2.2": "What five? ",
    "an5.240:2.3": "They’re not stingy regarding monasteries, ",
    "an5.240:2.4": "families, ",
    "an5.240:2.5": "material things, ",
    "an5.240:2.6": "praise, ",
    "an5.240:2.7": "and the teachings. ",
    "an5.240:2.8": "A resident mendicant with these five qualities is placed in heaven as if delivered there.” ",
    "an5.240:2.9": "",
    "an5.240:2.10": "",
    "an5.240:3.1": "",
    "an5.240:3.2": "",
    "an5.240:3.3": ""
  },
  "variant_text": {
    "an5.240:3.1": "piyo ca sobhano → ābhāvanīyo piyasobhanā ca (bj); āvāsiko appiyasobhanā ca (sya-all) ",
    "an5.240:3.4": "Macchariyā duvepi cāti → yathābhataṁ cādi tayo avaṇṇārahā duve macchariyā ca vuttā (bj); catukkamaccherapañcakena cāti (si, sya-all); catukkamacchariyena cāti (pts1ed); catuko macchariyena cāti (mr) "
  },
