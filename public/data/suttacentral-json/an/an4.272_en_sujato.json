  "root_text": {
    "an4.272:0.1": "Aṅguttara Nikāya 4.272 ",
    "an4.272:0.2": "27. Kammapathavagga ",
    "an4.272:0.3": "Byāpannacittasutta ",
    "an4.272:1.1": "…pe… Attanā ca byāpannacitto hoti, parañca byāpāde samādapeti, byāpāde ca samanuñño hoti, byāpādassa ca vaṇṇaṁ bhāsati—imehi …pe…. ",
    "an4.272:2.1": "Attanā ca abyāpannacitto hoti, parañca abyāpāde samādapeti, abyāpāde ca samanuñño hoti, abyāpādassa ca vaṇṇaṁ bhāsati—imehi …pe…. ",
    "an4.272:2.2": "Navamaṁ. "
  },
  "translation_text": {
    "an4.272:0.1": "Numbered Discourses 4.272 ",
    "an4.272:0.2": "27. Ways of Performing Deeds ",
    "an4.272:0.3": "Ill Will ",
    "an4.272:1.1": "“… They themselves have ill will … ",
    "an4.272:2.1": "… They themselves have good will …” "
  },
