  "root_text": {
    "an4.152:0.1": "Aṅguttara Nikāya 4.152 ",
    "an4.152:0.2": "16. Indriyavagga ",
    "an4.152:0.3": "Saddhābalasutta ",
    "an4.152:1.1": "“Cattārimāni, bhikkhave, balāni. ",
    "an4.152:1.2": "Katamāni cattāri? ",
    "an4.152:1.3": "Saddhābalaṁ, vīriyabalaṁ, satibalaṁ, samādhibalaṁ—",
    "an4.152:1.4": "Imāni kho, bhikkhave, cattāri balānī”ti. ",
    "an4.152:1.5": "Dutiyaṁ. "
  },
  "translation_text": {
    "an4.152:0.1": "Numbered Discourses 4.152 ",
    "an4.152:0.2": "16. Faculties ",
    "an4.152:0.3": "The Power of Faith ",
    "an4.152:1.1": "“Mendicants, there are these four powers. ",
    "an4.152:1.2": "What four? ",
    "an4.152:1.3": "The powers of faith, energy, mindfulness, and immersion. ",
    "an4.152:1.4": "These are the four powers.” "
  },
  "variant_text": {
    "an4.152:0.3": "Saddhābalasutta → balasuttaṁ (bj) "
  },
