  "root_text": {
    "an6.107:0.1": "Aṅguttara Nikāya 6.107 ",
    "an6.107:0.2": "11. Tikavagga ",
    "an6.107:0.3": "Rāgasutta ",
    "an6.107:1.1": "“Tayome, bhikkhave, dhammā. ",
    "an6.107:1.2": "Katame tayo? ",
    "an6.107:1.3": "Rāgo, doso, moho. ",
    "an6.107:1.4": "Ime kho, bhikkhave, tayo dhammā. ",
    "an6.107:1.5": "Imesaṁ kho, bhikkhave, tiṇṇaṁ dhammānaṁ pahānāya tayo dhammā bhāvetabbā. ",
    "an6.107:1.6": "Katame tayo? ",
    "an6.107:1.7": "Rāgassa pahānāya asubhā bhāvetabbā, dosassa pahānāya mettā bhāvetabbā, mohassa pahānāya paññā bhāvetabbā. ",
    "an6.107:1.8": "Imesaṁ kho, bhikkhave, tiṇṇaṁ dhammānaṁ pahānāya ime tayo dhammā bhāvetabbā”ti. ",
    "an6.107:1.9": "Paṭhamaṁ. "
  },
  "translation_text": {
    "an6.107:0.1": "Numbered Discourses 6.107 ",
    "an6.107:0.2": "11. Triads ",
    "an6.107:0.3": "Greed ",
    "an6.107:1.1": "“Mendicants, there are these three things. ",
    "an6.107:1.2": "What three? ",
    "an6.107:1.3": "Greed, hate, and delusion. ",
    "an6.107:1.4": "These are the three things. ",
    "an6.107:1.5": "To give up these three things you should develop three things. ",
    "an6.107:1.6": "What three? ",
    "an6.107:1.7": "You should develop the perception of ugliness to give up greed, love to give up hate, and wisdom to give up delusion. ",
    "an6.107:1.8": "These are the three things you should develop to give up those three things.” "
  },
