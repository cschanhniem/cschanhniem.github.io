  "root_text": {
    "an4.145:0.1": "Aṅguttara Nikāya 4.145 ",
    "an4.145:0.2": "15. Ābhāvagga ",
    "an4.145:0.3": "Pajjotasutta ",
    "an4.145:1.1": "“Cattārome, bhikkhave, pajjotā. ",
    "an4.145:1.2": "Katame cattāro? ",
    "an4.145:1.3": "Candapajjoto, sūriyapajjoto, aggipajjoto, paññāpajjoto—",
    "an4.145:1.4": "Ime kho, bhikkhave, cattāro pajjotā. ",
    "an4.145:1.5": "Etadaggaṁ, bhikkhave, imesaṁ catunnaṁ pajjotānaṁ yadidaṁ paññāpajjoto”ti. ",
    "an4.145:1.6": "Pañcamaṁ. "
  },
  "translation_text": {
    "an4.145:0.1": "Numbered Discourses 4.145 ",
    "an4.145:0.2": "15. Brightness ",
    "an4.145:0.3": "Lamps ",
    "an4.145:1.1": "“Mendicants, there are these four lamps. ",
    "an4.145:1.2": "What four? ",
    "an4.145:1.3": "The lamps of the moon, sun, fire, and wisdom. ",
    "an4.145:1.4": "These are the four lamps. ",
    "an4.145:1.5": "The best of these four lamps is the lamp of wisdom.” "
  },
