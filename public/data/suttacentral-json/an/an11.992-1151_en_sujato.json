  "root_text": {
    "an11.992-1151:0.1": "Aṅguttara Nikāya 11 ",
    "an11.992-1151:0.2": "Paṭhamapaṇṇāsaka ",
    "an11.992-1151:0.3": "Rāgapeyyāla ",
    "an11.992-1151:0.4": "~ ",
    "an11.992-1151:1.1": "“Dosassa… pe… ",
    "an11.992-1151:1.2": "mohassa… ",
    "an11.992-1151:1.3": "kodhassa… ",
    "an11.992-1151:1.4": "upanāhassa… ",
    "an11.992-1151:1.5": "makkhassa… ",
    "an11.992-1151:1.6": "paḷāsassa… ",
    "an11.992-1151:1.7": "issāya… ",
    "an11.992-1151:1.8": "macchariyassa… ",
    "an11.992-1151:1.9": "māyāya… ",
    "an11.992-1151:1.10": "sāṭheyyassa… ",
    "an11.992-1151:1.11": "thambhassa… ",
    "an11.992-1151:1.12": "sārambhassa… ",
    "an11.992-1151:1.13": "mānassa… ",
    "an11.992-1151:1.14": "atimānassa… ",
    "an11.992-1151:1.15": "madassa… ",
    "an11.992-1151:1.16": "pamādassa abhiññāya…pe… ",
    "an11.992-1151:1.17": "pariññāya… ",
    "an11.992-1151:1.18": "parikkhayāya… ",
    "an11.992-1151:1.19": "pahānāya… ",
    "an11.992-1151:1.20": "khayāya… ",
    "an11.992-1151:1.21": "vayāya… ",
    "an11.992-1151:1.22": "virāgāya… ",
    "an11.992-1151:1.23": "nirodhāya… ",
    "an11.992-1151:1.24": "cāgāya… ",
    "an11.992-1151:1.25": "paṭinissaggāya ime ekādasa dhammā bhāvetabbā”ti. ",
    "an11.992-1151:2.1": "Idamavoca bhagavā. ",
    "an11.992-1151:2.2": "Attamanā te bhikkhū bhagavato bhāsitaṁ abhinandunti. ",
    "an11.992-1151:2.3": "Rāgapeyyālaṁ niṭṭhitaṁ. ",
    "an11.992-1151:3.1": "Nava suttasahassāni, ",
    "an11.992-1151:3.2": "bhiyyo pañcasatāni ca; ",
    "an11.992-1151:3.3": "Sattapaññāsa suttantā, ",
    "an11.992-1151:3.4": "aṅguttarasamāyutāti. ",
    "an11.992-1151:3.5": "Ekādasakanipātapāḷi niṭṭhitā. ",
    "an11.992-1151:3.6": "Aṅguttaranikāyo samatto. "
  },
  "translation_text": {
    "an11.992-1151:0.1": "Numbered Discourses 11.992–1151 ",
    "an11.992-1151:0.2": "The First Fifty ",
    "an11.992-1151:0.3": "Abbreviated Texts Beginning with Greed ",
    "an11.992-1151:0.4": "Untitled Discourses on Hate, Etc. ",
    "an11.992-1151:1.1": "“Of hate … ",
    "an11.992-1151:1.2": "delusion … ",
    "an11.992-1151:1.3": "anger … ",
    "an11.992-1151:1.4": "acrimony … ",
    "an11.992-1151:1.5": "disdain … ",
    "an11.992-1151:1.6": "contempt … ",
    "an11.992-1151:1.7": "jealousy … ",
    "an11.992-1151:1.8": "stinginess … ",
    "an11.992-1151:1.9": "deceitfulness … ",
    "an11.992-1151:1.10": "deviousness … ",
    "an11.992-1151:1.11": "obstinacy … ",
    "an11.992-1151:1.12": "aggression … ",
    "an11.992-1151:1.13": "conceit … ",
    "an11.992-1151:1.14": "arrogance … ",
    "an11.992-1151:1.15": "vanity … ",
    "an11.992-1151:1.16": "for insight into negligence … ",
    "an11.992-1151:1.17": "complete understanding … ",
    "an11.992-1151:1.18": "complete ending … ",
    "an11.992-1151:1.19": "giving up … ",
    "an11.992-1151:1.20": "ending … ",
    "an11.992-1151:1.21": "vanishing … ",
    "an11.992-1151:1.22": "fading away … ",
    "an11.992-1151:1.23": "cessation … ",
    "an11.992-1151:1.24": "giving away … ",
    "an11.992-1151:1.25": "For the letting go of negligence, these eleven things should be developed.” ",
    "an11.992-1151:2.1": "That is what the Buddha said. ",
    "an11.992-1151:2.2": "Satisfied, the mendicants approved what the Buddha said. ",
    "an11.992-1151:2.3": "",
    "an11.992-1151:3.1": "",
    "an11.992-1151:3.2": "",
    "an11.992-1151:3.3": "",
    "an11.992-1151:3.4": "",
    "an11.992-1151:3.5": "The Book of the Elevens is finished. ",
    "an11.992-1151:3.6": "The Numbered Discourses are completed. "
  },
