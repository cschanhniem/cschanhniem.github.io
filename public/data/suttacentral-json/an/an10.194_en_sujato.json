  "root_text": {
    "an10.194:0.1": "Aṅguttara Nikāya 10.194 ",
    "an10.194:0.2": "19. Ariyamaggavagga ",
    "an10.194:0.3": "Āsevitabbadhammasutta ",
    "an10.194:1.1": "“Āsevitabbañca vo, bhikkhave, dhammaṁ desessāmi nāsevitabbañca. ",
    "an10.194:1.2": "Taṁ suṇātha …pe… ",
    "an10.194:1.3": "katamo ca, bhikkhave, nāsevitabbo dhammo? ",
    "an10.194:1.4": "Pāṇātipāto …pe… ",
    "an10.194:1.5": "micchādiṭṭhi—",
    "an10.194:1.6": "ayaṁ vuccati, bhikkhave, nāsevitabbo dhammo. ",
    "an10.194:2.1": "Katamo ca, bhikkhave, āsevitabbo dhammo? ",
    "an10.194:2.2": "Pāṇātipātā veramaṇī …pe… ",
    "an10.194:2.3": "sammādiṭṭhi—",
    "an10.194:2.4": "ayaṁ vuccati, bhikkhave, āsevitabbo dhammo”ti. ",
    "an10.194:2.5": "Chaṭṭhaṁ. "
  },
  "translation_text": {
    "an10.194:0.1": "Numbered Discourses 10.194 ",
    "an10.194:0.2": "19. The Noble Path ",
    "an10.194:0.3": "Principles That Should Be Cultivated ",
    "an10.194:1.1": "“I will teach you the principle to cultivate and the principle not to cultivate. … ",
    "an10.194:1.2": "",
    "an10.194:1.3": "And what is the principle not to cultivate? ",
    "an10.194:1.4": "Killing living creatures … ",
    "an10.194:1.5": "wrong view. ",
    "an10.194:1.6": "This is called the principle not to cultivate. ",
    "an10.194:2.1": "And what is the principle to cultivate? ",
    "an10.194:2.2": "Not killing living creatures … ",
    "an10.194:2.3": "right view. ",
    "an10.194:2.4": "This is called the principle to cultivate.” "
  },
