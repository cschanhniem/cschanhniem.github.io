  "root_text": {
    "an5.204:0.1": "Aṅguttara Nikāya 5.204 ",
    "an5.204:0.2": "21. Kimilavagga ",
    "an5.204:0.3": "Balasutta ",
    "an5.204:1.1": "“Pañcimāni, bhikkhave, balāni. ",
    "an5.204:1.2": "Katamāni pañca? ",
    "an5.204:1.3": "Saddhābalaṁ, hiribalaṁ, ottappabalaṁ, vīriyabalaṁ, paññābalaṁ—",
    "an5.204:1.4": "imāni kho, bhikkhave, pañca balānī”ti. ",
    "an5.204:1.5": "Catutthaṁ. "
  },
  "translation_text": {
    "an5.204:0.1": "Numbered Discourses 5.204 ",
    "an5.204:0.2": "21. With Kimbila ",
    "an5.204:0.3": "Powers ",
    "an5.204:1.1": "“Mendicants, there are these five powers. ",
    "an5.204:1.2": "What five? ",
    "an5.204:1.3": "Faith, conscience, prudence, energy, and wisdom. ",
    "an5.204:1.4": "These are the five powers.” "
  },
