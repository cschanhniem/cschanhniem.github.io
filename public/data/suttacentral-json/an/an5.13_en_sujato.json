  "root_text": {
    "an5.13:0.1": "Aṅguttara Nikāya 5.13 ",
    "an5.13:0.2": "2. Balavagga ",
    "an5.13:0.3": "Saṅkhittasutta ",
    "an5.13:1.1": "“Pañcimāni, bhikkhave, balāni. ",
    "an5.13:1.2": "Katamāni pañca? ",
    "an5.13:1.3": "Saddhābalaṁ, vīriyabalaṁ, satibalaṁ, samādhibalaṁ, paññābalaṁ—",
    "an5.13:1.4": "imāni kho, bhikkhave, pañca balānī”ti. ",
    "an5.13:1.5": "Tatiyaṁ. "
  },
  "translation_text": {
    "an5.13:0.1": "Numbered Discourses 5.13 ",
    "an5.13:0.2": "2. Powers ",
    "an5.13:0.3": "In Brief ",
    "an5.13:1.1": "“Mendicants, there are these five powers. ",
    "an5.13:1.2": "What five? ",
    "an5.13:1.3": "The powers of faith, energy, mindfulness, immersion, and wisdom. ",
    "an5.13:1.4": "These are the five powers.” "
  },
  "variant_text": {
    "an5.13:0.3": "Saṅkhittasutta → balasaṅkhittasuttaṁ (bj) "
  },
