  "root_text": {
    "an4.250:0.1": "Aṅguttara Nikāya 4.250 ",
    "an4.250:0.2": "25. Āpattibhayavagga ",
    "an4.250:0.3": "Paṭhamavohārasutta ",
    "an4.250:1.1": "“Cattārome, bhikkhave, anariyavohārā. ",
    "an4.250:1.2": "Katame cattāro? ",
    "an4.250:1.3": "Adiṭṭhe diṭṭhavāditā, asute sutavāditā, amute mutavāditā, aviññāte viññātavāditā—",
    "an4.250:1.4": "Ime kho, bhikkhave, cattāro anariyavohārā”ti. ",
    "an4.250:1.5": "Aṭṭhamaṁ. "
  },
  "translation_text": {
    "an4.250:0.1": "Numbered Discourses 4.250 ",
    "an4.250:0.2": "25. Perils of Offenses ",
    "an4.250:0.3": "Expressions (1st) ",
    "an4.250:1.1": "“Mendicants, there are these four ignoble expressions. ",
    "an4.250:1.2": "What four? ",
    "an4.250:1.3": "Saying you’ve seen, heard, thought, or known something, but you haven’t. ",
    "an4.250:1.4": "These are the four ignoble expressions.” "
  },
  "variant_text": {
    "an4.250:0.3": "Paṭhamavohārasutta → anariyavohārasuttaṁ (bj) "
  },
