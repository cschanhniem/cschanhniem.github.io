  "root_text": {
    "an5.60:0.1": "Aṅguttara Nikāya 5.60 ",
    "an5.60:0.2": "6. Nīvaraṇavagga ",
    "an5.60:0.3": "Dutiyavuḍḍhapabbajitasutta ",
    "an5.60:1.1": "Pañcahi, bhikkhave, dhammehi samannāgato dullabho vuḍḍhapabbajito. ",
    "an5.60:1.2": "Katamehi pañcahi? ",
    "an5.60:1.3": "Dullabho, bhikkhave, vuḍḍhapabbajito suvaco, dullabho suggahitaggāhī, dullabho padakkhiṇaggāhī, dullabho dhammakathiko, dullabho vinayadharo. ",
    "an5.60:1.4": "Imehi kho, bhikkhave, pañcahi dhammehi samannāgato dullabho vuḍḍhapabbajito”ti. ",
    "an5.60:1.5": "Dasamaṁ. ",
    "an5.60:1.6": "Nīvaraṇavaggo paṭhamo. ",
    "an5.60:2.0": "Tassuddānaṁ ",
    "an5.60:2.1": "Āvaraṇaṁ rāsi aṅgāni, ",
    "an5.60:2.2": "samayaṁ mātuputtikā; ",
    "an5.60:2.3": "Upajjhā ṭhānā licchavi, ",
    "an5.60:2.4": "kumārā aparā duveti. "
  },
  "translation_text": {
    "an5.60:0.1": "Numbered Discourses 5.60 ",
    "an5.60:0.2": "6. Hindrances ",
    "an5.60:0.3": "Gone Forth When Old (2nd) ",
    "an5.60:1.1": "“Mendicants, it’s hard to find someone gone forth when old who has five qualities. ",
    "an5.60:1.2": "What five? ",
    "an5.60:1.3": "It’s hard to find someone gone forth when old who is easy to admonish, retains what they learn, and learns respectfully, who can teach the Dhamma, and has memorized the monastic law. ",
    "an5.60:1.4": "It’s hard to find someone gone forth when old who possesses these five qualities.” ",
