  "root_text": {
    "an6.8:0.1": "Aṅguttara Nikāya 6.8 ",
    "an6.8:0.2": "1. Āhuneyyavagga ",
    "an6.8:0.3": "Anuttariyasutta ",
    "an6.8:1.1": "“Chayimāni, bhikkhave, anuttariyāni. ",
    "an6.8:1.2": "Katamāni cha? ",
    "an6.8:1.3": "Dassanānuttariyaṁ, savanānuttariyaṁ, lābhānuttariyaṁ, sikkhānuttariyaṁ, pāricariyānuttariyaṁ, anussatānuttariyaṁ. ",
    "an6.8:1.4": "Imāni kho, bhikkhave, cha anuttariyānī”ti. ",
    "an6.8:1.5": "Aṭṭhamaṁ. "
  },
  "translation_text": {
    "an6.8:0.1": "Numbered Discourses 6.8 ",
    "an6.8:0.2": "1. Worthy of Offerings ",
    "an6.8:0.3": "Unsurpassable ",
    "an6.8:1.1": "“Mendicants, these six things are unsurpassable. ",
    "an6.8:1.2": "What six? ",
    "an6.8:1.3": "The unsurpassable seeing, listening, acquisition, training, service, and recollection. ",
    "an6.8:1.4": "These are the six unsurpassable things.” "
  },
