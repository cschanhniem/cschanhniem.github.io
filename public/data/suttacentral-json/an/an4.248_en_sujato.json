  "root_text": {
    "an4.248:0.1": "Aṅguttara Nikāya 4.248 ",
    "an4.248:0.2": "25. Āpattibhayavagga ",
    "an4.248:0.3": "Paññāvuddhisutta ",
    "an4.248:1.1": "“Cattārome, bhikkhave, dhammā paññāvuddhiyā saṁvattanti. ",
    "an4.248:1.2": "Katame cattāro? ",
    "an4.248:1.3": "Sappurisasaṁsevo, saddhammasavanaṁ, yonisomanasikāro, dhammānudhammappaṭipatti—",
    "an4.248:1.4": "Ime kho, bhikkhave, cattāro dhammā paññāvuddhiyā saṁvattantī”ti. ",
    "an4.248:1.5": "Chaṭṭhaṁ. "
  },
  "translation_text": {
    "an4.248:0.1": "Numbered Discourses 4.248 ",
    "an4.248:0.2": "25. Perils of Offenses ",
    "an4.248:0.3": "The Growth of Wisdom ",
    "an4.248:1.1": "“Mendicants, these four things lead to the growth of wisdom. ",
    "an4.248:1.2": "What four? ",
    "an4.248:1.3": "Associating with true persons, listening to the true teaching, rational application of mind, and practicing in line with the teaching. ",
    "an4.248:1.4": "These four things lead to the growth of wisdom.” "
  },
