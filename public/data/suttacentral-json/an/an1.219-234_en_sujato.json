  "root_text": {
    "an1.219:0.1": "Aṅguttara Nikāya 1 ",
    "an1.219:0.2": "17. Catutthavagga ",
    "an1.219:1.1": "“Etadaggaṁ, bhikkhave, mama sāvakānaṁ bhikkhūnaṁ bahussutānaṁ yadidaṁ ānando. ",
    "an1.220:1.1": "… Satimantānaṁ yadidaṁ ānando. ",
    "an1.221:1.1": "… Gatimantānaṁ yadidaṁ ānando. ",
    "an1.222:1.1": "… Dhitimantānaṁ yadidaṁ ānando. ",
    "an1.223:1.1": "… Upaṭṭhākānaṁ yadidaṁ ānando. ",
    "an1.224:1.1": "… Mahāparisānaṁ yadidaṁ uruvelakassapo. ",
    "an1.225:1.1": "… Kulappasādakānaṁ yadidaṁ kāḷudāyī. ",
    "an1.226:1.1": "… Appābādhānaṁ yadidaṁ bākulo. ",
    "an1.227:1.1": "… Pubbenivāsaṁ anussarantānaṁ yadidaṁ sobhito. ",
    "an1.228:1.1": "… Vinayadharānaṁ yadidaṁ upāli. ",
    "an1.229:1.1": "… Bhikkhunovādakānaṁ yadidaṁ nandako. ",
    "an1.230:1.1": "… Indriyesu guttadvārānaṁ yadidaṁ nando. ",
    "an1.231:1.1": "… Bhikkhuovādakānaṁ yadidaṁ mahākappino. ",
    "an1.232:1.1": "… Tejodhātukusalānaṁ yadidaṁ sāgato. ",
    "an1.233:1.1": "… Paṭibhāneyyakānaṁ yadidaṁ rādho. ",
    "an1.234:1.1": "… Lūkhacīvaradharānaṁ yadidaṁ mogharājā”ti. ",
    "an1.234:1.2": "Vaggo catuttho. "
  },
  "translation_text": {
    "an1.219:0.1": "Numbered Discourses 1 ",
    "an1.219:0.2": "Chapter Four ",
    "an1.219:1.1": "“The foremost of my monk disciples who are very learned is Ānanda. ",
    "an1.220:1.1": "… with a good memory is Ānanda. ",
    "an1.221:1.1": "… with an extensive range is Ānanda. ",
    "an1.222:1.1": "… in retention is Ānanda. ",
    "an1.223:1.1": "… as a personal attendant is Ānanda. ",
    "an1.224:1.1": "… with a large congregation is Kassapa of Uruvelā. ",
    "an1.225:1.1": "… who inspire lay families is Kāḷudāyī. ",
    "an1.226:1.1": "… with good health is Bakkula. ",
    "an1.227:1.1": "… who recollect past lives is Sobhita. ",
    "an1.228:1.1": "… who have memorized the monastic law is Upāli. ",
    "an1.229:1.1": "… who advise the nuns is Nandaka. ",
    "an1.230:1.1": "… who guard the sense doors is Nanda. ",
    "an1.231:1.1": "… who advise the monks is Mahākappina. ",
    "an1.232:1.1": "… who are skilled in the fire element is Sāgata. ",
    "an1.233:1.1": "… who inspire eloquent teachings is Rādha. ",
    "an1.234:1.1": "… who wear coarse robes is Mogharāja.” "
  },
  "variant_text": {
    "an1.226:1.1": "bākulo → bakkulo (bj, sya-all, km, pts1ed) "
  },
