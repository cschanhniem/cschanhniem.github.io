  "root_text": {
    "an5.219:0.1": "Aṅguttara Nikāya 5.219 ",
    "an5.219:0.2": "22. Akkosakavagga ",
    "an5.219:0.3": "Aggisutta ",
    "an5.219:1.1": "“Pañcime, bhikkhave, ādīnavā aggismiṁ. ",
    "an5.219:1.2": "Katame pañca? ",
    "an5.219:1.3": "Acakkhusso, dubbaṇṇakaraṇo, dubbalakaraṇo, saṅgaṇikāpavaḍḍhano, tiracchānakathāpavattaniko hoti. ",
    "an5.219:1.4": "Ime kho, bhikkhave, pañca ādīnavā aggismin”ti. ",
    "an5.219:1.5": "Navamaṁ. "
  },
  "translation_text": {
    "an5.219:0.1": "Numbered Discourses 5.219 ",
    "an5.219:0.2": "22. Abuse ",
    "an5.219:0.3": "Fire ",
    "an5.219:1.1": "“Mendicants, there are these five drawbacks of a fire. ",
    "an5.219:1.2": "What five? ",
    "an5.219:1.3": "It’s bad for your eyes. It’s bad for your complexion. It makes you weak. It draws in groups. And it encourages low talk. ",
    "an5.219:1.4": "These are the five drawbacks of a fire.” "
  },
  "variant_text": {
    "an5.219:1.3": "saṅgaṇikāpavaḍḍhano → saṅgaṇikāpavaddhano (bj); saṅgaṇikārāmabandhano (mr) "
  },
