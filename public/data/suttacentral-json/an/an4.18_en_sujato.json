  "root_text": {
    "an4.18:0.1": "Aṅguttara Nikāya 4.18 ",
    "an4.18:0.2": "2. Caravagga ",
    "an4.18:0.3": "Dutiyaagatisutta ",
    "an4.18:1.1": "“Cattārimāni, bhikkhave, nāgatigamanāni. ",
    "an4.18:1.2": "Katamāni cattāri? ",
    "an4.18:1.3": "Na chandāgatiṁ gacchati, na dosāgatiṁ gacchati, na mohāgatiṁ gacchati, na bhayāgatiṁ gacchati—",
    "an4.18:1.4": "Imāni kho, bhikkhave, cattāri nāgatigamanānīti. ",
    "an4.18:2.1": "Chandā dosā bhayā mohā, ",
    "an4.18:2.2": "yo dhammaṁ nātivattati; ",
    "an4.18:2.3": "Āpūrati tassa yaso, ",
    "an4.18:2.4": "sukkapakkheva candimā”ti. ",
    "an4.18:2.5": "Aṭṭhamaṁ. "
  },
  "translation_text": {
    "an4.18:0.1": "Numbered Discourses 4.18 ",
    "an4.18:0.2": "2. Walking ",
    "an4.18:0.3": "Prejudice (2nd) ",
    "an4.18:1.1": "“Mendicants, there are these four ways of making unprejudiced decisions. ",
    "an4.18:1.2": "What four? ",
    "an4.18:1.3": "Making decisions unprejudiced by favoritism, hostility, stupidity, and cowardice. ",
    "an4.18:1.4": "These are the four ways of making unprejudiced decisions. ",
    "an4.18:2.1": "If you don’t act against the teaching ",
    "an4.18:2.2": "out of favoritism, hostility, cowardice, and stupidity, ",
    "an4.18:2.3": "your fame swells, ",
    "an4.18:2.4": "like the moon in the waxing fortnight.” "
  },
  "variant_text": {
    "an4.18:0.3": "Dutiyaagatisutta → nāgatisuttaṁ (bj) "
  },
