  "root_text": {
    "an10.146:0.1": "Aṅguttara Nikāya 10.146 ",
    "an10.146:0.2": "15. Ariyavagga ",
    "an10.146:0.3": "Kaṇhamaggasutta ",
    "an10.146:1.1": "“Kaṇhamaggañca vo, bhikkhave, dhammaṁ desessāmi sukkamaggañca. ",
    "an10.146:1.2": "Taṁ suṇātha …pe… ",
    "an10.146:1.3": "katamo ca, bhikkhave, kaṇhamaggo? ",
    "an10.146:1.4": "Micchādiṭṭhi …pe… micchāvimutti—",
    "an10.146:1.5": "ayaṁ vuccati, bhikkhave, kaṇhamaggo. ",
    "an10.146:1.6": "Katamo ca, bhikkhave, sukkamaggo? ",
    "an10.146:1.7": "Sammādiṭṭhi …pe… sammāvimutti—",
    "an10.146:1.8": "ayaṁ vuccati, bhikkhave, sukkamaggo”ti. ",
    "an10.146:1.9": "Dutiyaṁ. "
  },
  "translation_text": {
    "an10.146:0.1": "Numbered Discourses 10.146 ",
    "an10.146:0.2": "15. The Noble Path ",
    "an10.146:0.3": "The Dark Path ",
    "an10.146:1.1": "“I will teach you the dark path and the bright path. … ",
    "an10.146:1.2": "",
    "an10.146:1.3": "And what is the dark path? ",
    "an10.146:1.4": "Wrong view, wrong thought, wrong speech, wrong action, wrong livelihood, wrong effort, wrong mindfulness, wrong immersion, wrong knowledge, and wrong freedom. ",
    "an10.146:1.5": "This is called the dark path. ",
    "an10.146:1.6": "And what is the bright path? ",
    "an10.146:1.7": "Right view, right thought, right speech, right action, right livelihood, right effort, right mindfulness, right immersion, right knowledge, and right freedom. ",
    "an10.146:1.8": "This is called the bright path.” "
  },
  "variant_text": {
    "an10.146:0.3": "Kaṇhamaggasutta → sukkamaggasuttaṁ (bj) "
  },
