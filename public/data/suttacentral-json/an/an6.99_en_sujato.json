  "root_text": {
    "an6.99:0.1": "Aṅguttara Nikāya 6.99 ",
    "an6.99:0.2": "10. Ānisaṁsavagga ",
    "an6.99:0.3": "Dukkhasutta ",
    "an6.99:1.1": "“So vata, bhikkhave, bhikkhu kañci saṅkhāraṁ sukhato samanupassanto …pe… ",
    "an6.99:1.2": "sabbasaṅkhāre dukkhato samanupassanto …pe… ",
    "an6.99:1.3": "ṭhānametaṁ vijjati”. ",
    "an6.99:1.4": "Catutthaṁ. "
  },
  "translation_text": {
    "an6.99:0.1": "Numbered Discourses 6.99 ",
    "an6.99:0.2": "10. Benefit ",
    "an6.99:0.3": "Suffering ",
    "an6.99:1.1": "“Mendicants, it is quite impossible for a mendicant who regards any condition as pleasurable to accept views that agree with the teaching. … ",
    "an6.99:1.2": "It’s quite possible for a mendicant who regards all conditions as suffering to accept views that agree with the teaching. …” ",
    "an6.99:1.3": ""
  },
