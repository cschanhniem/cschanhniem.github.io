  "root_text": {
    "an4.119:0.1": "Aṅguttara Nikāya 4.119 ",
    "an4.119:0.2": "12. Kesivagga ",
    "an4.119:0.3": "Paṭhamabhayasutta ",
    "an4.119:1.1": "“Cattārimāni, bhikkhave, bhayāni. ",
    "an4.119:1.2": "Katamāni cattāri? ",
    "an4.119:1.3": "Jātibhayaṁ, jarābhayaṁ, byādhibhayaṁ, maraṇabhayaṁ—",
    "an4.119:1.4": "Imāni kho, bhikkhave, cattāri bhayānī”ti. ",
    "an4.119:1.5": "Navamaṁ. "
  },
  "translation_text": {
    "an4.119:0.1": "Numbered Discourses 4.119 ",
    "an4.119:0.2": "12. With Kesi ",
    "an4.119:0.3": "Perils (1st) ",
    "an4.119:1.1": "“Mendicants, there are these four perils. ",
    "an4.119:1.2": "What four? ",
    "an4.119:1.3": "The perils of rebirth, old age, sickness, and death. ",
    "an4.119:1.4": "These are the four perils.” "
  },
