  "root_text": {
    "an10.179:0.1": "Aṅguttara Nikāya 10.179 ",
    "an10.179:0.2": "18. Sādhuvagga ",
    "an10.179:0.3": "Ariyadhammasutta ",
    "an10.179:1.1": "“Ariyadhammañca vo, bhikkhave, desessāmi anariyadhammañca. ",
    "an10.179:1.2": "Taṁ suṇātha …pe… ",
    "an10.179:1.3": "katamo ca, bhikkhave, anariyo dhammo? ",
    "an10.179:1.4": "Pāṇātipāto …pe… ",
    "an10.179:1.5": "micchādiṭṭhi—",
    "an10.179:1.6": "ayaṁ vuccati, bhikkhave, anariyo dhammo. ",
    "an10.179:2.1": "Katamo ca, bhikkhave, ariyo dhammo? ",
    "an10.179:2.2": "Pāṇātipātā veramaṇī …pe… ",
    "an10.179:2.3": "sammādiṭṭhi—",
    "an10.179:2.4": "ayaṁ vuccati, bhikkhave, ariyo dhammo”ti. ",
    "an10.179:2.5": "Dutiyaṁ. "
  },
  "translation_text": {
    "an10.179:0.1": "Numbered Discourses 10.179 ",
    "an10.179:0.2": "18. Good ",
    "an10.179:0.3": "The Teaching of the Noble Ones ",
    "an10.179:1.1": "“Mendicants, I will teach you the teaching of the noble ones, and what is not the teaching of the noble ones. ",
    "an10.179:1.2": "Listen and apply your mind well, I will speak. … ",
    "an10.179:1.3": "And what is not the teaching of the noble ones? ",
    "an10.179:1.4": "Killing living creatures … ",
    "an10.179:1.5": "wrong view. ",
    "an10.179:1.6": "This is called what is not the teaching of the noble ones. ",
    "an10.179:2.1": "And what is the teaching of the noble ones? ",
    "an10.179:2.2": "Not killing living creatures … ",
    "an10.179:2.3": "right view. ",
    "an10.179:2.4": "This is called the teaching of the noble ones.” "
  },
