  "root_text": {
    "an9.70:0.1": "Aṅguttara Nikāya 9.70 ",
    "an9.70:0.2": "7. Satipaṭṭhānavagga ",
    "an9.70:0.3": "Uddhambhāgiyasutta ",
    "an9.70:1.1": "“Pañcimāni, bhikkhave, uddhambhāgiyāni saṁyojanāni. ",
    "an9.70:1.2": "Katamāni pañca? ",
    "an9.70:1.3": "Rūparāgo, arūparāgo, māno, uddhaccaṁ, avijjā—",
    "an9.70:1.4": "imāni kho, bhikkhave, pañcuddhambhāgiyāni saṁyojanāni. ",
    "an9.70:2.1": "Imesaṁ kho, bhikkhave, pañcannaṁ uddhambhāgiyānaṁ saṁyojanānaṁ pahānāya …pe… ime cattāro satipaṭṭhānā bhāvetabbā”ti. ",
    "an9.70:2.2": "Aṭṭhamaṁ. "
  },
  "translation_text": {
    "an9.70:0.1": "Numbered Discourses 9.70 ",
    "an9.70:0.2": "7. Mindfulness Meditation ",
    "an9.70:0.3": "Higher Fetters ",
    "an9.70:1.1": "“Mendicants, there are five higher fetters. ",
    "an9.70:1.2": "What five? ",
    "an9.70:1.3": "Desire for rebirth in the realm of luminous form, desire for rebirth in the formless realm, conceit, restlessness, and ignorance. ",
    "an9.70:1.4": "These are the five higher fetters. ",
    "an9.70:2.1": "To give up these five higher fetters you should develop the four kinds of mindfulness meditation. …” "
  },
