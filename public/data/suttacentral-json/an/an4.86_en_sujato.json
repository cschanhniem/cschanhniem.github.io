  "root_text": {
    "an4.86:0.1": "Aṅguttara Nikāya 4.86 ",
    "an4.86:0.2": "9. Macalavagga ",
    "an4.86:0.3": "Oṇatoṇatasutta ",
    "an4.86:1.1": "“Cattārome, bhikkhave, puggalā santo saṁvijjamānā lokasmiṁ. ",
    "an4.86:1.2": "Katame cattāro? ",
    "an4.86:1.3": "Oṇatoṇato, ",
    "an4.86:1.4": "oṇatuṇṇato, ",
    "an4.86:1.5": "uṇṇatoṇato, ",
    "an4.86:1.6": "uṇṇatuṇṇato. ",
    "an4.86:1.7": "… Ime kho, bhikkhave, cattāro puggalā santo saṁvijjamānā lokasmin”ti. ",
    "an4.86:1.8": "Chaṭṭhaṁ. "
  },
  "translation_text": {
    "an4.86:0.1": "Numbered Discourses 4.86 ",
    "an4.86:0.2": "9. Confirmed ",
    "an4.86:0.3": "Sunk Low ",
    "an4.86:1.1": "“These four individuals are found in the world. ",
    "an4.86:1.2": "What four? ",
    "an4.86:1.3": "One sunk low who sinks lower, ",
    "an4.86:1.4": "one sunk low who rises high, ",
    "an4.86:1.5": "one risen high who sinks low, and ",
    "an4.86:1.6": "one risen high who rises higher. ",
    "an4.86:1.7": "… These are the four individuals found in the world.” "
  },
  "variant_text": {
    "an4.86:0.3": "Oṇatoṇatasutta → onatonatasuttaṁ (bj) ",
    "an4.86:1.3": "Oṇatoṇato → onatonato (bj) ",
    "an4.86:1.4": "oṇatuṇṇato → onatunnato (bj) ",
    "an4.86:1.5": "uṇṇatoṇato → unnatonato (bj) ",
    "an4.86:1.6": "uṇṇatuṇṇato → unnatunnato (bj) "
  },
