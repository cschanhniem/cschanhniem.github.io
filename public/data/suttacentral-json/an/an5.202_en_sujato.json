  "root_text": {
    "an5.202:0.1": "Aṅguttara Nikāya 5.202 ",
    "an5.202:0.2": "21. Kimilavagga ",
    "an5.202:0.3": "Dhammassavanasutta ",
    "an5.202:1.1": "“Pañcime, bhikkhave, ānisaṁsā dhammassavane. ",
    "an5.202:1.2": "Katame pañca? ",
    "an5.202:1.3": "Assutaṁ suṇāti, sutaṁ pariyodāpeti, kaṅkhaṁ vitarati, diṭṭhiṁ ujuṁ karoti, cittamassa pasīdati. ",
    "an5.202:1.4": "Ime kho, bhikkhave, pañca ānisaṁsā dhammassavane”ti. ",
    "an5.202:1.5": "Dutiyaṁ. "
  },
  "translation_text": {
    "an5.202:0.1": "Numbered Discourses 5.202 ",
    "an5.202:0.2": "21. With Kimbila ",
    "an5.202:0.3": "Listening to the Teaching ",
    "an5.202:1.1": "“Mendicants, there are these five benefits of listening to the teaching. ",
    "an5.202:1.2": "What five? ",
    "an5.202:1.3": "You learn new things, clarify what you’ve learned, get over uncertainty, correct your views, and inspire confidence in your mind. ",
    "an5.202:1.4": "These are the five benefits of listening to the teaching.” "
  },
  "variant_text": {
    "an5.202:0.3": "Dhammassavanasutta → dhammasavaṇasuttaṁ (bj) ",
    "an5.202:1.1": "dhammassavane → dhammasavaṇe (bj) ",
    "an5.202:1.3": "vitarati → vihanati (sya-all, km, pts1ed, mr) "
  },
