  "root_text": {
    "an9.66:0.1": "Aṅguttara Nikāya 9.66 ",
    "an9.66:0.2": "7. Satipaṭṭhānavagga ",
    "an9.66:0.3": "Upādānakkhandhasutta ",
    "an9.66:1.1": "“Pañcime, bhikkhave, upādānakkhandhā. ",
    "an9.66:1.2": "Katame pañca? ",
    "an9.66:1.3": "Rūpupādānakkhandho, vedanupādānakkhandho, saññupādānakkhandho, saṅkhārupādānakkhandho, viññāṇupādānakkhandho—",
    "an9.66:1.4": "ime kho, bhikkhave, pañcupādānakkhandhā. ",
    "an9.66:2.1": "Imesaṁ kho, bhikkhave, pañcannaṁ upādānakkhandhānaṁ pahānāya …pe… ime cattāro satipaṭṭhānā bhāvetabbā”ti. ",
    "an9.66:2.2": "Catutthaṁ. "
  },
  "translation_text": {
    "an9.66:0.1": "Numbered Discourses 9.66 ",
    "an9.66:0.2": "7. Mindfulness Meditation ",
    "an9.66:0.3": "Grasping Aggregates ",
    "an9.66:1.1": "“Mendicants, there are these five grasping aggregates. ",
    "an9.66:1.2": "What five? ",
    "an9.66:1.3": "The grasping aggregates of form, feeling, perception, choices, and consciousness. ",
    "an9.66:1.4": "These are the five grasping aggregates. ",
    "an9.66:2.1": "To give up these five grasping aggregates you should develop the four kinds of mindfulness meditation. …” "
  },
