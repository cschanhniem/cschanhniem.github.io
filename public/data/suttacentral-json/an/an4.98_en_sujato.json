  "root_text": {
    "an4.98:0.1": "Aṅguttara Nikāya 4.98 ",
    "an4.98:0.2": "10. Asuravagga ",
    "an4.98:0.3": "Attahitasutta ",
    "an4.98:1.1": "“Cattārome, bhikkhave, puggalā santo saṁvijjamānā lokasmiṁ. ",
    "an4.98:1.2": "Katame cattāro? ",
    "an4.98:1.3": "Attahitāya paṭipanno no parahitāya, ",
    "an4.98:1.4": "parahitāya paṭipanno no attahitāya, ",
    "an4.98:1.5": "nevattahitāya paṭipanno no parahitāya, ",
    "an4.98:1.6": "attahitāya ceva paṭipanno parahitāya ca. ",
    "an4.98:1.7": "Ime kho, bhikkhave, cattāro puggalā santo saṁvijjamānā lokasmin”ti. ",
    "an4.98:1.8": "Aṭṭhamaṁ. "
  },
  "translation_text": {
    "an4.98:0.1": "Numbered Discourses 4.98 ",
    "an4.98:0.2": "10. Titans ",
    "an4.98:0.3": "To Benefit Oneself ",
    "an4.98:1.1": "“Mendicants, these four individuals are found in the world. ",
    "an4.98:1.2": "What four? ",
    "an4.98:1.3": "One who practices to benefit themselves, but not others; ",
    "an4.98:1.4": "one who practices to benefit others, but not themselves; ",
    "an4.98:1.5": "one who practices to benefit neither themselves nor others; and ",
    "an4.98:1.6": "one who practices to benefit both themselves and others. ",
    "an4.98:1.7": "These are the four individuals found in the world.” "
  },
