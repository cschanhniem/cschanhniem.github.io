  "root_text": {
    "an10.133:0.1": "Aṅguttara Nikāya 10.133 ",
    "an10.133:0.2": "13. Parisuddhavagga ",
    "an10.133:0.3": "Ekādasamasutta ",
    "an10.133:1.1": "“Dasayime, bhikkhave, sammattā. ",
    "an10.133:1.2": "Katame dasa? ",
    "an10.133:1.3": "Sammādiṭṭhi, sammāsaṅkappo, sammāvācā, sammākammanto, sammāājīvo, sammāvāyāmo, sammāsati, sammāsamādhi, sammāñāṇaṁ, sammāvimutti—",
    "an10.133:1.4": "ime kho, bhikkhave, dasa sammattā”ti. ",
    "an10.133:1.5": "Ekādasamaṁ. ",
    "an10.133:1.6": "Parisuddhavaggo tatiyo. "
  },
  "translation_text": {
    "an10.133:0.1": "Numbered Discourses 10.133 ",
    "an10.133:0.2": "13. Purified ",
    "an10.133:0.3": "Eleventh ",
    "an10.133:1.1": "“Mendicants, there are ten right ways. ",
    "an10.133:1.2": "What ten? ",
    "an10.133:1.3": "Right view, right thought, right speech, right action, right livelihood, right effort, right mindfulness, right immersion, right knowledge, and right freedom. ",
    "an10.133:1.4": "These are the ten right ways.” ",
    "an10.133:1.5": ""
  },
