  "root_text": {
    "an4.151:0.1": "Aṅguttara Nikāya 4.151 ",
    "an4.151:0.2": "16. Indriyavagga ",
    "an4.151:0.3": "Indriyasutta ",
    "an4.151:1.1": "“Cattārimāni, bhikkhave, indriyāni. ",
    "an4.151:1.2": "Katamāni cattāri? ",
    "an4.151:1.3": "Saddhindriyaṁ, vīriyindriyaṁ, satindriyaṁ, samādhindriyaṁ—",
    "an4.151:1.4": "Imāni kho, bhikkhave, cattāri indriyānī”ti. ",
    "an4.151:1.5": "Paṭhamaṁ. "
  },
  "translation_text": {
    "an4.151:0.1": "Numbered Discourses 4.151 ",
    "an4.151:0.2": "16. Faculties ",
    "an4.151:0.3": "Faculties ",
    "an4.151:1.1": "“Mendicants, there are these four faculties. ",
    "an4.151:1.2": "What four? ",
    "an4.151:1.3": "The faculties of faith, energy, mindfulness, and immersion. ",
    "an4.151:1.4": "These are the four faculties.” "
  },
