  "root_text": {
    "an10.187:0.1": "Aṅguttara Nikāya 10.187 ",
    "an10.187:0.2": "18. Sādhuvagga ",
    "an10.187:0.3": "Dukkhudrayasutta ",
    "an10.187:1.1": "“Dukkhudrayañca vo, bhikkhave, dhammaṁ desessāmi sukhudrayañca. ",
    "an10.187:1.2": "Taṁ suṇātha …pe… ",
    "an10.187:1.3": "katamo ca, bhikkhave, dukkhudrayo dhammo? ",
    "an10.187:1.4": "Pāṇātipāto …pe… ",
    "an10.187:1.5": "micchādiṭṭhi—",
    "an10.187:1.6": "ayaṁ vuccati, bhikkhave, dukkhudrayo dhammo. ",
    "an10.187:2.1": "Katamo ca, bhikkhave, sukhudrayo dhammo? ",
    "an10.187:2.2": "Pāṇātipātā veramaṇī …pe… ",
    "an10.187:2.3": "sammādiṭṭhi—",
    "an10.187:2.4": "ayaṁ vuccati, bhikkhave, sukhudrayo dhammo”ti. ",
    "an10.187:2.5": "Dasamaṁ. "
  },
  "translation_text": {
    "an10.187:0.1": "Numbered Discourses 10.187 ",
    "an10.187:0.2": "18. Good ",
    "an10.187:0.3": "With Suffering as Outcome ",
    "an10.187:1.1": "“I will teach you the principle that has suffering as outcome, and that which has happiness as outcome. … ",
    "an10.187:1.2": "",
    "an10.187:1.3": "And what is the principle whose outcome is suffering? ",
    "an10.187:1.4": "Killing living creatures … ",
    "an10.187:1.5": "wrong view. ",
    "an10.187:1.6": "This is the principle whose outcome is suffering. ",
    "an10.187:2.1": "And what is the principle whose outcome is happiness? ",
    "an10.187:2.2": "Not killing living creatures … ",
    "an10.187:2.3": "right view. ",
    "an10.187:2.4": "This is the principle whose outcome is happiness.” "
  },
