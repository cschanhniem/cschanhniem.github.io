  "root_text": {
    "an1.378:0.1": "Aṅguttara Nikāya 1 ",
    "an1.378:0.2": "28. Pasādakaradhammavagga ",
    "an1.378:1.1": "“Addhamidaṁ, bhikkhave, lābhānaṁ yadidaṁ āraññikattaṁ …pe… ",
    "an1.379:1.1": "piṇḍapātikattaṁ … ",
    "an1.380:1.1": "paṁsukūlikattaṁ … ",
    "an1.381:1.1": "tecīvarikattaṁ … ",
    "an1.382:1.1": "dhammakathikattaṁ … ",
    "an1.383:1.1": "vinayadharattaṁ … ",
    "an1.384:1.1": "bāhusaccaṁ … ",
    "an1.385:1.1": "thāvareyyaṁ … ",
    "an1.386:1.1": "ākappasampadā … ",
    "an1.387:1.1": "parivārasampadā … ",
    "an1.388:1.1": "mahāparivāratā … ",
    "an1.389:1.1": "kolaputti … ",
    "an1.390:1.1": "vaṇṇapokkharatā … ",
    "an1.391:1.1": "kalyāṇavākkaraṇatā … ",
    "an1.392:1.1": "appicchatā … ",
    "an1.393:1.1": "appābādhatā”ti. ",
    "an1.393:1.2": "(Soḷasa pasādakaradhammā niṭṭhitā.) "
  },
  "translation_text": {
    "an1.378:0.1": "Numbered Discourses 1 ",
    "an1.378:0.2": "The Chapter on Inspiring Qualities ",
    "an1.378:1.1": "“Mendicants, this is definitely something worth having, that is, living in the wilderness … ",
    "an1.379:1.1": "eating only almsfood … ",
    "an1.380:1.1": "wearing rag robes … ",
    "an1.381:1.1": "having just three robes … ",
    "an1.382:1.1": "teaching Dhamma … ",
    "an1.383:1.1": "memorizing the monastic law … ",
    "an1.384:1.1": "being very learned … ",
    "an1.385:1.1": "being respected … ",
    "an1.386:1.1": "being well-presented … ",
    "an1.387:1.1": "having a following … ",
    "an1.388:1.1": "having a large following … ",
    "an1.389:1.1": "coming from a good family … ",
    "an1.390:1.1": "being handsome … ",
    "an1.391:1.1": "being one who enunciates well … ",
    "an1.392:1.1": "having few wishes … ",
    "an1.393:1.1": "being healthy.” "
  },
  "variant_text": {
    "an1.378:1.1": "āraññikattaṁ → araññakattaṁ (sabbattha) ",
    "an1.383:1.1": "vinayadharattaṁ → vinayadharakattaṁ (sya-all, km, pts1ed, mr) "
