  "root_text": {
    "an3.138:0.1": "Aṅguttara Nikāya 3.138 ",
    "an3.138:0.2": "14. Yodhājīvavagga ",
    "an3.138:0.3": "Sampadāsutta ",
    "an3.138:1.1": "“Tisso imā, bhikkhave, sampadā. ",
    "an3.138:1.2": "Katamā tisso? ",
    "an3.138:1.3": "Saddhāsampadā, sīlasampadā, paññāsampadā—",
    "an3.138:1.4": "imā kho, bhikkhave, tisso sampadā”ti. ",
    "an3.138:1.5": "Chaṭṭhaṁ. "
  },
  "translation_text": {
    "an3.138:0.1": "Numbered Discourses 3.138 ",
    "an3.138:0.2": "14. A Warrior ",
    "an3.138:0.3": "Accomplishment ",
    "an3.138:1.1": "“Mendicants, there are three accomplishments. ",
    "an3.138:1.2": "What three? ",
    "an3.138:1.3": "Accomplishment in faith, ethics, and wisdom. ",
    "an3.138:1.4": "These are the three accomplishments.” "
  },
