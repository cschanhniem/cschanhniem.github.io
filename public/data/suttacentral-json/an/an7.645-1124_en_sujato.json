    "an7.645-1124:1.13": "conceit … ",
    "an7.645-1124:1.14": "arrogance … ",
    "an7.645-1124:1.15": "vanity … ",
    "an7.645-1124:1.16": "for insight into negligence … ",
    "an7.645-1124:1.17": "complete understanding … ",
    "an7.645-1124:1.18": "complete ending … ",
    "an7.645-1124:1.19": "giving up … ",
    "an7.645-1124:1.20": "ending … ",
    "an7.645-1124:1.21": "vanishing … ",
    "an7.645-1124:1.22": "fading away … ",
