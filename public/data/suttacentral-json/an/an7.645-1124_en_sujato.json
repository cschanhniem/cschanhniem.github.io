  "translation_text": {
    "an7.645-1124:0.1": "Numbered Discourses 7 ",
    "an7.645-1124:0.2": "11. Abbreviated Texts Beginning With Greed ",
    "an7.645-1124:0.3": "Untitled Discourses on Hate, Etc. ",
    "an7.645-1124:1.1": "“Of hate … ",
    "an7.645-1124:1.2": "delusion … ",
    "an7.645-1124:1.3": "anger … ",
    "an7.645-1124:1.4": "acrimony … ",
