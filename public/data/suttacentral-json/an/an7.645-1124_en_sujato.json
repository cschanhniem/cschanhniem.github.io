    "an7.645-1124:0.1": "Aṅguttara Nikāya 7 ",
    "an7.645-1124:0.2": "11. Rāgapeyyāla ",
    "an7.645-1124:0.3": "~ ",
    "an7.645-1124:1.1": "“Dosassa …pe… ",
