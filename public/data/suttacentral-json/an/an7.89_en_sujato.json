  "root_text": {
    "an7.89:0.1": "Aṅguttara Nikāya 7.89 ",
    "an7.89:0.2": "9. Samaṇavagga ",
    "an7.89:0.3": "Nhātakasutta ",
    "an7.89:1.1": "“… Nhātattā nhātako hoti …pe…. ",
    "an7.89:1.2": "Pañcamaṁ. "
  },
  "translation_text": {
    "an7.89:0.1": "Numbered Discourses 7.89 ",
    "an7.89:0.2": "9. An Ascetic ",
    "an7.89:0.3": "Bathed ",
    "an7.89:1.1": "“Mendicants, it’s because of bathing off seven things that you become a bathed initiate …” "
  },
  "variant_text": {
    "an7.89:0.3": "Nhātakasutta → nahātakadhammasuttaṁ (bj) ",
    "an7.89:1.1": "Nhātattā nhātako → nahātatto nahātako (bj, cck); ninahātattā nahātako (pts1ed) "
  },
