  "root_text": {
    "an4.149:0.1": "Aṅguttara Nikāya 4.149 ",
    "an4.149:0.2": "15. Ābhāvagga ",
    "an4.149:0.3": "Sucaritasutta ",
    "an4.149:1.1": "“Cattārimāni, bhikkhave, vacīsucaritāni. ",
    "an4.149:1.2": "Katamāni cattāri? ",
    "an4.149:1.3": "Saccavācā, apisuṇā vācā, saṇhā vācā, mantabhāsā—",
    "an4.149:1.4": "Imāni kho, bhikkhave, cattāri vacīsucaritānī”ti. ",
    "an4.149:1.5": "Navamaṁ. "
  },
  "translation_text": {
    "an4.149:0.1": "Numbered Discourses 4.149 ",
    "an4.149:0.2": "15. Brightness ",
    "an4.149:0.3": "Good Conduct ",
    "an4.149:1.1": "“Mendicants, there are these four kinds of good conduct by way of speech. ",
    "an4.149:1.2": "What four? ",
    "an4.149:1.3": "Speech that’s true, harmonious, gentle, and thoughtful. ",
    "an4.149:1.4": "These are the four kinds of good conduct by way of speech.” "
  },
  "variant_text": {
    "an4.149:0.3": "Sucaritasutta → vacīsucaritasuttaṁ (bj) "
  },
