  "root_text": {
    "an4.155:0.1": "Aṅguttara Nikāya 4.155 ",
    "an4.155:0.2": "16. Indriyavagga ",
    "an4.155:0.3": "Paṭisaṅkhānabalasutta ",
    "an4.155:1.1": "“Cattārimāni, bhikkhave, balāni. ",
    "an4.155:1.2": "Katamāni cattāri? ",
    "an4.155:1.3": "Paṭisaṅkhānabalaṁ, bhāvanābalaṁ, anavajjabalaṁ, saṅgahabalaṁ—",
    "an4.155:1.4": "Imāni kho, bhikkhave, cattāri balānī”ti. ",
    "an4.155:1.5": "Pañcamaṁ. "
  },
  "translation_text": {
    "an4.155:0.1": "Numbered Discourses 4.155 ",
    "an4.155:0.2": "16. Faculties ",
    "an4.155:0.3": "The Power of Reflection ",
    "an4.155:1.1": "“Mendicants, there are these four powers. ",
    "an4.155:1.2": "What four? ",
    "an4.155:1.3": "The powers of reflection, development, blamelessness, and inclusiveness. ",
    "an4.155:1.4": "These are the four powers.” "
  },
  "variant_text": {
    "an4.155:0.3": "Paṭisaṅkhānabalasutta → catutthabalasuttaṁ (bj) "
  },
