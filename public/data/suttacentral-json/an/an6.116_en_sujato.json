  "root_text": {
    "an6.116:0.1": "Aṅguttara Nikāya 6.116 ",
    "an6.116:0.2": "11. Tikavagga ",
    "an6.116:0.3": "Uddhaccasutta ",
    "an6.116:1.1": "“Tayome, bhikkhave, dhammā. ",
    "an6.116:1.2": "Katame tayo? ",
    "an6.116:1.3": "Uddhaccaṁ, asaṁvaro, pamādo. ",
    "an6.116:1.4": "Ime kho, bhikkhave, tayo dhammā. ",
    "an6.116:1.5": "Imesaṁ kho, bhikkhave, tiṇṇaṁ dhammānaṁ pahānāya tayo dhammā bhāvetabbā. ",
    "an6.116:1.6": "Katame tayo? ",
    "an6.116:1.7": "Uddhaccassa pahānāya samatho bhāvetabbo, asaṁvarassa pahānāya saṁvaro bhāvetabbo, pamādassa pahānāya appamādo bhāvetabbo. ",
    "an6.116:1.8": "Imesaṁ kho, bhikkhave, tiṇṇaṁ dhammānaṁ pahānāya ime tayo dhammā bhāvetabbā”ti. ",
    "an6.116:1.9": "Dasamaṁ. ",
    "an6.116:1.10": "Tikavaggo ekādasamo. ",
    "an6.116:2.0": "Tassuddānaṁ ",
    "an6.116:2.1": "Rāgaduccaritavitakka, ",
    "an6.116:2.2": "Saññā dhātūti vuccati; ",
    "an6.116:2.3": "Assādaaratituṭṭhi, ",
    "an6.116:2.4": "Duve ca uddhaccena vaggoti. "
  },
  "translation_text": {
    "an6.116:0.1": "Numbered Discourses 6.116 ",
    "an6.116:0.2": "11. Triads ",
    "an6.116:0.3": "Restlessness ",
    "an6.116:1.1": "“Mendicants, there are these three things. ",
    "an6.116:1.2": "What three? ",
    "an6.116:1.3": "Restlessness, lack of restraint, and negligence. ",
    "an6.116:1.4": "These are the three things. ",
    "an6.116:1.5": "To give up these three things you should develop three things. ",
    "an6.116:1.6": "What three? ",
    "an6.116:1.7": "You should develop serenity to give up restlessness, restraint to give up lack of restraint, and diligence to give up negligence. ",
    "an6.116:1.8": "These are the three things you should develop to give up those three things.” ",
