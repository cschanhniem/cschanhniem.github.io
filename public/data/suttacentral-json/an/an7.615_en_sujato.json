  "root_text": {
    "an7.615:0.1": "Aṅguttara Nikāya 7 ",
    "an7.615:0.2": "11. Rāgapeyyāla ",
    "an7.615:0.3": "~ ",
    "an7.615:1.1": "“Rāgassa, bhikkhave, abhiññāya satta dhammā bhāvetabbā. ",
    "an7.615:1.2": "Katame satta? ",
    "an7.615:1.3": "Satisambojjhaṅgo …pe… ",
    "an7.615:1.4": "upekkhāsambojjhaṅgo—",
    "an7.615:1.5": "rāgassa, bhikkhave, abhiññāya ime satta dhammā bhāvetabbā”ti. "
  },
  "translation_text": {
    "an7.615:0.1": "Numbered Discourses 7 ",
    "an7.615:0.2": "11. Abbreviated Texts Beginning With Greed ",
    "an7.615:0.3": "Untitled Discourse on Greed (1st) ",
    "an7.615:1.1": "“Mendicants, for insight into greed, seven things should be developed. ",
    "an7.615:1.2": "What seven? ",
    "an7.615:1.3": "The awakening factor of mindfulness … ",
    "an7.615:1.4": "the awakening factor of equanimity. ",
    "an7.615:1.5": "These seven things should be developed for insight into greed.” "
  },
  "variant_text": {
    "an7.615:0.2": "Rāgapeyyāla → rāgādipeyyālasuttāni (bj) "
  },
