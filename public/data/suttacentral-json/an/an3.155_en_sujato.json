  "root_text": {
    "an3.155:0.1": "Aṅguttara Nikāya 3.155 ",
    "an3.155:0.2": "15. Maṅgalavagga ",
    "an3.155:0.3": "Pubbaṇhasutta ",
    "an3.155:1.1": "“Ye, bhikkhave, sattā pubbaṇhasamayaṁ kāyena sucaritaṁ caranti, vācāya sucaritaṁ caranti, manasā sucaritaṁ caranti, supubbaṇho, bhikkhave, tesaṁ sattānaṁ. ",
    "an3.155:2.1": "Ye, bhikkhave, sattā majjhanhikasamayaṁ kāyena sucaritaṁ caranti, vācāya sucaritaṁ caranti, manasā sucaritaṁ caranti, sumajjhanhiko, bhikkhave, tesaṁ sattānaṁ. ",
    "an3.155:3.1": "Ye, bhikkhave, sattā sāyanhasamayaṁ kāyena sucaritaṁ caranti, vācāya sucaritaṁ caranti, manasā sucaritaṁ caranti, susāyanho, bhikkhave, tesaṁ sattānanti. ",
    "an3.155:4.1": "Sunakkhattaṁ sumaṅgalaṁ, ",
    "an3.155:4.2": "suppabhātaṁ suhuṭṭhitaṁ; ",
    "an3.155:4.3": "Sukhaṇo sumuhutto ca, ",
    "an3.155:4.4": "suyiṭṭhaṁ brahmacārisu. ",
    "an3.155:5.1": "Padakkhiṇaṁ kāyakammaṁ, ",
    "an3.155:5.2": "vācākammaṁ padakkhiṇaṁ; ",
    "an3.155:5.3": "Padakkhiṇaṁ manokammaṁ, ",
    "an3.155:5.4": "paṇīdhi te padakkhiṇe; ",
    "an3.155:5.5": "Padakkhiṇāni katvāna, ",
    "an3.155:5.6": "labhantatthe padakkhiṇe. ",
    "an3.155:6.1": "Te atthaladdhā sukhitā, ",
    "an3.155:6.2": "viruḷhā buddhasāsane; ",
    "an3.155:6.3": "Arogā sukhitā hotha, ",
    "an3.155:6.4": "saha sabbehi ñātibhī”ti. ",
    "an3.155:6.5": "Dasamaṁ. ",
    "an3.155:6.6": "Maṅgalavaggo pañcamo. ",
    "an3.155:7.0": "Tassuddānaṁ ",
    "an3.155:7.1": "Akusalañca sāvajjaṁ, ",
    "an3.155:7.2": "visamāsucinā saha; ",
    "an3.155:7.3": "Caturo khatā vandanā, ",
    "an3.155:7.4": "pubbaṇhena ca te dasāti. ",
    "an3.155:7.5": "Tatiyo paṇṇāsako samatto. "
  },
  "translation_text": {
    "an3.155:0.1": "Numbered Discourses 3.155 ",
    "an3.155:0.2": "15. Good Fortune ",
    "an3.155:0.3": "Morning ",
    "an3.155:1.1": "“Mendicants, those sentient beings who do good things in the morning by way of body, speech, and mind have a good morning. ",
    "an3.155:2.1": "Those sentient beings who do good things at midday by way of body, speech, and mind have a good midday. ",
    "an3.155:3.1": "Those sentient beings who do good things in the evening by way of body, speech, and mind have a good evening. ",
    "an3.155:4.1": "A good star, a good fortune, ",
    "an3.155:4.2": "a good dawn, a good rising, ",
    "an3.155:4.3": "a good moment, a good hour: ",
    "an3.155:4.4": "these come with good gifts to spiritual practitioners. ",
    "an3.155:5.1": "Auspicious deeds of body, ",
    "an3.155:5.2": "verbal auspicious deeds, ",
    "an3.155:5.3": "auspicious deeds of mind, ",
    "an3.155:5.4": "auspicious resolutions: ",
    "an3.155:5.5": "when your deeds have been auspicious, ",
    "an3.155:5.6": "you get auspicious benefits. ",
    "an3.155:6.1": "Those happy with these benefits ",
    "an3.155:6.2": "flourish in the Buddha’s teaching. ",
    "an3.155:6.3": "May you and all your relatives ",
    "an3.155:6.4": "be healthy and happy!” ",
    "an3.155:6.5": "",
    "an3.155:6.6": "",
    "an3.155:7.1": "",
    "an3.155:7.2": "",
    "an3.155:7.3": "",
    "an3.155:7.4": ""
  },
