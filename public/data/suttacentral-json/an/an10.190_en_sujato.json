  "root_text": {
    "an10.190:0.1": "Aṅguttara Nikāya 10.190 ",
    "an10.190:0.2": "19. Ariyamaggavagga ",
    "an10.190:0.3": "Kaṇhamaggasutta ",
    "an10.190:1.1": "“Kaṇhamaggañca vo, bhikkhave, desessāmi sukkamaggañca. ",
    "an10.190:1.2": "Taṁ suṇātha …pe… ",
    "an10.190:1.3": "katamo ca, bhikkhave, kaṇho maggo? ",
    "an10.190:1.4": "Pāṇātipāto …pe… ",
    "an10.190:1.5": "micchādiṭṭhi—",
    "an10.190:1.6": "ayaṁ vuccati, bhikkhave, kaṇho maggo. ",
    "an10.190:2.1": "Katamo ca, bhikkhave, sukko maggo? ",
    "an10.190:2.2": "Pāṇātipātā veramaṇī …pe… ",
    "an10.190:2.3": "sammādiṭṭhi—",
    "an10.190:2.4": "ayaṁ vuccati, bhikkhave, sukko maggo”ti. ",
    "an10.190:2.5": "Dutiyaṁ. "
  },
  "translation_text": {
    "an10.190:0.1": "Numbered Discourses 10.190 ",
    "an10.190:0.2": "19. The Noble Path ",
    "an10.190:0.3": "The Dark Path ",
    "an10.190:1.1": "“I will teach you the dark path and the bright path. … ",
    "an10.190:1.2": "",
    "an10.190:1.3": "And what is the dark path? ",
    "an10.190:1.4": "Killing living creatures … ",
    "an10.190:1.5": "wrong view. ",
    "an10.190:1.6": "This is called the dark path. ",
    "an10.190:2.1": "And what is the bright path? ",
    "an10.190:2.2": "Not killing living creatures … ",
    "an10.190:2.3": "right view. ",
    "an10.190:2.4": "This is called the bright path.” "
  },
