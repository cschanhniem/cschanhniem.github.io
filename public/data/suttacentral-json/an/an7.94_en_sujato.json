  "root_text": {
    "an7.94:0.1": "Aṅguttara Nikāya 7.94 ",
    "an7.94:0.2": "9. Samaṇavagga ",
    "an7.94:0.3": "Saddhammasutta ",
    "an7.94:1.1": "“Sattime, bhikkhave, saddhammā. ",
    "an7.94:1.2": "Katame satta? ",
    "an7.94:1.3": "Saddho hoti, hirīmā hoti, ottappī hoti, bahussuto hoti, āraddhavīriyo hoti, satimā hoti, paññavā hoti. ",
    "an7.94:1.4": "Ime kho, bhikkhave, satta saddhammā”ti. ",
    "an7.94:1.5": "Dasamaṁ. ",
    "an7.94:1.6": "Samaṇavaggo navamo. ",
    "an7.94:2.0": "Tassuddānaṁ ",
    "an7.94:2.1": "Bhikkhuṁ samaṇo brāhmaṇo, ",
    "an7.94:2.2": "sottiyo ceva nhātako; ",
    "an7.94:2.3": "Vedagū ariyo arahā, ",
    "an7.94:2.4": "asaddhammā ca saddhammāti. "
  },
  "translation_text": {
    "an7.94:0.1": "Numbered Discourses 7.94 ",
    "an7.94:0.2": "9. An Ascetic ",
    "an7.94:0.3": "Good Qualities ",
    "an7.94:1.1": "“Mendicants, there are these seven good qualities. ",
    "an7.94:1.2": "What seven? ",
    "an7.94:1.3": "Someone is faithful, conscientious, prudent, learned, energetic, mindful, and wise. ",
    "an7.94:1.4": "These are the seven good qualities.” ",
