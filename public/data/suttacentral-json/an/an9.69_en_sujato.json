  "root_text": {
    "an9.69:0.1": "Aṅguttara Nikāya 9.69 ",
    "an9.69:0.2": "7. Satipaṭṭhānavagga ",
    "an9.69:0.3": "Macchariyasutta ",
    "an9.69:1.1": "“Pañcimāni, bhikkhave, macchariyāni. ",
    "an9.69:1.2": "Katamāni pañca? ",
    "an9.69:1.3": "Āvāsamacchariyaṁ, kulamacchariyaṁ, lābhamacchariyaṁ, vaṇṇamacchariyaṁ, dhammamacchariyaṁ—",
    "an9.69:1.4": "imāni kho, bhikkhave, pañca macchariyāni. ",
    "an9.69:2.1": "Imesaṁ kho, bhikkhave, pañcannaṁ macchariyānaṁ pahānāya …pe… ime cattāro satipaṭṭhānā bhāvetabbā”ti. ",
    "an9.69:2.2": "Sattamaṁ. "
  },
  "translation_text": {
    "an9.69:0.1": "Numbered Discourses 9.69 ",
    "an9.69:0.2": "7. Mindfulness Meditation ",
    "an9.69:0.3": "Stinginess ",
    "an9.69:1.1": "“Mendicants, there are these five kinds of stinginess. ",
    "an9.69:1.2": "What five? ",
    "an9.69:1.3": "Stinginess with dwellings, families, material things, praise, and the teaching. ",
    "an9.69:1.4": "These are the five kinds of stinginess. ",
    "an9.69:2.1": "To give up these five kinds of stinginess you should develop the four kinds of mindfulness meditation. …” "
  },
