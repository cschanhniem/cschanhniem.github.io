  "root_text": {
    "an4.141:0.1": "Aṅguttara Nikāya 4.141 ",
    "an4.141:0.2": "15. Ābhāvagga ",
    "an4.141:0.3": "Ābhāsutta ",
    "an4.141:1.1": "“Catasso imā, bhikkhave, ābhā. ",
    "an4.141:1.2": "Katamā catasso? ",
    "an4.141:1.3": "Candābhā, sūriyābhā, aggābhā, paññābhā—",
    "an4.141:1.4": "imā kho, bhikkhave, catasso ābhā. ",
    "an4.141:1.5": "Etadaggaṁ, bhikkhave, imāsaṁ catunnaṁ ābhānaṁ yadidaṁ paññābhā”ti. ",
    "an4.141:1.6": "Paṭhamaṁ. "
  },
  "translation_text": {
    "an4.141:0.1": "Numbered Discourses 4.141 ",
    "an4.141:0.2": "15. Brightness ",
    "an4.141:0.3": "Brightness ",
    "an4.141:1.1": "“Mendicants, there are these four kinds of brightness. ",
    "an4.141:1.2": "What four? ",
    "an4.141:1.3": "The brightness of the moon, sun, fire, and wisdom. ",
    "an4.141:1.4": "These are the four kinds of brightness. ",
    "an4.141:1.5": "The best of these four kinds of brightness is the brightness of wisdom.” "
  },
  "variant_text": {
    "an4.141:1.5": "catunnaṁ → catassannaṁ (sya-all, km) "
  },
