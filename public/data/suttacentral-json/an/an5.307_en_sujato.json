  "root_text": {
    "an5.307:0.1": "Aṅguttara Nikāya 5 ",
    "an5.307:0.2": "29. Rāgapeyyāla ",
    "an5.307:0.3": "~ ",
    "an5.307:1.1": "“Rāgassa, bhikkhave, abhiññāya pañca dhammā bhāvetabbā. ",
    "an5.307:1.2": "Katame pañca? ",
    "an5.307:1.3": "Saddhābalaṁ, vīriyabalaṁ, satibalaṁ, samādhibalaṁ, paññābalaṁ—",
    "an5.307:1.4": "rāgassa, bhikkhave, abhiññāya ime pañca dhammā bhāvetabbā”ti. "
  },
  "translation_text": {
    "an5.307:0.1": "Numbered Discourses 5 ",
    "an5.307:0.2": "29. Abbreviated Texts Beginning With Greed ",
    "an5.307:0.3": "Untitled Discourse on Greed (5th) ",
    "an5.307:1.1": "“For insight into greed, five things should be developed. ",
    "an5.307:1.2": "What five? ",
    "an5.307:1.3": "The powers of faith, energy, mindfulness, immersion, and wisdom. ",
    "an5.307:1.4": "For insight into greed, these five things should be developed.” "
  },
