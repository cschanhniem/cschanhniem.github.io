  "root_text": {
    "an5.245:0.1": "Aṅguttara Nikāya 5.245 ",
    "an5.245:0.2": "25. Duccaritavagga ",
    "an5.245:0.3": "Dutiyaduccaritasutta ",
    "an5.245:1.1": "“Pañcime, bhikkhave, ādīnavā duccarite. ",
    "an5.245:1.2": "Katame pañca? ",
    "an5.245:1.3": "Attāpi attānaṁ upavadati; ",
    "an5.245:1.4": "anuvicca viññū garahanti; ",
    "an5.245:1.5": "pāpako kittisaddo abbhuggacchati; ",
    "an5.245:1.6": "saddhammā vuṭṭhāti; ",
    "an5.245:1.7": "asaddhamme patiṭṭhāti. ",
    "an5.245:1.8": "Ime kho, bhikkhave, pañca ādīnavā duccarite. ",
    "an5.245:2.1": "Pañcime, bhikkhave, ānisaṁsā sucarite. ",
    "an5.245:2.2": "Katame pañca? ",
    "an5.245:2.3": "Attāpi attānaṁ na upavadati; ",
    "an5.245:2.4": "anuvicca viññū pasaṁsanti; ",
    "an5.245:2.5": "kalyāṇo kittisaddo abbhuggacchati; ",
    "an5.245:2.6": "asaddhammā vuṭṭhāti; ",
    "an5.245:2.7": "saddhamme patiṭṭhāti. ",
    "an5.245:2.8": "Ime kho, bhikkhave, pañca ānisaṁsā sucarite”ti. ",
    "an5.245:2.9": "Pañcamaṁ. "
  },
  "translation_text": {
    "an5.245:0.1": "Numbered Discourses 5.245 ",
    "an5.245:0.2": "25. Bad Conduct ",
    "an5.245:0.3": "Bad Conduct (2nd) ",
    "an5.245:1.1": "“Mendicants, there are these five drawbacks of bad conduct. ",
    "an5.245:1.2": "What five? ",
    "an5.245:1.3": "You blame yourself. ",
    "an5.245:1.4": "After examination, sensible people criticize you. ",
    "an5.245:1.5": "You get a bad reputation. ",
    "an5.245:1.6": "You drift away from true teachings. ",
    "an5.245:1.7": "You settle on untrue teachings. ",
    "an5.245:1.8": "These are the five drawbacks of bad conduct. ",
    "an5.245:2.1": "There are these five benefits of good conduct. ",
    "an5.245:2.2": "What five? ",
    "an5.245:2.3": "You don’t blame yourself. ",
    "an5.245:2.4": "After examination, sensible people praise you. ",
    "an5.245:2.5": "You get a good reputation. ",
    "an5.245:2.6": "You drift away from untrue teachings. ",
    "an5.245:2.7": "You settle on true teachings. ",
    "an5.245:2.8": "These are the five benefits of good conduct.” "
  },
