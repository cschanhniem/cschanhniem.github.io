  "root_text": {
    "an8.27:0.1": "Aṅguttara Nikāya 8.27 ",
    "an8.27:0.2": "3. Gahapativagga ",
    "an8.27:0.3": "Paṭhamabalasutta ",
    "an8.27:1.1": "“Aṭṭhimāni, bhikkhave, balāni. ",
    "an8.27:1.2": "Katamāni aṭṭha? ",
    "an8.27:1.3": "Ruṇṇabalā, bhikkhave, dārakā, kodhabalā mātugāmā, āvudhabalā corā, issariyabalā rājāno, ujjhattibalā bālā, nijjhattibalā paṇḍitā, paṭisaṅkhānabalā bahussutā, khantibalā samaṇabrāhmaṇā—",
    "an8.27:1.4": "imāni kho, bhikkhave, aṭṭha balānī”ti. ",
    "an8.27:1.5": "Sattamaṁ. "
  },
  "translation_text": {
    "an8.27:0.1": "Numbered Discourses 8.27 ",
    "an8.27:0.2": "3. Householders ",
    "an8.27:0.3": "Powers (1st) ",
    "an8.27:1.1": "“Mendicants, there are these eight powers. ",
    "an8.27:1.2": "What eight? ",
    "an8.27:1.3": "Crying is the power of babies. Anger is the power of ladies. Weapons are the power of bandits. Authority is the power of rulers. Complaining is the power of fools. Reason is the power of the astute. Reflection is the power of the learned. Patience is the power of ascetics and brahmins. ",
    "an8.27:1.4": "These are the eight powers.” "
  },
