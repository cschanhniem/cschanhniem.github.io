  "root_text": {
    "an10.189:0.1": "Aṅguttara Nikāya 10.189 ",
    "an10.189:0.2": "19. Ariyamaggavagga ",
    "an10.189:0.3": "Ariyamaggasutta ",
    "an10.189:1.1": "“Ariyamaggañca vo, bhikkhave, desessāmi anariyamaggañca. ",
    "an10.189:1.2": "Taṁ suṇātha …pe… ",
    "an10.189:1.3": "katamo ca, bhikkhave, anariyo maggo? ",
    "an10.189:1.4": "Pāṇātipāto …pe… ",
    "an10.189:1.5": "micchādiṭṭhi—",
    "an10.189:1.6": "ayaṁ vuccati, bhikkhave, anariyo maggo. ",
    "an10.189:2.1": "Katamo ca, bhikkhave, ariyo maggo? ",
    "an10.189:2.2": "Pāṇātipātā veramaṇī …pe… ",
    "an10.189:2.3": "sammādiṭṭhi—",
    "an10.189:2.4": "ayaṁ vuccati, bhikkhave, ariyo maggo”ti. ",
    "an10.189:2.5": "Paṭhamaṁ. "
  },
  "translation_text": {
    "an10.189:0.1": "Numbered Discourses 10.189 ",
    "an10.189:0.2": "19. The Noble Path ",
    "an10.189:0.3": "The Noble Path ",
    "an10.189:1.1": "“I will teach you the noble path and the ignoble path. … ",
    "an10.189:1.2": "",
    "an10.189:1.3": "And what is the ignoble path? ",
    "an10.189:1.4": "Killing living creatures … ",
    "an10.189:1.5": "wrong view. ",
    "an10.189:1.6": "This is called the ignoble path. ",
    "an10.189:2.1": "And what is the noble path? ",
    "an10.189:2.2": "Not killing living creatures … ",
    "an10.189:2.3": "right view. ",
    "an10.189:2.4": "This is called the noble path.” "
  },
  "variant_text": {
    "an10.189:0.2": "Ariyamaggavagga → seṭṭhavaggo (sya-all) "
  },
