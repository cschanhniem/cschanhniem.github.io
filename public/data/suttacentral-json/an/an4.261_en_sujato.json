  "root_text": {
    "an4.261:0.1": "Aṅguttara Nikāya 4.261 ",
    "an4.261:0.2": "26. Abhiññāvagga ",
    "an4.261:0.3": "Balasutta ",
    "an4.261:1.1": "“Cattārimāni, bhikkhave, balāni. ",
    "an4.261:1.2": "Katamāni cattāri? ",
    "an4.261:1.3": "Vīriyabalaṁ, satibalaṁ, samādhibalaṁ, paññābalaṁ—",
    "an4.261:1.4": "Imāni kho, bhikkhave, cattāri balānī”ti. ",
    "an4.261:1.5": "Aṭṭhamaṁ. "
  },
  "translation_text": {
    "an4.261:0.1": "Numbered Discourses 4.261 ",
    "an4.261:0.2": "26. Insight ",
    "an4.261:0.3": "Powers ",
    "an4.261:1.1": "“Mendicants, there are these four powers. ",
    "an4.261:1.2": "What four? ",
    "an4.261:1.3": "The powers of energy, mindfulness, immersion, and wisdom. ",
    "an4.261:1.4": "These are the four powers.” "
  },
