  "root_text": {
    "an5.93:0.1": "Aṅguttara Nikāya 5.93 ",
    "an5.93:0.2": "10. Kakudhavagga ",
    "an5.93:0.3": "Byākaraṇasutta ",
    "an5.93:1.1": "“Pañcimāni, bhikkhave, aññābyākaraṇāni. ",
    "an5.93:1.2": "Katamāni pañca? ",
    "an5.93:1.3": "Mandattā momūhattā aññaṁ byākaroti; ",
    "an5.93:1.4": "pāpiccho icchāpakato aññaṁ byākaroti; ",
    "an5.93:1.5": "ummādā cittakkhepā aññaṁ byākaroti; ",
    "an5.93:1.6": "adhimānena aññaṁ byākaroti; ",
    "an5.93:1.7": "sammadeva aññaṁ byākaroti. ",
    "an5.93:1.8": "Imāni kho, bhikkhave, pañca aññābyākaraṇānī”ti. ",
    "an5.93:1.9": "Tatiyaṁ. "
  },
  "translation_text": {
    "an5.93:0.1": "Numbered Discourses 5.93 ",
    "an5.93:0.2": "10. With Kakudha ",
    "an5.93:0.3": "Declarations ",
    "an5.93:1.1": "“Mendicants, there are five ways of declaring enlightenment. ",
    "an5.93:1.2": "What five? ",
    "an5.93:1.3": "One declares enlightenment out of stupidity and folly. ",
    "an5.93:1.4": "Or because of corrupt wishes, being of wishful temperament. ",
    "an5.93:1.5": "Or because of madness and mental disorder. ",
    "an5.93:1.6": "Or out of overestimation. ",
    "an5.93:1.7": "Or one declares enlightenment rightly. ",
    "an5.93:1.8": "These are the five ways of declaring enlightenment.” "
  },
  "variant_text": {
    "an5.93:0.3": "Byākaraṇasutta → aññābyākaraṇasuttaṁ (bj) "
  },
