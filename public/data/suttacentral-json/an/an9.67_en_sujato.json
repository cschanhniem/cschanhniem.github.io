  "root_text": {
    "an9.67:0.1": "Aṅguttara Nikāya 9.67 ",
    "an9.67:0.2": "7. Satipaṭṭhānavagga ",
    "an9.67:0.3": "Orambhāgiyasutta ",
    "an9.67:1.1": "“Pañcimāni, bhikkhave, orambhāgiyāni saṁyojanāni. ",
    "an9.67:1.2": "Katamāni pañca? ",
    "an9.67:1.3": "Sakkāyadiṭṭhi, vicikicchā, sīlabbataparāmāso, kāmacchando, byāpādo—",
    "an9.67:1.4": "imāni kho, bhikkhave, pañcorambhāgiyāni saṁyojanāni. ",
    "an9.67:2.1": "Imesaṁ kho, bhikkhave, pañcannaṁ orambhāgiyānaṁ saṁyojanānaṁ pahānāya …pe… ime cattāro satipaṭṭhānā bhāvetabbā”ti. ",
    "an9.67:2.2": "Pañcamaṁ. "
  },
  "translation_text": {
    "an9.67:0.1": "Numbered Discourses 9.67 ",
    "an9.67:0.2": "7. Mindfulness Meditation ",
    "an9.67:0.3": "Lower Fetters ",
    "an9.67:1.1": "“Mendicants, there are five lower fetters. ",
    "an9.67:1.2": "What five? ",
    "an9.67:1.3": "Substantialist view, doubt, misapprehension of precepts and observances, sensual desire, and ill will. ",
    "an9.67:1.4": "These are the five lower fetters. ",
    "an9.67:2.1": "To give up these five lower fetters you should develop the four kinds of mindfulness meditation. …” "
  },
