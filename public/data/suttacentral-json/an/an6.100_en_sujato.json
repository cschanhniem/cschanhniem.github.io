  "root_text": {
    "an6.100:0.1": "Aṅguttara Nikāya 6.100 ",
    "an6.100:0.2": "10. Ānisaṁsavagga ",
    "an6.100:0.3": "Anattasutta ",
    "an6.100:1.1": "“So vata, bhikkhave, bhikkhu kañci dhammaṁ attato samanupassanto …pe… ",
    "an6.100:1.2": "sabbadhamme anattato samanupassanto …pe… ",
    "an6.100:1.3": "ṭhānametaṁ vijjati”. ",
    "an6.100:1.4": "Pañcamaṁ. "
  },
  "translation_text": {
    "an6.100:0.1": "Numbered Discourses 6.100 ",
    "an6.100:0.2": "10. Benefit ",
    "an6.100:0.3": "Not-Self ",
    "an6.100:1.1": "“Mendicants, it is quite impossible for a mendicant who regards any condition as self to accept views that agree with the teaching. … ",
    "an6.100:1.2": "It’s quite possible for a mendicant who regards all things as not-self to accept views that agree with the teaching. …” ",
    "an6.100:1.3": ""
  },
  "variant_text": {
    "an6.100:1.2": "sabbadhamme → sabbadhammaṁ (bj, pts1ed); kiñcidhammaṁ (mr) "
  },
