  "root_text": {
    "an5.15:0.1": "Aṅguttara Nikāya 5.15 ",
    "an5.15:0.2": "2. Balavagga ",
    "an5.15:0.3": "Daṭṭhabbasutta ",
    "an5.15:1.1": "“Pañcimāni, bhikkhave, balāni. ",
    "an5.15:1.2": "Katamāni pañca? ",
    "an5.15:1.3": "Saddhābalaṁ, vīriyabalaṁ, satibalaṁ, samādhibalaṁ, paññābalaṁ. ",
    "an5.15:1.4": "Kattha ca, bhikkhave, saddhābalaṁ daṭṭhabbaṁ? ",
    "an5.15:1.5": "Catūsu sotāpattiyaṅgesu. ",
    "an5.15:1.6": "Ettha saddhābalaṁ daṭṭhabbaṁ. ",
    "an5.15:1.7": "Kattha ca, bhikkhave, vīriyabalaṁ daṭṭhabbaṁ? ",
    "an5.15:1.8": "Catūsu sammappadhānesu. ",
    "an5.15:1.9": "Ettha vīriyabalaṁ daṭṭhabbaṁ. ",
    "an5.15:1.10": "Kattha ca, bhikkhave, satibalaṁ daṭṭhabbaṁ? ",
    "an5.15:1.11": "Catūsu satipaṭṭhānesu. ",
    "an5.15:1.12": "Ettha satibalaṁ daṭṭhabbaṁ. ",
    "an5.15:1.13": "Kattha ca, bhikkhave, samādhibalaṁ daṭṭhabbaṁ? ",
    "an5.15:1.14": "Catūsu jhānesu. ",
    "an5.15:1.15": "Ettha samādhibalaṁ daṭṭhabbaṁ. ",
    "an5.15:1.16": "Kattha ca, bhikkhave, paññābalaṁ daṭṭhabbaṁ? ",
    "an5.15:1.17": "Catūsu ariyasaccesu. ",
    "an5.15:1.18": "Ettha paññābalaṁ daṭṭhabbaṁ. ",
    "an5.15:1.19": "Imāni kho, bhikkhave, pañca balānī”ti. ",
    "an5.15:1.20": "Pañcamaṁ. "
  },
  "translation_text": {
    "an5.15:0.1": "Numbered Discourses 5.15 ",
    "an5.15:0.2": "2. Powers ",
    "an5.15:0.3": "Should Be Seen ",
    "an5.15:1.1": "“Mendicants, there are these five powers. ",
    "an5.15:1.2": "What five? ",
    "an5.15:1.3": "The powers of faith, energy, mindfulness, immersion, and wisdom. ",
    "an5.15:1.4": "And where should the power of faith be seen? ",
    "an5.15:1.5": "In the four factors of stream-entry. ",
    "an5.15:1.6": "",
    "an5.15:1.7": "And where should the power of energy be seen? ",
    "an5.15:1.8": "In the four right efforts. ",
    "an5.15:1.9": "",
    "an5.15:1.10": "And where should the power of mindfulness be seen? ",
    "an5.15:1.11": "In the four kinds of mindfulness meditation. ",
    "an5.15:1.12": "",
    "an5.15:1.13": "And where should the power of immersion be seen? ",
    "an5.15:1.14": "In the four absorptions. ",
    "an5.15:1.15": "",
    "an5.15:1.16": "And where should the power of wisdom be seen? ",
    "an5.15:1.17": "In the four noble truths. ",
    "an5.15:1.18": "",
    "an5.15:1.19": "These are the five powers.” "
  },
  "variant_text": {
    "an5.15:0.3": "Daṭṭhabbasutta → baladaṭṭhabbasuttaṁ (bj) "
  },
