  "root_text": {
    "an3.135:0.1": "Aṅguttara Nikāya 3.135 ",
    "an3.135:0.2": "14. Yodhājīvavagga ",
    "an3.135:0.3": "Mittasutta ",
    "an3.135:1.1": "“Tīhi, bhikkhave, aṅgehi samannāgato mitto sevitabbo. ",
    "an3.135:1.2": "Katamehi tīhi? (…) ",
    "an3.135:1.3": "Duddadaṁ dadāti, dukkaraṁ karoti, dukkhamaṁ khamati—",
    "an3.135:1.4": "imehi kho, bhikkhave, tīhi aṅgehi samannāgato mitto sevitabbo”ti. ",
    "an3.135:1.5": "Tatiyaṁ. "
  },
  "translation_text": {
    "an3.135:0.1": "Numbered Discourses 3.135 ",
    "an3.135:0.2": "14. A Warrior ",
    "an3.135:0.3": "A Friend ",
    "an3.135:1.1": "“Mendicants, you should associate with a friend who has three factors. ",
    "an3.135:1.2": "What three? ",
    "an3.135:1.3": "They give what is hard to give, they do what is hard to do, and they bear what is hard to bear. ",
    "an3.135:1.4": "You should associate with a friend who has these three factors.” "
  },
  "variant_text": {
    "an3.135:1.2": "(…) → (idha bhikkhave bhikkhu) (pts1ed, mr) "
  },
