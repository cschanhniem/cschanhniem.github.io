  "root_text": {
    "an4.267:0.1": "Aṅguttara Nikāya 4.267 ",
    "an4.267:0.2": "27. Kammapathavagga ",
    "an4.267:0.3": "Musāvādīsutta ",
    "an4.267:1.1": "…pe… Attanā ca musāvādī hoti, parañca musāvāde samādapeti, musāvāde ca samanuñño hoti, musāvādassa ca vaṇṇaṁ bhāsati—imehi kho …pe…. ",
    "an4.267:2.1": "Attanā ca musāvādā paṭivirato hoti, parañca musāvādā veramaṇiyā samādapeti, musāvādā veramaṇiyā ca samanuñño hoti, musāvādā veramaṇiyā ca vaṇṇaṁ bhāsati—imehi …pe…. ",
    "an4.267:2.2": "Catutthaṁ. "
  },
  "translation_text": {
    "an4.267:0.1": "Numbered Discourses 4.267 ",
    "an4.267:0.2": "27. Ways of Performing Deeds ",
    "an4.267:0.3": "Lying ",
    "an4.267:1.1": "“… They themselves lie … ",
    "an4.267:2.1": "… They themselves don’t lie …” "
  },
