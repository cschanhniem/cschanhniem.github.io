  "root_text": {
    "an3.139:0.1": "Aṅguttara Nikāya 3.139 ",
    "an3.139:0.2": "14. Yodhājīvavagga ",
    "an3.139:0.3": "Vuddhisutta ",
    "an3.139:1.1": "“Tisso imā, bhikkhave, vuddhiyo. ",
    "an3.139:1.2": "Katamā tisso? ",
    "an3.139:1.3": "Saddhāvuddhi, sīlavuddhi, paññāvuddhi—",
    "an3.139:1.4": "imā kho, bhikkhave, tisso vuddhiyo”ti. ",
    "an3.139:1.5": "Sattamaṁ. "
  },
  "translation_text": {
    "an3.139:0.1": "Numbered Discourses 3.139 ",
    "an3.139:0.2": "14. A Warrior ",
    "an3.139:0.3": "Growth ",
    "an3.139:1.1": "“Mendicants, there are three kinds of growth. ",
    "an3.139:1.2": "What three? ",
    "an3.139:1.3": "Growth in faith, ethics, and wisdom. ",
    "an3.139:1.4": "These are the three kinds of growth.” "
  },
