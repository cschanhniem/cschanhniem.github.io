  "root_text": {
    "an11.983-991:0.1": "Aṅguttara Nikāya 11 ",
    "an11.983-991:0.2": "Paṭhamapaṇṇāsaka ",
    "an11.983-991:0.3": "Rāgapeyyāla ",
    "an11.983-991:0.4": "~ ",
    "an11.983-991:1.1": "“Rāgassa, bhikkhave, pariññāya… ",
    "an11.983-991:1.2": "parikkhayāya… ",
    "an11.983-991:1.3": "pahānāya… ",
    "an11.983-991:1.4": "khayāya… ",
    "an11.983-991:1.5": "vayāya… ",
    "an11.983-991:1.6": "virāgāya… ",
    "an11.983-991:1.7": "nirodhāya… ",
    "an11.983-991:1.8": "cāgāya… ",
    "an11.983-991:1.9": "paṭinissaggāya… ",
    "an11.983-991:1.10": "ime ekādasa dhammā bhāvetabbā”. "
  },
  "translation_text": {
    "an11.983-991:0.1": "Numbered Discourses 11.983–991 ",
    "an11.983-991:0.2": "The First Fifty ",
    "an11.983-991:0.3": "Abbreviated Texts Beginning with Greed ",
    "an11.983-991:0.4": "Untitled Discourses on Greed ",
    "an11.983-991:1.1": "“For the complete understanding of greed … ",
    "an11.983-991:1.2": "complete ending … ",
    "an11.983-991:1.3": "giving up … ",
    "an11.983-991:1.4": "ending … ",
    "an11.983-991:1.5": "vanishing … ",
    "an11.983-991:1.6": "fading away … ",
    "an11.983-991:1.7": "cessation … ",
    "an11.983-991:1.8": "giving away … ",
    "an11.983-991:1.9": "letting go … ",
    "an11.983-991:1.10": "these eleven things should be developed.” "
  },
