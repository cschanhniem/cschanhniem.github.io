  "root_text": {
    "an10.79:0.1": "Aṅguttara Nikāya 10.79 ",
    "an10.79:0.2": "8. Ākaṅkhavagga ",
    "an10.79:0.3": "Āghātavatthusutta ",
    "an10.79:1.1": "“Dasayimāni, bhikkhave, āghātavatthūni. ",
    "an10.79:1.2": "Katamāni dasa? ",
    "an10.79:1.3": "‘Anatthaṁ me acarī’ti āghātaṁ bandhati; ",
    "an10.79:1.4": "‘anatthaṁ me caratī’ti āghātaṁ bandhati; ",
    "an10.79:1.5": "‘anatthaṁ me carissatī’ti āghātaṁ bandhati; ",
    "an10.79:1.6": "‘piyassa me manāpassa anatthaṁ acarī’ti …pe… ",
    "an10.79:1.7": "‘anatthaṁ caratī’ti …pe… ",
    "an10.79:1.8": "‘anatthaṁ carissatī’ti āghātaṁ bandhati, ",
    "an10.79:1.9": "‘appiyassa me amanāpassa atthaṁ acarī’ti …pe… ",
    "an10.79:1.10": "‘atthaṁ caratī’ti …pe… ",
    "an10.79:1.11": "‘atthaṁ carissatī’ti āghātaṁ bandhati; ",
    "an10.79:1.12": "aṭṭhāne ca kuppati—",
    "an10.79:1.13": "imāni kho, bhikkhave, dasa āghātavatthūnī”ti. ",
    "an10.79:1.14": "Navamaṁ. "
  },
  "translation_text": {
    "an10.79:0.1": "Numbered Discourses 10.79 ",
    "an10.79:0.2": "8. If You Want ",
    "an10.79:0.3": "Grounds for Resentment ",
    "an10.79:1.1": "“Mendicants, there are ten grounds for resentment. ",
    "an10.79:1.2": "What ten? ",
    "an10.79:1.3": "Thinking: ‘They did wrong to me,’ you harbor resentment. ",
    "an10.79:1.4": "Thinking: ‘They are doing wrong to me’ … ",
    "an10.79:1.5": "‘They will do wrong to me’ … ",
    "an10.79:1.6": "‘They did wrong by someone I love’ … ",
    "an10.79:1.7": "‘They are doing wrong by someone I love’ … ",
    "an10.79:1.8": "‘They will do wrong by someone I love’ … ",
    "an10.79:1.9": "‘They helped someone I dislike’ … ",
    "an10.79:1.10": "‘They are helping someone I dislike’ … ",
    "an10.79:1.11": "Thinking: ‘They will help someone I dislike,’ you harbor resentment. ",
    "an10.79:1.12": "You get angry for no reason. ",
    "an10.79:1.13": "These are the ten grounds for resentment.” "
  },
