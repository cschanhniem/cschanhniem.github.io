  "root_text": {
    "an4.276:0.1": "Aṅguttara Nikāya 4.276 ",
    "an4.276:0.2": "28. Rāgapeyyāla ",
    "an4.276:0.3": "Iddhipādasutta ",
    "an4.276:1.1": "“Rāgassa, bhikkhave, abhiññāya cattāro dhammā bhāvetabbā. ",
    "an4.276:1.2": "Katame cattāro? ",
    "an4.276:1.3": "Idha, bhikkhave, bhikkhu chandasamādhipadhānasaṅkhārasamannāgataṁ iddhipādaṁ bhāveti; ",
    "an4.276:1.4": "vīriyasamādhi …pe… ",
    "an4.276:1.5": "cittasamādhi …pe… ",
    "an4.276:1.6": "vīmaṁsāsamādhipadhānasaṅkhārasamannāgataṁ iddhipādaṁ bhāveti. ",
    "an4.276:1.7": "Rāgassa, bhikkhave, abhiññāya ime cattāro dhammā bhāvetabbā”ti. ",
    "an4.276:1.8": "Tatiyaṁ. "
  },
  "translation_text": {
    "an4.276:0.1": "Numbered Discourses 4.276 ",
    "an4.276:0.2": "28. Abbreviated Texts Beginning with Greed ",
    "an4.276:0.3": "Bases of Psychic Power ",
    "an4.276:1.1": "“For insight into greed, four things should be developed. ",
    "an4.276:1.2": "What four? ",
    "an4.276:1.3": "It’s when a mendicant develops the basis of psychic power that has immersion due to enthusiasm, and active effort. ",
    "an4.276:1.4": "They develop the basis of psychic power that has immersion due to energy … ",
    "an4.276:1.5": "mental development … ",
    "an4.276:1.6": "inquiry, and active effort. ",
    "an4.276:1.7": "For insight into greed, these four things should be developed.” "
  },
  "variant_text": {
    "an4.276:0.3": "Iddhipādasutta → catuiddhipādasuttaṁ (bj) "
  },
