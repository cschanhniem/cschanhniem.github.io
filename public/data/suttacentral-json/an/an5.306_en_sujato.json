  "root_text": {
    "an5.306:0.1": "Aṅguttara Nikāya 5 ",
    "an5.306:0.2": "29. Rāgapeyyāla ",
    "an5.306:0.3": "~ ",
    "an5.306:1.1": "“Rāgassa, bhikkhave, abhiññāya pañca dhammā bhāvetabbā. ",
    "an5.306:1.2": "Katame pañca? ",
    "an5.306:1.3": "Saddhindriyaṁ, vīriyindriyaṁ, satindriyaṁ, samādhindriyaṁ, paññindriyaṁ—",
    "an5.306:1.4": "rāgassa, bhikkhave, abhiññāya ime pañca dhammā bhāvetabbā”ti. "
  },
  "translation_text": {
    "an5.306:0.1": "Numbered Discourses 5 ",
    "an5.306:0.2": "29. Abbreviated Texts Beginning With Greed ",
    "an5.306:0.3": "Untitled Discourse on Greed (4th) ",
    "an5.306:1.1": "“For insight into greed, five things should be developed. ",
    "an5.306:1.2": "What five? ",
    "an5.306:1.3": "The faculties of faith, energy, mindfulness, immersion, and wisdom. ",
    "an5.306:1.4": "For insight into greed, these five things should be developed.” "
  },
