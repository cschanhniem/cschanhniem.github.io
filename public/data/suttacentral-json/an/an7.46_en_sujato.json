  "root_text": {
    "an7.46:0.1": "Aṅguttara Nikāya 7.46 ",
    "an7.46:0.2": "5. Mahāyaññavagga ",
    "an7.46:0.3": "Paṭhamaaggisutta ",
    "an7.46:1.1": "“Sattime, bhikkhave, aggī. ",
    "an7.46:1.2": "Katame satta? ",
    "an7.46:1.3": "Rāgaggi, dosaggi, mohaggi, āhuneyyaggi, gahapataggi, dakkhiṇeyyaggi, kaṭṭhaggi—",
    "an7.46:1.4": "ime kho, bhikkhave, satta aggī”ti. ",
    "an7.46:1.5": "Tatiyaṁ. "
  },
  "translation_text": {
    "an7.46:0.1": "Numbered Discourses 7.46 ",
    "an7.46:0.2": "5. A Great Sacrifice ",
    "an7.46:0.3": "Fires (1st) ",
    "an7.46:1.1": "“Mendicants, there are these seven fires. ",
    "an7.46:1.2": "What seven? ",
    "an7.46:1.3": "The fires of greed, hate, delusion. The fire of those worthy of offerings dedicated to the gods. A householder’s fire. The fire of those worthy of a religious donation. And a wood fire. ",
    "an7.46:1.4": "These are the seven fires.” "
  },
