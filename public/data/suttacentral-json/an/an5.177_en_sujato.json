  "root_text": {
    "an5.177:0.1": "Aṅguttara Nikāya 5.177 ",
    "an5.177:0.2": "18. Upāsakavagga ",
    "an5.177:0.3": "Vaṇijjāsutta ",
    "an5.177:1.1": "“Pañcimā, bhikkhave, vaṇijjā upāsakena akaraṇīyā. ",
    "an5.177:1.2": "Katamā pañca? ",
    "an5.177:1.3": "Satthavaṇijjā, sattavaṇijjā, maṁsavaṇijjā, majjavaṇijjā, visavaṇijjā—",
    "an5.177:1.4": "imā kho, bhikkhave, pañca vaṇijjā upāsakena akaraṇīyā”ti. ",
    "an5.177:1.5": "Sattamaṁ. "
  },
  "translation_text": {
    "an5.177:0.1": "Numbered Discourses 5.177 ",
    "an5.177:0.2": "18. A Lay Follower ",
    "an5.177:0.3": "Trades ",
    "an5.177:1.1": "“Mendicants, a lay follower should not engage in these five trades. ",
    "an5.177:1.2": "What five? ",
    "an5.177:1.3": "Trade in weapons, living creatures, meat, intoxicants, and poisons. ",
    "an5.177:1.4": "A lay follower should not engage in these five trades.” "
  },
