  "root_text": {
    "an5.220:0.1": "Aṅguttara Nikāya 5.220 ",
    "an5.220:0.2": "22. Akkosakavagga ",
    "an5.220:0.3": "Madhurāsutta ",
    "an5.220:1.1": "“Pañcime, bhikkhave, ādīnavā madhurāyaṁ. ",
    "an5.220:1.2": "Katame pañca? ",
    "an5.220:1.3": "Visamā, bahurajā, caṇḍasunakhā, vāḷayakkhā, dullabhapiṇḍā. ",
    "an5.220:1.4": "Ime kho, bhikkhave, pañca ādīnavā madhurāyan”ti. ",
    "an5.220:1.5": "Dasamaṁ. ",
    "an5.220:1.6": "Akkosakavaggo dutiyo. ",
    "an5.220:2.0": "Tassuddānaṁ ",
    "an5.220:2.1": "Akkosabhaṇḍanasīlaṁ, ",
    "an5.220:2.2": "bahubhāṇī dve akhantiyo; ",
    "an5.220:2.3": "Apāsādikā dve vuttā, ",
    "an5.220:2.4": "aggismiṁ madhurena cāti. "
  },
  "translation_text": {
    "an5.220:0.1": "Numbered Discourses 5.220 ",
    "an5.220:0.2": "22. Abuse ",
    "an5.220:0.3": "About Madhurā ",
    "an5.220:1.1": "“Mendicants, there are these five drawbacks of Madhurā. ",
    "an5.220:1.2": "What five? ",
    "an5.220:1.3": "The ground is uneven and dusty, the hounds are fierce, the native spirits are vicious, and it’s hard to get almsfood. ",
    "an5.220:1.4": "These are the five drawbacks of Madhurā.” ",
