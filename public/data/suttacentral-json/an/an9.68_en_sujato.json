  "root_text": {
    "an9.68:0.1": "Aṅguttara Nikāya 9.68 ",
    "an9.68:0.2": "7. Satipaṭṭhānavagga ",
    "an9.68:0.3": "Gatisutta ",
    "an9.68:1.1": "“Pañcimā, bhikkhave, gatiyo. ",
    "an9.68:1.2": "Katamā pañca? ",
    "an9.68:1.3": "Nirayo, tiracchānayoni, pettivisayo, manussā, devā—",
    "an9.68:1.4": "imā kho, bhikkhave, pañca gatiyo. ",
    "an9.68:2.1": "Imāsaṁ kho, bhikkhave, pañcannaṁ gatīnaṁ pahānāya …pe… ime cattāro satipaṭṭhānā bhāvetabbā”ti. ",
    "an9.68:2.2": "Chaṭṭhaṁ. "
  },
  "translation_text": {
    "an9.68:0.1": "Numbered Discourses 9.68 ",
    "an9.68:0.2": "7. Mindfulness Meditation ",
    "an9.68:0.3": "Places of Rebirth ",
    "an9.68:1.1": "“Mendicants, there are five destinations. ",
    "an9.68:1.2": "What five? ",
    "an9.68:1.3": "Hell, the animal realm, the ghost realm, humanity, and the gods. ",
    "an9.68:1.4": "These are the five destinations. ",
    "an9.68:2.1": "To give up these five destinations you should develop the four kinds of mindfulness meditation. …” "
  },
