  "root_text": {
    "an6.118:0.1": "Aṅguttara Nikāya 6.118 ",
    "an6.118:0.2": "12. Sāmaññavagga ",
    "an6.118:0.3": "Dhammānupassīsutta ",
    "an6.118:1.1": "“Cha, bhikkhave, dhamme appahāya abhabbo ajjhattaṁ kāye …pe… ",
    "an6.118:1.2": "bahiddhā kāye …pe… ",
    "an6.118:1.3": "ajjhattabahiddhā kāye …pe… ",
    "an6.118:1.4": "ajjhattaṁ vedanāsu …pe… ",
    "an6.118:1.5": "bahiddhā vedanāsu …pe… ",
    "an6.118:1.6": "ajjhattabahiddhā vedanāsu …pe… ",
    "an6.118:1.7": "ajjhattaṁ citte …pe… ",
    "an6.118:1.8": "bahiddhā citte …pe… ",
    "an6.118:1.9": "ajjhattabahiddhā citte …pe… ",
    "an6.118:1.10": "ajjhattaṁ dhammesu …pe… ",
    "an6.118:1.11": "bahiddhā dhammesu …pe… ",
    "an6.118:1.12": "ajjhattabahiddhā dhammesu dhammānupassī viharituṁ. ",
    "an6.118:1.13": "Katame cha? ",
    "an6.118:1.14": "Kammārāmataṁ, bhassārāmataṁ, niddārāmataṁ, saṅgaṇikārāmataṁ, indriyesu aguttadvārataṁ, bhojane amattaññutaṁ. ",
    "an6.118:1.15": "Ime kho, bhikkhave, cha dhamme pahāya bhabbo ajjhattabahiddhā dhammesu dhammānupassī viharitun”ti. ",
    "an6.118:1.16": "Dutiyaṁ. "
  },
  "translation_text": {
    "an6.118:0.1": "Numbered Discourses 6.118 ",
    "an6.118:0.2": "12. The Ascetic Life ",
    "an6.118:0.3": "Observing Principles, Etc. ",
    "an6.118:1.1": "“Mendicants, without giving up six things you can’t meditate observing an aspect of the body internally … ",
    "an6.118:1.2": "body externally … ",
    "an6.118:1.3": "body internally and externally … ",
    "an6.118:1.4": "feelings internally … ",
    "an6.118:1.5": "feelings externally … ",
    "an6.118:1.6": "feelings internally and externally … ",
    "an6.118:1.7": "mind internally … ",
    "an6.118:1.8": "mind externally … ",
    "an6.118:1.9": "mind internally and externally … ",
    "an6.118:1.10": "principles internally … ",
    "an6.118:1.11": "principles externally … ",
    "an6.118:1.12": "principles internally and externally. ",
    "an6.118:1.13": "What six? ",
    "an6.118:1.14": "Relishing work, talk, sleep, and company, not guarding the sense doors, and eating too much. ",
    "an6.118:1.15": "After giving up these six qualities you can meditate observing an aspect of principles internally and externally.” "
  },
