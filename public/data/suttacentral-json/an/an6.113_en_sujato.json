  "root_text": {
    "an6.113:0.1": "Aṅguttara Nikāya 6.113 ",
    "an6.113:0.2": "11. Tikavagga ",
    "an6.113:0.3": "Aratisutta ",
    "an6.113:1.1": "“Tayome, bhikkhave, dhammā. ",
    "an6.113:1.2": "Katame tayo? ",
    "an6.113:1.3": "Arati, vihiṁsā, adhammacariyā. ",
    "an6.113:1.4": "Ime kho, bhikkhave, tayo dhammā. ",
    "an6.113:1.5": "Imesaṁ kho, bhikkhave, tiṇṇaṁ dhammānaṁ pahānāya tayo dhammā bhāvetabbā. ",
    "an6.113:1.6": "Katame tayo? ",
    "an6.113:1.7": "Aratiyā pahānāya muditā bhāvetabbā, vihiṁsāya pahānāya avihiṁsā bhāvetabbā, adhammacariyāya pahānāya dhammacariyā bhāvetabbā. ",
    "an6.113:1.8": "Imesaṁ kho, bhikkhave, tiṇṇaṁ dhammānaṁ pahānāya ime tayo dhammā bhāvetabbā”ti. ",
    "an6.113:1.9": "Sattamaṁ. "
  },
  "translation_text": {
    "an6.113:0.1": "Numbered Discourses 6.113 ",
    "an6.113:0.2": "11. Triads ",
    "an6.113:0.3": "Discontent ",
    "an6.113:1.1": "“Mendicants, there are these three things. ",
    "an6.113:1.2": "What three? ",
    "an6.113:1.3": "Discontent, cruelty, and unprincipled conduct. ",
    "an6.113:1.4": "These are the three things. ",
    "an6.113:1.5": "To give up these three things you should develop three things. ",
    "an6.113:1.6": "What three? ",
    "an6.113:1.7": "You should develop rejoicing to give up discontent, harmlessness to give up cruelty, and principled conduct to give up unprincipled conduct. ",
    "an6.113:1.8": "These are the three things you should develop to give up those three things.” "
  },
  "variant_text": {
    "an6.113:1.3": "vihiṁsā → vihesā (mr) "
  },
