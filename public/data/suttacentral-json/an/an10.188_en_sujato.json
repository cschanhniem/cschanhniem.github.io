  "root_text": {
    "an10.188:0.1": "Aṅguttara Nikāya 10.188 ",
    "an10.188:0.2": "18. Sādhuvagga ",
    "an10.188:0.3": "Vipākasutta ",
    "an10.188:1.1": "“Dukkhavipākañca vo, bhikkhave, dhammaṁ desessāmi sukhavipākañca. ",
    "an10.188:1.2": "Taṁ suṇātha …pe… ",
    "an10.188:1.3": "katamo ca, bhikkhave, dukkhavipāko dhammo? ",
    "an10.188:1.4": "Pāṇātipāto …pe… ",
    "an10.188:1.5": "micchādiṭṭhi—",
    "an10.188:1.6": "ayaṁ vuccati, bhikkhave, dukkhavipāko dhammo. ",
    "an10.188:2.1": "Katamo ca, bhikkhave, sukhavipāko dhammo? ",
    "an10.188:2.2": "Pāṇātipātā veramaṇī …pe… ",
    "an10.188:2.3": "sammādiṭṭhi—",
    "an10.188:2.4": "ayaṁ vuccati, bhikkhave, sukhavipāko dhammo”ti. ",
    "an10.188:2.5": "Ekādasamaṁ. ",
    "an10.188:2.6": "Sādhuvaggo tatiyo. "
  },
  "translation_text": {
    "an10.188:0.1": "Numbered Discourses 10.188 ",
    "an10.188:0.2": "18. Good ",
    "an10.188:0.3": "Result ",
    "an10.188:1.1": "“I will teach you the principle that results in suffering and that which results in happiness. … ",
    "an10.188:1.2": "",
    "an10.188:1.3": "And what is the principle that results in suffering? ",
    "an10.188:1.4": "Killing living creatures … ",
    "an10.188:1.5": "wrong view. ",
    "an10.188:1.6": "This is called the principle that results in suffering. ",
    "an10.188:2.1": "And what is the principle that results in happiness? ",
    "an10.188:2.2": "Not killing living creatures … ",
    "an10.188:2.3": "right view. ",
    "an10.188:2.4": "This is called the principle that results in happiness.” ",
    "an10.188:2.5": ""
  },
  "variant_text": {
    "an10.188:0.3": "Vipākasutta → dukkhavipākasuttaṁ (bj) "
  },
