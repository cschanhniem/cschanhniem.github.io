  "root_text": {
    "an10.233-236:0.1": "Aṅguttara Nikāya 10 ",
    "an10.233-236:0.2": "22. Sāmaññavagga ",
    "an10.233-236:0.3": "~ ",
    "an10.233-236:1.1": "“Dasahi, bhikkhave, dhammehi samannāgato bālo veditabbo …pe… ",
    "an10.233-236:1.2": "paṇḍito veditabbo …pe… ",
    "an10.233-236:1.3": "vīsatiyā, bhikkhave …pe… ",
    "an10.233-236:1.4": "tiṁsāya, bhikkhave …pe… ",
    "an10.233-236:1.5": "cattārīsāya, bhikkhave, dhammehi samannāgato bālo veditabbo …pe… ",
    "an10.233-236:1.6": "paṇḍito veditabbo …pe… ",
    "an10.233-236:1.7": "imehi kho, bhikkhave, cattārīsāya dhammehi samannāgato paṇḍito veditabbo”ti. ",
    "an10.233-236:1.8": "Sāmaññavaggo dutiyo. "
  },
  "translation_text": {
