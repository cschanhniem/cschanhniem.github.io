  "root_text": {
    "an4.56:0.1": "Aṅguttara Nikāya 4.56 ",
    "an4.56:0.2": "6. Puññābhisandavagga ",
    "an4.56:0.3": "Dutiyasamajīvīsutta ",
    "an4.56:1.1": "“Ākaṅkheyyuñce, bhikkhave, ubho jānipatayo diṭṭhe ceva dhamme aññamaññaṁ passituṁ abhisamparāyañca aññamaññaṁ passituṁ ubhova assu samasaddhā samasīlā samacāgā samapaññā, te diṭṭhe ceva dhamme aññamaññaṁ passanti abhisamparāyañca aññamaññaṁ passantīti. ",
    "an4.56:2.1": "Ubho saddhā vadaññū ca, ",
    "an4.56:2.2": "saññatā dhammajīvino; ",
    "an4.56:2.3": "Te honti jānipatayo, ",
    "an4.56:2.4": "aññamaññaṁ piyaṁvadā. ",
    "an4.56:3.1": "Atthāsaṁ pacurā honti, ",
    "an4.56:3.2": "phāsukaṁ upajāyati; ",
    "an4.56:3.3": "Amittā dummanā honti, ",
    "an4.56:3.4": "ubhinnaṁ samasīlinaṁ. ",
    "an4.56:4.1": "Idha dhammaṁ caritvāna, ",
    "an4.56:4.2": "samasīlabbatā ubho; ",
    "an4.56:4.3": "Nandino devalokasmiṁ, ",
    "an4.56:4.4": "modanti kāmakāmino”ti. ",
    "an4.56:4.5": "Chaṭṭhaṁ. "
  },
  "translation_text": {
    "an4.56:0.1": "Numbered Discourses 4.56 ",
    "an4.56:0.2": "6. Overflowing Merit ",
    "an4.56:0.3": "Equality (2nd) ",
    "an4.56:1.1": "“Mendicants, if wife and husband want to see each other in both this life and the next, they should be equals in faith, ethics, generosity, and wisdom. …” ",
