  "root_text": {
    "an10.145:0.1": "Aṅguttara Nikāya 10.145 ",
    "an10.145:0.2": "15. Ariyavagga ",
    "an10.145:0.3": "Ariyamaggasutta ",
    "an10.145:1.1": "“Ariyamaggañca vo, bhikkhave, dhammaṁ desessāmi anariyamaggañca. ",
    "an10.145:1.2": "Taṁ suṇātha …pe… ",
    "an10.145:1.3": "katamo ca, bhikkhave, anariyo maggo? ",
    "an10.145:1.4": "Micchādiṭṭhi …pe… micchāvimutti—",
    "an10.145:1.5": "ayaṁ vuccati, bhikkhave, anariyo maggo. ",
    "an10.145:1.6": "Katamo ca, bhikkhave, ariyo maggo? ",
    "an10.145:1.7": "Sammādiṭṭhi …pe… sammāvimutti—",
    "an10.145:1.8": "ayaṁ vuccati, bhikkhave, ariyo maggo”ti. ",
    "an10.145:1.9": "Paṭhamaṁ. "
  },
  "translation_text": {
    "an10.145:0.1": "Numbered Discourses 10.145 ",
    "an10.145:0.2": "15. The Noble Path ",
    "an10.145:0.3": "The Noble Path ",
    "an10.145:1.1": "“I will teach you the noble path and the ignoble path. … ",
    "an10.145:1.2": "",
    "an10.145:1.3": "And what is the ignoble path? ",
    "an10.145:1.4": "Wrong view, wrong thought, wrong speech, wrong action, wrong livelihood, wrong effort, wrong mindfulness, wrong immersion, wrong knowledge, and wrong freedom. ",
    "an10.145:1.5": "This is called the ignoble path. ",
    "an10.145:1.6": "And what is the noble path? ",
    "an10.145:1.7": "Right view, right thought, right speech, right action, right livelihood, right effort, right mindfulness, right immersion, right knowledge, and right freedom. ",
    "an10.145:1.8": "This is called the noble path.” "
  },
  "variant_text": {
    "an10.145:0.2": "Ariyavagga → ariyamaggavaggo (sya-all); ariyamaggavagga (pts1ed) "
  },
