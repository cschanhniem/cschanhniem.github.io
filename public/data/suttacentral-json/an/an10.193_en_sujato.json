  "root_text": {
    "an10.193:0.1": "Aṅguttara Nikāya 10.193 ",
    "an10.193:0.2": "19. Ariyamaggavagga ",
    "an10.193:0.3": "Uppādetabbadhammasutta ",
    "an10.193:1.1": "“Uppādetabbañca vo, bhikkhave, dhammaṁ desessāmi na uppādetabbañca. ",
    "an10.193:1.2": "Taṁ suṇātha …pe… ",
    "an10.193:1.3": "katamo ca, bhikkhave, na uppādetabbo dhammo? ",
    "an10.193:1.4": "Pāṇātipāto …pe… ",
    "an10.193:1.5": "micchādiṭṭhi—",
    "an10.193:1.6": "ayaṁ vuccati, bhikkhave, na uppādetabbo dhammo. ",
    "an10.193:2.1": "Katamo ca, bhikkhave, uppādetabbo dhammo? ",
    "an10.193:2.2": "Pāṇātipātā veramaṇī …pe… ",
    "an10.193:2.3": "sammādiṭṭhi—",
    "an10.193:2.4": "ayaṁ vuccati, bhikkhave, uppādetabbo dhammo”ti. ",
    "an10.193:2.5": "Pañcamaṁ. "
  },
  "translation_text": {
    "an10.193:0.1": "Numbered Discourses 10.193 ",
    "an10.193:0.2": "19. The Noble Path ",
    "an10.193:0.3": "Principles That Should Be Activated ",
    "an10.193:1.1": "“I will teach you the principle to activate and the principle not to activate. … ",
    "an10.193:1.2": "",
    "an10.193:1.3": "And what is the principle not to activate? ",
    "an10.193:1.4": "Killing living creatures … ",
    "an10.193:1.5": "wrong view. ",
    "an10.193:1.6": "This is called the principle not to activate. ",
    "an10.193:2.1": "And what is the principle to activate? ",
    "an10.193:2.2": "Not killing living creatures … ",
    "an10.193:2.3": "right view. ",
    "an10.193:2.4": "This is called the principle to activate.” "
  },
