  "root_text": {
    "an10.195:0.1": "Aṅguttara Nikāya 10.195 ",
    "an10.195:0.2": "19. Ariyamaggavagga ",
    "an10.195:0.3": "Bhāvetabbadhammasutta ",
    "an10.195:1.1": "“Bhāvetabbañca vo, bhikkhave, dhammaṁ desessāmi na bhāvetabbañca. ",
    "an10.195:1.2": "Taṁ suṇātha …pe… ",
    "an10.195:1.3": "katamo ca, bhikkhave, na bhāvetabbo dhammo? ",
    "an10.195:1.4": "Pāṇātipāto …pe… ",
    "an10.195:1.5": "micchādiṭṭhi—",
    "an10.195:1.6": "ayaṁ vuccati, bhikkhave, na bhāvetabbo dhammo. ",
    "an10.195:2.1": "Katamo ca, bhikkhave, bhāvetabbo dhammo? ",
    "an10.195:2.2": "Pāṇātipātā veramaṇī …pe… ",
    "an10.195:2.3": "sammādiṭṭhi—",
    "an10.195:2.4": "ayaṁ vuccati, bhikkhave, bhāvetabbo dhammo”ti. ",
    "an10.195:2.5": "Sattamaṁ. "
  },
  "translation_text": {
    "an10.195:0.1": "Numbered Discourses 10.195 ",
    "an10.195:0.2": "19. The Noble Path ",
    "an10.195:0.3": "Principles That Should Be Developed ",
    "an10.195:1.1": "“I will teach you the principle to develop and the principle not to develop. … ",
    "an10.195:1.2": "Listen and apply your mind well, I will speak. ",
    "an10.195:1.3": "And what is the principle not to develop? ",
    "an10.195:1.4": "Killing living creatures … ",
    "an10.195:1.5": "wrong view. ",
    "an10.195:1.6": "This is called the principle not to develop. ",
    "an10.195:2.1": "And what is the principle to develop? ",
    "an10.195:2.2": "Not killing living creatures … ",
    "an10.195:2.3": "right view. ",
    "an10.195:2.4": "This is called the principle to develop.” "
  },
