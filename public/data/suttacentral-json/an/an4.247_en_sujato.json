  "root_text": {
    "an4.247:0.1": "Aṅguttara Nikāya 4.247 ",
    "an4.247:0.2": "25. Āpattibhayavagga ",
    "an4.247:0.3": "Thūpārahasutta ",
    "an4.247:1.1": "“Cattārome, bhikkhave, thūpārahā. ",
    "an4.247:1.2": "Katame cattāro? ",
    "an4.247:1.3": "Tathāgato arahaṁ sammāsambuddho thūpāraho, paccekabuddho thūpāraho, tathāgatasāvako thūpāraho, rājā cakkavattī thūpāraho—",
    "an4.247:1.4": "Ime kho, bhikkhave, cattāro thūpārahā”ti. ",
    "an4.247:1.5": "Pañcamaṁ. "
  },
  "translation_text": {
    "an4.247:0.1": "Numbered Discourses 4.247 ",
    "an4.247:0.2": "25. Perils of Offenses ",
    "an4.247:0.3": "Worthy of a Monument ",
    "an4.247:1.1": "“Mendicants, these four are worthy of a monument. ",
    "an4.247:1.2": "What four? ",
    "an4.247:1.3": "A Realized One, a perfected one, a fully awakened Buddha; an Independent Buddha; a disciple of a Realized One; and a wheel-turning monarch. ",
    "an4.247:1.4": "These four are worthy of a monument.” "
  },
