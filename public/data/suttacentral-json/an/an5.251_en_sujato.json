  "root_text": {
    "an5.251:0.1": "Aṅguttara Nikāya 5.251 ",
    "an5.251:0.2": "26. Upasampadāvagga ",
    "an5.251:0.3": "Upasampādetabbasutta ",
    "an5.251:1.1": "“Pañcahi, bhikkhave, dhammehi samannāgatena bhikkhunā upasampādetabbaṁ. ",
    "an5.251:1.2": "Katamehi pañcahi? ",
    "an5.251:1.3": "Idha, bhikkhave, bhikkhu asekhena sīlakkhandhena samannāgato hoti; ",
    "an5.251:1.4": "asekhena samādhikkhandhena samannāgato hoti; ",
    "an5.251:1.5": "asekhena paññākkhandhena samannāgato hoti; ",
    "an5.251:1.6": "asekhena vimuttikkhandhena samannāgato hoti; ",
    "an5.251:1.7": "asekhena vimuttiñāṇadassanakkhandhena samannāgato hoti. ",
    "an5.251:1.8": "Imehi kho, bhikkhave, pañcahi dhammehi samannāgatena bhikkhunā upasampādetabban”ti. ",
    "an5.251:1.9": "Paṭhamaṁ. "
  },
  "translation_text": {
    "an5.251:0.1": "Numbered Discourses 5.251 ",
    "an5.251:0.2": "26. Ordination ",
    "an5.251:0.3": "Who Should Give Ordination ",
    "an5.251:1.1": "“Mendicants, ordination should be given by a mendicant with five qualities. ",
    "an5.251:1.2": "What five? ",
    "an5.251:1.3": "It’s a mendicant who has the entire spectrum of an adept’s ethics, ",
    "an5.251:1.4": "immersion, ",
    "an5.251:1.5": "wisdom, ",
    "an5.251:1.6": "freedom, ",
    "an5.251:1.7": "and the knowledge and vision of freedom. ",
    "an5.251:1.8": "Ordination should be given by a mendicant with these five qualities.” "
  },
  "variant_text": {
    "an5.251:0.2": "Upasampadāvagga → vaggāsaṅgahitā suttantā (sya-all) "
  },
