  "root_text": {
    "an10.191:0.1": "Aṅguttara Nikāya 10.191 ",
    "an10.191:0.2": "19. Ariyamaggavagga ",
    "an10.191:0.3": "Saddhammasutta ",
    "an10.191:1.1": "“Saddhammañca vo, bhikkhave, desessāmi asaddhammañca. ",
    "an10.191:1.2": "Taṁ suṇātha …pe… ",
    "an10.191:1.3": "katamo ca, bhikkhave, asaddhammo? ",
    "an10.191:1.4": "Pāṇātipāto …pe… ",
    "an10.191:1.5": "micchādiṭṭhi—",
    "an10.191:1.6": "ayaṁ vuccati, bhikkhave, asaddhammo. ",
    "an10.191:2.1": "Katamo ca, bhikkhave, saddhammo? ",
    "an10.191:2.2": "Pāṇātipātā veramaṇī …pe… ",
    "an10.191:2.3": "sammādiṭṭhi—",
    "an10.191:2.4": "ayaṁ vuccati, bhikkhave, saddhammo”ti. ",
    "an10.191:2.5": "Tatiyaṁ. "
  },
  "translation_text": {
    "an10.191:0.1": "Numbered Discourses 10.191 ",
    "an10.191:0.2": "19. The Noble Path ",
    "an10.191:0.3": "The True Teaching ",
    "an10.191:1.1": "“I will teach you what is the true teaching and what is not the true teaching. … ",
    "an10.191:1.2": "",
    "an10.191:1.3": "And what is not the true teaching? ",
    "an10.191:1.4": "Killing living creatures … ",
    "an10.191:1.5": "wrong view. ",
    "an10.191:1.6": "This is called what is not the true teaching. ",
    "an10.191:2.1": "And what is the true teaching? ",
    "an10.191:2.2": "Not killing living creatures … ",
    "an10.191:2.3": "right view. ",
    "an10.191:2.4": "This is called the true teaching.” "
  },
