  "root_text": {
    "sn47.73-84:0.1": "Saṁyutta Nikāya 47.73–84 ",
    "sn47.73-84:0.2": "8. Balakaraṇīyavagga ",
    "sn47.73-84:0.3": "Balādisutta ",
    "sn47.73-84:1.1": "“Seyyathāpi, bhikkhave, ye keci balakaraṇīyā kammantā karīyantī”ti  ",
    "sn47.73-84:1.2": "vitthāretabbaṁ.",
    "sn47.73-84:1.3": "Balakaraṇīyavaggo aṭṭhamo. ",
    "sn47.73-84:2.0": "Tassuddānaṁ ",
    "sn47.73-84:2.1": "Balaṁ bījañca nāgo ca, ",
    "sn47.73-84:2.2": "rukkho kumbhena sūkiyā; ",
    "sn47.73-84:2.3": "Ākāsena ca dve meghā, ",
    "sn47.73-84:2.4": "nāvā āgantukā nadīti. "
  },
  "translation_text": {
    "sn47.73-84:0.1": "Linked Discourses 47.73–84 ",
    "sn47.73-84:0.2": "8. Hard Work ",
    "sn47.73-84:0.3": "Hard Work, Etc. ",
    "sn47.73-84:1.1": "“Mendicants, all the hard work that gets done depends on the earth and is grounded on the earth. …” ",
    "sn47.73-84:1.2": "(Tell in full as in SN 45.149–160.) ",
    "sn47.73-84:2.1": "Hard work, seeds, and dragons, ",
    "sn47.73-84:2.2": "a tree, a pot, and a spike, ",
    "sn47.73-84:2.3": "the atmosphere, and two on clouds, ",
    "sn47.73-84:2.4": "a ship, a guest house, and a river. "
  },
