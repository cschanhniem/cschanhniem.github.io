  "root_text": {
    "sn2.27:0.1": "Saṁyutta Nikāya 2.27 ",
    "sn2.27:0.2": "3. Nānātitthiyavagga ",
    "sn2.27:0.3": "Nandasutta ",
    "sn2.27:1.1": "Ekamantaṁ ṭhito kho nando devaputto bhagavato santike imaṁ gāthaṁ abhāsi: ",
    "sn2.27:2.1": "“Accenti kālā tarayanti rattiyo, ",
    "sn2.27:2.2": "Vayoguṇā anupubbaṁ jahanti; ",
    "sn2.27:2.3": "Etaṁ bhayaṁ maraṇe pekkhamāno, ",
    "sn2.27:2.4": "Puññāni kayirātha sukhāvahānī”ti. ",
    "sn2.27:3.1": "“Accenti kālā tarayanti rattiyo, ",
    "sn2.27:3.2": "Vayoguṇā anupubbaṁ jahanti; ",
    "sn2.27:3.3": "Etaṁ bhayaṁ maraṇe pekkhamāno, ",
    "sn2.27:3.4": "Lokāmisaṁ pajahe santipekkho”ti. "
  },
  "translation_text": {
    "sn2.27:0.1": "Linked Discourses 2.27 ",
    "sn2.27:0.2": "3. Various Sectarians ",
    "sn2.27:0.3": "With Nanda ",
    "sn2.27:1.1": "Standing to one side, the godling Nanda spoke this verse in the Buddha’s presence: ",
    "sn2.27:2.1": "“Time flies, nights pass by, ",
    "sn2.27:2.2": "the stages of life leave us one by one. ",
    "sn2.27:2.3": "Seeing this peril in death, ",
    "sn2.27:2.4": "do good deeds that bring you joy.” ",
    "sn2.27:3.1": "“Time flies, nights pass by, ",
    "sn2.27:3.2": "the stages of life leave us one by one. ",
    "sn2.27:3.3": "Seeing this peril in death, ",
    "sn2.27:3.4": "a seeker of peace would drop the world’s bait.” "
  },
