{
  "comment_text": {
    "sn1.81:3.1": "How this is achieved is treated in <a href='https://suttacentral.net/mn139/en/sujato#0.2'>MN 139:0.2</a>. ",
    "sn1.81:3.2": "The word for “life” here (<i lang='pi' translate='no'>vusitaṁ</i>) commonly describes the completion of the spiritual path. ",
    "sn1.81:4.4": "Such as King Ajātasattu (<a href='https://suttacentral.net/dn2/en/sujato#36.2'>DN 2:36.2</a>). "
  },
