  "root_text": {
    "sn1.81:0.1": "Saṁyutta Nikāya 1.81 ",
    "sn1.81:0.2": "8. Chetvāvagga ",
    "sn1.81:0.3": "Araṇasutta ",
    "sn1.81:1.1": "“Kesūdha araṇā loke, ",
    "sn1.81:1.2": "kesaṁ vusitaṁ na nassati; ",
    "sn1.81:1.3": "Kedha icchaṁ parijānanti, ",
    "sn1.81:1.4": "kesaṁ bhojissiyaṁ sadā. ",
    "sn1.81:2.1": "Kiṁsu mātā pitā bhātā, ",
    "sn1.81:2.2": "vandanti naṁ patiṭṭhitaṁ; ",
    "sn1.81:2.3": "Kiṁsu idha jātihīnaṁ, ",
    "sn1.81:2.4": "abhivādenti khattiyā”ti. ",
    "sn1.81:3.1": "“Samaṇīdha araṇā loke, ",
    "sn1.81:3.2": "Samaṇānaṁ vusitaṁ na nassati; ",
    "sn1.81:3.3": "Samaṇā icchaṁ parijānanti, ",
    "sn1.81:3.4": "Samaṇānaṁ bhojissiyaṁ sadā. ",
    "sn1.81:4.1": "Samaṇaṁ mātā pitā bhātā, ",
    "sn1.81:4.2": "vandanti naṁ patiṭṭhitaṁ; ",
    "sn1.81:4.3": "Samaṇīdha jātihīnaṁ, ",
    "sn1.81:4.4": "abhivādenti khattiyā”ti. ",
    "sn1.81:4.5": "Chetvāvaggo aṭṭhamo. ",
    "sn1.81:5.0": "Tassuddānaṁ ",
    "sn1.81:5.1": "Chetvā rathañca cittañca, ",
    "sn1.81:5.2": "vuṭṭhi bhītā najīrati; ",
    "sn1.81:5.3": "Issaraṁ kāmaṁ pātheyyaṁ, ",
    "sn1.81:5.4": "pajjoto araṇena cāti. ",
    "sn1.81:5.5": "Devatāsaṁyuttaṁ samattaṁ. "
  },
  "translation_text": {
    "sn1.81:0.1": "Linked Discourses 1.81 ",
    "sn1.81:0.2": "8. Slain ",
    "sn1.81:0.3": "Free of Strife ",
    "sn1.81:1.1": "“Who in the world is free of strife? ",
    "sn1.81:1.2": "Whose life is not wasted? ",
    "sn1.81:1.3": "Who here completely understands desire? ",
    "sn1.81:1.4": "Who always lives as their own master? ",
    "sn1.81:2.1": "To whom do mother, father, and brothers ",
    "sn1.81:2.2": "bow when they’re established? ",
    "sn1.81:2.3": "Who here, though low born, ",
    "sn1.81:2.4": "is bowed to even by aristocrats?” ",
    "sn1.81:3.1": "“Ascetics are free of strife in the world. ",
    "sn1.81:3.2": "The life of ascetics is not wasted. ",
    "sn1.81:3.3": "Ascetics completely understand desire. ",
    "sn1.81:3.4": "Ascetics always live as their own master. ",
    "sn1.81:4.1": "Mother, father, and brothers ",
    "sn1.81:4.2": "bow to ascetics when they’re established. ",
    "sn1.81:4.3": "Even though an ascetic is low born, ",
    "sn1.81:4.4": "they’re bowed to even by aristocrats.” ",
    "sn1.81:4.5": "",
    "sn1.81:5.1": "",
    "sn1.81:5.2": "",
    "sn1.81:5.3": "",
    "sn1.81:5.4": "",
    "sn1.81:5.5": "The Linked Discourses on Deities are complete. "
  },
