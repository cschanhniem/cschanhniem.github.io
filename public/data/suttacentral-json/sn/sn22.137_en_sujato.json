  "root_text": {
    "sn22.137:0.1": "Saṁyutta Nikāya 22.137 ",
    "sn22.137:0.2": "14. Kukkuḷavagga ",
    "sn22.137:0.3": "Aniccasutta ",
    "sn22.137:1.1": "Sāvatthinidānaṁ. ",
    "sn22.137:1.2": "“Yaṁ, bhikkhave, aniccaṁ; tatra vo chando pahātabbo. ",
    "sn22.137:1.3": "Kiñca, bhikkhave, aniccaṁ? ",
    "sn22.137:1.4": "Rūpaṁ, bhikkhave, aniccaṁ; tatra vo chando pahātabbo. ",
    "sn22.137:1.5": "Vedanā aniccā …pe… ",
    "sn22.137:1.6": "saññā … ",
    "sn22.137:1.7": "saṅkhārā … ",
    "sn22.137:1.8": "viññāṇaṁ aniccaṁ; tatra vo chando pahātabbo. ",
    "sn22.137:1.9": "Yaṁ, bhikkhave, aniccaṁ; tatra vo chando pahātabbo”ti. ",
    "sn22.137:1.10": "Dutiyaṁ. "
  },
  "translation_text": {
    "sn22.137:0.1": "Linked Discourses 22.137 ",
    "sn22.137:0.2": "14. Burning Chaff ",
    "sn22.137:0.3": "Impermanence ",
    "sn22.137:1.1": "At Sāvatthī. ",
    "sn22.137:1.2": "“Mendicants, you should give up desire for what is impermanent. ",
    "sn22.137:1.3": "And what is impermanent? ",
    "sn22.137:1.4": "Form is impermanent; you should give up desire for it. ",
    "sn22.137:1.5": "Feeling … ",
    "sn22.137:1.6": "Perception … ",
    "sn22.137:1.7": "Choices … ",
    "sn22.137:1.8": "Consciousness is impermanent; you should give up desire for it. ",
    "sn22.137:1.9": "You should give up desire for what is impermanent.” "
  },
