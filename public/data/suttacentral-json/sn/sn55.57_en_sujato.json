  "root_text": {
    "sn55.57:0.1": "Saṁyutta Nikāya 55.57 ",
    "sn55.57:0.2": "6. Sappaññavagga ",
    "sn55.57:0.3": "Anāgāmiphalasutta ",
    "sn55.57:1.1": "“… Anāgāmiphalasacchikiriyāya saṁvattantī”ti. ",
    "sn55.57:1.2": "Sattamaṁ. "
  },
  "translation_text": {
    "sn55.57:0.1": "Linked Discourses 55.57 ",
    "sn55.57:0.2": "6. A Wise Person ",
    "sn55.57:0.3": "The Fruit of Non-Return ",
    "sn55.57:1.1": "“Mendicants, when four things are developed and cultivated they lead to the realization of the fruit of non-return. …” "
  },
