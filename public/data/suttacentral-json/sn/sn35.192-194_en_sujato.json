  "root_text": {
    "sn35.192-194:0.1": "Saṁyutta Nikāya 35.192–194 ",
    "sn35.192-194:0.2": "17. Saṭṭhipeyyālavagga ",
    "sn35.192-194:0.3": "Ajjhattātītādianattasutta ",
    "sn35.192-194:1.1": "“Cakkhu, bhikkhave, anattā atītaṁ anāgataṁ paccuppannaṁ …pe… jivhā anattā …pe… mano anattā atīto anāgato paccuppanno. ",
    "sn35.192-194:1.2": "Evaṁ passaṁ …pe… ",
    "sn35.192-194:1.3": "nāparaṁ itthattāyāti pajānātī”ti. "
  },
  "translation_text": {
    "sn35.192-194:0.1": "Linked Discourses 35.192–194 ",
    "sn35.192-194:0.2": "17. Sixty Abbreviated Texts ",
    "sn35.192-194:0.3": "The Interior as Not-Self in the Three Times ",
    "sn35.192-194:1.1": "“Mendicants, in the past … future … present the eye, ear, nose, tongue, body, and mind are not-self …” ",
    "sn35.192-194:1.2": ""
  },
