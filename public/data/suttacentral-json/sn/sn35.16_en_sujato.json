  "root_text": {
    "sn35.16:0.1": "Saṁyutta Nikāya 35.16 ",
    "sn35.16:0.2": "2. Yamakavagga ",
    "sn35.16:0.3": "Dutiyaassādapariyesanasutta ",
    "sn35.16:1.1": "“Rūpānāhaṁ, bhikkhave, assādapariyesanaṁ acariṁ. ",
    "sn35.16:1.2": "Yo rūpānaṁ assādo tadajjhagamaṁ. ",
    "sn35.16:1.3": "Yāvatā rūpānaṁ assādo paññāya me so sudiṭṭho. ",
    "sn35.16:1.4": "Rūpānāhaṁ, bhikkhave, ādīnavapariyesanaṁ acariṁ. ",
    "sn35.16:1.5": "Yo rūpānaṁ ādīnavo tadajjhagamaṁ. ",
    "sn35.16:1.6": "Yāvatā rūpānaṁ ādīnavo paññāya me so sudiṭṭho. ",
    "sn35.16:1.7": "Rūpānāhaṁ, bhikkhave, nissaraṇapariyesanaṁ acariṁ. ",
    "sn35.16:1.8": "Yaṁ rūpānaṁ nissaraṇaṁ tadajjhagamaṁ. ",
    "sn35.16:1.9": "Yāvatā rūpānaṁ nissaraṇaṁ, paññāya me taṁ sudiṭṭhaṁ. ",
    "sn35.16:1.10": "Saddānāhaṁ, bhikkhave … ",
    "sn35.16:1.11": "gandhānāhaṁ, bhikkhave … ",
    "sn35.16:1.12": "rasānāhaṁ, bhikkhave … ",
    "sn35.16:1.13": "phoṭṭhabbānāhaṁ, bhikkhave … ",
    "sn35.16:1.14": "dhammānāhaṁ, bhikkhave, assādapariyesanaṁ acariṁ. ",
    "sn35.16:1.15": "Yo dhammānaṁ assādo tadajjhagamaṁ. ",
    "sn35.16:1.16": "Yāvatā dhammānaṁ assādo paññāya me so sudiṭṭho. ",
    "sn35.16:1.17": "Dhammānāhaṁ, bhikkhave, ādīnavapariyesanaṁ acariṁ. ",
    "sn35.16:1.18": "Yo dhammānaṁ ādīnavo tadajjhagamaṁ. ",
    "sn35.16:1.19": "Yāvatā dhammānaṁ ādīnavo paññāya me so sudiṭṭho. ",
    "sn35.16:1.20": "Dhammānāhaṁ, bhikkhave, nissaraṇapariyesanaṁ acariṁ. ",
    "sn35.16:1.21": "Yaṁ dhammānaṁ nissaraṇaṁ tadajjhagamaṁ. ",
    "sn35.16:1.22": "Yāvatā dhammānaṁ nissaraṇaṁ, paññāya me taṁ sudiṭṭhaṁ. ",
    "sn35.16:2.1": "Yāvakīvañcāhaṁ, bhikkhave, imesaṁ channaṁ bāhirānaṁ āyatanānaṁ assādañca assādato, ādīnavañca ādīnavato, nissaraṇañca nissaraṇato yathābhūtaṁ nābbhaññāsiṁ …pe… paccaññāsiṁ. ",
    "sn35.16:2.2": "Ñāṇañca pana me dassanaṁ udapādi: ",
    "sn35.16:2.3": "‘akuppā me vimutti, ayamantimā jāti, natthi dāni punabbhavo’”ti. ",
    "sn35.16:2.4": "Catutthaṁ. "
  },
  "translation_text": {
    "sn35.16:0.1": "Linked Discourses 35.16 ",
    "sn35.16:0.2": "2. Pairs ",
    "sn35.16:0.3": "In Search of Gratification (Exterior) ",
    "sn35.16:1.1": "“Mendicants, I went in search of the gratification of sights, ",
    "sn35.16:1.2": "and I found it. …” ",
