  "root_text": {
    "sn56.89:0.1": "Saṁyutta Nikāya 56.89 ",
    "sn56.89:0.2": "9. Tatiyaāmakadhaññapeyyālavagga ",
    "sn56.89:0.3": "Kukkuṭasūkarasutta ",
    "sn56.89:1.1": "… “Evameva kho, bhikkhave, appakā te sattā ye kukkuṭasūkarapaṭiggahaṇā paṭiviratā; atha kho eteva bahutarā sattā ye kukkuṭasūkarapaṭiggahaṇā appaṭiviratā …pe…. ",
    "sn56.89:1.2": "Navamaṁ. "
  },
  "translation_text": {
    "sn56.89:0.1": "Linked Discourses 56.89 ",
    "sn56.89:0.2": "9. Abbreviated Texts on Raw Grain ",
    "sn56.89:0.3": "Chickens and Pigs ",
    "sn56.89:1.1": "“… the sentient beings who refrain from receiving chickens and pigs are few, while those who don’t refrain are many. …” "
  },
