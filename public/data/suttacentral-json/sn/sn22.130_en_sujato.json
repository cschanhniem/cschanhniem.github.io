  "root_text": {
    "sn22.130:0.1": "Saṁyutta Nikāya 22.130 ",
    "sn22.130:0.2": "13. Avijjāvagga ",
    "sn22.130:0.3": "Dutiyaassādasutta ",
    "sn22.130:1.1": "Bārāṇasiyaṁ viharanti isipatane migadāye …pe… ",
    "sn22.130:1.2": "“‘vijja, vijjā’ti, āvuso sāriputta, vuccati. ",
    "sn22.130:1.3": "Katamā nu kho, āvuso, vijjā; ",
    "sn22.130:1.4": "kittāvatā ca vijjāgato hotī”ti? ",
    "sn22.130:2.1": "“Idhāvuso, sutavā ariyasāvako rūpassa assādañca ādīnavañca nissaraṇañca yathābhūtaṁ pajānāti. ",
    "sn22.130:2.2": "Vedanāya …pe… ",
    "sn22.130:2.3": "saññāya … ",
    "sn22.130:2.4": "saṅkhārānaṁ … ",
    "sn22.130:2.5": "viññāṇassa assādañca ādīnavañca nissaraṇañca yathābhūtaṁ pajānāti. ",
    "sn22.130:2.6": "Ayaṁ vuccatāvuso, vijjā; ",
    "sn22.130:2.7": "ettāvatā ca vijjāgato hotī”ti. ",
    "sn22.130:2.8": "Pañcamaṁ. "
  },
  "translation_text": {
    "sn22.130:0.1": "Linked Discourses 22.130 ",
    "sn22.130:0.2": "13. Ignorance ",
    "sn22.130:0.3": "Gratification (2nd) ",
    "sn22.130:1.1": "At Varanasi. ",
    "sn22.130:1.2": "“Reverend Sāriputta, they speak of this thing called ‘knowledge’. ",
    "sn22.130:1.3": "What is knowledge? ",
    "sn22.130:1.4": "And how is a knowledgeable person defined?” ",
    "sn22.130:2.1": "“Reverend, a learned noble disciple truly understands the gratification, the drawback, and the escape when it comes to form, ",
    "sn22.130:2.2": "feeling, ",
    "sn22.130:2.3": "perception, ",
    "sn22.130:2.4": "choices, ",
    "sn22.130:2.5": "and consciousness. ",
    "sn22.130:2.6": "This is called knowledge. ",
    "sn22.130:2.7": "And this is how a knowledgeable person is defined.” "
  },
