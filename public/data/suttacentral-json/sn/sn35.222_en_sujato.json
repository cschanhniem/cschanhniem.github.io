  "root_text": {
    "sn35.222:0.1": "Saṁyutta Nikāya 35.222 ",
    "sn35.222:0.2": "17. Saṭṭhipeyyālavagga ",
    "sn35.222:0.3": "Ajjhattāyatanaaniccasutta ",
    "sn35.222:1.1": "“Cakkhu, bhikkhave, aniccaṁ …pe… jivhā aniccā …pe… mano anicco. ",
    "sn35.222:1.2": "Evaṁ passaṁ …pe… ",
    "sn35.222:1.3": "nāparaṁ itthattāyāti pajānātī”ti. "
  },
  "translation_text": {
    "sn35.222:0.1": "Linked Discourses 35.222 ",
    "sn35.222:0.2": "17. Sixty Abbreviated Texts ",
    "sn35.222:0.3": "The Interior as Impermanent ",
    "sn35.222:1.1": "“Mendicants, the eye, ear, nose, tongue, body, and mind are impermanent. ",
    "sn35.222:1.2": "Seeing this … ",
    "sn35.222:1.3": "They understand: ‘… there is nothing further for this place.’” "
  },
  "variant_text": {
    "sn35.222:0.3": "Ajjhattāyatanaaniccasutta → ajjhatta (tayo) 1 (pts1ed) "
  },
