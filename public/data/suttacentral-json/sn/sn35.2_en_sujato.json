  "root_text": {
    "sn35.2:0.1": "Saṁyutta Nikāya 35.2 ",
    "sn35.2:0.2": "1. Aniccavagga ",
    "sn35.2:0.3": "Ajjhattadukkhasutta ",
    "sn35.2:1.1": "“Cakkhuṁ, bhikkhave, dukkhaṁ. ",
    "sn35.2:1.2": "Yaṁ dukkhaṁ tadanattā; ",
    "sn35.2:1.3": "yadanattā taṁ ‘netaṁ mama, nesohamasmi, na meso attā’ti evametaṁ yathābhūtaṁ sammappaññāya daṭṭhabbaṁ. ",
    "sn35.2:1.4": "Sotaṁ dukkhaṁ …pe… ",
    "sn35.2:1.5": "ghānaṁ dukkhaṁ … ",
    "sn35.2:1.6": "jivhā dukkhā … ",
    "sn35.2:1.7": "kāyo dukkho … ",
    "sn35.2:1.8": "mano dukkho. ",
    "sn35.2:1.9": "Yaṁ dukkhaṁ tadanattā; ",
    "sn35.2:1.10": "yadanattā taṁ ‘netaṁ mama, nesohamasmi, na meso attā’ti evametaṁ yathābhūtaṁ sammappaññāya daṭṭhabbaṁ. ",
    "sn35.2:1.11": "Evaṁ passaṁ …pe… ",
    "sn35.2:1.12": "nāparaṁ itthattāyāti pajānātī”ti. ",
    "sn35.2:1.13": "Dutiyaṁ. "
  },
  "translation_text": {
    "sn35.2:0.1": "Linked Discourses 35.2 ",
    "sn35.2:0.2": "1. Impermanence ",
    "sn35.2:0.3": "The Interior as Suffering ",
    "sn35.2:1.1": "“Mendicants, the eye is suffering. ",
    "sn35.2:1.2": "What’s suffering is not-self. ",
    "sn35.2:1.3": "And what’s not-self should be truly seen with right understanding like this: ‘This is not mine, I am not this, this is not my self.’ ",
    "sn35.2:1.4": "The ear, ",
    "sn35.2:1.5": "nose, ",
    "sn35.2:1.6": "tongue, ",
    "sn35.2:1.7": "body, ",
    "sn35.2:1.8": "and mind are suffering. ",
    "sn35.2:1.9": "What’s suffering is not-self. ",
    "sn35.2:1.10": "And what’s not-self should be truly seen with right understanding like this: ‘This is not mine, I am not this, this is not my self.’ ",
    "sn35.2:1.11": "Seeing this … ",
    "sn35.2:1.12": "They understand: ‘… there is nothing further for this place.’” "
  },
  "variant_text": {
    "sn35.2:0.3": "Ajjhattadukkhasutta → dukkhaṁ 1; ajjhattaṁ (pts1ed) "
  },
