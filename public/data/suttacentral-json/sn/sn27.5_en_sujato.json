  "root_text": {
    "sn27.5:0.1": "Saṁyutta Nikāya 27.5 ",
    "sn27.5:0.2": "1. Kilesavagga ",
    "sn27.5:0.3": "Samphassajasutta ",
    "sn27.5:1.1": "Sāvatthinidānaṁ. ",
    "sn27.5:1.2": "“Yo, bhikkhave, cakkhusamphassajāya vedanāya chandarāgo, cittasseso upakkileso. ",
    "sn27.5:1.3": "Yo sotasamphassajāya vedanāya … ",
    "sn27.5:1.4": "yo ghānasamphassajāya vedanāya … ",
    "sn27.5:1.5": "yo jivhāsamphassajāya vedanāya … ",
    "sn27.5:1.6": "yo kāyasamphassajāya vedanāya … ",
    "sn27.5:1.7": "yo manosamphassajāya vedanāya chandarāgo, cittasseso upakkileso. ",
    "sn27.5:1.8": "Yato kho, bhikkhave, bhikkhuno …pe… ",
    "sn27.5:1.9": "abhiññā sacchikaraṇīyesu dhammesū”ti. ",
    "sn27.5:1.10": "Pañcamaṁ. "
  },
  "translation_text": {
    "sn27.5:0.1": "Linked Discourses 27.5 ",
    "sn27.5:0.2": "1. Corruptions ",
    "sn27.5:0.3": "Feeling ",
    "sn27.5:1.1": "At Sāvatthī. ",
    "sn27.5:1.2": "“Mendicants, desire and greed for feeling born of eye contact, ",
    "sn27.5:1.3": "feeling born of ear contact, ",
    "sn27.5:1.4": "feeling born of nose contact, ",
    "sn27.5:1.5": "feeling born of tongue contact, ",
    "sn27.5:1.6": "feeling born of body contact, ",
    "sn27.5:1.7": "or feeling born of mind contact is a defilement of the mind. …” ",
    "sn27.5:1.8": "",
    "sn27.5:1.9": ""
  },
  "variant_text": {
    "sn27.5:0.3": "Samphassajasutta → vedanāsuttaṁ (bj); vedanāya (pts1ed) "
  },
