  "root_text": {
    "sn14.27:0.1": "Saṁyutta Nikāya 14.27 ",
    "sn14.27:0.2": "3. Kammapathavagga ",
    "sn14.27:0.3": "Dasakammapathasutta ",
    "sn14.27:1.1": "Sāvatthiyaṁ viharati. ",
    "sn14.27:1.2": "“Dhātusova, bhikkhave, sattā saṁsandanti samenti. ",
    "sn14.27:1.3": "Pāṇātipātino pāṇātipātīhi saddhiṁ saṁsandanti samenti; ",
    "sn14.27:1.4": "adinnādāyino …pe… ",
    "sn14.27:1.5": "kāmesumicchācārino … ",
    "sn14.27:1.6": "musāvādino … ",
    "sn14.27:1.7": "pisuṇavācā … ",
    "sn14.27:1.8": "pharusavācā … ",
    "sn14.27:1.9": "samphappalāpino samphappalāpīhi saddhiṁ saṁsandanti samenti; ",
    "sn14.27:1.10": "abhijjhāluno abhijjhālūhi saddhiṁ saṁsandanti samenti; ",
    "sn14.27:1.11": "byāpannacittā byāpannacittehi saddhiṁ saṁsandanti samenti; ",
    "sn14.27:1.12": "micchādiṭṭhikā micchādiṭṭhikehi saddhiṁ saṁsandanti samenti. ",
    "sn14.27:2.1": "Pāṇātipātā paṭiviratā pāṇātipātā paṭiviratehi saddhiṁ saṁsandanti samenti; ",
    "sn14.27:2.2": "adinnādānā paṭiviratā …pe… ",
    "sn14.27:2.3": "kāmesumicchācārā paṭiviratā … ",
    "sn14.27:2.4": "musāvādā paṭiviratā … ",
    "sn14.27:2.5": "pisuṇāya vācāya … ",
    "sn14.27:2.6": "pharusāya vācāya … ",
    "sn14.27:2.7": "samphappalāpā paṭiviratā samphappalāpā paṭiviratehi saddhiṁ saṁsandanti samenti; ",
    "sn14.27:2.8": "anabhijjhāluno anabhijjhālūhi saddhiṁ saṁsandanti samenti; ",
    "sn14.27:2.9": "abyāpannacittā abyāpannacittehi saddhiṁ saṁsandanti samenti; ",
    "sn14.27:2.10": "sammādiṭṭhikā sammādiṭṭhikehi saddhiṁ saṁsandanti samentī”ti. ",
    "sn14.27:2.11": "Pañcamaṁ. "
  },
  "translation_text": {
    "sn14.27:0.1": "Linked Discourses 14.27 ",
    "sn14.27:0.2": "3. Ways of Performing Deeds ",
    "sn14.27:0.3": "Ten Ways of Performing Deeds ",
    "sn14.27:1.1": "At Sāvatthī. ",
    "sn14.27:1.2": "“Mendicants, sentient beings join together and converge because of an element: ",
    "sn14.27:1.3": "those who kill living creatures with those who kill living creatures, ",
    "sn14.27:1.4": "those who steal … ",
    "sn14.27:1.5": "commit sexual misconduct … ",
    "sn14.27:1.6": "lie … ",
    "sn14.27:1.7": "speak divisively … ",
    "sn14.27:1.8": "speak harshly … ",
    "sn14.27:1.9": "talk nonsense … ",
    "sn14.27:1.10": "are covetous … ",
    "sn14.27:1.11": "are malicious … ",
    "sn14.27:1.12": "have wrong view … ",
    "sn14.27:2.1": "Those who refrain from killing living creatures … ",
    "sn14.27:2.2": "who refrain from stealing … ",
    "sn14.27:2.3": "who refrain from sexual misconduct … ",
    "sn14.27:2.4": "who refrain from lying … ",
    "sn14.27:2.5": "who refrain from divisive speech … ",
    "sn14.27:2.6": "who refrain from harsh speech … ",
    "sn14.27:2.7": "who refrain from talking nonsense … ",
    "sn14.27:2.8": "are not covetous … ",
    "sn14.27:2.9": "are not malicious … ",
    "sn14.27:2.10": "have right view with those who have right view.” "
  },
