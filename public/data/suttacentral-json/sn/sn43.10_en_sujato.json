  "root_text": {
    "sn43.10:0.1": "Saṁyutta Nikāya 43.10 ",
    "sn43.10:0.2": "1. Paṭhamavagga ",
    "sn43.10:0.3": "Bojjhaṅgasutta ",
    "sn43.10:1.1": "“Katamo ca, bhikkhave, asaṅkhatagāmimaggo? ",
    "sn43.10:1.2": "Satta bojjhaṅgā. Ayaṁ vuccati, bhikkhave, asaṅkhatagāmimaggo …pe…. ",
    "sn43.10:1.3": "Dasamaṁ. "
  },
  "translation_text": {
    "sn43.10:0.1": "Linked Discourses 43.10 ",
    "sn43.10:0.2": "Chapter One ",
    "sn43.10:0.3": "Awakening Factors ",
    "sn43.10:1.1": "“And what is the path that leads to the unconditioned? ",
    "sn43.10:1.2": "The seven awakening factors. …” "
  },
