  "root_text": {
    "sn48.1:0.1": "Saṁyutta Nikāya 48.1 ",
    "sn48.1:0.2": "1. Suddhikavagga ",
    "sn48.1:0.3": "Suddhikasutta ",
    "sn48.1:1.1": "Sāvatthinidānaṁ. ",
    "sn48.1:1.2": "Tatra kho bhagavā etadavoca. ",
    "sn48.1:1.3": "“Pañcimāni, bhikkhave, indriyāni. ",
    "sn48.1:1.4": "Katamāni pañca? ",
    "sn48.1:1.5": "Saddhindriyaṁ, vīriyindriyaṁ, satindriyaṁ, samādhindriyaṁ, paññindriyaṁ—",
    "sn48.1:1.6": "imāni kho, bhikkhave, pañcindriyānī”ti. ",
    "sn48.1:1.7": "Paṭhamaṁ. "
  },
  "translation_text": {
    "sn48.1:0.1": "Linked Discourses 48.1 ",
    "sn48.1:0.2": "1. Plain Version ",
    "sn48.1:0.3": "Plain Version ",
    "sn48.1:1.1": "At Sāvatthī. ",
    "sn48.1:1.2": "There the Buddha said: ",
    "sn48.1:1.3": "“Mendicants, there are these five faculties. ",
    "sn48.1:1.4": "What five? ",
    "sn48.1:1.5": "The faculties of faith, energy, mindfulness, immersion, and wisdom. ",
    "sn48.1:1.6": "These are the five faculties.” "
  },
  "variant_text": {
    "sn48.1:0.2": "Suddhikavagga → suddhakavaggo (bj) ",
    "sn48.1:0.3": "Suddhikasutta → suddhakasuttaṁ (bj) "
  },
