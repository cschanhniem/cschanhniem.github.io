  "root_text": {
    "sn1.48:0.1": "Saṁyutta Nikāya 1.48 ",
    "sn1.48:0.2": "5. Ādittavagga ",
    "sn1.48:0.3": "Jetavanasutta ",
    "sn1.48:1.1": "“Idañhi taṁ jetavanaṁ, ",
    "sn1.48:1.2": "isisaṅghanisevitaṁ; ",
    "sn1.48:1.3": "Āvutthaṁ dhammarājena, ",
    "sn1.48:1.4": "pītisañjananaṁ mama. ",
    "sn1.48:2.1": "Kammaṁ vijjā ca dhammo ca, ",
    "sn1.48:2.2": "sīlaṁ jīvitamuttamaṁ; ",
    "sn1.48:2.3": "Etena maccā sujjhanti, ",
    "sn1.48:2.4": "na gottena dhanena vā. ",
    "sn1.48:3.1": "Tasmā hi paṇḍito poso, ",
    "sn1.48:3.2": "sampassaṁ atthamattano; ",
    "sn1.48:3.3": "Yoniso vicine dhammaṁ, ",
    "sn1.48:3.4": "evaṁ tattha visujjhati. ",
    "sn1.48:4.1": "Sāriputtova paññāya, ",
    "sn1.48:4.2": "sīlena upasamena ca; ",
    "sn1.48:4.3": "Yopi pāraṅgato bhikkhu, ",
    "sn1.48:4.4": "etāvaparamo siyā”ti. "
  },
  "translation_text": {
    "sn1.48:0.1": "Linked Discourses 1.48 ",
    "sn1.48:0.2": "5. On Fire ",
    "sn1.48:0.3": "Jeta’s Grove ",
    "sn1.48:1.1": "“This is indeed that Jeta’s Grove, ",
    "sn1.48:1.2": "frequented by the Saṅgha of seers, ",
    "sn1.48:1.3": "where the King of Dhamma stayed: ",
    "sn1.48:1.4": "it brings me joy! ",
    "sn1.48:2.1": "Deeds, knowledge, and principle; ",
    "sn1.48:2.2": "ethical conduct, an excellent livelihood; ",
    "sn1.48:2.3": "by these are mortals purified, ",
    "sn1.48:2.4": "not by clan or wealth. ",
    "sn1.48:3.1": "That’s why an astute person, ",
    "sn1.48:3.2": "seeing what’s good for themselves, ",
    "sn1.48:3.3": "would examine the teaching rationally, ",
    "sn1.48:3.4": "and thus be purified in it. ",
    "sn1.48:4.1": "Sāriputta is full of wisdom, ",
    "sn1.48:4.2": "ethics, and peace. ",
    "sn1.48:4.3": "Even a mendicant who has crossed over ",
    "sn1.48:4.4": "might at best equal him.” "
  },
  "variant_text": {
    "sn1.48:1.3": "Āvutthaṁ → āvuṭṭhaṁ (mr) "
  },
