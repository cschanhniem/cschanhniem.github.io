  "root_text": {
    "sn35.187:0.1": "Saṁyutta Nikāya 35.187 ",
    "sn35.187:0.2": "17. Saṭṭhipeyyālavagga ",
    "sn35.187:0.3": "Ajjhattānāgatāniccasutta ",
    "sn35.187:1.1": "“Cakkhu, bhikkhave, aniccaṁ anāgataṁ …pe… jivhā aniccā anāgatā …pe… mano anicco anāgato. ",
    "sn35.187:1.2": "Evaṁ passaṁ …pe… ",
    "sn35.187:1.3": "nāparaṁ itthattāyāti pajānātī”ti. "
  },
  "translation_text": {
    "sn35.187:0.1": "Linked Discourses 35.187 ",
    "sn35.187:0.2": "17. Sixty Abbreviated Texts ",
    "sn35.187:0.3": "The Interior Will Be Impermanent in the Future ",
    "sn35.187:1.1": "“Mendicants, in the future the eye, ear, nose, tongue, body, and mind will be impermanent …” ",
