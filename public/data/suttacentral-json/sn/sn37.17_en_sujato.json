  "root_text": {
    "sn37.17:0.1": "Saṁyutta Nikāya 37.17 ",
    "sn37.17:0.2": "2. Dutiyapeyyālavagga ",
    "sn37.17:0.3": "Anissukīsutta ",
    "sn37.17:1.1": "“Pañcahi, anuruddha, dhammehi samannāgato mātugāmo kāyassa bhedā paraṁ maraṇā sugatiṁ saggaṁ lokaṁ upapajjati. ",
    "sn37.17:1.2": "Katamehi pañcahi? ",
    "sn37.17:1.3": "Saddho ca hoti, hirimā ca hoti, ottappī ca hoti, anissukī ca hoti, paññavā ca hoti …pe…. ",
    "sn37.17:1.4": "Tatiyaṁ. "
  },
  "translation_text": {
    "sn37.17:0.1": "Linked Discourses 37.17 ",
    "sn37.17:0.2": "2. Abbreviated Texts ",
    "sn37.17:0.3": "Free of Jealousy ",
    "sn37.17:1.1": "",
    "sn37.17:1.2": "",
    "sn37.17:1.3": "“… They’re faithful, conscientious, prudent, free of jealousy, and wise. …” "
  },
