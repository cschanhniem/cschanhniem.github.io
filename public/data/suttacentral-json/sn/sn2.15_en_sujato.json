  "root_text": {
    "sn2.15:0.1": "Saṁyutta Nikāya 2.15 ",
    "sn2.15:0.2": "2. Anāthapiṇḍikavagga ",
    "sn2.15:0.3": "Candanasutta ",
    "sn2.15:1.1": "Ekamantaṁ ṭhito kho candano devaputto bhagavantaṁ gāthāya ajjhabhāsi: ",
    "sn2.15:2.1": "“Kathaṁsu tarati oghaṁ, ",
    "sn2.15:2.2": "rattindivamatandito; ",
    "sn2.15:2.3": "Appatiṭṭhe anālambe, ",
    "sn2.15:2.4": "ko gambhīre na sīdatī”ti. ",
    "sn2.15:3.1": "“Sabbadā sīlasampanno, ",
    "sn2.15:3.2": "Paññavā susamāhito; ",
    "sn2.15:3.3": "Āraddhavīriyo pahitatto, ",
    "sn2.15:3.4": "Oghaṁ tarati duttaraṁ. ",
    "sn2.15:4.1": "Virato kāmasaññāya, ",
    "sn2.15:4.2": "rūpasaṁyojanātigo; ",
    "sn2.15:4.3": "Nandīrāgaparikkhīṇo, ",
    "sn2.15:4.4": "so gambhīre na sīdatī”ti. "
  },
  "translation_text": {
    "sn2.15:0.1": "Linked Discourses 2.15 ",
    "sn2.15:0.2": "2. With Anāthapiṇḍika ",
    "sn2.15:0.3": "With Candana ",
    "sn2.15:1.1": "Standing to one side, the godling Candana addressed the Buddha in verse: ",
    "sn2.15:2.1": "“Who here crosses the flood, ",
    "sn2.15:2.2": "tireless all day and night? ",
    "sn2.15:2.3": "Who, not standing and unsupported, ",
    "sn2.15:2.4": "does not sink in the deep?” ",
    "sn2.15:3.1": "“Someone who is always endowed with ethics, ",
    "sn2.15:3.2": "wise and serene, ",
    "sn2.15:3.3": "energetic and resolute, ",
    "sn2.15:3.4": "crosses the flood so hard to cross. ",
    "sn2.15:4.1": "Someone who desists from sensual perception, ",
    "sn2.15:4.2": "has moved past the fetter of form, ",
    "sn2.15:4.3": "and has finished with relishing and greed ",
    "sn2.15:4.4": "does not sink in the deep.” "
  },
  "variant_text": {
    "sn2.15:2.1": "Kathaṁsu → ko sū dha (bj, pts2ed) "
  },
