  "root_text": {
    "sn43.6:0.1": "Saṁyutta Nikāya 43.6 ",
    "sn43.6:0.2": "1. Paṭhamavagga ",
    "sn43.6:0.3": "Sammappadhānasutta ",
    "sn43.6:1.1": "“Katamo ca, bhikkhave, asaṅkhatagāmimaggo? ",
    "sn43.6:1.2": "Cattāro sammappadhānā. Ayaṁ vuccati, bhikkhave, asaṅkhatagāmimaggo …pe…. ",
    "sn43.6:1.3": "Chaṭṭhaṁ. "
  },
  "translation_text": {
    "sn43.6:0.1": "Linked Discourses 43.6 ",
    "sn43.6:0.2": "Chapter One ",
    "sn43.6:0.3": "Right Efforts ",
    "sn43.6:1.1": "“And what is the path that leads to the unconditioned? ",
    "sn43.6:1.2": "The four right efforts. …” "
  },
