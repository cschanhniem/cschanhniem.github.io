  "root_text": {
    "sn9.12:0.1": "Saṁyutta Nikāya 9.12 ",
    "sn9.12:0.2": "1. Vanavagga ",
    "sn9.12:0.3": "Majjhanhikasutta ",
    "sn9.12:1.1": "Ekaṁ samayaṁ aññataro bhikkhu kosalesu viharati aññatarasmiṁ vanasaṇḍe. ",
    "sn9.12:1.2": "Atha kho tasmiṁ vanasaṇḍe adhivatthā devatā yena so bhikkhu tenupasaṅkami; upasaṅkamitvā tassa bhikkhuno santike imaṁ gāthaṁ abhāsi: ",
    "sn9.12:2.1": "“Ṭhite majjhanhike kāle, ",
    "sn9.12:2.2": "sannisīvesu pakkhisu; ",
    "sn9.12:2.3": "Saṇateva brahāraññaṁ, ",
    "sn9.12:2.4": "taṁ bhayaṁ paṭibhāti maṁ. ",
    "sn9.12:3.1": "Ṭhite majjhanhike kāle, ",
    "sn9.12:3.2": "sannisīvesu pakkhisu; ",
    "sn9.12:3.3": "Saṇateva brahāraññaṁ, ",
    "sn9.12:3.4": "sā rati paṭibhāti man”ti. "
  },
  "translation_text": {
    "sn9.12:0.1": "Linked Discourses 9.12 ",
    "sn9.12:0.2": "1. In the Woods ",
    "sn9.12:0.3": "Midday ",
    "sn9.12:1.1": "At one time one of the mendicants was staying in the land of the Kosalans in a certain forest grove. ",
    "sn9.12:1.2": "The deity haunting that forest approached that mendicant and spoke this verse in their presence: ",
    "sn9.12:2.1": "“In the still of high noon, ",
    "sn9.12:2.2": "when the birds have settled down, ",
    "sn9.12:2.3": "the mighty forest itself resounds—",
    "sn9.12:2.4": "that strikes me as so scary!” ",
    "sn9.12:3.1": "“In the still of high noon, ",
    "sn9.12:3.2": "when the birds have settled down, ",
    "sn9.12:3.3": "the mighty forest itself resounds—",
    "sn9.12:3.4": "that strikes me as so delightful!” "
  },
  "variant_text": {
    "sn9.12:0.3": "Majjhanhikasutta → majjhantikasuttaṁ (bj, sya-all, pts2ed); majjhantiko (saṇika) (pts1ed) ",
    "sn9.12:2.1": "majjhanhike → majjhantike (bj, sya-all, pts1ed, pts2ed) ",
    "sn9.12:2.2": "sannisīvesu → sannisinnesu (bj, sya-all, km, pts1ed, pts2ed) "
  },
