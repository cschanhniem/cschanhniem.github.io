  "root_text": {
    "sn46.111-120:0.1": "Saṁyutta Nikāya 46.111–120 ",
    "sn46.111-120:0.2": "12. Esanāvagga ",
    "sn46.111-120:0.3": "Esanādisutta ",
    "sn46.111-120:1.1": "“Tisso imā, bhikkhave, esanā. ",
    "sn46.111-120:1.2": "Katamā tisso? ",
    "sn46.111-120:1.3": "Kāmesanā, bhavesanā, brahmacariyesanā”ti vitthāretabbaṁ. ",
    "sn46.111-120:1.4": "Esanāvaggo dvādasamo. ",
    "sn46.111-120:2.0": "Tassuddānaṁ ",
    "sn46.111-120:2.1": "Esanā vidhā āsavo, ",
    "sn46.111-120:2.2": "Bhavo ca dukkhatā tisso; ",
    "sn46.111-120:2.3": "Khilaṁ malañca nīgho ca, ",
    "sn46.111-120:2.4": "Vedanā taṇhā tasināya cāti. ",
    "sn46.111-120:3.1": "(Bojjhaṅgasaṁyuttassa esanāpeyyālaṁ vivekanissitato vitthāretabbaṁ.) "
  },
  "translation_text": {
    "sn46.111-120:0.1": "Linked Discourses 46.111–120 ",
    "sn46.111-120:0.2": "12. Searches ",
    "sn46.111-120:0.3": "Searches, Etc. ",
    "sn46.111-120:1.1": "“Mendicants, there are these three searches. ",
    "sn46.111-120:1.2": "What three? ",
    "sn46.111-120:1.3": "The search for sensual pleasures, the search for continued existence, and the search for a spiritual path. …” ",
    "sn46.111-120:1.4": "",
    "sn46.111-120:2.1": "",
    "sn46.111-120:2.2": "",
    "sn46.111-120:2.3": "",
    "sn46.111-120:2.4": "",
    "sn46.111-120:3.1": "(Tell in full as in SN 45.161–170.) "
  },
