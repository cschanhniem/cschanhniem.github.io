  "root_text": {
    "sn27.7:0.1": "Saṁyutta Nikāya 27.7 ",
    "sn27.7:0.2": "1. Kilesavagga ",
    "sn27.7:0.3": "Sañcetanāsutta ",
    "sn27.7:1.1": "Sāvatthinidānaṁ. ",
    "sn27.7:1.2": "“Yo, bhikkhave, rūpasañcetanāya chandarāgo, cittasseso upakkileso. ",
    "sn27.7:1.3": "Yo saddasañcetanāya … ",
    "sn27.7:1.4": "yo gandhasañcetanāya … ",
    "sn27.7:1.5": "yo rasasañcetanāya … ",
    "sn27.7:1.6": "yo phoṭṭhabbasañcetanāya … ",
    "sn27.7:1.7": "yo dhammasañcetanāya chandarāgo, cittasseso upakkileso. ",
    "sn27.7:1.8": "Yato kho, bhikkhave, bhikkhuno …pe… ",
    "sn27.7:1.9": "abhiññā sacchikaraṇīyesu dhammesū”ti. ",
    "sn27.7:1.10": "Sattamaṁ. "
  },
  "translation_text": {
    "sn27.7:0.1": "Linked Discourses 27.7 ",
    "sn27.7:0.2": "1. Corruptions ",
    "sn27.7:0.3": "Intention ",
    "sn27.7:1.1": "At Sāvatthī. ",
    "sn27.7:1.2": "“Mendicants, desire and greed for intention regarding sights, ",
    "sn27.7:1.3": "intention regarding sounds, ",
    "sn27.7:1.4": "intention regarding smells, ",
    "sn27.7:1.5": "intention regarding tastes, ",
    "sn27.7:1.6": "intention regarding touches, ",
    "sn27.7:1.7": "or intention regarding ideas is a corruption of the mind. …” ",
    "sn27.7:1.8": "",
    "sn27.7:1.9": ""
  },
  "variant_text": {
    "sn27.7:0.3": "Sañcetanāsutta → cetanāsuttaṁ (bj); cetanā (pts1ed) "
  },
