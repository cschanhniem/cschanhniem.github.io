  "root_text": {
    "sn34.13:0.1": "Saṁyutta Nikāya 34.13 ",
    "sn34.13:0.2": "1. Jhānavagga ",
    "sn34.13:0.3": "Samāpattimūlakakallitasutta ",
    "sn34.13:1.1": "Sāvatthinidānaṁ. ",
    "sn34.13:1.2": "“Cattārome, bhikkhave, jhāyī. ",
    "sn34.13:1.3": "Katame cattāro? ",
    "sn34.13:1.4": "Idha, bhikkhave, ekacco jhāyī samādhismiṁ samāpattikusalo hoti, na samādhismiṁ kallitakusalo. ",
    "sn34.13:1.5": "Idha pana, bhikkhave, ekacco jhāyī samādhismiṁ kallitakusalo hoti, na samādhismiṁ samāpattikusalo. ",
    "sn34.13:1.6": "Idha pana, bhikkhave, ekacco jhāyī neva samādhismiṁ samāpattikusalo hoti, na ca samādhismiṁ kallitakusalo. ",
    "sn34.13:1.7": "Idha pana, bhikkhave, ekacco jhāyī samādhismiṁ samāpattikusalo ca hoti, samādhismiṁ kallitakusalo ca. ",
    "sn34.13:1.8": "Tatra …pe… ",
    "sn34.13:1.9": "pavaro cā”ti. ",
    "sn34.13:1.10": "Terasamaṁ. "
  },
  "translation_text": {
    "sn34.13:0.1": "Linked Discourses 34.13 ",
    "sn34.13:0.2": "1. Absorption ",
    "sn34.13:0.3": "Entering and Gladdening ",
    "sn34.13:1.1": "At Sāvatthī. ",
    "sn34.13:1.2": "“Mendicants, there are these four meditators. ",
    "sn34.13:1.3": "What four? ",
    "sn34.13:1.4": "One meditator is skilled in entering immersion but not in positivity for immersion. …” "
  },
  "variant_text": {
    "sn34.13:0.3": "Samāpattimūlakakallitasutta → samāpattikallitakusalasuttaṁ (bj); samāpatti-kallita (pts1ed) "
  },
