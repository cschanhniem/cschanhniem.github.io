  "root_text": {
    "sn56.88:0.1": "Saṁyutta Nikāya 56.88 ",
    "sn56.88:0.2": "9. Tatiyaāmakadhaññapeyyālavagga ",
    "sn56.88:0.3": "Ajeḷakasutta ",
    "sn56.88:1.1": "… “Evameva kho, bhikkhave, appakā te sattā ye ajeḷakapaṭiggahaṇā paṭiviratā; atha kho eteva bahutarā sattā ye ajeḷakapaṭiggahaṇā appaṭiviratā …pe…. ",
    "sn56.88:1.2": "Aṭṭhamaṁ. "
  },
  "translation_text": {
    "sn56.88:0.1": "Linked Discourses 56.88 ",
    "sn56.88:0.2": "9. Abbreviated Texts on Raw Grain ",
    "sn56.88:0.3": "Goats and Sheep ",
    "sn56.88:1.1": "“… the sentient beings who refrain from receiving goats and sheep are few, while those who don’t refrain are many. …” "
  },
