  "root_text": {
    "sn46.58:0.1": "Saṁyutta Nikāya 46.58 ",
    "sn46.58:0.2": "7. Ānāpānavagga ",
    "sn46.58:0.3": "Puḷavakasutta ",
    "sn46.58:1.1": "“Puḷavakasaññā, bhikkhave, bhāvitā …pe…” ",
    "sn46.58:1.2": "dutiyaṁ. "
  },
  "translation_text": {
    "sn46.58:0.1": "Linked Discourses 46.58 ",
    "sn46.58:0.2": "7. Breathing ",
    "sn46.58:0.3": "Worm-Infested ",
    "sn46.58:1.1": "“Mendicants, when the perception of a worm-infested corpse is developed and cultivated it’s very fruitful and beneficial. …” "
  },
  "variant_text": {
