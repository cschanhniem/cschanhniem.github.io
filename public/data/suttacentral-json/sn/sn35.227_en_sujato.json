  "root_text": {
    "sn35.227:0.1": "Saṁyutta Nikāya 35.227 ",
    "sn35.227:0.2": "17. Saṭṭhipeyyālavagga ",
    "sn35.227:0.3": "Bāhirāyatanaanattasutta ",
    "sn35.227:1.1": "“Rūpā, bhikkhave, anattā. Saddā … gandhā … rasā … phoṭṭhabbā … dhammā anattā. ",
    "sn35.227:1.2": "Evaṁ passaṁ …pe… ",
    "sn35.227:1.3": "nāparaṁ itthattāyāti pajānātī”ti. ",
    "sn35.227:1.4": "Saṭṭhipeyyālo samatto. ",
    "sn35.227:2.0": "Tassuddānaṁ ",
    "sn35.227:2.1": "Chandenaṭṭhārasa honti, ",
    "sn35.227:2.2": "atītena ca dve nava; ",
    "sn35.227:2.3": "Yadaniccāṭṭhārasa vuttā, ",
    "sn35.227:2.4": "tayo ajjhattabāhirā; ",
    "sn35.227:2.5": "Peyyālo saṭṭhiko vutto, ",
    "sn35.227:2.6": "buddhenādiccabandhunāti. ",
    "sn35.227:2.7": "Suttantāni saṭṭhi. "
  },
  "translation_text": {
    "sn35.227:0.1": "Linked Discourses 35.227 ",
    "sn35.227:0.2": "17. Sixty Abbreviated Texts ",
    "sn35.227:0.3": "The Exterior as Not-Self ",
    "sn35.227:1.1": "“Mendicants, sights, sounds, smells, tastes, touches, and ideas are not-self. ",
    "sn35.227:1.2": "Seeing this … ",
    "sn35.227:1.3": "They understand: ‘… there is nothing further for this place.’” ",
