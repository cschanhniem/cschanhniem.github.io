  "root_text": {
    "sn1.26:0.1": "Saṁyutta Nikāya 1.26 ",
    "sn1.26:0.2": "3. Sattivagga ",
    "sn1.26:0.3": "Pajjotasutta ",
    "sn1.26:1.1": "“Kati lokasmiṁ pajjotā, ",
    "sn1.26:1.2": "Tehi loko pakāsati; ",
    "sn1.26:1.3": "Bhagavantaṁ puṭṭhumāgamma, ",
    "sn1.26:1.4": "Kathaṁ jānemu taṁ mayan”ti. ",
    "sn1.26:2.1": "“Cattāro loke pajjotā, ",
    "sn1.26:2.2": "pañcamettha na vijjati; ",
    "sn1.26:2.3": "Divā tapati ādicco, ",
    "sn1.26:2.4": "rattimābhāti candimā. ",
    "sn1.26:3.1": "Atha aggi divārattiṁ, ",
    "sn1.26:3.2": "tattha tattha pakāsati; ",
    "sn1.26:3.3": "Sambuddho tapataṁ seṭṭho, ",
    "sn1.26:3.4": "esā ābhā anuttarā”ti. "
  },
  "translation_text": {
    "sn1.26:0.1": "Linked Discourses 1.26 ",
    "sn1.26:0.2": "3. A Sword ",
    "sn1.26:0.3": "Lamps ",
    "sn1.26:1.1": "“How many lamps are there ",
    "sn1.26:1.2": "that light up the world? ",
    "sn1.26:1.3": "We’ve come to ask you, worthy sir: ",
    "sn1.26:1.4": "how are we to understand this?” ",
    "sn1.26:2.1": "“There are four lamps in the world, ",
    "sn1.26:2.2": "a fifth is not found. ",
    "sn1.26:2.3": "The sun blazes by day, ",
    "sn1.26:2.4": "the moon radiates at night, ",
    "sn1.26:3.1": "while a fire illuminates both ",
    "sn1.26:3.2": "by day and by night. ",
    "sn1.26:3.3": "But a Buddha is the best of blazes: ",
    "sn1.26:3.4": "this is the supreme radiance.” "
  },
  "variant_text": {
    "sn1.26:1.2": "pakāsati → pabhāsati (bj) ",
