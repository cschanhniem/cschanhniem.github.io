  "root_text": {
    "sn14.21:0.1": "Saṁyutta Nikāya 14.21 ",
    "sn14.21:0.2": "2. Dutiyavagga ",
    "sn14.21:0.3": "Appassutamūlakasutta ",
    "sn14.21:1.1": "Sāvatthiyaṁ viharati. ",
    "sn14.21:1.2": "“Dhātusova, bhikkhave, sattā saṁsandanti samenti. ",
    "sn14.21:1.3": "Appassutā appassutehi saddhiṁ saṁsandanti samenti; ",
    "sn14.21:1.4": "kusītā kusītehi saddhiṁ saṁsandanti samenti; ",
    "sn14.21:1.5": "duppaññā duppaññehi saddhiṁ saṁsandanti samenti; ",
    "sn14.21:1.6": "bahussutā bahussutehi saddhiṁ saṁsandanti samenti; ",
    "sn14.21:1.7": "āraddhavīriyā āraddhavīriyehi saddhiṁ saṁsandanti samenti; paññavanto paññavantehi saddhiṁ saṁsandanti samenti …pe…. ",
    "sn14.21:2.1": "Appassutā appassutehi saddhiṁ saṁsandanti samenti; ",
    "sn14.21:2.2": "muṭṭhassatino muṭṭhassatīhi saddhiṁ saṁsandanti samenti; ",
    "sn14.21:2.3": "duppaññā duppaññehi saddhiṁ saṁsandanti samenti; ",
    "sn14.21:2.4": "bahussutā bahussutehi saddhiṁ saṁsandanti samenti; ",
    "sn14.21:2.5": "upaṭṭhitassatino upaṭṭhitassatīhi saddhiṁ saṁsandanti samenti; paññavanto paññavantehi saddhiṁ saṁsandanti samentī”ti …pe…. ",
    "sn14.21:2.6": "Ekādasamaṁ. "
  },
  "translation_text": {
    "sn14.21:0.1": "Linked Discourses 14.21 ",
    "sn14.21:0.2": "Chapter Two ",
    "sn14.21:0.3": "Beginning With the Unlearned ",
    "sn14.21:1.1": "At Sāvatthī. ",
    "sn14.21:1.2": "“Mendicants, sentient beings join together and converge because of an element: ",
    "sn14.21:1.3": "the unlearned with the unlearned … ",
    "sn14.21:1.4": "lazy … ",
    "sn14.21:1.5": "witless. ",
    "sn14.21:1.6": "The learned with the learned … ",
    "sn14.21:1.7": "energetic … wise. ",
    "sn14.21:2.1": "… the unlearned with the unlearned … ",
    "sn14.21:2.2": "unmindful … ",
    "sn14.21:2.3": "witless. ",
    "sn14.21:2.4": "The learned with the learned … ",
    "sn14.21:2.5": "mindful … wise.” "
  },
  "variant_text": {
    "sn14.21:0.3": "Appassutamūlakasutta → appassutamūlakatikadvayasuttaṁ (bj); appassutena dve (pts1ed, pts2ed) "
  },
