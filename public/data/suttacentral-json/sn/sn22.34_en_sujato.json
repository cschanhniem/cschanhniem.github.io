  "root_text": {
    "sn22.34:0.1": "Saṁyutta Nikāya 22.34 ",
    "sn22.34:0.2": "4. Natumhākavagga ",
    "sn22.34:0.3": "Dutiyanatumhākasutta ",
    "sn22.34:1.1": "Sāvatthinidānaṁ. ",
    "sn22.34:1.2": "“Yaṁ, bhikkhave, na tumhākaṁ, taṁ pajahatha. ",
    "sn22.34:1.3": "Taṁ vo pahīnaṁ hitāya sukhāya bhavissati. ",
    "sn22.34:1.4": "Kiñca, bhikkhave, na tumhākaṁ? ",
    "sn22.34:1.5": "Rūpaṁ, bhikkhave, na tumhākaṁ, taṁ pajahatha. ",
    "sn22.34:1.6": "Taṁ vo pahīnaṁ hitāya sukhāya bhavissati. ",
    "sn22.34:1.7": "Vedanā na tumhākaṁ … ",
    "sn22.34:1.8": "saññā na tumhākaṁ … ",
    "sn22.34:1.9": "saṅkhārā na tumhākaṁ … ",
    "sn22.34:1.10": "viññāṇaṁ na tumhākaṁ, taṁ pajahatha. ",
    "sn22.34:1.11": "Taṁ vo pahīnaṁ hitāya sukhāya bhavissati. ",
    "sn22.34:1.12": "Yaṁ, bhikkhave, na tumhākaṁ taṁ pajahatha. ",
    "sn22.34:1.13": "Taṁ vo pahīnaṁ hitāya sukhāya bhavissatī”ti. ",
    "sn22.34:1.14": "Dutiyaṁ. "
  },
  "translation_text": {
    "sn22.34:0.1": "Linked Discourses 22.34 ",
    "sn22.34:0.2": "4. It’s Not Yours ",
    "sn22.34:0.3": "It’s Not Yours (2nd) ",
    "sn22.34:1.1": "At Sāvatthī. ",
    "sn22.34:1.2": "“Mendicants, give up what’s not yours. ",
    "sn22.34:1.3": "Giving it up will be for your welfare and happiness. ",
    "sn22.34:1.4": "And what isn’t yours? ",
    "sn22.34:1.5": "Form isn’t yours: give it up. ",
    "sn22.34:1.6": "Giving it up will be for your welfare and happiness. ",
    "sn22.34:1.7": "Feeling … ",
    "sn22.34:1.8": "Perception … ",
    "sn22.34:1.9": "Choices … ",
    "sn22.34:1.10": "Consciousness isn’t yours: give it up. ",
    "sn22.34:1.11": "Giving it up will be for your welfare and happiness. ",
    "sn22.34:1.12": "Give up what’s not yours. ",
    "sn22.34:1.13": "Giving it up will be for your welfare and happiness.” "
  },
