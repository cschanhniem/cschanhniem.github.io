  "root_text": {
    "sn56.87:0.1": "Saṁyutta Nikāya 56.87 ",
    "sn56.87:0.2": "9. Tatiyaāmakadhaññapeyyālavagga ",
    "sn56.87:0.3": "Dāsidāsasutta ",
    "sn56.87:1.1": "… “Evameva kho, bhikkhave, appakā te sattā ye dāsidāsapaṭiggahaṇā paṭiviratā; atha kho eteva bahutarā sattā ye dāsidāsapaṭiggahaṇā appaṭiviratā …pe…. ",
    "sn56.87:1.2": "Sattamaṁ. "
  },
  "translation_text": {
    "sn56.87:0.1": "Linked Discourses 56.87 ",
    "sn56.87:0.2": "9. Abbreviated Texts on Raw Grain ",
    "sn56.87:0.3": "Bondservants ",
    "sn56.87:1.1": "“… the sentient beings who refrain from receiving male and female bondservants are few, while those who don’t refrain are many. …” "
  },
  "variant_text": {
    "sn56.87:0.3": "Dāsidāsasutta → dāsī (pts1ed) ",
    "sn56.87:1.1": "dāsidāsapaṭiggahaṇā → dāsīdāsapaṭiggahaṇā (sya-all, km, pts1ed) "
  },
