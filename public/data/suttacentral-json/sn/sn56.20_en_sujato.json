  "root_text": {
    "sn56.20:0.1": "Saṁyutta Nikāya 56.20 ",
    "sn56.20:0.2": "2. Dhammacakkappavattanavagga ",
    "sn56.20:0.3": "Tathasutta ",
    "sn56.20:1.1": "“Cattārimāni, bhikkhave, tathāni avitathāni anaññathāni. ",
    "sn56.20:1.2": "Katamāni cattāri? ",
    "sn56.20:1.3": "‘Idaṁ dukkhan’ti, bhikkhave, tathametaṁ avitathametaṁ anaññathametaṁ; ",
    "sn56.20:1.4": "‘ayaṁ dukkhasamudayo’ti tathametaṁ avitathametaṁ anaññathametaṁ; ",
    "sn56.20:1.5": "‘ayaṁ dukkhanirodho’ti tathametaṁ avitathametaṁ anaññathametaṁ; ",
    "sn56.20:1.6": "‘ayaṁ dukkhanirodhagāminī paṭipadā’ti tathametaṁ avitathametaṁ anaññathametaṁ—",
    "sn56.20:1.7": "imāni kho, bhikkhave, cattāri tathāni avitathāni anaññathāni. ",
    "sn56.20:2.1": "Tasmātiha, bhikkhave, ‘idaṁ dukkhan’ti yogo karaṇīyo …pe… ‘ayaṁ dukkhanirodhagāminī paṭipadā’ti yogo karaṇīyo”ti. ",
    "sn56.20:2.2": "Dasamaṁ. ",
    "sn56.20:2.3": "Dhammacakkappavattanavaggo dutiyo. ",
    "sn56.20:3.0": "Tassuddānaṁ ",
    "sn56.20:3.1": "Dhammacakkaṁ tathāgataṁ, ",
    "sn56.20:3.2": "khandhā āyatanena ca; ",
    "sn56.20:3.3": "Dhāraṇā ca dve avijjā, ",
    "sn56.20:3.4": "vijjā saṅkāsanā tathāti. "
  },
  "translation_text": {
    "sn56.20:0.1": "Linked Discourses 56.20 ",
    "sn56.20:0.2": "2. Rolling Forth the Wheel of Dhamma ",
    "sn56.20:0.3": "Real ",
    "sn56.20:1.1": "“Mendicants, these four things are real, not unreal, not otherwise. ",
    "sn56.20:1.2": "What four? ",
    "sn56.20:1.3": "‘This is suffering’ … ",
    "sn56.20:1.4": "‘This is the origin of suffering’ … ",
    "sn56.20:1.5": "‘This is the cessation of suffering’ … ",
    "sn56.20:1.6": "‘This is the practice that leads to the cessation of suffering’ … ",
    "sn56.20:1.7": "These four things are real, not unreal, not otherwise. ",
    "sn56.20:2.1": "That’s why you should practice meditation …” ",
