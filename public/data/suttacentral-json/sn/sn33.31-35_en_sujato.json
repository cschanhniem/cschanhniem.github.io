  "root_text": {
    "sn33.31-35:0.1": "Saṁyutta Nikāya 33.31–35 ",
    "sn33.31-35:0.2": "1. Vacchagottavagga ",
    "sn33.31-35:0.3": "Rūpaanupalakkhaṇādisuttapañcaka ",
    "sn33.31-35:1.1": "Sāvatthinidānaṁ. ",
    "sn33.31-35:1.2": "“Rūpe kho, vaccha, anupalakkhaṇā …pe… viññāṇe kho, vaccha, anupalakkhaṇā …pe…. ",
    "sn33.31-35:1.3": "Pañcatiṁsatimaṁ. "
  },
  "translation_text": {
    "sn33.31-35:0.1": "Linked Discourses 33.31–35 ",
    "sn33.31-35:0.2": "1. With Vacchagotta ",
    "sn33.31-35:0.3": "Five Discourses on Not Detecting Form, Etc. ",
    "sn33.31-35:1.1": "At Sāvatthī. ",
    "sn33.31-35:1.2": "“Vaccha, it is because of not detecting form …” "
  },
