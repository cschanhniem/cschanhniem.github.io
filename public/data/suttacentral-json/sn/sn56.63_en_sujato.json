  "root_text": {
    "sn56.63:0.1": "Saṁyutta Nikāya 56.63 ",
    "sn56.63:0.2": "7. Paṭhamaāmakadhaññapeyyālavagga ",
    "sn56.63:0.3": "Paññāsutta ",
    "sn56.63:1.1": "… “Evameva kho, bhikkhave, appakā te sattā ye pana ariyena paññācakkhunā samannāgatā; atha kho eteva bahutarā sattā ye avijjāgatā sammuḷhā …pe…. ",
    "sn56.63:1.2": "Tatiyaṁ. "
  },
  "translation_text": {
    "sn56.63:0.1": "Linked Discourses 56.63 ",
    "sn56.63:0.2": "7. Abbreviated Texts on Raw Grain ",
    "sn56.63:0.3": "Wisdom ",
    "sn56.63:1.1": "“… the sentient beings who have the noble eye of wisdom are few, while those who are ignorant and confused are many. …” "
  },
