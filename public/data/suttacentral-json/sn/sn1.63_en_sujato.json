  "root_text": {
    "sn1.63:0.1": "Saṁyutta Nikāya 1.63 ",
    "sn1.63:0.2": "7. Addhavagga ",
    "sn1.63:0.3": "Taṇhāsutta ",
    "sn1.63:1.1": "“Kenassu nīyati loko, ",
    "sn1.63:1.2": "kenassu parikassati; ",
    "sn1.63:1.3": "Kissassu ekadhammassa, ",
    "sn1.63:1.4": "sabbeva vasamanvagū”ti. ",
    "sn1.63:2.1": "“Taṇhāya nīyati loko, ",
    "sn1.63:2.2": "taṇhāya parikassati; ",
    "sn1.63:2.3": "Taṇhāya ekadhammassa, ",
    "sn1.63:2.4": "sabbeva vasamanvagū”ti. "
  },
  "translation_text": {
    "sn1.63:0.1": "Linked Discourses 1.63 ",
    "sn1.63:0.2": "7. Overcome ",
    "sn1.63:0.3": "Craving ",
    "sn1.63:1.1": "“What leads the world on? ",
    "sn1.63:1.2": "What drags it around? ",
    "sn1.63:1.3": "What is the one thing ",
    "sn1.63:1.4": "that has everything under its sway?” ",
    "sn1.63:2.1": "“Craving leads the world on. ",
    "sn1.63:2.2": "Craving drags it around. ",
    "sn1.63:2.3": "Craving is the one thing ",
    "sn1.63:2.4": "that has everything under its sway.” "
  },
