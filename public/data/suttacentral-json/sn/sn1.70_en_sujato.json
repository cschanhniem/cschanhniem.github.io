  "root_text": {
    "sn1.70:0.1": "Saṁyutta Nikāya 1.70 ",
    "sn1.70:0.2": "7. Addhavagga ",
    "sn1.70:0.3": "Lokasutta ",
    "sn1.70:1.1": "“Kismiṁ loko samuppanno, ",
    "sn1.70:1.2": "kismiṁ kubbati santhavaṁ; ",
    "sn1.70:1.3": "Kissa loko upādāya, ",
    "sn1.70:1.4": "kismiṁ loko vihaññatī”ti. ",
    "sn1.70:2.1": "“Chasu loko samuppanno, ",
    "sn1.70:2.2": "chasu kubbati santhavaṁ; ",
    "sn1.70:2.3": "Channameva upādāya, ",
    "sn1.70:2.4": "chasu loko vihaññatī”ti. ",
    "sn1.70:2.5": "Addhavaggo sattamo. ",
    "sn1.70:3.0": "Tassuddānaṁ ",
    "sn1.70:3.1": "Nāmaṁ cittañca taṇhā ca, ",
    "sn1.70:3.2": "saṁyojanañca bandhanā; ",
    "sn1.70:3.3": "Abbhāhatuḍḍito pihito, ",
    "sn1.70:3.4": "icchā lokena te dasāti. "
  },
  "translation_text": {
    "sn1.70:0.1": "Linked Discourses 1.70 ",
    "sn1.70:0.2": "7. Overcome ",
    "sn1.70:0.3": "The World ",
    "sn1.70:1.1": "“In what has the world arisen? ",
    "sn1.70:1.2": "With what does it get intimate? ",
    "sn1.70:1.3": "By grasping what ",
    "sn1.70:1.4": "is the world troubled in what?” ",
    "sn1.70:2.1": "“The world has arisen in six. ",
    "sn1.70:2.2": "It gets intimate with six. ",
    "sn1.70:2.3": "Derived from the six, ",
    "sn1.70:2.4": "the world’s troubled in six.” ",
