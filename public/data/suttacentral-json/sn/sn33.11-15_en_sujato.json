  "root_text": {
    "sn33.11:0.1": "Saṁyutta Nikāya 33.11–15 ",
    "sn33.11:0.2": "1. Vacchagottavagga ",
    "sn33.11:0.3": "Rūpaanabhisamayādisuttapañcaka ",
    "sn33.11:1.1": "Sāvatthinidānaṁ. ",
    "sn33.11:1.2": "“Rūpe kho, vaccha, anabhisamayā …pe… rūpanirodhagāminiyā paṭipadāya anabhisamayā …pe…. ",
    "sn33.12:1.1": "Sāvatthinidānaṁ. ",
    "sn33.12:1.2": "“Vedanāya kho, vaccha, anabhisamayā …pe…. ",
    "sn33.13:1.1": "Sāvatthinidānaṁ. ",
    "sn33.13:1.2": "“Saññāya kho, vaccha, anabhisamayā …pe…. ",
    "sn33.14:1.1": "Sāvatthinidānaṁ. ",
    "sn33.14:1.2": "“Saṅkhāresu kho, vaccha, anabhisamayā …pe…. ",
    "sn33.15:1.1": "Sāvatthinidānaṁ. ",
    "sn33.15:1.2": "“Viññāṇe kho, vaccha, anabhisamayā …pe…. ",
    "sn33.15:1.3": "Pannarasamaṁ. "
  },
  "translation_text": {
    "sn33.11:0.1": "Linked Discourses 33.11 ",
    "sn33.11:0.2": "1. With Vacchagotta ",
    "sn33.11:0.3": "Five Discourses on Not Comprehending Form, Etc. ",
    "sn33.11:1.1": "At Sāvatthī. ",
    "sn33.11:1.2": "“Vaccha, it is because of not comprehending form … ",
    "sn33.12:1.1": "",
    "sn33.12:1.2": "feeling … ",
    "sn33.13:1.1": "",
    "sn33.13:1.2": "perception … ",
    "sn33.14:1.1": "",
    "sn33.14:1.2": "choices … ",
    "sn33.15:1.1": "",
    "sn33.15:1.2": "consciousness …” "
  },
