  "root_text": {
    "sn35.12:0.1": "Saṁyutta Nikāya 35.12 ",
    "sn35.12:0.2": "1. Aniccavagga ",
    "sn35.12:0.3": "Bāhirānattātītānāgatasutta ",
    "sn35.12:1.1": "“Rūpā, bhikkhave, anattā atītānāgatā; ",
    "sn35.12:1.2": "ko pana vādo paccuppannānaṁ. ",
    "sn35.12:1.3": "Evaṁ passaṁ, bhikkhave, sutavā ariyasāvako atītesu rūpesu anapekkho hoti; ",
    "sn35.12:1.4": "anāgate rūpe nābhinandati; ",
    "sn35.12:1.5": "paccuppannānaṁ rūpānaṁ nibbidāya virāgāya nirodhāya paṭipanno hoti. ",
    "sn35.12:1.6": "Saddā … ",
    "sn35.12:1.7": "gandhā … ",
    "sn35.12:1.8": "rasā … ",
    "sn35.12:1.9": "phoṭṭhabbā … ",
    "sn35.12:1.10": "dhammā anattā atītānāgatā; ",
    "sn35.12:1.11": "ko pana vādo paccuppannānaṁ. ",
    "sn35.12:1.12": "Evaṁ passaṁ, bhikkhave, sutavā ariyasāvako atītesu dhammesu anapekkho hoti; ",
    "sn35.12:1.13": "anāgate dhamme nābhinandati; ",
    "sn35.12:1.14": "paccuppannānaṁ dhammānaṁ nibbidāya virāgāya nirodhāya paṭipanno hotī”ti. ",
    "sn35.12:1.15": "Dvādasamaṁ. ",
    "sn35.12:1.16": "Aniccavaggo paṭhamo. ",
    "sn35.12:2.0": "Tassuddānaṁ ",
    "sn35.12:2.1": "Aniccaṁ dukkhaṁ anattā ca, ",
    "sn35.12:2.2": "tayo ajjhattabāhirā; ",
    "sn35.12:2.3": "Yadaniccena tayo vuttā, ",
    "sn35.12:2.4": "te te ajjhattabāhirāti. "
  },
  "translation_text": {
    "sn35.12:0.1": "Linked Discourses 35.12 ",
    "sn35.12:0.2": "1. Impermanence ",
    "sn35.12:0.3": "The Exterior as Not-Self in the Three Times ",
    "sn35.12:1.1": "“Mendicants, sights of the past and future are not-self, ",
    "sn35.12:1.2": "let alone the present. …” ",
