  "root_text": {
    "sn1.76:0.1": "Saṁyutta Nikāya 1.76 ",
    "sn1.76:0.2": "8. Chetvāvagga ",
    "sn1.76:0.3": "Najīratisutta ",
    "sn1.76:1.1": "“Kiṁ jīrati kiṁ na jīrati, ",
    "sn1.76:1.2": "kiṁsu uppathoti vuccati; ",
    "sn1.76:1.3": "Kiṁsu dhammānaṁ paripantho, ",
    "sn1.76:1.4": "kiṁsu rattindivakkhayo; ",
    "sn1.76:1.5": "Kiṁ malaṁ brahmacariyassa, ",
    "sn1.76:1.6": "kiṁ sinānamanodakaṁ. ",
    "sn1.76:2.1": "Kati lokasmiṁ chiddāni, ",
    "sn1.76:2.2": "yattha vittaṁ na tiṭṭhati; ",
    "sn1.76:2.3": "Bhagavantaṁ puṭṭhumāgamma, ",
    "sn1.76:2.4": "kathaṁ jānemu taṁ mayan”ti. ",
    "sn1.76:3.1": "“Rūpaṁ jīrati maccānaṁ, ",
    "sn1.76:3.2": "nāmagottaṁ na jīrati; ",
    "sn1.76:3.3": "Rāgo uppathoti vuccati. ",
    "sn1.76:4.1": "Lobho dhammānaṁ paripantho, ",
    "sn1.76:4.2": "Vayo rattindivakkhayo; ",
    "sn1.76:4.3": "Itthī malaṁ brahmacariyassa, ",
    "sn1.76:4.4": "Etthāyaṁ sajjate pajā; ",
    "sn1.76:4.5": "Tapo ca brahmacariyañca, ",
    "sn1.76:4.6": "Taṁ sinānamanodakaṁ. ",
    "sn1.76:5.1": "Cha lokasmiṁ chiddāni, ",
    "sn1.76:5.2": "yattha vittaṁ na tiṭṭhati; ",
    "sn1.76:5.3": "Ālasyañca pamādo ca, ",
    "sn1.76:5.4": "anuṭṭhānaṁ asaṁyamo; ",
    "sn1.76:5.5": "Niddā tandī ca te chidde, ",
    "sn1.76:5.6": "sabbaso taṁ vivajjaye”ti. "
  },
  "translation_text": {
    "sn1.76:0.1": "Linked Discourses 1.76 ",
    "sn1.76:0.2": "8. Slain ",
    "sn1.76:0.3": "Getting Old ",
    "sn1.76:1.1": "“What ages, what does not age? ",
    "sn1.76:1.2": "What’s called a deviation? ",
    "sn1.76:1.3": "What’s a roadblock for skillful qualities? ",
    "sn1.76:1.4": "What is ending day and night? ",
    "sn1.76:1.5": "What’s the stain of celibacy? ",
    "sn1.76:1.6": "What’s the waterless bath? ",
    "sn1.76:2.1": "How many holes are there in the world, ",
    "sn1.76:2.2": "where one’s wealth leaks out? ",
    "sn1.76:2.3": "We’ve come to ask you, worthy sir: ",
    "sn1.76:2.4": "how are we to understand this?” ",
    "sn1.76:3.1": "“The physical form of mortals gets old, ",
    "sn1.76:3.2": "but their name and clan don’t. ",
    "sn1.76:3.3": "Lust is called a deviation, ",
    "sn1.76:4.1": "and greed is a roadblock for skillful qualities. ",
    "sn1.76:4.2": "Youth is ending day and night. ",
    "sn1.76:4.3": "Women are the stain of chastity, ",
    "sn1.76:4.4": "to which this generation clings. ",
    "sn1.76:4.5": "Fervor and chastity ",
    "sn1.76:4.6": "are the waterless bath. ",
    "sn1.76:5.1": "There are six holes in the world, ",
    "sn1.76:5.2": "where one’s wealth leaks out: ",
    "sn1.76:5.3": "laziness and negligence, ",
    "sn1.76:5.4": "lack of initiative and lack of restraint, ",
    "sn1.76:5.5": "sleepiness and sloth. ",
    "sn1.76:5.6": "You should completely get rid of these holes!” "
  },
  "variant_text": {
    "sn1.76:2.2": "vittaṁ → cittaṁ (bj, sya-all, km, pts1ed, pts2ed) ",
    "sn1.76:5.3": "Ālasyañca → ālassañca (bj, pts2ed); alassañca (pts1ed) ",
    "sn1.76:5.5": "tandī → tandi (bj) "
  },
