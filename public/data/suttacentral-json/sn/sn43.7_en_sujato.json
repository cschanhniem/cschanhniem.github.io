  "root_text": {
    "sn43.7:0.1": "Saṁyutta Nikāya 43.7 ",
    "sn43.7:0.2": "1. Paṭhamavagga ",
    "sn43.7:0.3": "Iddhipādasutta ",
    "sn43.7:1.1": "“Katamo ca, bhikkhave, asaṅkhatagāmimaggo? ",
    "sn43.7:1.2": "Cattāro iddhipādā. Ayaṁ vuccati, bhikkhave, asaṅkhatagāmimaggo …pe…. ",
    "sn43.7:1.3": "Sattamaṁ. "
  },
  "translation_text": {
    "sn43.7:0.1": "Linked Discourses 43.7 ",
    "sn43.7:0.2": "Chapter One ",
    "sn43.7:0.3": "Bases of Psychic Power ",
    "sn43.7:1.1": "“And what is the path that leads to the unconditioned? ",
    "sn43.7:1.2": "The four bases of psychic power. …” "
  },
