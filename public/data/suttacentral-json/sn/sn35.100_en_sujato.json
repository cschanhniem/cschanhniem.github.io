  "root_text": {
    "sn35.100:0.1": "Saṁyutta Nikāya 35.100 ",
    "sn35.100:0.2": "10. Saḷavagga ",
    "sn35.100:0.3": "Paṭisallānasutta ",
    "sn35.100:1.1": "“Paṭisallāne, bhikkhave, yogamāpajjatha. ",
    "sn35.100:1.2": "Paṭisallīno, bhikkhave, bhikkhu yathābhūtaṁ pajānāti. ",
    "sn35.100:1.3": "Kiñca yathābhūtaṁ pajānāti? ",
    "sn35.100:1.4": "‘Cakkhu aniccan’ti yathābhūtaṁ pajānāti; ",
    "sn35.100:1.5": "‘rūpā aniccā’ti yathābhūtaṁ pajānāti; ",
    "sn35.100:1.6": "‘cakkhuviññāṇaṁ aniccan’ti yathābhūtaṁ pajānāti; ",
    "sn35.100:1.7": "‘cakkhusamphasso anicco’ti yathābhūtaṁ pajānāti …pe… ",
    "sn35.100:1.8": "‘yampidaṁ manosamphassapaccayā uppajjati vedayitaṁ sukhaṁ vā dukkhaṁ vā adukkhamasukhaṁ vā tampi aniccan’ti yathābhūtaṁ pajānāti. ",
    "sn35.100:1.9": "Paṭisallāne, bhikkhave, yogamāpajjatha. ",
    "sn35.100:1.10": "Paṭisallīno, bhikkhave, bhikkhu yathābhūtaṁ pajānātī”ti. ",
    "sn35.100:1.11": "Sattamaṁ. "
  },
  "translation_text": {
    "sn35.100:0.1": "Linked Discourses 35.100 ",
    "sn35.100:0.2": "10. The Sixes ",
    "sn35.100:0.3": "Retreat ",
    "sn35.100:1.1": "“Mendicants, meditate in retreat. ",
    "sn35.100:1.2": "A mendicant in retreat truly understands. ",
    "sn35.100:1.3": "What do they truly understand? ",
    "sn35.100:1.4": "They truly understand that the eye is impermanent. ",
    "sn35.100:1.5": "They truly understand that sights … ",
    "sn35.100:1.6": "eye consciousness … ",
    "sn35.100:1.7": "eye contact … ",
    "sn35.100:1.8": "the pleasant, painful, or neutral feeling that arises dependent on mind contact is impermanent. ",
    "sn35.100:1.9": "Mendicants, meditate in retreat. ",
    "sn35.100:1.10": "A mendicant in retreat truly understands.” "
  },
  "variant_text": {
    "sn35.100:0.3": "Paṭisallānasutta → paṭisallāṇa (pts1ed) ",
    "sn35.100:1.1": "Paṭisallāne → paṭisallānaṁ (bj, mr); paṭisallāno (bj); paṭisallīnā (sya-all, km); paṭisallāṇaṁ (pts1ed) "
  },
