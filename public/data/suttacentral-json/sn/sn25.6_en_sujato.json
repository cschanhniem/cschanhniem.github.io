  "root_text": {
    "sn25.6:0.1": "Saṁyutta Nikāya 25.6 ",
    "sn25.6:0.2": "1. Cakkhuvagga ",
    "sn25.6:0.3": "Rūpasaññāsutta ",
    "sn25.6:1.1": "Sāvatthinidānaṁ. ",
    "sn25.6:1.2": "“Rūpasaññā, bhikkhave, aniccā vipariṇāmī aññathābhāvī; ",
    "sn25.6:1.3": "saddasaññā … ",
    "sn25.6:1.4": "gandhasaññā … ",
    "sn25.6:1.5": "rasasaññā … ",
    "sn25.6:1.6": "phoṭṭhabbasaññā … ",
    "sn25.6:1.7": "dhammasaññā aniccā vipariṇāmī aññathābhāvī. ",
    "sn25.6:1.8": "Yo, bhikkhave, ime dhamme evaṁ saddahati adhimuccati, ayaṁ vuccati ‘saddhānusārī …pe… ",
    "sn25.6:1.9": "sambodhiparāyano’”ti. ",
    "sn25.6:1.10": "Chaṭṭhaṁ. "
  },
  "translation_text": {
    "sn25.6:0.1": "Linked Discourses 25.6 ",
    "sn25.6:0.2": "1. The Eye ",
    "sn25.6:0.3": "Perception ",
    "sn25.6:1.1": "At Sāvatthī. ",
    "sn25.6:1.2": "“Mendicants, perception of sights is impermanent, decaying, and perishing. ",
    "sn25.6:1.3": "Perception of sounds, ",
    "sn25.6:1.4": "perception of smells, ",
    "sn25.6:1.5": "perception of tastes, ",
    "sn25.6:1.6": "perception of touches, ",
    "sn25.6:1.7": "and perception of ideas are impermanent, decaying, and perishing. ",
    "sn25.6:1.8": "Someone who has faith and confidence in these teachings is called a follower by faith. …” ",
    "sn25.6:1.9": ""
  },
  "variant_text": {
    "sn25.6:0.3": "Rūpasaññāsutta → saññāsuttaṁ (bj); saññā (pts1ed) "
  },
