  "root_text": {
    "sn34.16:0.1": "Saṁyutta Nikāya 34.16 ",
    "sn34.16:0.2": "1. Jhānavagga ",
    "sn34.16:0.3": "Samāpattimūlakaabhinīhārasutta ",
    "sn34.16:1.1": "Sāvatthinidānaṁ. ",
    "sn34.16:1.2": "“Cattārome, bhikkhave, jhāyī. ",
    "sn34.16:1.3": "Katame cattāro? ",
    "sn34.16:1.4": "Idha, bhikkhave, ekacco jhāyī samādhismiṁ samāpattikusalo hoti, na samādhismiṁ abhinīhārakusalo. ",
    "sn34.16:1.5": "Idha pana, bhikkhave, ekacco jhāyī samādhismiṁ abhinīhārakusalo hoti, na samādhismiṁ samāpattikusalo. ",
    "sn34.16:1.6": "Idha pana, bhikkhave, ekacco jhāyī neva samādhismiṁ samāpattikusalo hoti, na ca samādhismiṁ abhinīhārakusalo. ",
    "sn34.16:1.7": "Idha pana, bhikkhave, ekacco jhāyī samādhismiṁ samāpattikusalo ca hoti, samādhismiṁ abhinīhārakusalo ca. ",
    "sn34.16:1.8": "Tatra …pe… ",
    "sn34.16:1.9": "pavaro cā”ti. ",
    "sn34.16:1.10": "Soḷasamaṁ. "
  },
  "translation_text": {
    "sn34.16:0.1": "Linked Discourses 34.16 ",
    "sn34.16:0.2": "1. Absorption ",
    "sn34.16:0.3": "Entering and Projecting ",
    "sn34.16:1.1": "At Sāvatthī. ",
    "sn34.16:1.2": "“Mendicants, there are these four meditators. ",
    "sn34.16:1.3": "What four? ",
    "sn34.16:1.4": "One meditator is skilled in entering immersion but not in projecting the mind purified by immersion. …” "
  },
  "variant_text": {
    "sn34.16:0.3": "Samāpattimūlakaabhinīhārasutta → samāpattiabhinīhārasuttaṁ (bj); samāpatti-abhinīhāra (pts1ed) "
  },
