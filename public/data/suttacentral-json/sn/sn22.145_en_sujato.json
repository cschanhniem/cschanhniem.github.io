  "root_text": {
    "sn22.145:0.1": "Saṁyutta Nikāya 22.145 ",
    "sn22.145:0.2": "14. Kukkuḷavagga ",
    "sn22.145:0.3": "Tatiyaanattasutta ",
    "sn22.145:1.1": "Sāvatthinidānaṁ. ",
    "sn22.145:1.2": "“Yo, bhikkhave, anattā; tatra vo chandarāgo pahātabbo. ",
    "sn22.145:1.3": "Ko ca, bhikkhave, anattā? ",
    "sn22.145:1.4": "Rūpaṁ, bhikkhave, anattā; tatra vo chandarāgo pahātabbo. ",
    "sn22.145:1.5": "Vedanā anattā … ",
    "sn22.145:1.6": "saññā … ",
    "sn22.145:1.7": "saṅkhārā … ",
    "sn22.145:1.8": "viññāṇaṁ anattā; tatra vo chandarāgo pahātabbo. ",
    "sn22.145:1.9": "Yo, bhikkhave, anattā; tatra vo chandarāgo pahātabbo”ti. ",
    "sn22.145:1.10": "Dasamaṁ. "
  },
  "translation_text": {
    "sn22.145:0.1": "Linked Discourses 22.145 ",
    "sn22.145:0.2": "14. Burning Chaff ",
    "sn22.145:0.3": "Not-Self (3rd) ",
    "sn22.145:1.1": "At Sāvatthī. ",
    "sn22.145:1.2": "“Mendicants, you should give up desire and greed for what is not-self. …” ",
