  "root_text": {
    "sn23.17:0.1": "Saṁyutta Nikāya 23.17 ",
    "sn23.17:0.2": "2. Dutiyamāravagga ",
    "sn23.17:0.3": "Anattasutta ",
    "sn23.17:1.1": "Sāvatthinidānaṁ. ",
    "sn23.17:1.2": "Ekamantaṁ nisinno kho āyasmā rādho bhagavantaṁ etadavoca: ",
    "sn23.17:1.3": "“‘anattā, anattā’ti, bhante, vuccati. ",
    "sn23.17:1.4": "Katamo nu kho, bhante, anattā”ti? ",
    "sn23.17:1.5": "“Rūpaṁ kho, rādha, anattā, vedanā anattā, saññā anattā, saṅkhārā anattā, viññāṇaṁ anattā. ",
    "sn23.17:1.6": "Evaṁ passaṁ …pe… ",
    "sn23.17:1.7": "nāparaṁ itthattāyāti pajānātī”ti. ",
    "sn23.17:1.8": "Sattamaṁ. "
  },
  "translation_text": {
    "sn23.17:0.1": "Linked Discourses 23.17 ",
    "sn23.17:0.2": "2. About Māra (2nd) ",
    "sn23.17:0.3": "Not-Self ",
    "sn23.17:1.1": "At Sāvatthī. ",
    "sn23.17:1.2": "Seated to one side, Venerable Rādha said to the Buddha: ",
    "sn23.17:1.3": "“Sir, they speak of this thing called ‘not-self’. ",
    "sn23.17:1.4": "What is not-self?” ",
    "sn23.17:1.5": "“Rādha, form, feeling, perception, choices, and consciousness are not-self. ",
    "sn23.17:1.6": "Seeing this … ",
    "sn23.17:1.7": "They understand: ‘… there is nothing further for this place.’” "
  },
  "variant_text": {
    "sn23.17:0.3": "Anattasutta → anatta 1 (pts1ed) "
  },
