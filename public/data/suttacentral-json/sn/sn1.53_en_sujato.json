  "root_text": {
    "sn1.53:0.1": "Saṁyutta Nikāya 1.53 ",
    "sn1.53:0.2": "6. Jarāvagga ",
    "sn1.53:0.3": "Mittasutta ",
    "sn1.53:1.1": "“Kiṁsu pavasato mittaṁ, ",
    "sn1.53:1.2": "kiṁsu mittaṁ sake ghare; ",
    "sn1.53:1.3": "Kiṁ mittaṁ atthajātassa, ",
    "sn1.53:1.4": "kiṁ mittaṁ samparāyikan”ti. ",
    "sn1.53:2.1": "“Sattho pavasato mittaṁ, ",
    "sn1.53:2.2": "mātā mittaṁ sake ghare; ",
    "sn1.53:2.3": "Sahāyo atthajātassa, ",
    "sn1.53:2.4": "hoti mittaṁ punappunaṁ; ",
    "sn1.53:2.5": "Sayaṅkatāni puññāni, ",
    "sn1.53:2.6": "taṁ mittaṁ samparāyikan”ti. "
  },
  "translation_text": {
    "sn1.53:0.1": "Linked Discourses 1.53 ",
    "sn1.53:0.2": "6. Old Age ",
    "sn1.53:0.3": "A Friend ",
    "sn1.53:1.1": "“Who’s your friend while journeying? ",
    "sn1.53:1.2": "Who’s your friend at home? ",
    "sn1.53:1.3": "Who’s your friend in need? ",
    "sn1.53:1.4": "Who’s your friend in the next life?” ",
    "sn1.53:2.1": "“A caravan is your friend while journeying. ",
    "sn1.53:2.2": "Mother is your friend at home. ",
    "sn1.53:2.3": "An ally in a time of need ",
    "sn1.53:2.4": "is a friend time and again. ",
    "sn1.53:2.5": "But the good deeds you’ve done yourself—",
    "sn1.53:2.6": "that’s your friend in the next life.” "
  },
  "variant_text": {
    "sn1.53:1.1": "pavasato → pasavato (sya-all); pathavato (pts1ed, mr) "
  },
