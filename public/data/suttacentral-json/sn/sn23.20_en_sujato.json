  "root_text": {
    "sn23.20:0.1": "Saṁyutta Nikāya 23.20 ",
    "sn23.20:0.2": "2. Dutiyamāravagga ",
    "sn23.20:0.3": "Vayadhammasutta ",
    "sn23.20:1.1": "Sāvatthinidānaṁ. ",
    "sn23.20:1.2": "Ekamantaṁ nisinno kho āyasmā rādho bhagavantaṁ etadavoca: ",
    "sn23.20:1.3": "“‘vayadhammo, vayadhammo’ti, bhante, vuccati. ",
    "sn23.20:1.4": "Katamo nu kho, bhante, vayadhammo”ti? ",
    "sn23.20:1.5": "“Rūpaṁ kho, rādha, vayadhammo, vedanā vayadhammo, saññā vayadhammo, saṅkhārā vayadhammo, viññāṇaṁ vayadhammo. ",
    "sn23.20:1.6": "Evaṁ passaṁ …pe… ",
    "sn23.20:1.7": "nāparaṁ itthattāyāti pajānātī”ti. ",
    "sn23.20:1.8": "Dasamaṁ. "
  },
  "translation_text": {
    "sn23.20:0.1": "Linked Discourses 23.20 ",
    "sn23.20:0.2": "2. About Māra (2nd) ",
    "sn23.20:0.3": "liable to fall ",
    "sn23.20:1.1": "At Sāvatthī. ",
    "sn23.20:1.2": "Seated to one side, Venerable Rādha said to the Buddha: ",
    "sn23.20:1.3": "“Sir, they speak of ‘liable to fall’. ",
    "sn23.20:1.4": "What is liable to fall?” ",
    "sn23.20:1.5": "“Rādha, form, feeling, perception, choices, and consciousness are liable to fall. ",
    "sn23.20:1.6": "Seeing this … ",
    "sn23.20:1.7": "They understand: ‘… there is nothing further for this place.’” "
  },
  "variant_text": {
    "sn23.20:0.3": "Vayadhammasutta → vaya (pts1ed) "
  },
