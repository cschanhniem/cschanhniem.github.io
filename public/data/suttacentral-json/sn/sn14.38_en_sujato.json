  "root_text": {
    "sn14.38:0.1": "Saṁyutta Nikāya 14.38 ",
    "sn14.38:0.2": "4. Catutthavagga ",
    "sn14.38:0.3": "Dutiyasamaṇabrāhmaṇasutta ",
    "sn14.38:1.1": "Sāvatthiyaṁ viharati. ",
    "sn14.38:1.2": "“Catasso imā, bhikkhave, dhātuyo. ",
    "sn14.38:1.3": "Katamā catasso? ",
    "sn14.38:1.4": "Pathavīdhātu, āpodhātu, tejodhātu, vāyodhātu. ",
    "sn14.38:1.5": "Ye hi keci, bhikkhave, samaṇā vā brāhmaṇā vā imāsaṁ catunnaṁ dhātūnaṁ samudayañca atthaṅgamañca assādañca ādīnavañca nissaraṇañca yathābhūtaṁ nappajānanti …pe… ",
    "sn14.38:1.6": "(vitthāretabbaṁ) ",
    "sn14.38:1.7": "pajānanti …pe… ",
    "sn14.38:1.8": "sayaṁ abhiññā sacchikatvā upasampajja viharantī”ti. ",
    "sn14.38:1.9": "Navamaṁ. "
  },
  "translation_text": {
    "sn14.38:0.1": "Linked Discourses 14.38 ",
    "sn14.38:0.2": "4. Chapter Four ",
    "sn14.38:0.3": "Ascetics and Brahmins (2nd) ",
    "sn14.38:1.1": "At Sāvatthī. ",
    "sn14.38:1.2": "“Mendicants, there are these four elements. ",
    "sn14.38:1.3": "What four? ",
    "sn14.38:1.4": "The elements of earth, water, fire, and air. ",
    "sn14.38:1.5": "There are ascetics and brahmins who don’t truly understand these four elements’ origin, disappearance, gratification, drawback, and escape … ",
    "sn14.38:1.6": "(Tell all in full.) ",
    "sn14.38:1.7": "There are ascetics and brahmins who do truly understand these four elements’ origin, disappearance, gratification, drawback, and escape …” "
  },
