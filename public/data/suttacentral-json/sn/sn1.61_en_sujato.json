  "root_text": {
    "sn1.61:0.1": "Saṁyutta Nikāya 1.61 ",
    "sn1.61:0.2": "7. Addhavagga ",
    "sn1.61:0.3": "Nāmasutta ",
    "sn1.61:1.1": "“Kiṁsu sabbaṁ addhabhavi, ",
    "sn1.61:1.2": "kismā bhiyyo na vijjati; ",
    "sn1.61:1.3": "Kissassu ekadhammassa, ",
    "sn1.61:1.4": "sabbeva vasamanvagū”ti. ",
    "sn1.61:2.1": "“Nāmaṁ sabbaṁ addhabhavi, ",
    "sn1.61:2.2": "nāmā bhiyyo na vijjati; ",
    "sn1.61:2.3": "Nāmassa ekadhammassa, ",
    "sn1.61:2.4": "sabbeva vasamanvagū”ti. "
  },
  "translation_text": {
    "sn1.61:0.1": "Linked Discourses 1.61 ",
    "sn1.61:0.2": "7. Overcome ",
    "sn1.61:0.3": "Name ",
    "sn1.61:1.1": "“What overcomes everything? ",
    "sn1.61:1.2": "What is it that nothing excels? ",
    "sn1.61:1.3": "What is the one thing ",
    "sn1.61:1.4": "that has everything under its sway?” ",
    "sn1.61:2.1": "“Name overcomes everything. ",
    "sn1.61:2.2": "Nothing excels name. ",
    "sn1.61:2.3": "Name is the one thing ",
    "sn1.61:2.4": "that has everything under its sway.” "
  },
