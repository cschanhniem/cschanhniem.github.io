  "root_text": {
    "sn35.206:0.1": "Saṁyutta Nikāya 35.206 ",
    "sn35.206:0.2": "17. Saṭṭhipeyyālavagga ",
    "sn35.206:0.3": "Ajjhattapaccuppannayadaniccasutta ",
    "sn35.206:1.1": "“Cakkhu, bhikkhave, aniccaṁ paccuppannaṁ. ",
    "sn35.206:1.2": "Yadaniccaṁ, taṁ dukkhaṁ. ",
    "sn35.206:1.3": "Yaṁ dukkhaṁ, tadanattā. ",
    "sn35.206:1.4": "Yadanattā taṁ ‘netaṁ mama, nesohamasmi, na meso attā’ti evametaṁ yathābhūtaṁ sammappaññāya daṭṭhabbaṁ …pe… ",
    "sn35.206:1.5": "jivhā aniccā paccuppannā. ",
    "sn35.206:1.6": "Yadaniccaṁ, taṁ dukkhaṁ. ",
    "sn35.206:1.7": "Yaṁ dukkhaṁ, tadanattā. ",
    "sn35.206:1.8": "Yadanattā, taṁ ‘netaṁ mama, nesohamasmi, na meso attā’ti evametaṁ yathābhūtaṁ sammappaññāya daṭṭhabbaṁ …pe… ",
    "sn35.206:1.9": "mano anicco paccuppanno. ",
    "sn35.206:1.10": "Yadaniccaṁ taṁ dukkhaṁ. ",
    "sn35.206:1.11": "Yaṁ dukkhaṁ tadanattā. ",
    "sn35.206:1.12": "Yadanattā, taṁ ‘netaṁ mama, nesohamasmi, na meso attā’ti evametaṁ yathābhūtaṁ sammappaññāya daṭṭhabbaṁ. ",
    "sn35.206:1.13": "Evaṁ passaṁ …pe… ",
    "sn35.206:1.14": "nāparaṁ itthattāyāti pajānātī”ti. "
  },
  "translation_text": {
    "sn35.206:0.1": "Linked Discourses 35.206 ",
    "sn35.206:0.2": "17. Sixty Abbreviated Texts ",
    "sn35.206:0.3": "The Interior and What’s Impermanent in the Present ",
    "sn35.206:1.1": "“Mendicants, in the present the eye, ear, nose, tongue, body, and mind are impermanent. ",
    "sn35.206:1.2": "What’s impermanent is suffering. …” ",
