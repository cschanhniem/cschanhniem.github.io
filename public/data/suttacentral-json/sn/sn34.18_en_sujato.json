  "root_text": {
    "sn34.18:0.1": "Saṁyutta Nikāya 34.18 ",
    "sn34.18:0.2": "1. Jhānavagga ",
    "sn34.18:0.3": "Samāpattimūlakasātaccasutta ",
    "sn34.18:1.1": "Sāvatthinidānaṁ. ",
    "sn34.18:1.2": "“Cattārome, bhikkhave, jhāyī. ",
    "sn34.18:1.3": "Katame cattāro? ",
    "sn34.18:1.4": "Idha, bhikkhave, ekacco jhāyī samādhismiṁ samāpattikusalo hoti, na samādhismiṁ sātaccakārī. ",
    "sn34.18:1.5": "Idha pana, bhikkhave, ekacco jhāyī samādhismiṁ sātaccakārī hoti, na samādhismiṁ samāpattikusalo. ",
    "sn34.18:1.6": "Idha pana, bhikkhave, ekacco jhāyī neva samādhismiṁ samāpattikusalo hoti, na ca samādhismiṁ sātaccakārī. ",
    "sn34.18:1.7": "Idha pana, bhikkhave, ekacco jhāyī samādhismiṁ samāpattikusalo ca hoti, samādhismiṁ sātaccakārī ca. ",
    "sn34.18:1.8": "Tatra …pe… ",
    "sn34.18:1.9": "pavaro cā”ti. ",
    "sn34.18:1.10": "Aṭṭhārasamaṁ. "
  },
  "translation_text": {
    "sn34.18:0.1": "Linked Discourses 34.18 ",
    "sn34.18:0.2": "1. Absorption ",
    "sn34.18:0.3": "Entering and Persistence ",
    "sn34.18:1.1": "At Sāvatthī. ",
    "sn34.18:1.2": "“Mendicants, there are these four meditators. ",
    "sn34.18:1.3": "What four? ",
    "sn34.18:1.4": "One meditator is skilled in entering immersion but not in practicing persistently for it. …” "
  },
  "variant_text": {
    "sn34.18:0.3": "Samāpattimūlakasātaccasutta → samāpattisātaccakārīsuttaṁ (bj); samāpatti-sātaccakārī (pts1ed) "
  },
