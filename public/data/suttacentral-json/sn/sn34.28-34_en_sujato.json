  "root_text": {
    "sn34.28-34:0.1": "Saṁyutta Nikāya 34.28–34 ",
    "sn34.28-34:0.2": "1. Jhānavagga ",
    "sn34.28-34:0.3": "Vuṭṭhānamūlakakallitasuttādisattaka ",
    "sn34.28-34:1.1": "Sāvatthinidānaṁ. ",
    "sn34.28-34:1.2": "“Cattārome, bhikkhave, jhāyī. ",
    "sn34.28-34:1.3": "Katame cattāro? ",
    "sn34.28-34:1.4": "Idha, bhikkhave, ekacco jhāyī samādhismiṁ vuṭṭhānakusalo hoti, na samādhismiṁ kallitakusalo … ",
    "sn34.28-34:1.5": "samādhismiṁ kallitakusalo hoti, na samādhismiṁ vuṭṭhānakusalo … ",
    "sn34.28-34:1.6": "neva samādhismiṁ vuṭṭhānakusalo hoti, na ca samādhismiṁ kallitakusalo … ",
    "sn34.28-34:1.7": "samādhismiṁ vuṭṭhānakusalo ca hoti samādhismiṁ kallitakusalo ca. ",
    "sn34.28-34:1.8": "Tatra, bhikkhave, yvāyaṁ jhāyī …pe… ",
    "sn34.28-34:1.9": "uttamo ca pavaro cā”ti. ",
    "sn34.28-34:1.10": "Aṭṭhavīsatimaṁ. ",
    "sn34.28-34:1.11": "(Purimamūlakāni viya yāva catuttiṁsatimā vuṭṭhānamūlakasappāyakārīsuttā satta suttāni pūretabbāni.) ",
    "sn34.28-34:1.12": "(Vuṭṭhānamūlakaṁ.) "
  },
  "translation_text": {
    "sn34.28-34:0.1": "Linked Discourses 34.28–34 ",
    "sn34.28-34:0.2": "1. Absorption ",
    "sn34.28-34:0.3": "Seven on Emergence and Gladdening, Etc. ",
    "sn34.28-34:1.1": "At Sāvatthī. ",
    "sn34.28-34:1.2": "“Mendicants, there are these four meditators. ",
    "sn34.28-34:1.3": "What four? ",
    "sn34.28-34:1.4": "One meditator is skilled in emerging from immersion but not in positivity for immersion. …” ",
    "sn34.28-34:1.11": "(These seven discourses should be told in full as the previous set.) "
  },
