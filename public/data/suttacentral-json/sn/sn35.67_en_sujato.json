  "root_text": {
    "sn35.67:0.1": "Saṁyutta Nikāya 35.67 ",
    "sn35.67:0.2": "7. Migajālavagga ",
    "sn35.67:0.3": "Samiddhidukkhapañhāsutta ",
    "sn35.67:1.1": "“‘Dukkhaṁ, dukkhan’ti, bhante, vuccati. ",
    "sn35.67:1.2": "Kittāvatā nu kho, bhante, dukkhaṁ vā assa dukkhapaññatti vā”ti …pe…. ",
    "sn35.67:1.3": "Pañcamaṁ. "
  },
  "translation_text": {
    "sn35.67:0.1": "Linked Discourses 35.67 ",
    "sn35.67:0.2": "7. With Migajāla ",
    "sn35.67:0.3": "Samiddhi’s Question About Suffering ",
    "sn35.67:1.1": "“Sir, they speak of this thing called ‘suffering’. ",
    "sn35.67:1.2": "How do we define suffering or what is known as suffering?” … "
  },
