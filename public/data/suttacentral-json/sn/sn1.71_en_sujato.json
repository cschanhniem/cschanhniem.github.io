  "root_text": {
    "sn1.71:0.1": "Saṁyutta Nikāya 1.71 ",
    "sn1.71:0.2": "8. Chetvāvagga ",
    "sn1.71:0.3": "Chetvāsutta ",
    "sn1.71:1.1": "Sāvatthinidānaṁ. ",
    "sn1.71:1.2": "Ekamantaṁ ṭhitā kho sā devatā bhagavantaṁ gāthāya ajjhabhāsi: ",
    "sn1.71:2.1": "“Kiṁsu chetvā sukhaṁ seti, ",
    "sn1.71:2.2": "kiṁsu chetvā na socati; ",
    "sn1.71:2.3": "Kissassu ekadhammassa, ",
    "sn1.71:2.4": "vadhaṁ rocesi gotamā”ti. ",
    "sn1.71:3.1": "“Kodhaṁ chetvā sukhaṁ seti, ",
    "sn1.71:3.2": "kodhaṁ chetvā na socati; ",
    "sn1.71:3.3": "Kodhassa visamūlassa, ",
    "sn1.71:3.4": "madhuraggassa devate; ",
    "sn1.71:3.5": "Vadhaṁ ariyā pasaṁsanti, ",
    "sn1.71:3.6": "tañhi chetvā na socatī”ti. "
  },
  "translation_text": {
    "sn1.71:0.1": "Linked Discourses 1.71 ",
    "sn1.71:0.2": "8. Slain ",
    "sn1.71:0.3": "Slain ",
    "sn1.71:1.1": "At Sāvatthī. ",
    "sn1.71:1.2": "Standing to one side, that deity addressed the Buddha in verse: ",
    "sn1.71:2.1": "“When what is slain do you sleep at ease? ",
    "sn1.71:2.2": "When what is slain is there no sorrow? ",
    "sn1.71:2.3": "What’s the one thing, Gotama, ",
    "sn1.71:2.4": "whose killing you approve?” ",
    "sn1.71:3.1": "“When anger’s slain you sleep at ease. ",
    "sn1.71:3.2": "When anger’s slain there is no sorrow. ",
    "sn1.71:3.3": "O deity, anger has a poisonous root ",
    "sn1.71:3.4": "and a honey tip. ",
    "sn1.71:3.5": "The noble ones praise its killing, ",
    "sn1.71:3.6": "for when it’s slain there is no sorrow.” "
  },
  "variant_text": {
    "sn1.71:0.2": "Chetvāvagga → jhatvāvaggo (bj, pts2ed); ghatvāvaggo (sya-all) ",
    "sn1.71:0.3": "Chetvāsutta → jhatvāsuttaṁ (bj, pts2ed); ghatvāsuttaṁ (sya-all) ",
    "sn1.71:2.1": "chetvā → jhatvā (bj, pts2ed); ghatvā (sya-all, km) "
  },
