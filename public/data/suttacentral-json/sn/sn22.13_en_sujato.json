  "root_text": {
    "sn22.13:0.1": "Saṁyutta Nikāya 22.13 ",
    "sn22.13:0.2": "2. Aniccavagga ",
    "sn22.13:0.3": "Dukkhasutta ",
    "sn22.13:1.1": "Sāvatthinidānaṁ. ",
    "sn22.13:1.2": "“Rūpaṁ, bhikkhave, dukkhaṁ, vedanā dukkhā, saññā dukkhā, saṅkhārā dukkhā, viññāṇaṁ dukkhaṁ. ",
    "sn22.13:1.3": "Evaṁ passaṁ …pe… ",
    "sn22.13:1.4": "nāparaṁ itthattāyāti pajānātī”ti. ",
    "sn22.13:1.5": "Dutiyaṁ. "
  },
  "translation_text": {
    "sn22.13:0.1": "Linked Discourses 22.13 ",
    "sn22.13:0.2": "2. Impermanence ",
    "sn22.13:0.3": "Suffering ",
    "sn22.13:1.1": "At Sāvatthī. ",
    "sn22.13:1.2": "“Mendicants, form, feeling, perception, choices, and consciousness are suffering. ",
    "sn22.13:1.3": "Seeing this … ",
    "sn22.13:1.4": "They understand: ‘… there is nothing further for this place.’” "
  },
