  "root_text": {
    "sn18.5:0.1": "Saṁyutta Nikāya 18.5 ",
    "sn18.5:0.2": "1. Paṭhamavagga ",
    "sn18.5:0.3": "Vedanāsutta ",
    "sn18.5:1.1": "Sāvatthiyaṁ viharati. ",
    "sn18.5:1.2": "“Taṁ kiṁ maññasi, rāhula, ",
    "sn18.5:1.3": "cakkhusamphassajā vedanā niccā vā aniccā vā”ti? ",
    "sn18.5:1.4": "“Aniccā, bhante” … ",
    "sn18.5:1.5": "“sotasamphassajā vedanā …pe… ",
    "sn18.5:1.6": "ghānasamphassajā vedanā … ",
    "sn18.5:1.7": "jivhāsamphassajā vedanā … ",
    "sn18.5:1.8": "kāyasamphassajā vedanā … ",
    "sn18.5:1.9": "manosamphassajā vedanā niccā vā aniccā vā”ti? ",
    "sn18.5:1.10": "“Aniccā, bhante” … ",
    "sn18.5:1.11": "“evaṁ passaṁ, rāhula, sutavā ariyasāvako cakkhusamphassajāya vedanāyapi nibbindati …pe… sota … ghāna … jivhā … kāya … manosamphassajāya vedanāyapi nibbindati …pe… ",
    "sn18.5:1.12": "pajānātī”ti. ",
    "sn18.5:1.13": "Pañcamaṁ. "
  },
  "translation_text": {
    "sn18.5:0.1": "Linked Discourses 18.5 ",
    "sn18.5:0.2": "Chapter One ",
    "sn18.5:0.3": "Feeling ",
    "sn18.5:1.1": "At Sāvatthī. ",
    "sn18.5:1.2": "“What do you think, Rāhula? ",
    "sn18.5:1.3": "Is feeling born of eye contact permanent or impermanent?” ",
    "sn18.5:1.4": "“Impermanent, sir.” … ",
    "sn18.5:1.5": "“… feeling born of ear contact … ",
    "sn18.5:1.6": "feeling born of nose contact … ",
    "sn18.5:1.7": "feeling born of tongue contact … ",
    "sn18.5:1.8": "feeling born of body contact … ",
    "sn18.5:1.9": "Is feeling born of mind contact permanent or impermanent?” ",
    "sn18.5:1.10": "“Impermanent, sir.” … ",
    "sn18.5:1.11": "“Seeing this, a learned noble disciple grows disillusioned with feeling born of eye contact, ear contact, nose contact, tongue contact, body contact, and mind contact. …” ",
    "sn18.5:1.12": ""
  },
