  "root_text": {
    "sn33.46-50:0.1": "Saṁyutta Nikāya 33.46–50 ",
    "sn33.46-50:0.2": "1. Vacchagottavagga ",
    "sn33.46-50:0.3": "Rūpaappaccupekkhaṇādisuttapañcaka ",
    "sn33.46-50:1.1": "Sāvatthinidānaṁ. ",
    "sn33.46-50:1.2": "“Rūpe kho, vaccha, appaccupekkhaṇā …pe… viññāṇe kho, vaccha, appaccupekkhaṇā …pe…. ",
    "sn33.46-50:1.3": "Paññāsamaṁ. "
  },
  "translation_text": {
    "sn33.46-50:0.1": "Linked Discourses 33.46–50 ",
    "sn33.46-50:0.2": "1. With Vacchagotta ",
    "sn33.46-50:0.3": "Five Discourses on Not Scrutinizing Form, Etc. ",
    "sn33.46-50:1.1": "At Sāvatthī. ",
    "sn33.46-50:1.2": "“Vaccha, it is because of not scrutinizing form …” "
  },
