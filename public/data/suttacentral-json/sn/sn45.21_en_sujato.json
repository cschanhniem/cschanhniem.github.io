  "root_text": {
    "sn45.21:0.1": "Saṁyutta Nikāya 45.21 ",
    "sn45.21:0.2": "3. Micchattavagga ",
    "sn45.21:0.3": "Micchattasutta ",
    "sn45.21:1.1": "Sāvatthinidānaṁ. ",
    "sn45.21:1.2": "“Micchattañca vo, bhikkhave, desessāmi, sammattañca. ",
    "sn45.21:1.3": "Taṁ suṇātha. ",
    "sn45.21:1.4": "Katamañca, bhikkhave, micchattaṁ? ",
    "sn45.21:1.5": "Seyyathidaṁ—micchādiṭṭhi …pe… micchāsamādhi. ",
    "sn45.21:1.6": "Idaṁ vuccati, bhikkhave, micchattaṁ. ",
    "sn45.21:1.7": "Katamañca, bhikkhave, sammattaṁ? ",
    "sn45.21:1.8": "Seyyathidaṁ—sammādiṭṭhi …pe… sammāsamādhi. ",
    "sn45.21:1.9": "Idaṁ vuccati, bhikkhave, sammattan”ti. ",
    "sn45.21:1.10": "Paṭhamaṁ. "
  },
  "translation_text": {
    "sn45.21:0.1": "Linked Discourses 45.21 ",
    "sn45.21:0.2": "3. The Wrong Way ",
    "sn45.21:0.3": "The Wrong Way ",
    "sn45.21:1.1": "At Sāvatthī. ",
    "sn45.21:1.2": "“Mendicants, I will teach you the wrong way and the right way. ",
    "sn45.21:1.3": "Listen … ",
    "sn45.21:1.4": "And what is the wrong way? ",
    "sn45.21:1.5": "It is wrong view, wrong thought, wrong speech, wrong action, wrong livelihood, wrong effort, wrong mindfulness, and wrong immersion. ",
    "sn45.21:1.6": "This is called the wrong way. ",
    "sn45.21:1.7": "And what is the right way? ",
    "sn45.21:1.8": "It is right view, right thought, right speech, right action, right livelihood, right effort, right mindfulness, and right immersion. ",
    "sn45.21:1.9": "This is called the right way.” "
  },
