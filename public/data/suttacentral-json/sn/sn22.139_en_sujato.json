  "root_text": {
    "sn22.139:0.1": "Saṁyutta Nikāya 22.139 ",
    "sn22.139:0.2": "14. Kukkuḷavagga ",
    "sn22.139:0.3": "Tatiyaaniccasutta ",
    "sn22.139:1.1": "Sāvatthinidānaṁ. ",
    "sn22.139:1.2": "“Yaṁ, bhikkhave, aniccaṁ; tatra vo chandarāgo pahātabbo. ",
    "sn22.139:1.3": "Kiñca, bhikkhave, aniccaṁ? ",
    "sn22.139:1.4": "Rūpaṁ, bhikkhave, aniccaṁ, tatra vo chandarāgo pahātabbo. ",
    "sn22.139:1.5": "Vedanā aniccā … ",
    "sn22.139:1.6": "saññā … ",
    "sn22.139:1.7": "saṅkhārā … ",
    "sn22.139:1.8": "viññāṇaṁ aniccaṁ; tatra vo chandarāgo pahātabbo. ",
    "sn22.139:1.9": "Yaṁ, bhikkhave, aniccaṁ; tatra vo chandarāgo pahātabbo”ti. ",
    "sn22.139:1.10": "Catutthaṁ. "
  },
  "translation_text": {
    "sn22.139:0.1": "Linked Discourses 22.139 ",
    "sn22.139:0.2": "14. Burning Chaff ",
    "sn22.139:0.3": "Impermanence (3rd) ",
    "sn22.139:1.1": "At Sāvatthī. ",
    "sn22.139:1.2": "“Mendicants, you should give up desire and greed for what is impermanent. ",
    "sn22.139:1.3": "And what is impermanent? ",
    "sn22.139:1.4": "Form is impermanent; you should give up desire and greed for it. ",
    "sn22.139:1.5": "Feeling … ",
    "sn22.139:1.6": "Perception … ",
    "sn22.139:1.7": "Choices … ",
    "sn22.139:1.8": "Consciousness is impermanent; you should give up desire and greed for it. ",
    "sn22.139:1.9": "You should give up desire and greed for what is impermanent.” "
  },
