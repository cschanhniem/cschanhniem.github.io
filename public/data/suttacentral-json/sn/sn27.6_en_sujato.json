  "root_text": {
    "sn27.6:0.1": "Saṁyutta Nikāya 27.6 ",
    "sn27.6:0.2": "1. Kilesavagga ",
    "sn27.6:0.3": "Saññāsutta ",
    "sn27.6:1.1": "Sāvatthinidānaṁ. ",
    "sn27.6:1.2": "“Yo, bhikkhave, rūpasaññāya chandarāgo, cittasseso upakkileso. ",
    "sn27.6:1.3": "Yo saddasaññāya … ",
    "sn27.6:1.4": "yo gandhasaññāya … ",
    "sn27.6:1.5": "yo rasasaññāya … ",
    "sn27.6:1.6": "yo phoṭṭhabbasaññāya … ",
    "sn27.6:1.7": "yo dhammasaññāya chandarāgo, cittasseso upakkileso. ",
    "sn27.6:1.8": "Yato kho, bhikkhave, bhikkhuno …pe… ",
    "sn27.6:1.9": "abhiññā sacchikaraṇīyesu dhammesū”ti. ",
    "sn27.6:1.10": "Chaṭṭhaṁ. "
  },
  "translation_text": {
    "sn27.6:0.1": "Linked Discourses 27.6 ",
    "sn27.6:0.2": "1. Corruptions ",
    "sn27.6:0.3": "Perception ",
    "sn27.6:1.1": "At Sāvatthī. ",
    "sn27.6:1.2": "“Mendicants, desire and greed for perception of sights, ",
    "sn27.6:1.3": "perception of sounds, ",
    "sn27.6:1.4": "perception of smells, ",
    "sn27.6:1.5": "perception of tastes, ",
    "sn27.6:1.6": "perception of touches, ",
    "sn27.6:1.7": "or perception of ideas is a corruption of the mind. …” ",
    "sn27.6:1.8": "",
    "sn27.6:1.9": ""
  },
  "variant_text": {
    "sn27.6:0.3": "Saññāsutta → saññāya (pts1ed) "
  },
