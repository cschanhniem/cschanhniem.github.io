  "root_text": {
    "sn27.10:0.1": "Saṁyutta Nikāya 27.10 ",
    "sn27.10:0.2": "1. Kilesavagga ",
    "sn27.10:0.3": "Khandhasutta ",
    "sn27.10:1.1": "Sāvatthinidānaṁ. ",
    "sn27.10:1.2": "“Yo, bhikkhave, rūpasmiṁ chandarāgo, cittasseso upakkileso …pe… yo viññāṇasmiṁ chandarāgo, cittasseso upakkileso. ",
    "sn27.10:1.3": "Yato kho, bhikkhave, bhikkhuno imesu pañcasu ṭhānesu cetaso upakkileso pahīno hoti, nekkhammaninnañcassa cittaṁ hoti. ",
    "sn27.10:1.4": "Nekkhammaparibhāvitaṁ cittaṁ kammaniyaṁ khāyati, abhiññā sacchikaraṇīyesu dhammesū”ti. ",
    "sn27.10:1.5": "Dasamaṁ. ",
    "sn27.10:1.6": "Kilesavaggo paṭhamo. ",
    "sn27.10:2.0": "Tassuddānaṁ ",
    "sn27.10:2.1": "Cakkhu rūpañca viññāṇaṁ, ",
    "sn27.10:2.2": "phasso ca vedanāya ca; ",
    "sn27.10:2.3": "Saññā ca cetanā taṇhā, ",
    "sn27.10:2.4": "dhātu khandhena te dasāti. ",
    "sn27.10:2.5": "Kilesasaṁyuttaṁ samattaṁ. "
  },
  "translation_text": {
    "sn27.10:0.1": "Linked Discourses 27.10 ",
    "sn27.10:0.2": "1. Corruptions ",
    "sn27.10:0.3": "The Aggregates ",
    "sn27.10:1.1": "At Sāvatthī. ",
    "sn27.10:1.2": "“Mendicants, desire and greed for form, feeling, perception, choices, or consciousness is a corruption of the mind. ",
    "sn27.10:1.3": "When a mendicant has given up mental corruption in these five cases, their mind inclines to renunciation. ",
    "sn27.10:1.4": "A mind imbued with renunciation is said to be fit for work regarding anything that can be realized by insight.” ",
    "sn27.10:1.5": "",
    "sn27.10:1.6": "",
    "sn27.10:2.1": "",
    "sn27.10:2.2": "",
    "sn27.10:2.3": "",
    "sn27.10:2.4": "",
    "sn27.10:2.5": "The Linked Discourses on corruptions are complete. "
  },
