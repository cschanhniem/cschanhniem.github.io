  "root_text": {
    "sn48.65:0.1": "Saṁyutta Nikāya 48.65 ",
    "sn48.65:0.2": "7. Bodhipakkhiyavagga ",
    "sn48.65:0.3": "Paṭhamaphalasutta ",
    "sn48.65:1.1": "“Pañcimāni, bhikkhave, indriyāni. ",
    "sn48.65:1.2": "Katamāni pañca? ",
    "sn48.65:1.3": "Saddhindriyaṁ …pe… paññindriyaṁ—",
    "sn48.65:1.4": "imāni kho, bhikkhave, pañcindriyāni. ",
    "sn48.65:1.5": "Imesaṁ kho, bhikkhave, pañcannaṁ indriyānaṁ bhāvitattā bahulīkatattā dvinnaṁ phalānaṁ aññataraṁ phalaṁ pāṭikaṅkhaṁ—",
    "sn48.65:1.6": "diṭṭheva dhamme aññā, sati vā upādisese anāgāmitā”ti. ",
    "sn48.65:1.7": "Pañcamaṁ. "
  },
  "translation_text": {
    "sn48.65:0.1": "Linked Discourses 48.65 ",
    "sn48.65:0.2": "7. Leading to Awakening ",
    "sn48.65:0.3": "Two Fruits ",
    "sn48.65:1.1": "“Mendicants, there are these five faculties. ",
    "sn48.65:1.2": "What five? ",
    "sn48.65:1.3": "The faculties of faith, energy, mindfulness, immersion, and wisdom. ",
    "sn48.65:1.4": "These are the five faculties. ",
    "sn48.65:1.5": "Because of developing and cultivating these five faculties, one of two results can be expected: ",
    "sn48.65:1.6": "enlightenment in this very life, or if there’s something left over, non-return.” "
  },
  "variant_text": {
    "sn48.65:0.3": "Paṭhamaphalasutta → dve phalā (pts1ed) "
  },
