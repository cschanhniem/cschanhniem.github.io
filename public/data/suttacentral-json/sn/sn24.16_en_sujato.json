  "root_text": {
    "sn24.16:0.1": "Saṁyutta Nikāya 24.16 ",
    "sn24.16:0.2": "1. Sotāpattivagga ",
    "sn24.16:0.3": "Nahotitathāgatosutta ",
    "sn24.16:1.1": "Sāvatthinidānaṁ. ",
    "sn24.16:1.2": "“Kismiṁ nu kho, bhikkhave, sati, kiṁ upādāya, kiṁ abhinivissa evaṁ diṭṭhi uppajjati: ",
    "sn24.16:1.3": "‘na hoti tathāgato paraṁ maraṇā’”ti? ",
    "sn24.16:1.4": "“Bhagavaṁmūlakā no, bhante, dhammā …pe… ",
    "sn24.16:1.5": "niyato sambodhiparāyano”ti. ",
    "sn24.16:1.6": "Soḷasamaṁ. "
  },
  "translation_text": {
    "sn24.16:0.1": "Linked Discourses 24.16 ",
    "sn24.16:0.2": "1. Stream-Entry ",
    "sn24.16:0.3": "A Realized One No Longer Exists ",
    "sn24.16:1.1": "At Sāvatthī. ",
    "sn24.16:1.2": "“Mendicants, when what exists, because of grasping what and insisting on what, does the view arise: ",
    "sn24.16:1.3": "‘A realized one no longer exists after death’?” … ",
    "sn24.16:1.4": "",
    "sn24.16:1.5": ""
  },
