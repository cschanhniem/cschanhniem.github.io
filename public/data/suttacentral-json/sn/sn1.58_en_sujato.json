  "root_text": {
    "sn1.58:0.1": "Saṁyutta Nikāya 1.58 ",
    "sn1.58:0.2": "6. Jarāvagga ",
    "sn1.58:0.3": "Uppathasutta ",
    "sn1.58:1.1": "“Kiṁsu uppatho akkhāto, ",
    "sn1.58:1.2": "kiṁsu rattindivakkhayo; ",
    "sn1.58:1.3": "Kiṁ malaṁ brahmacariyassa, ",
    "sn1.58:1.4": "kiṁ sinānamanodakan”ti. ",
    "sn1.58:2.1": "“Rāgo uppatho akkhāto, ",
    "sn1.58:2.2": "Vayo rattindivakkhayo; ",
    "sn1.58:2.3": "Itthī malaṁ brahmacariyassa, ",
    "sn1.58:2.4": "Etthāyaṁ sajjate pajā; ",
    "sn1.58:2.5": "Tapo ca brahmacariyañca, ",
    "sn1.58:2.6": "Taṁ sinānamanodakan”ti. "
  },
  "translation_text": {
    "sn1.58:0.1": "Linked Discourses 1.58 ",
    "sn1.58:0.2": "6. Old Age ",
    "sn1.58:0.3": "Deviation ",
    "sn1.58:1.1": "“What’s declared to be a deviation? ",
    "sn1.58:1.2": "What is ending day and night? ",
    "sn1.58:1.3": "What’s the stain of chastity? ",
    "sn1.58:1.4": "What’s the waterless bath?” ",
    "sn1.58:2.1": "“Lust is declared to be a deviation. ",
    "sn1.58:2.2": "Youth is ending day and night. ",
    "sn1.58:2.3": "Women are the stain of chastity, ",
    "sn1.58:2.4": "to which this generation clings. ",
    "sn1.58:2.5": "Fervor and chastity ",
    "sn1.58:2.6": "are the waterless bath.” "
  },
