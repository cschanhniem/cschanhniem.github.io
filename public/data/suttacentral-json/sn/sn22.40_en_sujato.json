  "root_text": {
    "sn22.40:0.1": "Saṁyutta Nikāya 22.40 ",
    "sn22.40:0.2": "4. Natumhākavagga ",
    "sn22.40:0.3": "Dutiyaanudhammasutta ",
    "sn22.40:1.1": "Sāvatthinidānaṁ. ",
    "sn22.40:1.2": "“Dhammānudhammappaṭipannassa, bhikkhave, bhikkhuno ayamanudhammo hoti yaṁ rūpe aniccānupassī vihareyya …pe… ",
    "sn22.40:1.3": "‘parimuccati dukkhasmā’ti vadāmī”ti. ",
    "sn22.40:1.4": "Aṭṭhamaṁ. "
  },
  "translation_text": {
    "sn22.40:0.1": "Linked Discourses 22.40 ",
    "sn22.40:0.2": "4. It’s Not Yours ",
    "sn22.40:0.3": "In Line With the Teaching (2nd) ",
    "sn22.40:1.1": "At Sāvatthī. ",
    "sn22.40:1.2": "“Mendicants, when a mendicant is practicing in line with the teaching, this is what’s in line with the teaching. They should meditate observing impermanence in form, feeling, perception, choices, and consciousness. … ",
    "sn22.40:1.3": "They’re freed from suffering, I say.” "
  },
