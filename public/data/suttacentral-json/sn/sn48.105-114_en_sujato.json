  "root_text": {
    "sn48.105-114:0.1": "Saṁyutta Nikāya 48.105 ",
    "sn48.105-114:0.2": "11. Esanāvagga ",
    "sn48.105-114:0.3": "Esanāvagga ",
    "sn48.105-114:1.1": "(Esanāvaggo vitthāretabbo.) ",
    "sn48.105-114:2.0": "Tassuddānaṁ ",
    "sn48.105-114:2.1": "Esanā vidhā āsavo, ",
    "sn48.105-114:2.2": "Bhavo ca dukkhatā tisso; ",
    "sn48.105-114:2.3": "Khilaṁ malañca nīgho ca, ",
    "sn48.105-114:2.4": "Vedanā taṇhā tasinā cāti. "
  },
  "translation_text": {
    "sn48.105-114:0.1": "Linked Discourses 48.105–114 ",
    "sn48.105-114:0.2": "11. The Chapter on Searches ",
    "sn48.105-114:0.3": "The Chapter on Searches ",
    "sn48.105-114:1.1": "(Tell in full as in the chapter on searches at SN 45.161–170.) ",
    "sn48.105-114:2.1": "Searches, discriminations, defilements, ",
    "sn48.105-114:2.2": "states of existence, three kinds of suffering, ",
    "sn48.105-114:2.3": "barrenness, stains, and troubles, ",
    "sn48.105-114:2.4": "feelings, craving, and thirst. "
  },
