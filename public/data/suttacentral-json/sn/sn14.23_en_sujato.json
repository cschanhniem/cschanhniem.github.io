  "root_text": {
    "sn14.23:0.1": "Saṁyutta Nikāya 14.23 ",
    "sn14.23:0.2": "3. Kammapathavagga ",
    "sn14.23:0.3": "Asamāhitasutta ",
    "sn14.23:1.1": "Sāvatthiyaṁ viharati. ",
    "sn14.23:1.2": "“Dhātusova, bhikkhave, sattā saṁsandanti samenti. ",
    "sn14.23:1.3": "Assaddhā assaddhehi saddhiṁ saṁsandanti samenti; ",
    "sn14.23:1.4": "ahirikā ahirikehi saddhiṁ saṁsandanti samenti; ",
    "sn14.23:1.5": "anottappino anottappīhi saddhiṁ saṁsandanti samenti; ",
    "sn14.23:1.6": "asamāhitā asamāhitehi saddhiṁ saṁsandanti samenti; ",
    "sn14.23:1.7": "duppaññā duppaññehi saddhiṁ saṁsandanti samenti. ",
    "sn14.23:2.1": "Saddhā saddhehi saddhiṁ saṁsandanti samenti; ",
    "sn14.23:2.2": "hirimanā hirimanehi saddhiṁ saṁsandanti samenti; ",
    "sn14.23:2.3": "ottappino ottappīhi saddhiṁ saṁsandanti samenti; ",
    "sn14.23:2.4": "samāhitā samāhitehi saddhiṁ saṁsandanti samenti; ",
    "sn14.23:2.5": "paññavanto paññavantehi saddhiṁ saṁsandanti samentī”ti. ",
    "sn14.23:2.6": "Paṭhamaṁ. "
  },
  "translation_text": {
    "sn14.23:0.1": "Linked Discourses 14.23 ",
    "sn14.23:0.2": "3. Ways of Performing Deeds ",
    "sn14.23:0.3": "Lacking Immersion ",
    "sn14.23:1.1": "At Sāvatthī. ",
    "sn14.23:1.2": "“Mendicants, sentient beings join together and converge because of an element: ",
    "sn14.23:1.3": "the faithless with the faithless … ",
    "sn14.23:1.4": "shameless … ",
    "sn14.23:1.5": "imprudent … ",
    "sn14.23:1.6": "lacking immersion … ",
    "sn14.23:1.7": "witless … ",
    "sn14.23:2.1": "The faithful with the faithful … ",
    "sn14.23:2.2": "conscientious … ",
    "sn14.23:2.3": "prudent … ",
    "sn14.23:2.4": "possessing immersion … ",
    "sn14.23:2.5": "and the wise with the wise.” "
  },
