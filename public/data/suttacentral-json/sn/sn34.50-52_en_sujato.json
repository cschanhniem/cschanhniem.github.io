  "root_text": {
    "sn34.50:0.1": "Saṁyutta Nikāya 34.50–52 ",
    "sn34.50:0.2": "1. Jhānavagga ",
    "sn34.50:0.3": "Abhinīhāramūlakasakkaccasuttāditika ",
    "sn34.50:1.1": "Sāvatthinidānaṁ … ",
    "sn34.50:1.2": "“samādhismiṁ abhinīhārakusalo hoti, na samādhismiṁ sakkaccakārī … ",
    "sn34.50:1.3": "samādhismiṁ sakkaccakārī hoti, na samādhismiṁ abhinīhārakusalo … ",
    "sn34.50:1.4": "neva samādhismiṁ abhinīhārakusalo hoti, na ca samādhismiṁ sakkaccakārī … ",
    "sn34.50:1.5": "samādhismiṁ abhinīhārakusalo ca hoti, samādhismiṁ sakkaccakārī ca. ",
    "sn34.50:1.6": "Tatra, bhikkhave, yvāyaṁ jhāyī …pe… ",
    "sn34.50:1.7": "uttamo ca pavaro cā”ti. ",
    "sn34.50:1.8": "Paññāsamaṁ.  ",
    "sn34.51:1.1": "“Samādhismiṁ abhinīhārakusalo hoti, na samādhismiṁ sātaccakārī …pe….",
    "sn34.51:1.2": "Ekapaññāsamaṁ. ",
    "sn34.52:1.1": "“Samādhismiṁ abhinīhārakusalo hoti, na samādhismiṁ sappāyakārī …pe…. ",
    "sn34.52:1.2": "Dvepaññāsamaṁ. ",
    "sn34.52:1.3": "(Abhinīhāramūlakaṁ.) "
  },
  "translation_text": {
    "sn34.50:0.1": "Linked Discourses 34.50–52 ",
    "sn34.50:0.2": "1. Absorption ",
    "sn34.50:0.3": "Three on Projection and Carefulness ",
    "sn34.50:1.1": "At Sāvatthī. ",
    "sn34.50:1.2": "“One meditator is skilled in projecting the mind purified by immersion but not in practicing carefully for it. …” ",
    "sn34.51:1.1": "“One meditator is skilled in projecting the mind purified by immersion but not in practicing persistently for it. …” ",
    "sn34.52:1.1": "“One meditator is skilled in projecting the mind purified by immersion but not in doing what’s conducive to it. …” "
  },
