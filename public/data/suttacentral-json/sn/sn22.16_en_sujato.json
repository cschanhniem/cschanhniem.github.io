  "root_text": {
    "sn22.16:0.1": "Saṁyutta Nikāya 22.16 ",
    "sn22.16:0.2": "2. Aniccavagga ",
    "sn22.16:0.3": "Yaṁdukkhasutta ",
    "sn22.16:1.1": "Sāvatthinidānaṁ. ",
    "sn22.16:1.2": "“Rūpaṁ, bhikkhave, dukkhaṁ. ",
    "sn22.16:1.3": "Yaṁ dukkhaṁ tadanattā; ",
    "sn22.16:1.4": "yadanattā taṁ ‘netaṁ mama, nesohamasmi, na meso attā’ti evametaṁ yathābhūtaṁ sammappaññāya daṭṭhabbaṁ. ",
    "sn22.16:1.5": "Vedanā dukkhā … ",
    "sn22.16:1.6": "saññā dukkhā … ",
    "sn22.16:1.7": "saṅkhārā dukkhā … ",
    "sn22.16:1.8": "viññāṇaṁ dukkhaṁ. ",
    "sn22.16:1.9": "Yaṁ dukkhaṁ tadanattā; ",
    "sn22.16:1.10": "yadanattā taṁ ‘netaṁ mama, nesohamasmi, na meso attā’ti evametaṁ yathābhūtaṁ sammappaññāya daṭṭhabbaṁ. ",
    "sn22.16:1.11": "Evaṁ passaṁ …pe… ",
    "sn22.16:1.12": "nāparaṁ itthattāyā’ti pajānātī”ti. ",
    "sn22.16:1.13": "Pañcamaṁ. "
  },
  "translation_text": {
    "sn22.16:0.1": "Linked Discourses 22.16 ",
    "sn22.16:0.2": "2. Impermanence ",
    "sn22.16:0.3": "That Which is Suffering ",
    "sn22.16:1.1": "At Sāvatthī. ",
    "sn22.16:1.2": "“Mendicants, form is suffering. ",
    "sn22.16:1.3": "What’s suffering is not-self. ",
    "sn22.16:1.4": "And what’s not-self should be truly seen with right understanding like this: ‘This is not mine, I am not this, this is not my self.’ ",
    "sn22.16:1.5": "Feeling is suffering … ",
    "sn22.16:1.6": "Perception is suffering … ",
    "sn22.16:1.7": "Choices are suffering … ",
    "sn22.16:1.8": "Consciousness is suffering. ",
    "sn22.16:1.9": "What’s suffering is not-self. ",
    "sn22.16:1.10": "And what’s not-self should be truly seen with right understanding like this: ‘This is not mine, I am not this, this is not my self.’ ",
    "sn22.16:1.11": "Seeing this … ",
    "sn22.16:1.12": "They understand: ‘… there is nothing further for this place.’” "
  },
  "variant_text": {
    "sn22.16:0.3": "Yaṁdukkhasutta → yad anicca 2 (pts1ed) "
  },
