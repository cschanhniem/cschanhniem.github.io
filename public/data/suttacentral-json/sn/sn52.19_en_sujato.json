  "root_text": {
    "sn52.19:0.1": "Saṁyutta Nikāya 52.19 ",
    "sn52.19:0.2": "2. Dutiyavagga ",
    "sn52.19:0.3": "Nānādhimuttisutta ",
    "sn52.19:1.1": "“Imesañca panāhaṁ, āvuso, catunnaṁ satipaṭṭhānānaṁ bhāvitattā bahulīkatattā sattānaṁ nānādhimuttikataṁ yathābhūtaṁ pajānāmī”ti. ",
    "sn52.19:1.2": "Navamaṁ. "
  },
  "translation_text": {
    "sn52.19:0.1": "Linked Discourses 52.19 ",
    "sn52.19:0.2": "2. A Thousand ",
    "sn52.19:0.3": "Diverse Beliefs ",
    "sn52.19:1.1": "“… And it’s because of developing and cultivating these four kinds of mindfulness meditation that I truly understand the diverse convictions of sentient beings.” "
  },
  "variant_text": {
    "sn52.19:0.3": "Nānādhimuttisutta → nānādhimuttikasuttaṁ (bj) "
  },
