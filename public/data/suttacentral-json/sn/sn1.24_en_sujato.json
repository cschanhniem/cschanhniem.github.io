  "root_text": {
    "sn1.24:0.1": "Saṁyutta Nikāya 1.24 ",
    "sn1.24:0.2": "3. Sattivagga ",
    "sn1.24:0.3": "Manonivāraṇasutta ",
    "sn1.24:1.1": "“Yato yato mano nivāraye, ",
    "sn1.24:1.2": "Na dukkhameti naṁ tato tato; ",
    "sn1.24:1.3": "Sa sabbato mano nivāraye, ",
    "sn1.24:1.4": "Sa sabbato dukkhā pamuccatī”ti. ",
    "sn1.24:2.1": "“Na sabbato mano nivāraye, ",
    "sn1.24:2.2": "Na mano saṁyatattamāgataṁ; ",
    "sn1.24:2.3": "Yato yato ca pāpakaṁ, ",
    "sn1.24:2.4": "Tato tato mano nivāraye”ti. "
  },
  "translation_text": {
    "sn1.24:0.1": "Linked Discourses 1.24 ",
    "sn1.24:0.2": "3. A Sword ",
    "sn1.24:0.3": "Shielding the Mind ",
    "sn1.24:1.1": "“Whatever you’ve shielded the mind from ",
    "sn1.24:1.2": "can’t cause you suffering. ",
    "sn1.24:1.3": "So you should shield the mind from everything, ",
    "sn1.24:1.4": "then you’re freed from all suffering.” ",
    "sn1.24:2.1": "“You need not shield the mind from everything, ",
    "sn1.24:2.2": "nor has the mind gained self-control. ",
    "sn1.24:2.3": "The mind need only be shielded ",
    "sn1.24:2.4": "from where the bad things come.” "
  },
  "variant_text": {
    "sn1.24:1.4": "pamuccatī”ti → pamuccati (pts1ed, csp1ed, csp2ed) "
  },
