  "root_text": {
    "sn35.219-221:0.1": "Saṁyutta Nikāya 35.219–221 ",
    "sn35.219-221:0.2": "17. Saṭṭhipeyyālavagga ",
    "sn35.219-221:0.3": "Bāhirātītādiyadanattasutta ",
    "sn35.219-221:1.1": "“Rūpā, bhikkhave, anattā atītā anāgatā paccuppannā. ",
    "sn35.219-221:1.2": "Yadanattā, taṁ ‘netaṁ mama, nesohamasmi, na meso attā’ti evametaṁ yathābhūtaṁ sammappaññāya daṭṭhabbaṁ. ",
    "sn35.219-221:1.3": "Saddā … ",
    "sn35.219-221:1.4": "gandhā … ",
    "sn35.219-221:1.5": "rasā … ",
    "sn35.219-221:1.6": "phoṭṭhabbā … ",
    "sn35.219-221:1.7": "dhammā anattā atītā anāgatā paccuppannā. ",
    "sn35.219-221:1.8": "Yadanattā, taṁ ‘netaṁ mama, nesohamasmi, na meso attā’ti evametaṁ yathābhūtaṁ sammappaññāya daṭṭhabbaṁ. ",
    "sn35.219-221:1.9": "Evaṁ passaṁ …pe… ",
    "sn35.219-221:1.10": "nāparaṁ itthattāyāti pajānātī”ti. "
  },
  "translation_text": {
    "sn35.219-221:0.1": "Linked Discourses 35.219–221 ",
    "sn35.219-221:0.2": "17. Sixty Abbreviated Texts ",
    "sn35.219-221:0.3": "The Exterior and What’s Not-Self in the Three Times ",
    "sn35.219-221:1.1": "“Mendicants, in the past … future … present sights, sounds, smells, tastes, touches, and ideas are not-self. ",
    "sn35.219-221:1.2": "And what’s not-self should be truly seen with right understanding like this: ‘This is not mine, I am not this, this is not my self.’ …” ",
