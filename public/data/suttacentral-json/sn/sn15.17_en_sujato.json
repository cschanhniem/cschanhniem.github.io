  "root_text": {
    "sn15.17:0.1": "Saṁyutta Nikāya 15.17 ",
    "sn15.17:0.2": "2. Dutiyavagga ",
    "sn15.17:0.3": "Bhaginisutta ",
    "sn15.17:1.1": "Sāvatthiyaṁ viharati …pe… ",
    "sn15.17:1.2": "“na so, bhikkhave, satto sulabharūpo yo nabhaginibhūtapubbo …pe… ",
    "sn15.17:1.3": "alaṁ vimuccitun”ti. ",
    "sn15.17:1.4": "Sattamaṁ. "
  },
  "translation_text": {
    "sn15.17:0.1": "Linked Discourses 15.17 ",
    "sn15.17:0.2": "Chapter Two ",
    "sn15.17:0.3": "Sister ",
    "sn15.17:1.1": "At Sāvatthī. ",
    "sn15.17:1.2": "“It’s not easy to find a sentient being who in all this long time has not previously been your sister. … ",
    "sn15.17:1.3": "This is quite enough for you to become disillusioned, dispassionate, and freed regarding all conditions.” "
  },
