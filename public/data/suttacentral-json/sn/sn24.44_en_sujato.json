  "root_text": {
    "sn24.44:0.1": "Saṁyutta Nikāya 24.44 ",
    "sn24.44:0.2": "2. Dutiyagamanavagga ",
    "sn24.44:0.3": "Adukkhamasukhīsutta ",
    "sn24.44:1.1": "“Adukkhamasukhī attā hoti arogo paraṁ maraṇā”ti? ",
    "sn24.44:1.2": "“Bhagavaṁmūlakā no, bhante, dhammā …pe… ",
    "sn24.44:2.1": "“Rūpe kho, bhikkhave, sati, rūpaṁ upādāya, rūpaṁ abhinivissa evaṁ diṭṭhi uppajjati: ",
    "sn24.44:2.2": "‘adukkhamasukhī attā hoti arogo paraṁ maraṇā’ti. ",
    "sn24.44:2.3": "Vedanāya sati … ",
    "sn24.44:2.4": "saññāya sati … ",
    "sn24.44:2.5": "saṅkhāresu sati … ",
    "sn24.44:2.6": "viññāṇe sati, viññāṇaṁ upādāya, viññāṇaṁ abhinivissa evaṁ diṭṭhi uppajjati: ",
    "sn24.44:2.7": "‘adukkhamasukhī attā hoti arogo paraṁ maraṇā’ti. ",
    "sn24.44:3.1": "Taṁ kiṁ maññatha, bhikkhave, rūpaṁ niccaṁ vā aniccaṁ vā”ti? ",
    "sn24.44:3.2": "“Aniccaṁ, bhante” …pe… ",
    "sn24.44:3.3": "vipariṇāmadhammaṁ, api nu taṁ anupādāya evaṁ diṭṭhi uppajjeyya: ",
    "sn24.44:3.4": "‘adukkhamasukhī attā hoti arogo paraṁ maraṇā’”ti? ",
    "sn24.44:3.5": "“No hetaṁ, bhante”. ",
    "sn24.44:3.6": "“Iti kho, bhikkhave, dukkhe sati, dukkhaṁ upādāya, dukkhaṁ abhinivissa evaṁ diṭṭhi uppajjati: ",
    "sn24.44:3.7": "‘adukkhamasukhī attā hoti arogo paraṁ maraṇā’”ti. ",
    "sn24.44:3.8": "“Vedanā … ",
    "sn24.44:3.9": "saññā … ",
    "sn24.44:3.10": "saṅkhārā … ",
    "sn24.44:3.11": "viññāṇaṁ niccaṁ vā aniccaṁ vā”ti? ",
    "sn24.44:3.12": "“Aniccaṁ, bhante” …pe… ",
    "sn24.44:3.13": "vipariṇāmadhammaṁ, api nu taṁ anupādāya evaṁ diṭṭhi uppajjeyya: ",
    "sn24.44:3.14": "‘adukkhamasukhī attā hoti arogo paraṁ maraṇā’”ti? ",
    "sn24.44:3.15": "“No hetaṁ, bhante”. ",
    "sn24.44:3.16": "“Iti kho, bhikkhave, dukkhe sati, dukkhaṁ upādāya, dukkhaṁ abhinivissa evaṁ diṭṭhi uppajjati: ",
    "sn24.44:3.17": "‘adukkhamasukhī attā hoti arogo paraṁ maraṇā’”ti. ",
    "sn24.44:3.18": "Chabbīsatimaṁ. ",
    "sn24.44:3.19": "Dutiyapeyyālo. ",
    "sn24.44:4.0": "Tassuddānaṁ ",
    "sn24.44:4.1": "Vātaṁ etaṁ mama so, ",
    "sn24.44:4.2": "attā no ca me siyā; ",
    "sn24.44:4.3": "Natthi karoto hetu ca, ",
    "sn24.44:4.4": "mahādiṭṭhena aṭṭhamaṁ. ",
    "sn24.44:5.1": "Sassato asassato ceva, ",
    "sn24.44:5.2": "antānantavā ca vuccati; ",
    "sn24.44:5.3": "Taṁ jīvaṁ aññaṁ jīvañca, ",
    "sn24.44:5.4": "tathāgatena cattāro. ",
    "sn24.44:6.1": "Rūpī attā hoti arūpī ca attā hoti, ",
    "sn24.44:6.2": "Rūpī ca arūpī ca attā hoti; ",
    "sn24.44:6.3": "Neva rūpī nārūpī attā hoti, ",
    "sn24.44:6.4": "Ekantasukhī attā hoti. ",
    "sn24.44:7.1": "Ekantadukkhī attā hoti, ",
    "sn24.44:7.2": "Sukhadukkhī attā hoti; ",
    "sn24.44:7.3": "Adukkhamasukhī attā hoti, ",
    "sn24.44:7.4": "Arogo paraṁ maraṇāti; ",
    "sn24.44:7.5": "Ime chabbīsati suttā, ",
    "sn24.44:7.6": "Dutiyavārena desitā. "
  },
