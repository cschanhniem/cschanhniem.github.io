  "root_text": {
    "sn22.140:0.1": "Saṁyutta Nikāya 22.140 ",
    "sn22.140:0.2": "14. Kukkuḷavagga ",
    "sn22.140:0.3": "Dukkhasutta ",
    "sn22.140:1.1": "Sāvatthinidānaṁ. ",
    "sn22.140:1.2": "“Yaṁ, bhikkhave, dukkhaṁ; tatra vo chando pahātabbo …pe… ",
    "sn22.140:1.3": "yaṁ, bhikkhave, dukkhaṁ; tatra vo chando pahātabbo”ti. ",
    "sn22.140:1.4": "Pañcamaṁ. "
  },
  "translation_text": {
    "sn22.140:0.1": "Linked Discourses 22.140 ",
    "sn22.140:0.2": "14. Burning Chaff ",
    "sn22.140:0.3": "Suffering ",
    "sn22.140:1.1": "At Sāvatthī. ",
    "sn22.140:1.2": "“Mendicants, you should give up desire for what is suffering. …” ",
    "sn22.140:1.3": ""
  },
