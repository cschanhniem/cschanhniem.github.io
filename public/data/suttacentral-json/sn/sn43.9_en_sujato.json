  "root_text": {
    "sn43.9:0.1": "Saṁyutta Nikāya 43.9 ",
    "sn43.9:0.2": "1. Paṭhamavagga ",
    "sn43.9:0.3": "Balasutta ",
    "sn43.9:1.1": "“Katamo ca, bhikkhave, asaṅkhatagāmimaggo? ",
    "sn43.9:1.2": "Pañca balāni. Ayaṁ vuccati, bhikkhave, asaṅkhatagāmimaggo …pe…. ",
    "sn43.9:1.3": "Navamaṁ. "
  },
  "translation_text": {
    "sn43.9:0.1": "Linked Discourses 43.9 ",
    "sn43.9:0.2": "Chapter One ",
    "sn43.9:0.3": "Powers ",
    "sn43.9:1.1": "“And what is the path that leads to the unconditioned? ",
    "sn43.9:1.2": "The five powers. …” "
