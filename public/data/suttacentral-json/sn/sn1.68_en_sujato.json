  "root_text": {
    "sn1.68:0.1": "Saṁyutta Nikāya 1.68 ",
    "sn1.68:0.2": "7. Addhavagga ",
    "sn1.68:0.3": "Pihitasutta ",
    "sn1.68:1.1": "“Kenassu pihito loko, ",
    "sn1.68:1.2": "kismiṁ loko patiṭṭhito; ",
    "sn1.68:1.3": "Kenassu uḍḍito loko, ",
    "sn1.68:1.4": "kenassu parivārito”ti. ",
    "sn1.68:2.1": "“Maccunā pihito loko, ",
    "sn1.68:2.2": "dukkhe loko patiṭṭhito; ",
    "sn1.68:2.3": "Taṇhāya uḍḍito loko, ",
    "sn1.68:2.4": "jarāya parivārito”ti. "
  },
  "translation_text": {
    "sn1.68:0.1": "Linked Discourses 1.68 ",
    "sn1.68:0.2": "7. Overcome ",
    "sn1.68:0.3": "Fastened Shut ",
    "sn1.68:1.1": "“By what is the world fastened shut? ",
    "sn1.68:1.2": "On what is the world grounded? ",
    "sn1.68:1.3": "By what is the world ensnared? ",
    "sn1.68:1.4": "By what is it surrounded?” ",
    "sn1.68:2.1": "“The world is fastened shut by mortality. ",
    "sn1.68:2.2": "The world is grounded on suffering. ",
    "sn1.68:2.3": "Craving has ensnared the world. ",
    "sn1.68:2.4": "It’s surrounded by old age.” "
  },
