  "root_text": {
    "sn22.11:0.1": "Saṁyutta Nikāya 22.11 ",
    "sn22.11:0.2": "1. Nakulapituvagga ",
    "sn22.11:0.3": "Kālattayaanattasutta ",
    "sn22.11:1.1": "Sāvatthinidānaṁ. ",
    "sn22.11:1.2": "“Rūpaṁ, bhikkhave, anattā atītānāgataṁ; ",
    "sn22.11:1.3": "ko pana vādo paccuppannassa. ",
    "sn22.11:1.4": "Evaṁ passaṁ, bhikkhave, sutavā ariyasāvako atītasmiṁ rūpasmiṁ anapekkho hoti; ",
    "sn22.11:1.5": "anāgataṁ rūpaṁ nābhinandati; ",
    "sn22.11:1.6": "paccuppannassa rūpassa nibbidāya virāgāya nirodhāya paṭipanno hoti. ",
    "sn22.11:1.7": "Vedanā anattā … ",
    "sn22.11:1.8": "saññā anattā … ",
    "sn22.11:1.9": "saṅkhārā anattā … ",
    "sn22.11:1.10": "viññāṇaṁ anattā atītānāgataṁ; ",
    "sn22.11:1.11": "ko pana vādo paccuppannassa. ",
    "sn22.11:1.12": "Evaṁ passaṁ, bhikkhave, sutavā ariyasāvako atītasmiṁ viññāṇasmiṁ anapekkho hoti; ",
    "sn22.11:1.13": "anāgataṁ viññāṇaṁ nābhinandati; ",
    "sn22.11:1.14": "paccuppannassa viññāṇassa nibbidāya virāgāya nirodhāya paṭipanno hotī”ti. ",
    "sn22.11:1.15": "Ekādasamaṁ. ",
    "sn22.11:1.16": "Nakulapituvaggo paṭhamo. ",
    "sn22.11:2.0": "Tassuddānaṁ ",
    "sn22.11:2.1": "Nakulapitā devadahā, ",
    "sn22.11:2.2": "Dvepi hāliddikāni ca; ",
    "sn22.11:2.3": "Samādhipaṭisallāṇā, ",
    "sn22.11:2.4": "Upādāparitassanā duve; ",
    "sn22.11:2.5": "Atītānāgatapaccuppannā, ",
    "sn22.11:2.6": "Vaggo tena pavuccati. "
  },
  "translation_text": {
    "sn22.11:0.1": "Linked Discourses 22.11 ",
    "sn22.11:0.2": "1. Nakula’s Father ",
    "sn22.11:0.3": "Not-Self in the Three Times ",
    "sn22.11:1.1": "At Sāvatthī. ",
    "sn22.11:1.2": "“Mendicants, form of the past and future is not-self, ",
    "sn22.11:1.3": "let alone the present. ",
    "sn22.11:1.4": "Seeing this, a learned noble disciple is not concerned with past form, ",
    "sn22.11:1.5": "doesn’t look forward to enjoying future form, ",
    "sn22.11:1.6": "and they practice for disillusionment, dispassion, and cessation regarding present form. ",
    "sn22.11:1.7": "Feeling … ",
    "sn22.11:1.8": "Perception … ",
    "sn22.11:1.9": "Choices … ",
    "sn22.11:1.10": "Consciousness of the past and future is not-self, ",
    "sn22.11:1.11": "let alone the present. ",
    "sn22.11:1.12": "Seeing this, a learned noble disciple is not concerned with past consciousness, ",
    "sn22.11:1.13": "doesn’t look forward to enjoying future consciousness, ",
    "sn22.11:1.14": "and they practice for the disillusionment, dispassion, and cessation regarding present consciousness.” ",
