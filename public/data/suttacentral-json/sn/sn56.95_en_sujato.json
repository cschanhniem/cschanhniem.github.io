  "root_text": {
    "sn56.95:0.1": "Saṁyutta Nikāya 56.95 ",
    "sn56.95:0.2": "10. Catutthaāmakadhaññapeyyālavagga ",
    "sn56.95:0.3": "Ukkoṭanasutta ",
    "sn56.95:1.1": "… “Evameva kho, bhikkhave, appakā te sattā ye ukkoṭanavañcananikatisāciyogā paṭiviratā; atha kho eteva bahutarā sattā ye ukkoṭanavañcananikatisāciyogā appaṭiviratā …pe…. ",
    "sn56.95:1.2": "Pañcamaṁ. "
  },
  "translation_text": {
    "sn56.95:0.1": "Linked Discourses 56.95 ",
    "sn56.95:0.2": "10. Abbreviated Texts on Raw Grain ",
    "sn56.95:0.3": "Bribery ",
    "sn56.95:1.1": "“… the sentient beings who refrain from bribery, fraud, cheating, and duplicity are few, while those who don’t refrain are many. …” "
  },
  "variant_text": {
    "sn56.95:0.3": "Ukkoṭanasutta → ukkoṭanādisuttāni (bj) ",
    "sn56.95:1.1": "ukkoṭanavañcananikatisāciyogā → ukkoṭanavañcananikatisāviyogā (sya-all, km, pts1ed, mr) "
  },
