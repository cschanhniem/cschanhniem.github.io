  "root_text": {
    "sn22.15:0.1": "Saṁyutta Nikāya 22.15 ",
    "sn22.15:0.2": "2. Aniccavagga ",
    "sn22.15:0.3": "Yadaniccasutta ",
    "sn22.15:1.1": "Sāvatthinidānaṁ. ",
    "sn22.15:1.2": "“Rūpaṁ, bhikkhave, aniccaṁ. ",
    "sn22.15:1.3": "Yadaniccaṁ taṁ dukkhaṁ; ",
    "sn22.15:1.4": "yaṁ dukkhaṁ tadanattā; ",
    "sn22.15:1.5": "yadanattā taṁ ‘netaṁ mama, nesohamasmi, na meso attā’ti evametaṁ yathābhūtaṁ sammappaññāya daṭṭhabbaṁ. ",
    "sn22.15:1.6": "Vedanā aniccā. ",
    "sn22.15:1.7": "Yadaniccaṁ taṁ dukkhaṁ; ",
    "sn22.15:1.8": "yaṁ dukkhaṁ tadanattā; ",
    "sn22.15:1.9": "yadanattā taṁ ‘netaṁ mama, nesohamasmi, na meso attā’ti evametaṁ yathābhūtaṁ sammappaññāya daṭṭhabbaṁ. ",
    "sn22.15:1.10": "Saññā aniccā …pe… ",
    "sn22.15:1.11": "saṅkhārā aniccā … ",
    "sn22.15:1.12": "viññāṇaṁ aniccaṁ. ",
    "sn22.15:1.13": "Yadaniccaṁ taṁ dukkhaṁ; ",
    "sn22.15:1.14": "yaṁ dukkhaṁ tadanattā; ",
    "sn22.15:1.15": "yadanattā taṁ ‘netaṁ mama, nesohamasmi, na meso attā’ti evametaṁ yathābhūtaṁ sammappaññāya daṭṭhabbaṁ. ",
    "sn22.15:1.16": "Evaṁ passaṁ …pe… ",
    "sn22.15:1.17": "nāparaṁ itthattāyā’ti pajānātī”ti. ",
    "sn22.15:1.18": "Catutthaṁ. "
  },
  "translation_text": {
    "sn22.15:0.1": "Linked Discourses 22.15 ",
    "sn22.15:0.2": "2. Impermanence ",
    "sn22.15:0.3": "That Which is Impermanent ",
    "sn22.15:1.1": "At Sāvatthī. ",
    "sn22.15:1.2": "“Mendicants, form is impermanent. ",
    "sn22.15:1.3": "What’s impermanent is suffering. ",
    "sn22.15:1.4": "What’s suffering is not-self. ",
    "sn22.15:1.5": "And what’s not-self should be truly seen with right understanding like this: ‘This is not mine, I am not this, this is not my self.’ ",
    "sn22.15:1.6": "Feeling is impermanent … ",
    "sn22.15:1.7": "",
    "sn22.15:1.8": "",
    "sn22.15:1.9": "",
    "sn22.15:1.10": "Perception is impermanent … ",
    "sn22.15:1.11": "Choices are impermanent … ",
    "sn22.15:1.12": "Consciousness is impermanent. ",
    "sn22.15:1.13": "What’s impermanent is suffering. ",
    "sn22.15:1.14": "What’s suffering is not-self. ",
    "sn22.15:1.15": "And what’s not-self should be truly seen with right understanding like this: ‘This is not mine, I am not this, this is not my self.’ ",
    "sn22.15:1.16": "Seeing this … ",
    "sn22.15:1.17": "They understand: ‘… there is nothing further for this place.’” "
  },
  "variant_text": {
    "sn22.15:0.3": "Yadaniccasutta → yad anicca 1 (pts1ed) "
  },
