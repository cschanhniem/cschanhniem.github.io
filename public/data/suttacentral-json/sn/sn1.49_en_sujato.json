  "root_text": {
    "sn1.49:0.1": "Saṁyutta Nikāya 1.49 ",
    "sn1.49:0.2": "5. Ādittavagga ",
    "sn1.49:0.3": "Maccharisutta ",
    "sn1.49:1.1": "“Yedha maccharino loke, ",
    "sn1.49:1.2": "kadariyā paribhāsakā; ",
    "sn1.49:1.3": "Aññesaṁ dadamānānaṁ, ",
    "sn1.49:1.4": "antarāyakarā narā. ",
    "sn1.49:2.1": "Kīdiso tesaṁ vipāko, ",
    "sn1.49:2.2": "samparāyo ca kīdiso; ",
    "sn1.49:2.3": "Bhagavantaṁ puṭṭhumāgamma, ",
    "sn1.49:2.4": "kathaṁ jānemu taṁ mayan”ti. ",
    "sn1.49:3.1": "“Yedha maccharino loke, ",
    "sn1.49:3.2": "kadariyā paribhāsakā; ",
    "sn1.49:3.3": "Aññesaṁ dadamānānaṁ, ",
    "sn1.49:3.4": "antarāyakarā narā. ",
    "sn1.49:4.1": "Nirayaṁ tiracchānayoniṁ, ",
    "sn1.49:4.2": "yamalokaṁ upapajjare; ",
    "sn1.49:4.3": "Sace enti manussattaṁ, ",
    "sn1.49:4.4": "dalidde jāyare kule. ",
    "sn1.49:5.1": "Coḷaṁ piṇḍo ratī khiḍḍā, ",
    "sn1.49:5.2": "yattha kicchena labbhati; ",
    "sn1.49:5.3": "Parato āsīsare bālā, ",
    "sn1.49:5.4": "tampi tesaṁ na labbhati; ",
    "sn1.49:5.5": "Diṭṭhe dhammesa vipāko, ",
    "sn1.49:5.6": "samparāye ca duggatī”ti. ",
    "sn1.49:6.1": "“Itihetaṁ vijānāma, ",
    "sn1.49:6.2": "aññaṁ pucchāma gotama; ",
    "sn1.49:6.3": "Yedha laddhā manussattaṁ, ",
    "sn1.49:6.4": "vadaññū vītamaccharā. ",
    "sn1.49:7.1": "Buddhe pasannā dhamme ca, ",
    "sn1.49:7.2": "saṅghe ca tibbagāravā; ",
    "sn1.49:7.3": "Kīdiso tesaṁ vipāko, ",
    "sn1.49:7.4": "samparāyo ca kīdiso; ",
    "sn1.49:7.5": "Bhagavantaṁ puṭṭhumāgamma, ",
    "sn1.49:7.6": "kathaṁ jānemu taṁ mayan”ti. ",
    "sn1.49:8.1": "“Yedha laddhā manussattaṁ, ",
    "sn1.49:8.2": "vadaññū vītamaccharā; ",
    "sn1.49:8.3": "Buddhe pasannā dhamme ca, ",
    "sn1.49:8.4": "saṅghe ca tibbagāravā; ",
    "sn1.49:8.5": "Ete saggā pakāsanti, ",
    "sn1.49:8.6": "yattha te upapajjare. ",
    "sn1.49:9.1": "Sace enti manussattaṁ, ",
    "sn1.49:9.2": "aḍḍhe ājāyare kule; ",
    "sn1.49:9.3": "Coḷaṁ piṇḍo ratī khiḍḍā, ",
    "sn1.49:9.4": "yatthākicchena labbhati. ",
    "sn1.49:10.1": "Parasambhatesu bhogesu, ",
    "sn1.49:10.2": "vasavattīva modare; ",
    "sn1.49:10.3": "Diṭṭhe dhammesa vipāko, ",
    "sn1.49:10.4": "samparāye ca suggatī”ti. "
  },
  "translation_text": {
    "sn1.49:0.1": "Linked Discourses 1.49 ",
    "sn1.49:0.2": "5. On Fire ",
    "sn1.49:0.3": "Stingy ",
    "sn1.49:1.1": "“Those folk in the world who are stingy, ",
    "sn1.49:1.2": "miserly and abusive, ",
    "sn1.49:1.3": "setting up obstacles ",
    "sn1.49:1.4": "for others who give. ",
    "sn1.49:2.1": "What kind of result do they reap? ",
    "sn1.49:2.2": "What kind of future life? ",
    "sn1.49:2.3": "We’ve come to ask you, worthy sir: ",
    "sn1.49:2.4": "how are we to understand this?” ",
    "sn1.49:3.1": "“Those folk in the world who are stingy, ",
    "sn1.49:3.2": "miserly and abusive, ",
    "sn1.49:3.3": "setting up obstacles ",
    "sn1.49:3.4": "for others who give: ",
    "sn1.49:4.1": "they’re reborn in hell, ",
    "sn1.49:4.2": "the animal realm, or Yama’s world. ",
    "sn1.49:4.3": "If they return to the human state, ",
    "sn1.49:4.4": "they’re born in a poor family, ",
    "sn1.49:5.1": "where clothes, food, pleasure, and play ",
    "sn1.49:5.2": "are hard to find. ",
    "sn1.49:5.3": "They don’t even get ",
    "sn1.49:5.4": "what they hope for from others. ",
    "sn1.49:5.5": "This is the result in the present life, ",
    "sn1.49:5.6": "and in the next, a bad destination.” ",
    "sn1.49:6.1": "“We understand what you’re saying, ",
    "sn1.49:6.2": "and ask another question, Gotama. ",
    "sn1.49:6.3": "What about those who’ve gained the human state, ",
    "sn1.49:6.4": "who are bountiful and rid of stinginess, ",
    "sn1.49:7.1": "confident in the Buddha and the teaching, ",
    "sn1.49:7.2": "with keen respect for the Saṅgha? ",
    "sn1.49:7.3": "What kind of result do they reap? ",
    "sn1.49:7.4": "What kind of future life? ",
    "sn1.49:7.5": "We’ve come to ask you, worthy sir: ",
    "sn1.49:7.6": "how are we to understand this?” ",
    "sn1.49:8.1": "“Those who’ve gained the human state ",
    "sn1.49:8.2": "who are bountiful and rid of stinginess, ",
    "sn1.49:8.3": "confident in the Buddha and the teaching, ",
    "sn1.49:8.4": "with keen respect for the Saṅgha: ",
    "sn1.49:8.5": "they illuminate the heavens ",
    "sn1.49:8.6": "wherever they’re reborn. ",
    "sn1.49:9.1": "If they return to the human state, ",
    "sn1.49:9.2": "they’re reborn in a rich family, ",
    "sn1.49:9.3": "where clothes, food, pleasure, and play ",
    "sn1.49:9.4": "are easy to find. ",
    "sn1.49:10.1": "They rejoice like those ",
    "sn1.49:10.2": "who control the possessions of others. ",
    "sn1.49:10.3": "This is the result in the present life, ",
    "sn1.49:10.4": "and in the next, a good destination.” "
  },
