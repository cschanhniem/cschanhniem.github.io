  "root_text": {
    "sn1.23:0.1": "Saṁyutta Nikāya 1.23 ",
    "sn1.23:0.2": "3. Sattivagga ",
    "sn1.23:0.3": "Jaṭāsutta ",
    "sn1.23:1.1": "“Antojaṭā bahijaṭā, ",
    "sn1.23:1.2": "Jaṭāya jaṭitā pajā; ",
    "sn1.23:1.3": "Taṁ taṁ gotama pucchāmi, ",
    "sn1.23:1.4": "Ko imaṁ vijaṭaye jaṭan”ti. ",
    "sn1.23:2.1": "“Sīle patiṭṭhāya naro sapañño, ",
    "sn1.23:2.2": "Cittaṁ paññañca bhāvayaṁ; ",
    "sn1.23:2.3": "Ātāpī nipako bhikkhu, ",
    "sn1.23:2.4": "So imaṁ vijaṭaye jaṭaṁ. ",
    "sn1.23:3.1": "Yesaṁ rāgo ca doso ca, ",
    "sn1.23:3.2": "avijjā ca virājitā; ",
    "sn1.23:3.3": "Khīṇāsavā arahanto, ",
    "sn1.23:3.4": "tesaṁ vijaṭitā jaṭā. ",
    "sn1.23:4.1": "Yattha nāmañca rūpañca, ",
    "sn1.23:4.2": "asesaṁ uparujjhati; ",
    "sn1.23:4.3": "Paṭighaṁ rūpasaññā ca, ",
    "sn1.23:4.4": "etthesā chijjate jaṭā”ti. "
  },
  "translation_text": {
    "sn1.23:0.1": "Linked Discourses 1.23 ",
    "sn1.23:0.2": "3. A Sword ",
    "sn1.23:0.3": "A Tangle ",
    "sn1.23:1.1": "“Tangled within, tangled without: ",
    "sn1.23:1.2": "these people are tangled in tangles. ",
    "sn1.23:1.3": "I ask you this, Gotama: ",
    "sn1.23:1.4": "who can untangle this tangle?” ",
    "sn1.23:2.1": "“A wise person grounded in ethics, ",
    "sn1.23:2.2": "developing the mind and wisdom, ",
    "sn1.23:2.3": "a keen and alert mendicant—",
    "sn1.23:2.4": "they can untangle this tangle. ",
    "sn1.23:3.1": "Those in whom greed, hate, and ignorance ",
    "sn1.23:3.2": "have faded away; ",
    "sn1.23:3.3": "the perfected ones with defilements ended—",
    "sn1.23:3.4": "they have untangled the tangle. ",
    "sn1.23:4.1": "And where name and form ",
    "sn1.23:4.2": "cease with nothing left over; ",
    "sn1.23:4.3": "and impingement and perception of form: ",
    "sn1.23:4.4": "it’s here that the tangle is cut.” "
  },
  "variant_text": {
    "sn1.23:4.4": "chijjate → vijaṭe (mr) "
  },
