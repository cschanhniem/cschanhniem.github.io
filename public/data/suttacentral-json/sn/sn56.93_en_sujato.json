  "root_text": {
    "sn56.93:0.1": "Saṁyutta Nikāya 56.93 ",
    "sn56.93:0.2": "10. Catutthaāmakadhaññapeyyālavagga ",
    "sn56.93:0.3": "Dūteyyasutta ",
    "sn56.93:1.1": "… “Evameva kho, bhikkhave, appakā te sattā ye dūteyyapahiṇagamanānuyogā paṭiviratā; atha kho eteva bahutarā sattā ye dūteyyapahiṇagamanānuyogā appaṭiviratā …pe…. ",
    "sn56.93:1.2": "Tatiyaṁ. "
  },
  "translation_text": {
    "sn56.93:0.1": "Linked Discourses 56.93 ",
    "sn56.93:0.2": "10. Abbreviated Texts on Raw Grain ",
    "sn56.93:0.3": "Errands ",
    "sn56.93:1.1": "“… the sentient beings who refrain from running errands and messages are few, while those who don’t refrain are many. …” "
  },
