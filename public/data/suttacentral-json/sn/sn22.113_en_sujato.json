  "root_text": {
    "sn22.113:0.1": "Saṁyutta Nikāya 22.113 ",
    "sn22.113:0.2": "12. Dhammakathikavagga ",
    "sn22.113:0.3": "Avijjāsutta ",
    "sn22.113:1.1": "Sāvatthinidānaṁ. ",
    "sn22.113:1.2": "Atha kho aññataro bhikkhu yena bhagavā tenupasaṅkami …pe… ",
    "sn22.113:1.3": "ekamantaṁ nisinno kho so bhikkhu bhagavantaṁ etadavoca: ",
    "sn22.113:1.4": "“‘avijjā, avijjā’ti, bhante, vuccati. ",
    "sn22.113:1.5": "Katamā nu kho, bhante, avijjā; ",
    "sn22.113:1.6": "kittāvatā ca avijjāgato hotī”ti? ",
    "sn22.113:1.7": "“Idha, bhikkhu, assutavā puthujjano rūpaṁ nappajānāti, rūpasamudayaṁ nappajānāti, rūpanirodhaṁ nappajānāti, rūpanirodhagāminiṁ paṭipadaṁ nappajānāti; ",
    "sn22.113:1.8": "vedanaṁ nappajānāti … ",
    "sn22.113:1.9": "saññaṁ … ",
    "sn22.113:1.10": "saṅkhāre nappajānāti …pe… ",
    "sn22.113:1.11": "viññāṇanirodhagāminiṁ paṭipadaṁ nappajānāti. ",
    "sn22.113:1.12": "Ayaṁ vuccati, bhikkhu, avijjā; ",
    "sn22.113:1.13": "ettāvatā ca avijjāgato hotī”ti. ",
    "sn22.113:1.14": "Paṭhamaṁ. "
  },
  "translation_text": {
    "sn22.113:0.1": "Linked Discourses 22.113 ",
    "sn22.113:0.2": "12. A Dhamma speaker ",
    "sn22.113:0.3": "Ignorance ",
    "sn22.113:1.1": "At Sāvatthī. ",
    "sn22.113:1.2": "Then a mendicant went up to the Buddha ",
    "sn22.113:1.3": "and said to him: ",
    "sn22.113:1.4": "“Sir, they speak of this thing called ‘ignorance’. ",
    "sn22.113:1.5": "What is ignorance? ",
    "sn22.113:1.6": "And how is an ignorant person defined?” ",
    "sn22.113:1.7": "“Mendicant, it’s when an unlearned ordinary person doesn’t understand form, its origin, its cessation, and the practice that leads to its cessation. ",
    "sn22.113:1.8": "They don’t understand feeling … ",
    "sn22.113:1.9": "perception … ",
    "sn22.113:1.10": "choices … ",
    "sn22.113:1.11": "consciousness, its origin, its cessation, and the practice that leads to its cessation. ",
    "sn22.113:1.12": "This is called ignorance. ",
    "sn22.113:1.13": "And this is how an ignorant person is defined.” "
  },
  "variant_text": {
    "sn22.113:0.3": "Avijjāsutta → avijjā or bhikkhu 1 (pts1ed) "
  },
