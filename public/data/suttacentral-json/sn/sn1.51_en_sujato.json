  "root_text": {
    "sn1.51:0.1": "Saṁyutta Nikāya 1.51 ",
    "sn1.51:0.2": "6. Jarāvagga ",
    "sn1.51:0.3": "Jarāsutta ",
    "sn1.51:1.1": "“Kiṁsu yāva jarā sādhu, ",
    "sn1.51:1.2": "kiṁsu sādhu patiṭṭhitaṁ; ",
    "sn1.51:1.3": "Kiṁsu narānaṁ ratanaṁ, ",
    "sn1.51:1.4": "kiṁsu corehi dūharan”ti. ",
    "sn1.51:2.1": "“Sīlaṁ yāva jarā sādhu, ",
    "sn1.51:2.2": "saddhā sādhu patiṭṭhitā; ",
    "sn1.51:2.3": "Paññā narānaṁ ratanaṁ, ",
    "sn1.51:2.4": "puññaṁ corehi dūharan”ti. "
  },
  "translation_text": {
    "sn1.51:0.1": "Linked Discourses 1.51 ",
    "sn1.51:0.2": "6. Old Age ",
    "sn1.51:0.3": "Old Age ",
    "sn1.51:1.1": "“What’s still good in old age? ",
    "sn1.51:1.2": "What’s good when grounded? ",
    "sn1.51:1.3": "What is people’s treasure? ",
    "sn1.51:1.4": "What’s hard for thieves to take?” ",
    "sn1.51:2.1": "“Ethics are still good in old age. ",
    "sn1.51:2.2": "Faith is good when grounded. ",
    "sn1.51:2.3": "Wisdom is people’s treasure. ",
    "sn1.51:2.4": "Merit’s hard for thieves to take.” "
  },
