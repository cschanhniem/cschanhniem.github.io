  "root_text": {
    "sn35.198-200:0.1": "Saṁyutta Nikāya 35.198–200 ",
    "sn35.198-200:0.2": "17. Saṭṭhipeyyālavagga ",
    "sn35.198-200:0.3": "Bāhirātītādidukkhasutta ",
    "sn35.198-200:1.1": "“Rūpā, bhikkhave, dukkhā atītā anāgatā paccuppannā. Saddā … gandhā … rasā … phoṭṭhabbā … dhammā dukkhā atītā anāgatā paccuppannā. ",
    "sn35.198-200:1.2": "Evaṁ passaṁ …pe… ",
    "sn35.198-200:1.3": "nāparaṁ itthattāyāti pajānātī”ti. "
  },
  "translation_text": {
    "sn35.198-200:0.1": "Linked Discourses 35.198–200 ",
    "sn35.198-200:0.2": "17. Sixty Abbreviated Texts ",
    "sn35.198-200:0.3": "The Exterior as Suffering in the Three Times ",
    "sn35.198-200:1.1": "“Mendicants, in the past … future … present sights, sounds, smells, tastes, touches, and ideas are suffering …” ",
    "sn35.198-200:1.2": ""
  },
