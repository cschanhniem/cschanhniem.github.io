  "root_text": {
    "sn35.189-191:0.1": "Saṁyutta Nikāya 35.189–191 ",
    "sn35.189-191:0.2": "17. Saṭṭhipeyyālavagga ",
    "sn35.189-191:0.3": "Ajjhattātītādidukkhasutta ",
    "sn35.189-191:1.1": "“Cakkhu, bhikkhave, dukkhaṁ atītaṁ anāgataṁ paccuppannaṁ …pe… jivhā dukkhā atītā anāgatā paccuppannā …pe… mano dukkho atīto anāgato paccuppanno. ",
    "sn35.189-191:1.2": "Evaṁ passaṁ, bhikkhave …pe… ",
    "sn35.189-191:1.3": "nāparaṁ itthattāyāti pajānātī”ti. "
  },
  "translation_text": {
    "sn35.189-191:0.1": "Linked Discourses 35.189–191 ",
    "sn35.189-191:0.2": "17. Sixty Abbreviated Texts ",
    "sn35.189-191:0.3": "The Interior as Suffering in the Three Times ",
    "sn35.189-191:1.1": "“Mendicants, in the past … future … present the eye, ear, nose, tongue, body, and mind are suffering …” ",
    "sn35.189-191:1.2": ""
  },
  "variant_text": {
    "sn35.189-191:0.3": "Ajjhattātītādidukkhasutta → paccuppannadukkhasuttāni (bj); 6 (pts1ed) "
  },
