  "root_text": {
    "sn35.224:0.1": "Saṁyutta Nikāya 35.224 ",
    "sn35.224:0.2": "17. Saṭṭhipeyyālavagga ",
    "sn35.224:0.3": "Ajjhattāyatanaanattasutta ",
    "sn35.224:1.1": "“Cakkhu, bhikkhave, anattā …pe… jivhā anattā …pe… mano anattā. ",
    "sn35.224:1.2": "Evaṁ passaṁ …pe… ",
    "sn35.224:1.3": "nāparaṁ itthattāyāti pajānātī”ti. "
  },
  "translation_text": {
    "sn35.224:0.1": "Linked Discourses 35.224 ",
    "sn35.224:0.2": "17. Sixty Abbreviated Texts ",
    "sn35.224:0.3": "The Interior as Not-Self ",
    "sn35.224:1.1": "“Mendicants, the eye, ear, nose, tongue, body, and mind are not-self. ",
    "sn35.224:1.2": "Seeing this … ",
    "sn35.224:1.3": "They understand: ‘… there is nothing further for this place.’” "
  },
