  "root_text": {
    "sn23.18:0.1": "Saṁyutta Nikāya 23.18 ",
    "sn23.18:0.2": "2. Dutiyamāravagga ",
    "sn23.18:0.3": "Anattadhammasutta ",
    "sn23.18:1.1": "Sāvatthinidānaṁ. ",
    "sn23.18:1.2": "Ekamantaṁ nisinno kho āyasmā rādho bhagavantaṁ etadavoca: ",
    "sn23.18:1.3": "“‘anattadhammo, anattadhammo’ti, bhante, vuccati. ",
    "sn23.18:1.4": "Katamo nu kho, bhante, anattadhammo”ti? ",
    "sn23.18:1.5": "“Rūpaṁ kho, rādha, anattadhammo, vedanā anattadhammo, saññā anattadhammo, saṅkhārā anattadhammo, viññāṇaṁ anattadhammo. ",
    "sn23.18:1.6": "Evaṁ passaṁ …pe… ",
    "sn23.18:1.7": "nāparaṁ itthattāyāti pajānātī”ti. ",
    "sn23.18:1.8": "Aṭṭhamaṁ. "
  },
  "translation_text": {
    "sn23.18:0.1": "Linked Discourses 23.18 ",
    "sn23.18:0.2": "2. About Māra (2nd) ",
    "sn23.18:0.3": "Naturally Not-Self ",
    "sn23.18:1.1": "At Sāvatthī. ",
    "sn23.18:1.2": "Seated to one side, Venerable Rādha said to the Buddha: ",
    "sn23.18:1.3": "“Sir, they speak of this thing called ‘liable to not-self’. ",
    "sn23.18:1.4": "What is liable to not-self?” ",
    "sn23.18:1.5": "“Rādha, form, feeling, perception, choices, and consciousness are liable to not-self. ",
    "sn23.18:1.6": "Seeing this … ",
    "sn23.18:1.7": "They understand: ‘… there is nothing further for this place.’” "
  },
  "variant_text": {
    "sn23.18:0.3": "Anattadhammasutta → anatta 2 (pts1ed) "
  },
