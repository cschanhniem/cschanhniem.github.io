  "root_text": {
    "sn46.25:0.1": "Saṁyutta Nikāya 46.25 ",
    "sn46.25:0.2": "3. Udāyivagga ",
    "sn46.25:0.3": "Aparihāniyasutta ",
    "sn46.25:1.1": "“Satta vo, bhikkhave, aparihāniye dhamme desessāmi; ",
    "sn46.25:1.2": "taṁ suṇātha. ",
    "sn46.25:1.3": "Katame ca, bhikkhave, satta aparihāniyā dhammā? ",
    "sn46.25:1.4": "Yadidaṁ—",
    "sn46.25:1.5": "satta bojjhaṅgā. ",
    "sn46.25:1.6": "Katame satta? ",
    "sn46.25:1.7": "Satisambojjhaṅgo …pe… upekkhāsambojjhaṅgo—",
    "sn46.25:1.8": "ime kho, bhikkhave, satta aparihāniyā dhammā”ti. ",
    "sn46.25:1.9": "Pañcamaṁ. "
  },
  "translation_text": {
    "sn46.25:0.1": "Linked Discourses 46.25 ",
    "sn46.25:0.2": "3. With Udāyī ",
    "sn46.25:0.3": "Non-decline ",
    "sn46.25:1.1": "“Mendicants, I will teach you seven principles that prevent decline. ",
    "sn46.25:1.2": "Listen … ",
    "sn46.25:1.3": "And what are the seven principles that prevent decline? ",
    "sn46.25:1.4": "",
    "sn46.25:1.5": "They are the seven awakening factors. ",
    "sn46.25:1.6": "What seven? ",
    "sn46.25:1.7": "The awakening factors of mindfulness, investigation of principles, energy, rapture, tranquility, immersion, and equanimity. ",
    "sn46.25:1.8": "These are the seven principles that prevent decline.” "
  },
