  "root_text": {
    "sn40.11:0.1": "Saṁyutta Nikāya 40.11 ",
    "sn40.11:0.2": "1. Moggallānavagga ",
    "sn40.11:0.3": "Candanasutta ",
    "sn40.11:1.1": "Atha kho candano devaputto …pe…. ",
    "sn40.11:2.1": "Atha kho suyāmo devaputto …pe…. ",
    "sn40.11:3.1": "Atha kho santusito devaputto …pe…. ",
    "sn40.11:4.1": "Atha kho sunimmito devaputto …pe…. ",
    "sn40.11:5.1": "Atha kho vasavatti devaputto …pe…. ",
    "sn40.11:6.1": "(Yathā sakkasuttaṁ tathā ime pañca peyyālā vitthāretabbā.) ",
    "sn40.11:6.2": "Ekādasamaṁ. ",
    "sn40.11:6.3": "Moggallānavaggo paṭhamo. ",
    "sn40.11:7.0": "Tassuddānaṁ ",
    "sn40.11:7.1": "Savitakkāvitakkañca, ",
    "sn40.11:7.2": "sukhena ca upekkhako; ",
    "sn40.11:7.3": "Ākāsañceva viññāṇaṁ, ",
    "sn40.11:7.4": "ākiñcaṁ nevasaññinā; ",
    "sn40.11:7.5": "Animitto ca sakko ca, ",
    "sn40.11:7.6": "candanekādasena cāti. ",
    "sn40.11:7.7": "Moggallānasaṁyuttaṁ samattaṁ. "
  },
  "translation_text": {
    "sn40.11:0.1": "Linked Discourses 40.11 ",
    "sn40.11:0.2": "1. By Moggallāna ",
    "sn40.11:0.3": "With Candana, Etc. ",
    "sn40.11:1.1": "Then the godling Candana … ",
    "sn40.11:2.1": "the godling Suyāma … ",
    "sn40.11:3.1": "the godling Santusita … ",
    "sn40.11:4.1": "the godling Sunimmita … ",
    "sn40.11:5.1": "the godling Vasavatti … ",
    "sn40.11:6.1": "(Tell in full  as in the Discourse With Sakka.) ",
    "sn40.11:6.2": "",
    "sn40.11:6.3": "",
    "sn40.11:7.1": "",
    "sn40.11:7.2": "",
    "sn40.11:7.3": "",
    "sn40.11:7.4": "",
    "sn40.11:7.5": "",
    "sn40.11:7.6": "",
    "sn40.11:7.7": "The Linked Discourses on Moggallāna are complete. "
  },
