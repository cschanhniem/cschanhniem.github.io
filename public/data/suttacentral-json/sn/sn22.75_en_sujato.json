  "root_text": {
    "sn22.75:0.1": "Saṁyutta Nikāya 22.75 ",
    "sn22.75:0.2": "8. Khajjanīyavagga ",
    "sn22.75:0.3": "Dutiyasamudayasutta ",
    "sn22.75:1.1": "Sāvatthinidānaṁ. ",
    "sn22.75:1.2": "“Sutavā, bhikkhave, ariyasāvako rūpassa samudayañca atthaṅgamañca assādañca ādīnavañca nissaraṇañca yathābhūtaṁ pajānāti. ",
    "sn22.75:1.3": "Vedanāya … ",
    "sn22.75:1.4": "saññāya … ",
    "sn22.75:1.5": "saṅkhārānaṁ … ",
    "sn22.75:1.6": "viññāṇassa samudayañca atthaṅgamañca assādañca ādīnavañca nissaraṇañca yathābhūtaṁ pajānātī”ti. ",
    "sn22.75:1.7": "Tatiyaṁ. "
  },
  "translation_text": {
    "sn22.75:0.1": "Linked Discourses 22.75 ",
    "sn22.75:0.2": "8. Bitable ",
    "sn22.75:0.3": "Origin (2nd) ",
    "sn22.75:1.1": "At Sāvatthī. ",
    "sn22.75:1.2": "“Mendicants, a learned noble disciple truly understands the origin, the disappearance, the gratification, the drawback, and the escape when it comes to form, ",
    "sn22.75:1.3": "feeling, ",
    "sn22.75:1.4": "perception, ",
    "sn22.75:1.5": "choices, ",
    "sn22.75:1.6": "and consciousness.” "
  },
