  "root_text": {
    "sn35.170:0.1": "Saṁyutta Nikāya 35.170 ",
    "sn35.170:0.2": "17. Saṭṭhipeyyālavagga ",
    "sn35.170:0.3": "Ajjhattaaniccachandarāgasutta ",
    "sn35.170:1.1": "“Yaṁ, bhikkhave, aniccaṁ, tatra vo chandarāgo pahātabbo. ",
    "sn35.170:1.2": "Kiñca, bhikkhave, aniccaṁ? ",
    "sn35.170:1.3": "Cakkhu, bhikkhave, aniccaṁ; ",
    "sn35.170:1.4": "tatra vo chandarāgo pahātabbo …pe… ",
    "sn35.170:1.5": "jivhā aniccā; ",
    "sn35.170:1.6": "tatra vo chandarāgo pahātabbo …pe… ",
    "sn35.170:1.7": "mano anicco; ",
    "sn35.170:1.8": "tatra vo chandarāgo pahātabbo. ",
    "sn35.170:1.9": "Yaṁ, bhikkhave, aniccaṁ, tatra vo chandarāgo pahātabbo”ti. "
  },
  "translation_text": {
    "sn35.170:0.1": "Linked Discourses 35.170 ",
    "sn35.170:0.2": "17. Sixty Abbreviated Texts ",
    "sn35.170:0.3": "Desire and Greed for the Impermanent Interior ",
    "sn35.170:1.1": "“Mendicants, you should give up desire and greed for what is impermanent. ",
    "sn35.170:1.2": "And what is impermanent? ",
    "sn35.170:1.3": "The eye, ear, nose, tongue, body, and mind are impermanent …” ",
