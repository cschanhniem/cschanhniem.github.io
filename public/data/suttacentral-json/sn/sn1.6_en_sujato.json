  "root_text": {
    "sn1.6:0.1": "Saṁyutta Nikāya 1.6 ",
    "sn1.6:0.2": "1. Naḷavagga ",
    "sn1.6:0.3": "Jāgarasutta ",
    "sn1.6:1.1": "Sāvatthinidānaṁ. ",
    "sn1.6:1.2": "Ekamantaṁ ṭhitā kho sā devatā bhagavato santike imaṁ gāthaṁ abhāsi: ",
    "sn1.6:2.1": "“Kati jāgarataṁ suttā, ",
    "sn1.6:2.2": "kati suttesu jāgarā; ",
    "sn1.6:2.3": "Katibhi rajamādeti, ",
    "sn1.6:2.4": "katibhi parisujjhatī”ti. ",
    "sn1.6:3.1": "“Pañca jāgarataṁ suttā, ",
    "sn1.6:3.2": "pañca suttesu jāgarā; ",
    "sn1.6:3.3": "Pañcabhi rajamādeti, ",
    "sn1.6:3.4": "pañcabhi parisujjhatī”ti. "
  },
  "translation_text": {
    "sn1.6:0.1": "Linked Discourses 1.6 ",
    "sn1.6:0.2": "1. A Reed ",
    "sn1.6:0.3": "Awake ",
    "sn1.6:1.1": "At Sāvatthī. ",
    "sn1.6:1.2": "Standing to one side, that deity spoke this verse in the Buddha’s presence: ",
    "sn1.6:2.1": "“How many sleep among the waking? ",
    "sn1.6:2.2": "How many wake among the sleeping? ",
    "sn1.6:2.3": "By how many do you gather dust? ",
    "sn1.6:2.4": "By how many are you cleansed?” ",
    "sn1.6:3.1": "“Five sleep among the waking. ",
    "sn1.6:3.2": "Five wake among the sleeping. ",
    "sn1.6:3.3": "By five you gather dust. ",
    "sn1.6:3.4": "By five you’re cleansed.” "
  },
  "variant_text": {
