  "root_text": {
    "sn31.1:0.1": "Saṁyutta Nikāya 31.1 ",
    "sn31.1:0.2": "1. Gandhabbavagga ",
    "sn31.1:0.3": "Suddhikasutta ",
    "sn31.1:1.1": "Ekaṁ samayaṁ bhagavā sāvatthiyaṁ viharati jetavane anāthapiṇḍikassa ārāme …pe… ",
    "sn31.1:1.2": "bhagavā etadavoca: ",
    "sn31.1:1.3": "“gandhabbakāyike vo, bhikkhave, deve desessāmi. ",
    "sn31.1:1.4": "Taṁ suṇātha. ",
    "sn31.1:1.5": "Katamā ca, bhikkhave, gandhabbakāyikā devā? ",
    "sn31.1:1.6": "Santi, bhikkhave, mūlagandhe adhivatthā devā. ",
    "sn31.1:1.7": "Santi, bhikkhave, sāragandhe adhivatthā devā. ",
    "sn31.1:1.8": "Santi, bhikkhave, pheggugandhe adhivatthā devā. ",
    "sn31.1:1.9": "Santi, bhikkhave, tacagandhe adhivatthā devā. ",
    "sn31.1:1.10": "Santi, bhikkhave, papaṭikagandhe adhivatthā devā. ",
    "sn31.1:1.11": "Santi, bhikkhave, pattagandhe adhivatthā devā. ",
    "sn31.1:1.12": "Santi, bhikkhave, pupphagandhe adhivatthā devā. ",
    "sn31.1:1.13": "Santi, bhikkhave, phalagandhe adhivatthā devā. ",
    "sn31.1:1.14": "Santi, bhikkhave, rasagandhe adhivatthā devā. ",
    "sn31.1:1.15": "Santi, bhikkhave, gandhagandhe adhivatthā devā. ",
    "sn31.1:1.16": "Ime vuccanti, bhikkhave, gandhabbakāyikā devā”ti. ",
    "sn31.1:1.17": "Paṭhamaṁ. "
  },
  "translation_text": {
    "sn31.1:0.1": "Linked Discourses 31.1 ",
    "sn31.1:0.2": "1. Centaurs ",
    "sn31.1:0.3": "Plain Version ",
    "sn31.1:1.1": "At one time the Buddha was staying near Sāvatthī in Jeta’s Grove, Anāthapiṇḍika’s monastery. … ",
    "sn31.1:1.2": "The Buddha said this: ",
    "sn31.1:1.3": "“Mendicants, I will teach you about the gods of the centaur realm. ",
    "sn31.1:1.4": "Listen … ",
    "sn31.1:1.5": "And what are the gods of the centaur realm? ",
    "sn31.1:1.6": "There are gods who live in fragrant roots, ",
    "sn31.1:1.7": "fragrant heartwood, ",
    "sn31.1:1.8": "fragrant softwood, ",
    "sn31.1:1.9": "fragrant bark, ",
    "sn31.1:1.10": "fragrant shoots, ",
    "sn31.1:1.11": "fragrant leaves, ",
    "sn31.1:1.12": "fragrant flowers, ",
    "sn31.1:1.13": "fragrant fruit, ",
    "sn31.1:1.14": "fragrant sap, ",
    "sn31.1:1.15": "and fragrant scents. ",
    "sn31.1:1.16": "These are called the gods of the centaur realm.” "
  },
