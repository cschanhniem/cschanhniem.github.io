  "root_text": {
    "sn38.7:0.1": "Saṁyutta Nikāya 38.7 ",
    "sn38.7:0.2": "1. Jambukhādakavagga ",
    "sn38.7:0.3": "Vedanāpañhāsutta ",
    "sn38.7:1.1": "“‘Vedanā, vedanā’ti, āvuso sāriputta, vuccati. ",
    "sn38.7:1.2": "Katamā nu kho, āvuso, vedanā”ti? ",
    "sn38.7:1.3": "“Tisso imāvuso, vedanā. ",
    "sn38.7:1.4": "Katamā tisso? ",
    "sn38.7:1.5": "Sukhā vedanā, dukkhā vedanā, adukkhamasukhā vedanā—",
    "sn38.7:1.6": "imā kho, āvuso, tisso vedanā”ti. ",
    "sn38.7:1.7": "“Atthi panāvuso, maggo atthi paṭipadā, etāsaṁ tissannaṁ vedanānaṁ pariññāyā”ti? ",
    "sn38.7:1.8": "“Atthi kho, āvuso, maggo atthi paṭipadā, etāsaṁ tissannaṁ vedanānaṁ pariññāyā”ti. ",
    "sn38.7:1.9": "“Katamo panāvuso, maggo katamā paṭipadā, etāsaṁ tissannaṁ vedanānaṁ pariññāyā”ti? ",
    "sn38.7:1.10": "“Ayameva kho, āvuso, ariyo aṭṭhaṅgiko maggo, etāsaṁ tissannaṁ vedanānaṁ pariññāya, seyyathidaṁ—",
    "sn38.7:1.11": "sammādiṭṭhi …pe… sammāsamādhi. ",
    "sn38.7:1.12": "Ayaṁ kho, āvuso, maggo ayaṁ paṭipadā, etāsaṁ tissannaṁ vedanānaṁ pariññāyā”ti. ",
    "sn38.7:1.13": "“Bhaddako, āvuso, maggo bhaddikā paṭipadā, etāsaṁ tissannaṁ vedanānaṁ pariññāya. ",
    "sn38.7:1.14": "Alañca panāvuso sāriputta, appamādāyā”ti. ",
    "sn38.7:1.15": "Sattamaṁ. "
  },
  "translation_text": {
    "sn38.7:0.1": "Linked Discourses 38.7 ",
    "sn38.7:0.2": "1. With Jambukhādaka ",
    "sn38.7:0.3": "A Question About Feeling ",
    "sn38.7:1.1": "“Reverend Sāriputta, they speak of this thing called ‘feeling’. ",
    "sn38.7:1.2": "What is feeling?” ",
    "sn38.7:1.3": "“Reverend, there are three feelings. ",
    "sn38.7:1.4": "What three? ",
    "sn38.7:1.5": "Pleasant, painful, and neutral feeling. ",
    "sn38.7:1.6": "These are the three feelings.” ",
    "sn38.7:1.7": "“But reverend, is there a path and a practice for completely understanding these three feelings?” ",
    "sn38.7:1.8": "“There is.” … ",
