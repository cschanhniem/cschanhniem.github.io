  "root_text": {
    "sn35.201-203:0.1": "Saṁyutta Nikāya 35.201–203 ",
    "sn35.201-203:0.2": "17. Saṭṭhipeyyālavagga ",
    "sn35.201-203:0.3": "Bāhirātītādianattasutta ",
    "sn35.201-203:1.1": "“Rūpā, bhikkhave, anattā atītā anāgatā paccuppannā. Saddā … gandhā … rasā … phoṭṭhabbā … dhammā anattā atītā anāgatā paccuppannā. ",
    "sn35.201-203:1.2": "Evaṁ passaṁ …pe… ",
    "sn35.201-203:1.3": "nāparaṁ itthattāyāti pajānātī”ti. "
  },
  "translation_text": {
    "sn35.201-203:0.1": "Linked Discourses 35.201–203 ",
    "sn35.201-203:0.2": "17. Sixty Abbreviated Texts ",
    "sn35.201-203:0.3": "The Exterior as Not-Self in the Three Times ",
    "sn35.201-203:1.1": "“Mendicants, in the past … future … present sights, sounds, smells, tastes, touches, and ideas are not-self …” ",
    "sn35.201-203:1.2": ""
  },
  "variant_text": {
    "sn35.201-203:0.3": "Bāhirātītādianattasutta → 18 (pts1ed) "
