  "root_text": {
    "sn56.73:0.1": "Saṁyutta Nikāya 56.73 ",
    "sn56.73:0.2": "8. Dutiyaāmakadhaññapeyyālavagga ",
    "sn56.73:0.3": "Kāmesumicchācārasutta ",
    "sn56.73:1.1": "… “Evameva kho, bhikkhave, appakā te sattā ye kāmesumicchācārā paṭiviratā; atha kho eteva bahutarā sattā ye kāmesumicchācārā appaṭiviratā …pe…. ",
    "sn56.73:1.2": "Tatiyaṁ. "
  },
  "translation_text": {
    "sn56.73:0.1": "Linked Discourses 56.73 ",
    "sn56.73:0.2": "8. Abbreviated Texts on Raw Grain ",
    "sn56.73:0.3": "Sexual Misconduct ",
    "sn56.73:1.1": "“… the sentient beings who refrain from sexual misconduct are few, while those who don’t refrain are many. …” "
  },
  "variant_text": {
    "sn56.73:0.3": "Kāmesumicchācārasutta → kāmesu (pts1ed) "
  },
