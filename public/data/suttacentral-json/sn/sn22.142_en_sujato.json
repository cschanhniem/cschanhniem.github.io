  "root_text": {
    "sn22.142:0.1": "Saṁyutta Nikāya 22.142 ",
    "sn22.142:0.2": "14. Kukkuḷavagga ",
    "sn22.142:0.3": "Tatiyadukkhasutta ",
    "sn22.142:1.1": "Sāvatthinidānaṁ. ",
    "sn22.142:1.2": "“Yaṁ, bhikkhave, dukkhaṁ; tatra vo chandarāgo pahātabbo …pe… ",
    "sn22.142:1.3": "yaṁ, bhikkhave, dukkhaṁ; tatra vo chandarāgo pahātabbo”ti. ",
    "sn22.142:1.4": "Sattamaṁ. "
  },
  "translation_text": {
    "sn22.142:0.1": "Linked Discourses 22.142 ",
    "sn22.142:0.2": "14. Burning Chaff ",
    "sn22.142:0.3": "Suffering (3rd) ",
    "sn22.142:1.1": "At Sāvatthī. ",
    "sn22.142:1.2": "“Mendicants, you should give up desire and greed for what is suffering. …” ",
    "sn22.142:1.3": ""
  },
