  "root_text": {
    "sn1.46:0.1": "Saṁyutta Nikāya 1.46 ",
    "sn1.46:0.2": "5. Ādittavagga ",
    "sn1.46:0.3": "Accharāsutta ",
    "sn1.46:1.1": "“Accharāgaṇasaṅghuṭṭhaṁ, ",
    "sn1.46:1.2": "pisācagaṇasevitaṁ; ",
    "sn1.46:1.3": "Vanantaṁ mohanaṁ nāma, ",
    "sn1.46:1.4": "kathaṁ yātrā bhavissatī”ti. ",
    "sn1.46:2.1": "“Ujuko nāma so maggo, ",
    "sn1.46:2.2": "abhayā nāma sā disā; ",
    "sn1.46:2.3": "Ratho akūjano nāma, ",
    "sn1.46:2.4": "dhammacakkehi saṁyuto. ",
    "sn1.46:3.1": "Hirī tassa apālambo, ",
    "sn1.46:3.2": "satyassa parivāraṇaṁ; ",
    "sn1.46:3.3": "Dhammāhaṁ sārathiṁ brūmi, ",
    "sn1.46:3.4": "sammādiṭṭhipurejavaṁ. ",
    "sn1.46:4.1": "Yassa etādisaṁ yānaṁ, ",
    "sn1.46:4.2": "itthiyā purisassa vā; ",
    "sn1.46:4.3": "Sa ve etena yānena, ",
    "sn1.46:4.4": "nibbānasseva santike”ti. "
  },
  "translation_text": {
    "sn1.46:0.1": "Linked Discourses 1.46 ",
    "sn1.46:0.2": "5. On Fire ",
    "sn1.46:0.3": "Nymphs ",
    "sn1.46:1.1": "“It’s resounding with a group of nymphs, ",
    "sn1.46:1.2": "but haunted by a gang of goblins! ",
    "sn1.46:1.3": "This grove is called ‘Deluding’. ",
    "sn1.46:1.4": "How will I keep going?” ",
    "sn1.46:2.1": "“That path is called ‘the direct way’, ",
    "sn1.46:2.2": "and it’s headed for the place called ‘fearless’. ",
    "sn1.46:2.3": "The chariot is called ‘unswerving’, ",
    "sn1.46:2.4": "fitted with wheels of the teaching. ",
    "sn1.46:3.1": "Conscience is its bench-back, ",
    "sn1.46:3.2": "mindfulness its upholstery. ",
    "sn1.46:3.3": "I say the teaching is the driver, ",
    "sn1.46:3.4": "with right view running out in front. ",
    "sn1.46:4.1": "Any woman or man ",
    "sn1.46:4.2": "who has such a vehicle, ",
    "sn1.46:4.3": "by means of this vehicle ",
    "sn1.46:4.4": "has drawn near to extinguishment.” "
  },
