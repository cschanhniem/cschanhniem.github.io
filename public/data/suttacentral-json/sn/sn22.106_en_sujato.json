  "root_text": {
    "sn22.106:0.1": "Saṁyutta Nikāya 22.106 ",
    "sn22.106:0.2": "11. Antavagga ",
    "sn22.106:0.3": "Pariññeyyasutta ",
    "sn22.106:1.1": "Sāvatthinidānaṁ. ",
    "sn22.106:1.2": "“Pariññeyye ca, bhikkhave, dhamme desessāmi pariññañca pariññātāviñca puggalaṁ. ",
    "sn22.106:1.3": "Taṁ suṇātha. ",
    "sn22.106:1.4": "Katame ca, bhikkhave, pariññeyyā dhammā? ",
    "sn22.106:1.5": "Rūpaṁ, bhikkhave, pariññeyyo dhammo. ",
    "sn22.106:1.6": "Vedanā …pe… ",
    "sn22.106:1.7": "saññā … ",
    "sn22.106:1.8": "saṅkhārā … ",
    "sn22.106:1.9": "viññāṇaṁ pariññeyyo dhammo. ",
    "sn22.106:1.10": "Ime vuccanti, bhikkhave, pariññeyyā dhammā. ",
    "sn22.106:1.11": "Katamā ca, bhikkhave, pariññā? ",
    "sn22.106:1.12": "Rāgakkhayo, dosakkhayo, mohakkhayo—",
    "sn22.106:1.13": "ayaṁ vuccati, bhikkhave, pariññā. ",
    "sn22.106:1.14": "Katamo ca, bhikkhave, pariññātāvī puggalo? ",
    "sn22.106:1.15": "Arahātissa vacanīyaṁ. ",
    "sn22.106:1.16": "Yvāyaṁ āyasmā evaṁnāmo evaṅgotto—",
    "sn22.106:1.17": "ayaṁ vuccati, bhikkhave, pariññātāvī puggalo”ti. ",
    "sn22.106:1.18": "Catutthaṁ. "
  },
  "translation_text": {
    "sn22.106:0.1": "Linked Discourses 22.106 ",
    "sn22.106:0.2": "11. Ends ",
    "sn22.106:0.3": "Should Be Completely Understood ",
    "sn22.106:1.1": "At Sāvatthī. ",
    "sn22.106:1.2": "“Mendicants, I will teach you the things that should be completely understood, complete understanding, and the individual who has completely understood. ",
    "sn22.106:1.3": "Listen … ",
    "sn22.106:1.4": "And what things should be completely understood? ",
    "sn22.106:1.5": "Form, ",
    "sn22.106:1.6": "feeling, ",
    "sn22.106:1.7": "perception, ",
    "sn22.106:1.8": "choices, ",
    "sn22.106:1.9": "and consciousness. ",
    "sn22.106:1.10": "These are called the things that should be completely understood. ",
    "sn22.106:1.11": "And what is complete understanding? ",
    "sn22.106:1.12": "The ending of greed, hate, and delusion. ",
    "sn22.106:1.13": "This is called complete understanding. ",
    "sn22.106:1.14": "And who is the individual who has completely understood? ",
    "sn22.106:1.15": "It should be said: a perfected one, ",
    "sn22.106:1.16": "the venerable of such and such name and clan. ",
    "sn22.106:1.17": "This is called the individual who has completely understood.” "
  },
