  "root_text": {
    "sn15.15:0.1": "Saṁyutta Nikāya 15.15 ",
    "sn15.15:0.2": "2. Dutiyavagga ",
    "sn15.15:0.3": "Pitusutta ",
    "sn15.15:1.1": "Sāvatthiyaṁ viharati. ",
    "sn15.15:1.2": "“Anamataggoyaṁ, bhikkhave, saṁsāro …pe… ",
    "sn15.15:1.3": "na so, bhikkhave, satto sulabharūpo yo napitābhūtapubbo …pe… ",
    "sn15.15:1.4": "alaṁ vimuccitun”ti. ",
    "sn15.15:1.5": "Pañcamaṁ. "
  },
  "translation_text": {
    "sn15.15:0.1": "Linked Discourses 15.15 ",
    "sn15.15:0.2": "Chapter Two ",
    "sn15.15:0.3": "Father ",
    "sn15.15:1.1": "At Sāvatthī. ",
    "sn15.15:1.2": "“Mendicants, this transmigration has no known beginning. … ",
    "sn15.15:1.3": "It’s not easy to find a sentient being who in all this long time has not previously been your father. … ",
    "sn15.15:1.4": "This is quite enough for you to become disillusioned, dispassionate, and freed regarding all conditions.” "
  },
