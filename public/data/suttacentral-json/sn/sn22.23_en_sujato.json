  "root_text": {
    "sn22.23:0.1": "Saṁyutta Nikāya 22.23 ",
    "sn22.23:0.2": "3. Bhāravagga ",
    "sn22.23:0.3": "Pariññasutta ",
    "sn22.23:1.1": "Sāvatthinidānaṁ. ",
    "sn22.23:1.2": "“Pariññeyye ca, bhikkhave, dhamme desessāmi pariññañca. ",
    "sn22.23:1.3": "Taṁ suṇātha. ",
    "sn22.23:1.4": "Katame ca, bhikkhave, pariññeyyā dhammā? ",
    "sn22.23:1.5": "Rūpaṁ, bhikkhave, pariññeyyo dhammo, vedanā pariññeyyo dhammo, saññā pariññeyyo dhammo, saṅkhārā pariññeyyo dhammo, viññāṇaṁ pariññeyyo dhammo. ",
    "sn22.23:1.6": "Ime vuccanti, bhikkhave, pariññeyyā dhammā. ",
    "sn22.23:1.7": "Katamā ca, bhikkhave, pariññā? ",
    "sn22.23:1.8": "Yo, bhikkhave, rāgakkhayo dosakkhayo mohakkhayo. ",
    "sn22.23:1.9": "Ayaṁ vuccati, bhikkhave, pariññā”ti. ",
    "sn22.23:1.10": "Dutiyaṁ. "
  },
  "translation_text": {
    "sn22.23:0.1": "Linked Discourses 22.23 ",
    "sn22.23:0.2": "3. The Burden ",
    "sn22.23:0.3": "Complete Understanding ",
    "sn22.23:1.1": "At Sāvatthī. ",
    "sn22.23:1.2": "“Mendicants, I will teach you the things that should be completely understood, and complete understanding. ",
    "sn22.23:1.3": "Listen … ",
    "sn22.23:1.4": "And what things should be completely understood? ",
    "sn22.23:1.5": "Form, feeling, perception, choices, and consciousness. ",
    "sn22.23:1.6": "These are called the things that should be completely understood. ",
    "sn22.23:1.7": "And what is complete understanding? ",
    "sn22.23:1.8": "The ending of greed, hate, and delusion. ",
    "sn22.23:1.9": "This is called complete understanding.” "
  },
  "variant_text": {
    "sn22.23:0.3": "Pariññasutta → pariññāsuttaṁ (bj) "
  },
