  "root_text": {
    "sn54.17:0.1": "Saṁyutta Nikāya 54.17 ",
    "sn54.17:0.2": "2. Dutiyavagga ",
    "sn54.17:0.3": "Saṁyojanappahānasutta ",
    "sn54.17:1.1": "“Ānāpānassatisamādhi, bhikkhave, bhāvito bahulīkato saṁyojanappahānāya saṁvattati …pe…. ",
    "sn54.17:1.2": "Sattamaṁ. "
  },
  "translation_text": {
    "sn54.17:0.1": "Linked Discourses 54.17 ",
    "sn54.17:0.2": "Chapter Two ",
    "sn54.17:0.3": "Giving Up the Fetters ",
    "sn54.17:1.1": "“Mendicants, when immersion due to mindfulness of breathing is developed and cultivated it leads to giving up the fetters …” "
  },
  "variant_text": {
    "sn54.17:0.3": "Saṁyojanappahānasutta → saṁyojanasuttaṁ (bj); saṁyojanaṁ (pts1ed) "
  },
