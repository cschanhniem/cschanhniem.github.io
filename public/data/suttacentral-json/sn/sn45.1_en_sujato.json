  "root_text": {
    "sn45.1:0.1": "Saṁyutta Nikāya 45.1 ",
    "sn45.1:0.2": "1. Avijjāvagga ",
    "sn45.1:0.3": "Avijjāsutta ",
    "sn45.1:1.1": "Evaṁ me sutaṁ—",
    "sn45.1:1.2": "ekaṁ samayaṁ bhagavā sāvatthiyaṁ viharati jetavane anāthapiṇḍikassa ārāme. ",
    "sn45.1:1.3": "Tatra kho bhagavā bhikkhū āmantesi: ",
    "sn45.1:1.4": "“bhikkhavo”ti. ",
    "sn45.1:1.5": "“Bhadante”ti te bhikkhū bhagavato paccassosuṁ. ",
    "sn45.1:1.6": "Bhagavā etadavoca: ",
    "sn45.1:2.1": "“Avijjā, bhikkhave, pubbaṅgamā akusalānaṁ dhammānaṁ samāpattiyā, anvadeva ahirikaṁ anottappaṁ. ",
    "sn45.1:2.2": "Avijjāgatassa, bhikkhave, aviddasuno micchādiṭṭhi pahoti; ",
    "sn45.1:2.3": "micchādiṭṭhissa micchāsaṅkappo pahoti; ",
    "sn45.1:2.4": "micchāsaṅkappassa micchāvācā pahoti; ",
    "sn45.1:2.5": "micchāvācassa micchākammanto pahoti; ",
    "sn45.1:2.6": "micchākammantassa micchāājīvo pahoti; ",
    "sn45.1:2.7": "micchāājīvassa micchāvāyāmo pahoti; ",
    "sn45.1:2.8": "micchāvāyāmassa micchāsati pahoti; ",
    "sn45.1:2.9": "micchāsatissa micchāsamādhi pahoti. ",
    "sn45.1:3.1": "Vijjā ca kho, bhikkhave, pubbaṅgamā kusalānaṁ dhammānaṁ samāpattiyā, anvadeva hirottappaṁ. ",
    "sn45.1:3.2": "Vijjāgatassa, bhikkhave, viddasuno sammādiṭṭhi pahoti; ",
    "sn45.1:3.3": "sammādiṭṭhissa sammāsaṅkappo pahoti; ",
    "sn45.1:3.4": "sammāsaṅkappassa sammāvācā pahoti; ",
    "sn45.1:3.5": "sammāvācassa sammākammanto pahoti; ",
    "sn45.1:3.6": "sammākammantassa sammāājīvo pahoti; ",
    "sn45.1:3.7": "sammāājīvassa sammāvāyāmo pahoti; ",
    "sn45.1:3.8": "sammāvāyāmassa sammāsati pahoti; ",
    "sn45.1:3.9": "sammāsatissa sammāsamādhi pahotī”ti. ",
    "sn45.1:3.10": "Paṭhamaṁ. "
  },
  "translation_text": {
    "sn45.1:0.1": "Linked Discourses 45.1 ",
    "sn45.1:0.2": "1. Ignorance ",
    "sn45.1:0.3": "Ignorance ",
    "sn45.1:1.1": "So I have heard. ",
    "sn45.1:1.2": "At one time the Buddha was staying near Sāvatthī in Jeta’s Grove, Anāthapiṇḍika’s monastery. ",
    "sn45.1:1.3": "There the Buddha addressed the mendicants, ",
    "sn45.1:1.4": "“Mendicants!” ",
    "sn45.1:1.5": "“Venerable sir,” they replied. ",
    "sn45.1:1.6": "The Buddha said this: ",
    "sn45.1:2.1": "“Mendicants, ignorance precedes the attainment of unskillful qualities, with lack of conscience and prudence following along. ",
    "sn45.1:2.2": "An ignoramus, sunk in ignorance, produces wrong view. ",
    "sn45.1:2.3": "Wrong view produces wrong thought. ",
    "sn45.1:2.4": "Wrong thought produces wrong speech. ",
    "sn45.1:2.5": "Wrong speech produces wrong action. ",
    "sn45.1:2.6": "Wrong action produces wrong livelihood. ",
    "sn45.1:2.7": "Wrong livelihood produces wrong effort. ",
    "sn45.1:2.8": "Wrong effort produces wrong mindfulness. ",
    "sn45.1:2.9": "Wrong mindfulness produces wrong immersion. ",
    "sn45.1:3.1": "Knowledge precedes the attainment of skillful qualities, with conscience and prudence following along. ",
    "sn45.1:3.2": "A sage, firm in knowledge, produces right view. ",
    "sn45.1:3.3": "Right view produces right thought. ",
    "sn45.1:3.4": "Right thought produces right speech. ",
    "sn45.1:3.5": "Right speech produces right action. ",
    "sn45.1:3.6": "Right action produces right livelihood. ",
    "sn45.1:3.7": "Right livelihood produces right effort. ",
    "sn45.1:3.8": "Right effort produces right mindfulness. ",
    "sn45.1:3.9": "Right mindfulness produces right immersion.” "
  },
  "variant_text": {
    "sn45.1:2.1": "anvadeva → anudeva (bj, pts1ed, mr) "
  },
