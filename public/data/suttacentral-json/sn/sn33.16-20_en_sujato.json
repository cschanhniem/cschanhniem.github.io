  "root_text": {
    "sn33.16:0.1": "Saṁyutta Nikāya 33.16–20 ",
    "sn33.16:0.2": "1. Vacchagottavagga ",
    "sn33.16:0.3": "Rūpaananubodhādisuttapañcaka ",
    "sn33.16:1.1": "Sāvatthinidānaṁ. ",
    "sn33.16:1.2": "Ekamantaṁ nisinno kho vacchagotto paribbājako bhagavantaṁ etadavoca—",
    "sn33.16:1.3": "ko nu kho, bho gotama, hetu, ko paccayo …pe… ",
    "sn33.16:1.4": "rūpe kho, vaccha, ananubodhā …pe… “rūpanirodhagāminiyā paṭipadāya ananubodhā …pe…. ",
    "sn33.17:1.1": "Sāvatthinidānaṁ. ",
    "sn33.17:1.2": "“Vedanāya kho, vaccha …pe…. ",
    "sn33.18:1.1": "Sāvatthinidānaṁ. ",
    "sn33.18:1.2": "“Saññāya kho, vaccha …pe…. ",
    "sn33.19:1.1": "Sāvatthinidānaṁ. ",
    "sn33.19:1.2": "“Saṅkhāresu kho, vaccha …pe…. ",
    "sn33.20:1.1": "Sāvatthinidānaṁ. ",
    "sn33.20:1.2": "“Viññāṇe kho, vaccha, ananubodhā …pe… ",
    "sn33.20:1.3": "viññāṇanirodhagāminiyā paṭipadāya ananubodhā …pe… ",
    "sn33.20:1.4": "vīsatimaṁ. "
  },
  "translation_text": {
    "sn33.16:0.1": "Linked Discourses 33.16–20 ",
    "sn33.16:0.2": "1. With Vacchagotta ",
    "sn33.16:0.3": "Five Discourses on Not Understanding Form, Etc. ",
    "sn33.16:1.1": "At Sāvatthī. ",
    "sn33.16:1.2": "",
    "sn33.16:1.3": "",
    "sn33.16:1.4": "“Vaccha, it is because of not understanding form … ",
    "sn33.17:1.1": "",
    "sn33.17:1.2": "feeling … ",
    "sn33.18:1.1": "",
    "sn33.18:1.2": "perception … ",
    "sn33.19:1.1": "",
    "sn33.19:1.2": "choices … ",
    "sn33.20:1.1": "",
    "sn33.20:1.2": "consciousness …” ",
    "sn33.20:1.3": ""
  },
