  "root_text": {
    "sn35.225:0.1": "Saṁyutta Nikāya 35.225 ",
    "sn35.225:0.2": "17. Saṭṭhipeyyālavagga ",
    "sn35.225:0.3": "Bāhirāyatanaaniccasutta ",
    "sn35.225:1.1": "“Rūpā, bhikkhave, aniccā. Saddā … gandhā … rasā … phoṭṭhabbā … dhammā aniccā. ",
    "sn35.225:1.2": "Evaṁ passaṁ …pe… ",
    "sn35.225:1.3": "nāparaṁ itthattāyāti pajānātī”ti. "
  },
  "translation_text": {
    "sn35.225:0.1": "Linked Discourses 35.225 ",
    "sn35.225:0.2": "17. Sixty Abbreviated Texts ",
    "sn35.225:0.3": "The Exterior as Impermanent ",
    "sn35.225:1.1": "“Mendicants, sights, sounds, smells, tastes, touches, and ideas are impermanent. ",
    "sn35.225:1.2": "Seeing this … ",
    "sn35.225:1.3": "They understand: ‘… there is nothing further for this place.’” "
  },
  "variant_text": {
    "sn35.225:0.3": "Bāhirāyatanaaniccasutta → bāhira (tayo) 1 (pts1ed) "
  },
