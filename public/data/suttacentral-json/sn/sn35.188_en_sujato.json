  "root_text": {
    "sn35.188:0.1": "Saṁyutta Nikāya 35.188 ",
    "sn35.188:0.2": "17. Saṭṭhipeyyālavagga ",
    "sn35.188:0.3": "Ajjhattapaccuppannāniccasutta ",
    "sn35.188:1.1": "“Cakkhu, bhikkhave, aniccaṁ paccuppannaṁ …pe… jivhā aniccā paccuppannā …pe… mano anicco paccuppanno. ",
    "sn35.188:1.2": "Evaṁ passaṁ …pe… ",
    "sn35.188:1.3": "nāparaṁ itthattāyāti pajānātī”ti. "
  },
  "translation_text": {
    "sn35.188:0.1": "Linked Discourses 35.188 ",
    "sn35.188:0.2": "17. Sixty Abbreviated Texts ",
    "sn35.188:0.3": "The Interior Is Impermanent in the Present ",
    "sn35.188:1.1": "“Mendicants, in the present the eye, ear, nose, tongue, body, and mind are impermanent …” ",
    "sn35.188:1.2": ""
