  "root_text": {
    "sn46.73:0.1": "Saṁyutta Nikāya 46.73 ",
    "sn46.73:0.2": "8. Nirodhavagga ",
    "sn46.73:0.3": "Anattasutta ",
    "sn46.73:1.1": "“Dukkhe anattasaññā, bhikkhave …pe…” ",
    "sn46.73:1.2": "sattamaṁ. "
  },
  "translation_text": {
    "sn46.73:0.1": "Linked Discourses 46.73 ",
    "sn46.73:0.2": "8. Cessation ",
    "sn46.73:0.3": "Not-Self in Suffering ",
    "sn46.73:1.1": "“Mendicants, when the perception of not-self in suffering is developed and cultivated it’s very fruitful and beneficial. …” "
  },
