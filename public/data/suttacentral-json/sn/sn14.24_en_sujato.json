  "root_text": {
    "sn14.24:0.1": "Saṁyutta Nikāya 14.24 ",
    "sn14.24:0.2": "3. Kammapathavagga ",
    "sn14.24:0.3": "Dussīlasutta ",
    "sn14.24:1.1": "Sāvatthiyaṁ viharati. ",
    "sn14.24:1.2": "“Dhātusova, bhikkhave, sattā saṁsandanti samenti. ",
    "sn14.24:1.3": "Assaddhā assaddhehi saddhiṁ saṁsandanti samenti; ",
    "sn14.24:1.4": "ahirikā ahirikehi saddhiṁ saṁsandanti samenti; ",
    "sn14.24:1.5": "anottappino anottappīhi saddhiṁ saṁsandanti samenti; ",
    "sn14.24:1.6": "dussīlā dussīlehi saddhiṁ saṁsandanti samenti; ",
    "sn14.24:1.7": "duppaññā duppaññehi saddhiṁ saṁsandanti samenti. ",
    "sn14.24:2.1": "Saddhā saddhehi saddhiṁ saṁsandanti samenti; ",
    "sn14.24:2.2": "hirimanā hirimanehi saddhiṁ saṁsandanti samenti; ",
    "sn14.24:2.3": "ottappino ottappīhi saddhiṁ saṁsandanti samenti; ",
    "sn14.24:2.4": "sīlavanto sīlavantehi saddhiṁ saṁsandanti samenti; ",
    "sn14.24:2.5": "paññavanto paññavantehi saddhiṁ saṁsandanti samentī”ti. ",
    "sn14.24:2.6": "Dutiyaṁ. "
  },
  "translation_text": {
    "sn14.24:0.1": "Linked Discourses 14.24 ",
    "sn14.24:0.2": "3. Ways of Performing Deeds ",
    "sn14.24:0.3": "Unethical ",
    "sn14.24:1.1": "At Sāvatthī. ",
    "sn14.24:1.2": "“Mendicants, sentient beings join together and converge because of an element: ",
    "sn14.24:1.3": "the faithless with the faithless … ",
    "sn14.24:1.4": "shameless … ",
    "sn14.24:1.5": "imprudent … ",
    "sn14.24:1.6": "unethical … ",
    "sn14.24:1.7": "witless … ",
    "sn14.24:2.1": "The faithful with the faithful … ",
    "sn14.24:2.2": "conscientious … ",
    "sn14.24:2.3": "prudent … ",
    "sn14.24:2.4": "ethical … ",
    "sn14.24:2.5": "and the wise with the wise.” "
  },
