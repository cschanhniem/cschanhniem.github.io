  "root_text": {
    "sn22.147:0.1": "Saṁyutta Nikāya 22.147 ",
    "sn22.147:0.2": "14. Kukkuḷavagga ",
    "sn22.147:0.3": "Aniccānupassīsutta ",
    "sn22.147:1.1": "Sāvatthinidānaṁ. ",
    "sn22.147:1.2": "“Saddhāpabbajitassa, bhikkhave, kulaputtassa ayamanudhammo hoti—",
    "sn22.147:1.3": "yaṁ rūpe aniccānupassī vihareyya. ",
    "sn22.147:1.4": "Vedanāya … ",
    "sn22.147:1.5": "saññāya … ",
    "sn22.147:1.6": "saṅkhāresu … ",
    "sn22.147:1.7": "viññāṇe aniccānupassī vihareyya …pe… ",
    "sn22.147:1.8": "‘parimuccati dukkhasmā’ti vadāmī”ti. ",
    "sn22.147:1.9": "Dvādasamaṁ. "
  },
  "translation_text": {
    "sn22.147:0.1": "Linked Discourses 22.147 ",
    "sn22.147:0.2": "14. Burning Chaff ",
    "sn22.147:0.3": "Observing Impermanence ",
    "sn22.147:1.1": "At Sāvatthī. ",
    "sn22.147:1.2": "“Mendicants, when a gentleman has gone forth out of faith, this is what’s in line with the teaching. ",
    "sn22.147:1.3": "They should meditate observing impermanence in form, ",
    "sn22.147:1.4": "feeling, ",
    "sn22.147:1.5": "perception, ",
    "sn22.147:1.6": "choices, ",
    "sn22.147:1.7": "and consciousness. … ",
    "sn22.147:1.8": "They’re freed from suffering, I say.” "
  },
  "variant_text": {
    "sn22.147:0.3": "Aniccānupassīsutta → aniccānupassanāsuttaṁ (bj); kulaputtena dukkhā 2 (pts1ed) "
  },
