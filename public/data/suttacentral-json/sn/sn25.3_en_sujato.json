  "root_text": {
    "sn25.3:0.1": "Saṁyutta Nikāya 25.3 ",
    "sn25.3:0.2": "1. Cakkhuvagga ",
    "sn25.3:0.3": "Viññāṇasutta ",
    "sn25.3:1.1": "Sāvatthinidānaṁ. ",
    "sn25.3:1.2": "“Cakkhuviññāṇaṁ, bhikkhave, aniccaṁ vipariṇāmi aññathābhāvi; ",
    "sn25.3:1.3": "sotaviññāṇaṁ … ",
    "sn25.3:1.4": "ghānaviññāṇaṁ … ",
    "sn25.3:1.5": "jivhāviññāṇaṁ … ",
    "sn25.3:1.6": "kāyaviññāṇaṁ … ",
    "sn25.3:1.7": "manoviññāṇaṁ aniccaṁ vipariṇāmi aññathābhāvi. ",
    "sn25.3:1.8": "Yo bhikkhave …pe… ",
    "sn25.3:1.9": "sambodhiparāyano”ti. ",
    "sn25.3:1.10": "Tatiyaṁ. "
  },
  "translation_text": {
    "sn25.3:0.1": "Linked Discourses 25.3 ",
    "sn25.3:0.2": "1. The Eye ",
    "sn25.3:0.3": "Consciousness ",
    "sn25.3:1.1": "At Sāvatthī. ",
    "sn25.3:1.2": "“Mendicants, eye consciousness is impermanent, decaying, and perishing. ",
    "sn25.3:1.3": "Ear consciousness, ",
    "sn25.3:1.4": "nose consciousness, ",
    "sn25.3:1.5": "tongue consciousness, ",
    "sn25.3:1.6": "body consciousness, ",
    "sn25.3:1.7": "and mind consciousness are impermanent, decaying, and perishing. ",
    "sn25.3:1.8": "Someone who has faith and confidence in these teachings is called a follower by faith. …” ",
    "sn25.3:1.9": ""
  },
