  "root_text": {
    "sn12.93-103:0.1": "Saṁyutta Nikāya 12.93–213 ",
    "sn12.93-103:0.2": "9. Antarapeyyāla ",
    "sn12.93-103:0.3": "Sikkhāsuttādipeyyālaekādasaka ",
    "sn12.93-103:1.1": "“Jarāmaraṇaṁ, bhikkhave, ajānatā apassatā yathābhūtaṁ jarāmaraṇe yathābhūtaṁ ñāṇāya sikkhā karaṇīyā. ",
    "sn12.93-103:2.1": "(Peyyālo. Catusaccikaṁ kātabbaṁ.) ",
    "sn12.104-114:1.1": "“Jarāmaraṇaṁ, bhikkhave, ajānatā …pe… ",
    "sn12.104-114:1.2": "yogo karaṇīyo …pe…. ",
    "sn12.115-125:1.1": "“Jarāmaraṇaṁ, bhikkhave, ajānatā …pe… ",
    "sn12.115-125:1.2": "chando karaṇīyo …pe…. ",
    "sn12.126-136:1.1": "“Jarāmaraṇaṁ, bhikkhave, ajānatā …pe… ",
    "sn12.126-136:1.2": "ussoḷhī karaṇīyā …pe…. ",
    "sn12.137-147:1.1": "“Jarāmaraṇaṁ, bhikkhave, ajānatā …pe… ",
    "sn12.137-147:1.2": "appaṭivānī karaṇīyā …pe…. ",
    "sn12.148-158:1.1": "“Jarāmaraṇaṁ, bhikkhave, ajānatā …pe… ",
    "sn12.148-158:1.2": "ātappaṁ karaṇīyaṁ …pe…. ",
    "sn12.159-169:1.1": "“Jarāmaraṇaṁ, bhikkhave, ajānatā …pe… ",
    "sn12.159-169:1.2": "vīriyaṁ karaṇīyaṁ …pe…. ",
    "sn12.170-180:1.1": "“Jarāmaraṇaṁ, bhikkhave, ajānatā …pe… ",
    "sn12.170-180:1.2": "sātaccaṁ karaṇīyaṁ …pe…. ",
    "sn12.181-191:1.1": "“Jarāmaraṇaṁ, bhikkhave, ajānatā …pe… ",
    "sn12.181-191:1.2": "sati karaṇīyā …pe…. ",
    "sn12.192-202:1.1": "“Jarāmaraṇaṁ, bhikkhave, ajānatā …pe… ",
    "sn12.192-202:1.2": "sampajaññaṁ karaṇīyaṁ …pe…. ",
    "sn12.203-213:1.1": "“Jarāmaraṇaṁ, bhikkhave, ajānatā …pe… ",
    "sn12.203-213:1.2": "appamādo karaṇīyo …pe…. ",
    "sn12.203-213:1.3": "Antarapeyyālo navamo. ",
    "sn12.203-213:2.0": "Tassuddānaṁ ",
    "sn12.203-213:2.1": "Satthā sikkhā ca yogo ca, ",
    "sn12.203-213:2.2": "chando ussoḷhipañcamī; ",
    "sn12.203-213:2.3": "Appaṭivāni yātappaṁ, ",
    "sn12.203-213:2.4": "vīriyaṁ sātaccamuccati; ",
    "sn12.203-213:2.5": "Sati ca sampajaññañca, ",
    "sn12.203-213:2.6": "appamādena dvādasāti. ",
    "sn12.203-213:2.7": "Suttantā antarapeyyālā niṭṭhitā. ",
    "sn12.203-213:3.1": "Pare te dvādasa honti, ",
    "sn12.203-213:3.2": "suttā dvattiṁsa satāni; ",
    "sn12.203-213:3.3": "Catusaccena te vuttā, ",
    "sn12.203-213:3.4": "peyyālaantaramhi yeti. ",
    "sn12.203-213:3.5": "Antarapeyyālesu uddānaṁ samattaṁ. ",
    "sn12.203-213:3.6": "Nidānasaṁyuttaṁ samattaṁ. "
  },
  "translation_text": {
