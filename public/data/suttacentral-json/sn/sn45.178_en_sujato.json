  "root_text": {
    "sn45.178:0.1": "Saṁyutta Nikāya 45.178 ",
    "sn45.178:0.2": "14. Oghavagga ",
    "sn45.178:0.3": "Upādānakkhandhasutta ",
    "sn45.178:1.1": "“Pañcime, bhikkhave, upādānakkhandhā. ",
    "sn45.178:1.2": "Katame pañca? ",
    "sn45.178:1.3": "Seyyathidaṁ—rūpupādānakkhandho, vedanupādānakkhandho, saññupādānakkhandho, saṅkhārupādānakkhandho, viññāṇupādānakkhandho. ",
    "sn45.178:1.4": "Ime kho, bhikkhave, pañcupādānakkhandhā. ",
    "sn45.178:1.5": "Imesaṁ kho, bhikkhave, pañcannaṁ upādānakkhandhānaṁ abhiññāya pariññāya parikkhayāya pahānāya …pe… ayaṁ ariyo aṭṭhaṅgiko maggo bhāvetabbo”ti. ",
    "sn45.178:1.6": "Aṭṭhamaṁ. "
  },
  "translation_text": {
    "sn45.178:0.1": "Linked Discourses 45.178 ",
    "sn45.178:0.2": "14. Floods ",
    "sn45.178:0.3": "Grasping Aggregates ",
    "sn45.178:1.1": "“Mendicants, there are these five grasping aggregates. ",
    "sn45.178:1.2": "What five? ",
    "sn45.178:1.3": "The grasping aggregates of form, feeling, perception, choices, and consciousness. ",
    "sn45.178:1.4": "These are the five grasping aggregates. ",
    "sn45.178:1.5": "The noble eightfold path should be developed for the direct knowledge, complete understanding, finishing, and giving up of these five grasping aggregates.” "
  },
  "variant_text": {
    "sn45.178:0.3": "Upādānakkhandhasutta → khandhā (pts1ed) "
  },
