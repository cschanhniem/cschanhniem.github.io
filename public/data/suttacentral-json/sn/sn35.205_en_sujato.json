  "root_text": {
    "sn35.205:0.1": "Saṁyutta Nikāya 35.205 ",
    "sn35.205:0.2": "17. Saṭṭhipeyyālavagga ",
    "sn35.205:0.3": "Ajjhattānāgatayadaniccasutta ",
    "sn35.205:1.1": "“Cakkhu, bhikkhave, aniccaṁ anāgataṁ. ",
    "sn35.205:1.2": "Yadaniccaṁ, taṁ dukkhaṁ. ",
    "sn35.205:1.3": "Yaṁ dukkhaṁ, tadanattā. ",
    "sn35.205:1.4": "Yadanattā taṁ ‘netaṁ mama, nesohamasmi, na meso attā’ti evametaṁ yathābhūtaṁ sammappaññāya daṭṭhabbaṁ …pe… ",
    "sn35.205:1.5": "jivhā aniccā anāgatā. ",
    "sn35.205:1.6": "Yadaniccaṁ, taṁ dukkhaṁ. ",
    "sn35.205:1.7": "Yaṁ dukkhaṁ, tadanattā. ",
    "sn35.205:1.8": "Yadanattā, taṁ ‘netaṁ mama, nesohamasmi, na meso attā’ti evametaṁ yathābhūtaṁ sammappaññāya daṭṭhabbaṁ …pe… ",
    "sn35.205:1.9": "mano anicco anāgato. ",
    "sn35.205:1.10": "Yadaniccaṁ, taṁ dukkhaṁ. ",
    "sn35.205:1.11": "Yaṁ dukkhaṁ, tadanattā. ",
    "sn35.205:1.12": "Yadanattā, taṁ ‘netaṁ mama, nesohamasmi, na meso attā’ti evametaṁ yathābhūtaṁ sammappaññāya daṭṭhabbaṁ. ",
    "sn35.205:1.13": "Evaṁ passaṁ, bhikkhave …pe… ",
    "sn35.205:1.14": "nāparaṁ itthattāyāti pajānātī”ti. "
  },
  "translation_text": {
    "sn35.205:0.1": "Linked Discourses 35.205 ",
    "sn35.205:0.2": "17. Sixty Abbreviated Texts ",
    "sn35.205:0.3": "The Interior and What’s Impermanent in the Future ",
    "sn35.205:1.1": "“Mendicants, in the future the eye, ear, nose, tongue, body, and mind will be impermanent. ",
    "sn35.205:1.2": "What’s impermanent is suffering …” ",
