  "root_text": {
    "sn18.2:0.1": "Saṁyutta Nikāya 18.2 ",
    "sn18.2:0.2": "1. Paṭhamavagga ",
    "sn18.2:0.3": "Rūpasutta ",
    "sn18.2:1.1": "Sāvatthiyaṁ viharati. ",
    "sn18.2:1.2": "“Taṁ kiṁ maññasi, rāhula, ",
    "sn18.2:1.3": "rūpā niccā vā aniccā vā”ti? ",
    "sn18.2:1.4": "“Aniccā, bhante” …pe… ",
    "sn18.2:1.5": "saddā … ",
    "sn18.2:1.6": "gandhā … ",
    "sn18.2:1.7": "rasā … ",
    "sn18.2:1.8": "phoṭṭhabbā … ",
    "sn18.2:1.9": "dhammā niccā vā aniccā vā”ti? ",
    "sn18.2:1.10": "“Aniccā, bhante” … ",
    "sn18.2:1.11": "“evaṁ passaṁ, rāhula, sutavā ariyasāvako rūpesupi nibbindati … saddesupi nibbindati … gandhesupi nibbindati … rasesupi nibbindati … phoṭṭhabbesupi nibbindati … dhammesupi nibbindati; ",
    "sn18.2:1.12": "nibbindaṁ virajjati …pe… ",
    "sn18.2:1.13": "pajānātī”ti. ",
    "sn18.2:1.14": "Dutiyaṁ. "
  },
  "translation_text": {
    "sn18.2:0.1": "Linked Discourses 18.2 ",
    "sn18.2:0.2": "Chapter One ",
    "sn18.2:0.3": "Sights, Etc. ",
    "sn18.2:1.1": "At Sāvatthī. ",
    "sn18.2:1.2": "“What do you think, Rāhula? ",
    "sn18.2:1.3": "Are sights permanent or impermanent?” ",
    "sn18.2:1.4": "“Impermanent, sir.” … ",
    "sn18.2:1.5": "“… sounds … ",
    "sn18.2:1.6": "smells … ",
    "sn18.2:1.7": "tastes … ",
    "sn18.2:1.8": "touches … ",
    "sn18.2:1.9": "Are ideas permanent or impermanent?” ",
    "sn18.2:1.10": "“Impermanent, sir.” … ",
    "sn18.2:1.11": "“Seeing this, a learned noble disciple grows disillusioned with sights, sounds, smells, tastes, touches, and ideas. ",
    "sn18.2:1.12": "Being disillusioned, desire fades away. …” ",
    "sn18.2:1.13": ""
  },
  "variant_text": {
    "sn18.2:0.3": "Rūpasutta → rūpādiārammaṇasuttaṁ (bj) "
  },
