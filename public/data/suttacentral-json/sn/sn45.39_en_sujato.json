  "root_text": {
    "sn45.39:0.1": "Saṁyutta Nikāya 45.39 ",
    "sn45.39:0.2": "4. Paṭipattivagga ",
    "sn45.39:0.3": "Paṭhamabrahmacariyasutta ",
    "sn45.39:1.1": "Sāvatthinidānaṁ. ",
    "sn45.39:1.2": "“Brahmacariyañca vo, bhikkhave, desessāmi, brahmacariyaphalāni ca. ",
    "sn45.39:1.3": "Taṁ suṇātha. ",
    "sn45.39:1.4": "Katamañca, bhikkhave, brahmacariyaṁ? ",
    "sn45.39:1.5": "Ayameva ariyo aṭṭhaṅgiko maggo, seyyathidaṁ—",
    "sn45.39:1.6": "sammādiṭṭhi …pe… sammāsamādhi. ",
    "sn45.39:1.7": "Idaṁ vuccati, bhikkhave, brahmacariyaṁ. ",
    "sn45.39:1.8": "Katamāni ca, bhikkhave, brahmacariyaphalāni? ",
    "sn45.39:1.9": "Sotāpattiphalaṁ, sakadāgāmiphalaṁ, anāgāmiphalaṁ, arahattaphalaṁ—",
    "sn45.39:1.10": "imāni vuccanti, bhikkhave, brahmacariyaphalānī”ti. ",
    "sn45.39:1.11": "Navamaṁ. "
  },
  "translation_text": {
    "sn45.39:0.1": "Linked Discourses 45.39 ",
    "sn45.39:0.2": "4. Practice ",
    "sn45.39:0.3": "The Spiritual Path (1st) ",
    "sn45.39:1.1": "At Sāvatthī. ",
    "sn45.39:1.2": "“Mendicants, I will teach you the spiritual path and the fruits of the spiritual path. ",
    "sn45.39:1.3": "Listen … ",
    "sn45.39:1.4": "And what is the spiritual path? ",
    "sn45.39:1.5": "It is simply this noble eightfold path, that is: ",
    "sn45.39:1.6": "right view, right thought, right speech, right action, right livelihood, right effort, right mindfulness, and right immersion. ",
    "sn45.39:1.7": "This is called the spiritual path. ",
    "sn45.39:1.8": "And what are the fruits of the spiritual path? ",
    "sn45.39:1.9": "The fruits of stream-entry, once-return, non-return, and perfection. ",
    "sn45.39:1.10": "These are called the fruits of the spiritual path.” "
  },
