  "root_text": {
    "sn27.1:0.1": "Saṁyutta Nikāya 27.1 ",
    "sn27.1:0.2": "1. Kilesavagga ",
    "sn27.1:0.3": "Cakkhusutta ",
    "sn27.1:1.1": "Sāvatthinidānaṁ. ",
    "sn27.1:1.2": "“Yo, bhikkhave, cakkhusmiṁ chandarāgo, cittasseso upakkileso. ",
    "sn27.1:1.3": "Yo sotasmiṁ chandarāgo, cittasseso upakkileso. ",
    "sn27.1:1.4": "Yo ghānasmiṁ chandarāgo, cittasseso upakkileso. ",
    "sn27.1:1.5": "Yo jivhāya chandarāgo, cittasseso upakkileso. ",
    "sn27.1:1.6": "Yo kāyasmiṁ chandarāgo, cittasseso upakkileso. ",
    "sn27.1:1.7": "Yo manasmiṁ chandarāgo, cittasseso upakkileso. ",
    "sn27.1:1.8": "Yato kho, bhikkhave, bhikkhuno imesu chasu ṭhānesu cetaso upakkileso pahīno hoti, nekkhammaninnañcassa cittaṁ hoti. ",
    "sn27.1:1.9": "Nekkhammaparibhāvitaṁ cittaṁ kammaniyaṁ khāyati, abhiññā sacchikaraṇīyesu dhammesū”ti. ",
    "sn27.1:1.10": "Paṭhamaṁ. "
  },
  "translation_text": {
    "sn27.1:0.1": "Linked Discourses 27.1 ",
    "sn27.1:0.2": "1. Corruptions ",
    "sn27.1:0.3": "The Eye ",
    "sn27.1:1.1": "At Sāvatthī. ",
    "sn27.1:1.2": "“Mendicants, desire and greed for the eye, ",
    "sn27.1:1.3": "ear, ",
    "sn27.1:1.4": "nose, ",
    "sn27.1:1.5": "tongue, ",
    "sn27.1:1.6": "body, ",
    "sn27.1:1.7": "or mind is a corruption of the mind. ",
    "sn27.1:1.8": "When a mendicant has given up mental corruption in these six cases, their mind inclines to renunciation. ",
    "sn27.1:1.9": "A mind imbued with renunciation is said to be fit for work regarding anything that can be realized by insight.” "
  },
