  "root_text": {
    "sn19.19:0.1": "Saṁyutta Nikāya 19.19 ",
    "sn19.19:0.2": "2. Dutiyavagga ",
    "sn19.19:0.3": "Pāpasikkhamānasutta ",
    "sn19.19:1.1": "“Addasaṁ sikkhamānaṁ vehāsaṁ gacchantiṁ. ",
    "sn19.19:1.2": "Tassā saṅghāṭipi ādittā …pe… ",
    "sn19.19:1.3": "pāpasikkhamānā ahosi …pe…. ",
    "sn19.19:1.4": "Navamaṁ. "
  },
  "translation_text": {
    "sn19.19:0.1": "Linked Discourses 19.19 ",
    "sn19.19:0.2": "Chapter Two ",
    "sn19.19:0.3": "A Bad Trainee Nun ",
    "sn19.19:1.1": "“I saw a trainee nun flying through the air. ",
    "sn19.19:1.2": "Her outer robe was burning …” … ",
    "sn19.19:1.3": "“She used to be a bad trainee nun …” "
  },
