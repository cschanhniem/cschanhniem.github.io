  "root_text": {
    "sn2.19:0.1": "Saṁyutta Nikāya 2.19 ",
    "sn2.19:0.2": "2. Anāthapiṇḍikavagga ",
    "sn2.19:0.3": "Uttarasutta ",
    "sn2.19:1.1": "Rājagahanidānaṁ. ",
    "sn2.19:1.2": "Ekamantaṁ ṭhito kho uttaro devaputto bhagavato santike imaṁ gāthaṁ abhāsi: ",
    "sn2.19:2.1": "“Upanīyati jīvitamappamāyu, ",
    "sn2.19:2.2": "Jarūpanītassa na santi tāṇā; ",
    "sn2.19:2.3": "Etaṁ bhayaṁ maraṇe pekkhamāno, ",
    "sn2.19:2.4": "Puññāni kayirātha sukhāvahānī”ti. ",
    "sn2.19:3.1": "“Upanīyati jīvitamappamāyu, ",
    "sn2.19:3.2": "Jarūpanītassa na santi tāṇā; ",
    "sn2.19:3.3": "Etaṁ bhayaṁ maraṇe pekkhamāno, ",
    "sn2.19:3.4": "Lokāmisaṁ pajahe santipekkho”ti. "
  },
  "translation_text": {
    "sn2.19:0.1": "Linked Discourses 2.19 ",
    "sn2.19:0.2": "2. With Anāthapiṇḍika ",
    "sn2.19:0.3": "With Uttara ",
    "sn2.19:1.1": "At Rājagaha. ",
    "sn2.19:1.2": "Standing to one side, the godling Uttara spoke this verse in the Buddha’s presence: ",
    "sn2.19:2.1": "“This life, so very short, is led onward. ",
    "sn2.19:2.2": "One led on to old age has no shelter. ",
    "sn2.19:2.3": "Seeing this peril in death, ",
    "sn2.19:2.4": "do good deeds that bring you joy.” ",
    "sn2.19:3.1": "“This life, so very short, is led onward. ",
    "sn2.19:3.2": "One led on to old age has no shelter. ",
    "sn2.19:3.3": "Seeing this peril in death, ",
    "sn2.19:3.4": "a seeker of peace would drop the world’s bait.” "
  },
