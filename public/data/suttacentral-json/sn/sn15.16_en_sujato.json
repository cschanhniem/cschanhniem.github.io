  "root_text": {
    "sn15.16:0.1": "Saṁyutta Nikāya 15.16 ",
    "sn15.16:0.2": "2. Dutiyavagga ",
    "sn15.16:0.3": "Bhātusutta ",
    "sn15.16:1.1": "Sāvatthiyaṁ viharati …pe… ",
    "sn15.16:1.2": "“na so, bhikkhave, satto sulabharūpo yo nabhātābhūtapubbo …pe… ",
    "sn15.16:1.3": "alaṁ vimuccitun”ti. ",
    "sn15.16:1.4": "Chaṭṭhaṁ. "
  },
  "translation_text": {
    "sn15.16:0.1": "Linked Discourses 15.16 ",
    "sn15.16:0.2": "Chapter Two ",
    "sn15.16:0.3": "Brother ",
    "sn15.16:1.1": "At Sāvatthī. ",
    "sn15.16:1.2": "“It’s not easy to find a sentient being who in all this long time has not previously been your brother. … ",
    "sn15.16:1.3": "This is quite enough for you to become disillusioned, dispassionate, and freed regarding all conditions.” "
  },
