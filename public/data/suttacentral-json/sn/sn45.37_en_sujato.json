  "root_text": {
    "sn45.37:0.1": "Saṁyutta Nikāya 45.37 ",
    "sn45.37:0.2": "4. Paṭipattivagga ",
    "sn45.37:0.3": "Paṭhamabrahmaññasutta ",
    "sn45.37:1.1": "Sāvatthinidānaṁ. ",
    "sn45.37:1.2": "“Brahmaññañca vo, bhikkhave, desessāmi, brahmaññaphalāni ca. ",
    "sn45.37:1.3": "Taṁ suṇātha. ",
    "sn45.37:1.4": "Katamañca kho, bhikkhave, brahmaññaṁ? ",
    "sn45.37:1.5": "Ayameva ariyo aṭṭhaṅgiko maggo, seyyathidaṁ—",
    "sn45.37:1.6": "sammādiṭṭhi …pe… sammāsamādhi. ",
    "sn45.37:1.7": "Idaṁ vuccati, bhikkhave, brahmaññaṁ. ",
    "sn45.37:1.8": "Katamāni ca, bhikkhave, brahmaññaphalāni? ",
    "sn45.37:1.9": "Sotāpattiphalaṁ, sakadāgāmiphalaṁ, anāgāmiphalaṁ, arahattaphalaṁ—",
    "sn45.37:1.10": "imāni vuccanti, bhikkhave, brahmaññaphalānī”ti. ",
    "sn45.37:1.11": "Sattamaṁ. "
  },
  "translation_text": {
    "sn45.37:0.1": "Linked Discourses 45.37 ",
    "sn45.37:0.2": "4. Practice ",
    "sn45.37:0.3": "The Brahmin Life (1st) ",
    "sn45.37:1.1": "At Sāvatthī. ",
    "sn45.37:1.2": "“Mendicants, I will teach you life as a brahmin and the fruits of life as a brahmin. ",
    "sn45.37:1.3": "Listen … ",
    "sn45.37:1.4": "And what is life as a brahmin? ",
    "sn45.37:1.5": "It is simply this noble eightfold path, that is: ",
    "sn45.37:1.6": "right view, right thought, right speech, right action, right livelihood, right effort, right mindfulness, and right immersion. ",
    "sn45.37:1.7": "This is called life as a brahmin. ",
    "sn45.37:1.8": "And what are the fruits of life as a brahmin? ",
    "sn45.37:1.9": "The fruits of stream-entry, once-return, non-return, and perfection. ",
    "sn45.37:1.10": "These are called the fruits of life as a brahmin.” "
  },
