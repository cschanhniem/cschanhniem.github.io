  "root_text": {
    "sn1.4:0.1": "Saṁyutta Nikāya 1.4 ",
    "sn1.4:0.2": "1. Naḷavagga ",
    "sn1.4:0.3": "Accentisutta ",
    "sn1.4:1.1": "Sāvatthinidānaṁ. ",
    "sn1.4:1.2": "Ekamantaṁ ṭhitā kho sā devatā bhagavato santike imaṁ gāthaṁ abhāsi: ",
    "sn1.4:2.1": "“Accenti kālā tarayanti rattiyo, ",
    "sn1.4:2.2": "Vayoguṇā anupubbaṁ jahanti; ",
    "sn1.4:2.3": "Etaṁ bhayaṁ maraṇe pekkhamāno, ",
    "sn1.4:2.4": "Puññāni kayirātha sukhāvahānī”ti. ",
    "sn1.4:3.1": "“Accenti kālā tarayanti rattiyo, ",
    "sn1.4:3.2": "Vayoguṇā anupubbaṁ jahanti; ",
    "sn1.4:3.3": "Etaṁ bhayaṁ maraṇe pekkhamāno, ",
    "sn1.4:3.4": "Lokāmisaṁ pajahe santipekkho”ti. "
  },
  "translation_text": {
    "sn1.4:0.1": "Linked Discourses 1.4 ",
    "sn1.4:0.2": "1. A Reed ",
    "sn1.4:0.3": "Time Flies ",
    "sn1.4:1.1": "At Sāvatthī. ",
    "sn1.4:1.2": "Standing to one side, that deity spoke this verse in the Buddha’s presence: ",
    "sn1.4:2.1": "“Time flies, nights pass by, ",
    "sn1.4:2.2": "the stages of life leave us one by one. ",
    "sn1.4:2.3": "Seeing this peril in death, ",
    "sn1.4:2.4": "do good deeds that bring you joy.” ",
    "sn1.4:3.1": "“Time flies, nights pass by, ",
    "sn1.4:3.2": "the stages of life leave us one by one. ",
    "sn1.4:3.3": "Seeing this peril in death, ",
    "sn1.4:3.4": "a seeker of peace would drop the world’s bait.” "
  },
