  "root_text": {
    "sn18.8:0.1": "Saṁyutta Nikāya 18.8 ",
    "sn18.8:0.2": "1. Paṭhamavagga ",
    "sn18.8:0.3": "Taṇhāsutta ",
    "sn18.8:1.1": "Sāvatthiyaṁ viharati. ",
    "sn18.8:1.2": "“Taṁ kiṁ maññasi, rāhula, ",
    "sn18.8:1.3": "rūpataṇhā niccā vā aniccā vā”ti? ",
    "sn18.8:1.4": "“Aniccā, bhante” … ",
    "sn18.8:1.5": "“saddataṇhā …pe… ",
    "sn18.8:1.6": "gandhataṇhā … ",
    "sn18.8:1.7": "rasataṇhā … ",
    "sn18.8:1.8": "phoṭṭhabbataṇhā … ",
    "sn18.8:1.9": "dhammataṇhā niccā vā aniccā vā”ti? ",
    "sn18.8:1.10": "“Aniccā, bhante” … ",
    "sn18.8:1.11": "“evaṁ passaṁ, rāhula, sutavā ariyasāvako rūpataṇhāyapi nibbindati …pe… saddataṇhāyapi nibbindati … gandhataṇhāyapi nibbindati … rasataṇhāyapi nibbindati … phoṭṭhabbataṇhāyapi nibbindati … dhammataṇhāyapi nibbindati …pe… ",
    "sn18.8:1.12": "pajānātī”ti. ",
    "sn18.8:1.13": "Aṭṭhamaṁ. "
  },
  "translation_text": {
    "sn18.8:0.1": "Linked Discourses 18.8 ",
    "sn18.8:0.2": "Chapter One ",
    "sn18.8:0.3": "Craving ",
    "sn18.8:1.1": "At Sāvatthī. ",
    "sn18.8:1.2": "“What do you think, Rāhula? ",
    "sn18.8:1.3": "Is craving for sights permanent or impermanent?” ",
    "sn18.8:1.4": "“Impermanent, sir.” … ",
    "sn18.8:1.5": "“… craving for sounds … ",
    "sn18.8:1.6": "craving for smells … ",
    "sn18.8:1.7": "craving for tastes … ",
    "sn18.8:1.8": "craving for touches … ",
    "sn18.8:1.9": "Is craving for ideas permanent or impermanent?” ",
    "sn18.8:1.10": "“Impermanent, sir.” … ",
    "sn18.8:1.11": "“Seeing this, a learned noble disciple grows disillusioned with craving for sights, sounds, smells, tastes, touches, and ideas. …” ",
    "sn18.8:1.12": ""
  },
