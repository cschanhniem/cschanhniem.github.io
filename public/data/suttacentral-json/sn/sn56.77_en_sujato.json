  "root_text": {
    "sn56.77:0.1": "Saṁyutta Nikāya 56.77 ",
    "sn56.77:0.2": "8. Dutiyaāmakadhaññapeyyālavagga ",
    "sn56.77:0.3": "Samphappalāpasutta ",
    "sn56.77:1.1": "… “Evameva kho, bhikkhave, appakā te sattā ye samphappalāpā paṭiviratā; atha kho eteva bahutarā sattā ye samphappalāpā appaṭiviratā …pe…. ",
    "sn56.77:1.2": "Sattamaṁ. "
  },
  "translation_text": {
    "sn56.77:0.1": "Linked Discourses 56.77 ",
    "sn56.77:0.2": "8. Abbreviated Texts on Raw Grain ",
    "sn56.77:0.3": "Nonsense ",
    "sn56.77:1.1": "“… the sentient beings who refrain from talking nonsense are few, while those who don’t refrain are many. …” "
  },
