  "root_text": {
    "sn22.32:0.1": "Saṁyutta Nikāya 22.32 ",
    "sn22.32:0.2": "3. Bhāravagga ",
    "sn22.32:0.3": "Pabhaṅgusutta ",
    "sn22.32:1.1": "Sāvatthinidānaṁ. ",
    "sn22.32:1.2": "“Pabhaṅguñca, bhikkhave, desessāmi appabhaṅguñca. ",
    "sn22.32:1.3": "Taṁ suṇātha. ",
    "sn22.32:1.4": "Kiñca, bhikkhave, pabhaṅgu, kiṁ appabhaṅgu? ",
    "sn22.32:1.5": "Rūpaṁ, bhikkhave, pabhaṅgu. ",
    "sn22.32:1.6": "Yo tassa nirodho vūpasamo atthaṅgamo, idaṁ appabhaṅgu. ",
    "sn22.32:1.7": "Vedanā pabhaṅgu. ",
    "sn22.32:1.8": "Yo tassā nirodho vūpasamo atthaṅgamo, idaṁ appabhaṅgu. ",
    "sn22.32:1.9": "Saññā pabhaṅgu … ",
    "sn22.32:1.10": "saṅkhārā pabhaṅgu. ",
    "sn22.32:1.11": "Yo tesaṁ nirodho vūpasamo atthaṅgamo, idaṁ appabhaṅgu. ",
    "sn22.32:1.12": "Viññāṇaṁ pabhaṅgu. ",
    "sn22.32:1.13": "Yo tassa nirodho vūpasamo atthaṅgamo, idaṁ appabhaṅgū”ti. ",
    "sn22.32:1.14": "Ekādasamaṁ. ",
    "sn22.32:1.15": "Bhāravaggo tatiyo. ",
    "sn22.32:2.0": "Tassuddānaṁ ",
    "sn22.32:2.1": "Bhāraṁ pariññaṁ abhijānaṁ, ",
    "sn22.32:2.2": "chandarāgaṁ catutthakaṁ; ",
    "sn22.32:2.3": "Assādā ca tayo vuttā, ",
    "sn22.32:2.4": "abhinandanamaṭṭhamaṁ; ",
    "sn22.32:2.5": "Uppādaṁ aghamūlañca, ",
    "sn22.32:2.6": "ekādasamo pabhaṅgūti. "
  },
  "translation_text": {
    "sn22.32:0.1": "Linked Discourses 22.32 ",
    "sn22.32:0.2": "3. The Burden ",
    "sn22.32:0.3": "Brittle ",
    "sn22.32:1.1": "At Sāvatthī. ",
    "sn22.32:1.2": "“Mendicants, I will teach you what is brittle and what is not brittle. ",
    "sn22.32:1.3": "Listen … ",
    "sn22.32:1.4": "And what is brittle? What is not brittle? ",
    "sn22.32:1.5": "Form is brittle, ",
    "sn22.32:1.6": "but its cessation, settling, and ending is not brittle. ",
    "sn22.32:1.7": "Feeling … ",
    "sn22.32:1.8": "",
    "sn22.32:1.9": "perception … ",
    "sn22.32:1.10": "choices … ",
    "sn22.32:1.11": "",
    "sn22.32:1.12": "consciousness is brittle, ",
    "sn22.32:1.13": "but its cessation, settling, and ending is not brittle.” ",
    "sn22.32:1.14": "",
