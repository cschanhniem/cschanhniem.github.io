  "translation_text": {
    "sn18.12-20:0.1": "Linked Discourses 18.12–20 ",
    "sn18.12-20:0.2": "Chapter Two ",
    "sn18.12-20:0.3": "The Nine Discourses on Sights, Etc. ",
    "sn18.12-20:1.1": "At Sāvatthī. ",
    "sn18.12-20:1.2": "“What do you think, Rāhula? ",
    "sn18.12-20:1.3": "Are sights permanent or impermanent?” ",
    "sn18.12-20:1.4": "“Impermanent, sir.” … ",
    "sn18.12-20:1.5": "“… sounds … ",
    "sn18.12-20:1.6": "smells … ",
    "sn18.12-20:1.7": "tastes … ",
    "sn18.12-20:1.8": "touches … ",
    "sn18.12-20:1.9": "ideas …” ",
    "sn18.12-20:2.1": "“… eye consciousness … ",
    "sn18.12-20:2.2": "ear consciousness … ",
    "sn18.12-20:2.3": "nose consciousness … ",
    "sn18.12-20:2.4": "tongue consciousness … ",
    "sn18.12-20:2.5": "body consciousness … ",
    "sn18.12-20:2.6": "mind consciousness …” ",
    "sn18.12-20:3.1": "“… eye contact … ",
    "sn18.12-20:3.2": "ear contact … ",
    "sn18.12-20:3.3": "nose contact … ",
    "sn18.12-20:3.4": "tongue contact … ",
    "sn18.12-20:3.5": "body contact … ",
    "sn18.12-20:3.6": "mind contact …” ",
    "sn18.12-20:4.1": "“… feeling born of eye contact … ",
    "sn18.12-20:4.2": "feeling born of ear contact … ",
    "sn18.12-20:4.3": "feeling born of nose contact … ",
    "sn18.12-20:4.4": "feeling born of tongue contact … ",
    "sn18.12-20:4.5": "feeling born of body contact … ",
    "sn18.12-20:4.6": "feeling born of mind contact …” ",
    "sn18.12-20:5.1": "“… perception of sights … ",
    "sn18.12-20:5.2": "perception of sounds … ",
    "sn18.12-20:5.3": "perception of smells … ",
    "sn18.12-20:5.4": "perception of tastes … ",
    "sn18.12-20:5.5": "perception of touches … ",
    "sn18.12-20:5.6": "perception of ideas …” ",
    "sn18.12-20:6.1": "“… intention regarding sights … ",
    "sn18.12-20:6.2": "intention regarding sounds … ",
    "sn18.12-20:6.3": "intention regarding smells … ",
    "sn18.12-20:6.4": "intention regarding tastes … ",
    "sn18.12-20:6.5": "intention regarding touches … ",
    "sn18.12-20:6.6": "intention regarding ideas …” ",
    "sn18.12-20:7.1": "“… craving for sights … ",
    "sn18.12-20:7.2": "craving for sounds … ",
    "sn18.12-20:7.3": "craving for smells … ",
    "sn18.12-20:7.4": "craving for tastes … ",
    "sn18.12-20:7.5": "craving for touches … ",
    "sn18.12-20:7.6": "craving for ideas …” ",
    "sn18.12-20:8.1": "“… the earth element … ",
    "sn18.12-20:8.2": "the water element … ",
    "sn18.12-20:8.3": "the fire element … ",
    "sn18.12-20:8.4": "the air element … ",
    "sn18.12-20:8.5": "the space element … ",
    "sn18.12-20:8.6": "the consciousness element …” ",
    "sn18.12-20:9.1": "“… form … ",
    "sn18.12-20:9.2": "feeling … ",
    "sn18.12-20:9.3": "perception … ",
    "sn18.12-20:9.4": "choices … ",
    "sn18.12-20:9.5": "Is consciousness permanent or impermanent?” ",
    "sn18.12-20:9.6": "“Impermanent, sir.” … ",
    "sn18.12-20:9.7": "“Seeing this … ",
    "sn18.12-20:9.8": "They understand: ‘… there is nothing further for this place.’” "
  },
