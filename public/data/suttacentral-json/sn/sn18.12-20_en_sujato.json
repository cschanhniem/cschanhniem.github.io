    "sn18.12-20:4.2": "sotasamphassajā vedanā … ",
    "sn18.12-20:4.3": "ghānasamphassajā vedanā … ",
    "sn18.12-20:4.4": "jivhāsamphassajā vedanā … ",
    "sn18.12-20:4.5": "kāyasamphassajā vedanā … ",
    "sn18.12-20:4.6": "manosamphassajā vedanā …. ",
    "sn18.12-20:5.1": "Rūpasaññā …pe… ",
    "sn18.12-20:5.2": "saddasaññā … ",
    "sn18.12-20:5.3": "gandhasaññā … ",
    "sn18.12-20:5.4": "rasasaññā … ",
    "sn18.12-20:5.5": "phoṭṭhabbasaññā … ",
