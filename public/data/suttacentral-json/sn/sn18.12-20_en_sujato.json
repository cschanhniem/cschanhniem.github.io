  "root_text": {
    "sn18.12-20:0.1": "Saṁyutta Nikāya 18.12–20 ",
    "sn18.12-20:0.2": "2. Dutiyavagga ",
    "sn18.12-20:0.3": "Rūpādisuttanavaka ",
    "sn18.12-20:1.1": "Sāvatthiyaṁ viharati. ",
    "sn18.12-20:1.2": "“Taṁ kiṁ maññasi, rāhula, ",
    "sn18.12-20:1.3": "rūpā niccā vā aniccā vā”ti? ",
    "sn18.12-20:1.4": "“Aniccā, bhante” …pe… ",
    "sn18.12-20:1.5": "saddā … ",
    "sn18.12-20:1.6": "gandhā … ",
    "sn18.12-20:1.7": "rasā … ",
    "sn18.12-20:1.8": "phoṭṭhabbā … ",
    "sn18.12-20:1.9": "dhammā …. ",
    "sn18.12-20:2.1": "“Cakkhuviññāṇaṁ …pe… ",
    "sn18.12-20:2.2": "sotaviññāṇaṁ … ",
    "sn18.12-20:2.3": "ghānaviññāṇaṁ … ",
    "sn18.12-20:2.4": "jivhāviññāṇaṁ … ",
    "sn18.12-20:2.5": "kāyaviññāṇaṁ … ",
    "sn18.12-20:2.6": "manoviññāṇaṁ …. ",
    "sn18.12-20:3.1": "Cakkhusamphasso …pe… ",
    "sn18.12-20:3.2": "sotasamphasso … ",
    "sn18.12-20:3.3": "ghānasamphasso … ",
    "sn18.12-20:3.4": "jivhāsamphasso … ",
    "sn18.12-20:3.5": "kāyasamphasso … ",
    "sn18.12-20:3.6": "manosamphasso …. ",
