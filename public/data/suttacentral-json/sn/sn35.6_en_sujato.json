  "root_text": {
    "sn35.6:0.1": "Saṁyutta Nikāya 35.6 ",
    "sn35.6:0.2": "1. Aniccavagga ",
    "sn35.6:0.3": "Bāhirānattasutta ",
    "sn35.6:1.1": "“Rūpā, bhikkhave, anattā. ",
    "sn35.6:1.2": "Yadanattā taṁ ‘netaṁ mama, nesohamasmi, na meso attā’ti evametaṁ yathābhūtaṁ sammappaññāya daṭṭhabbaṁ. ",
    "sn35.6:1.3": "Saddā …pe… ",
    "sn35.6:1.4": "gandhā … ",
    "sn35.6:1.5": "rasā … ",
    "sn35.6:1.6": "phoṭṭhabbā … ",
    "sn35.6:1.7": "dhammā anattā. ",
    "sn35.6:1.8": "Yadanattā taṁ ‘netaṁ mama, nesohamasmi, na meso attā’ti evametaṁ yathābhūtaṁ sammappaññāya daṭṭhabbaṁ. ",
    "sn35.6:1.9": "Evaṁ passaṁ …pe… ",
    "sn35.6:1.10": "nāparaṁ itthattāyāti pajānātī”ti. ",
    "sn35.6:1.11": "Chaṭṭhaṁ. "
  },
  "translation_text": {
    "sn35.6:0.1": "Linked Discourses 35.6 ",
    "sn35.6:0.2": "1. Impermanence ",
    "sn35.6:0.3": "The Exterior as Not-Self ",
    "sn35.6:1.1": "“Mendicants, sights are not-self. ",
    "sn35.6:1.2": "And what’s not-self should be truly seen with right understanding like this: ‘This is not mine, I am not this, this is not my self.’ …” ",
