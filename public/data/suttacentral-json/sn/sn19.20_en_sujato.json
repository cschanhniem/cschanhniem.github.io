    "sn19.20:0.1": "Saṁyutta Nikāya 19.20 ",
    "sn19.20:0.2": "2. Dutiyavagga ",
    "sn19.20:0.3": "Pāpasāmaṇerasutta ",
    "sn19.20:1.1": "“Addasaṁ sāmaṇeraṁ vehāsaṁ gacchantaṁ. ",
    "sn19.20:1.2": "Tassa saṅghāṭipi ādittā …pe… ",
    "sn19.20:1.3": "pāpasāmaṇero ahosi …pe…. ",
    "sn19.20:1.4": "Dasamaṁ. "
  },
