  "root_text": {
    "sn56.78:0.1": "Saṁyutta Nikāya 56.78 ",
    "sn56.78:0.2": "8. Dutiyaāmakadhaññapeyyālavagga ",
    "sn56.78:0.3": "Bījagāmasutta ",
    "sn56.78:1.1": "… “Evameva kho, bhikkhave, appakā te sattā ye bījagāmabhūtagāmasamārambhā paṭiviratā; atha kho eteva bahutarā sattā ye bījagāmabhūtagāmasamārambhā appaṭiviratā …pe…. ",
    "sn56.78:1.2": "Aṭṭhamaṁ. "
  },
  "translation_text": {
    "sn56.78:0.1": "Linked Discourses 56.78 ",
    "sn56.78:0.2": "8. Abbreviated Texts on Raw Grain ",
    "sn56.78:0.3": "Plants ",
    "sn56.78:1.1": "“… the sentient beings who refrain from injuring plants and seeds are few, while those who don’t refrain are many. …” "
  },
  "variant_text": {
    "sn56.78:0.3": "Bījagāmasutta → bījaṁ (pts1ed) ",
    "sn56.78:1.1": "bījagāmabhūtagāmasamārambhā → bījagāmabhūtagāmasamārabbhā (mr) "
  },
