  "root_text": {
    "sn35.137:0.1": "Saṁyutta Nikāya 35.137 ",
    "sn35.137:0.2": "14. Devadahavagga ",
    "sn35.137:0.3": "Dutiyarūpārāmasutta ",
    "sn35.137:1.1": "“Rūpārāmā, bhikkhave, devamanussā rūparatā rūpasammuditā. ",
    "sn35.137:1.2": "Rūpavipariṇāmavirāganirodhā dukkhā, bhikkhave, devamanussā viharanti. ",
    "sn35.137:1.3": "Saddārāmā … ",
    "sn35.137:1.4": "gandhārāmā … ",
    "sn35.137:1.5": "rasārāmā … ",
    "sn35.137:1.6": "phoṭṭhabbārāmā … ",
    "sn35.137:1.7": "dhammārāmā, bhikkhave, devamanussā dhammaratā dhammasammuditā. ",
    "sn35.137:1.8": "Dhammavipariṇāmavirāganirodhā dukkhā, bhikkhave, devamanussā viharanti. ",
    "sn35.137:1.9": "Tathāgato ca, bhikkhave, arahaṁ sammāsambuddho rūpānaṁ samudayañca atthaṅgamañca assādañca ādīnavañca nissaraṇañca yathābhūtaṁ viditvā na rūpārāmo na rūparato na rūpasammudito. ",
    "sn35.137:1.10": "Rūpavipariṇāmavirāganirodhā sukho, bhikkhave, tathāgato viharati. ",
    "sn35.137:1.11": "Saddānaṁ … ",
    "sn35.137:1.12": "gandhānaṁ … ",
    "sn35.137:1.13": "rasānaṁ … ",
    "sn35.137:1.14": "phoṭṭhabbānaṁ … ",
    "sn35.137:1.15": "dhammānaṁ samudayañca atthaṅgamañca assādañca ādīnavañca nissaraṇañca yathābhūtaṁ viditvā na dhammārāmo na dhammarato na dhammasammudito. ",
    "sn35.137:1.16": "Dhammavipariṇāmavirāganirodhā sukho, bhikkhave, tathāgato viharatī”ti. ",
    "sn35.137:1.17": "Catutthaṁ. "
  },
  "translation_text": {
    "sn35.137:0.1": "Linked Discourses 35.137 ",
    "sn35.137:0.2": "14. At Devadaha ",
    "sn35.137:0.3": "Liking Sights (2nd) ",
    "sn35.137:1.1": "“Mendicants, gods and humans like sights, they love them and enjoy them. ",
    "sn35.137:1.2": "But when sights perish, fade away, and cease, gods and humans live in suffering. … ",
    "sn35.137:1.3": "",
    "sn35.137:1.4": "",
    "sn35.137:1.5": "",
    "sn35.137:1.6": "",
    "sn35.137:1.7": "",
    "sn35.137:1.8": "",
    "sn35.137:1.9": "The Realized One has truly understood the origin, disappearance, gratification, drawback, and escape of sights, so he doesn’t like, love, or enjoy them. ",
    "sn35.137:1.10": "When sights perish, fade away, and cease, the Realized One lives happily. …” ",
    "sn35.137:1.11": "",
    "sn35.137:1.12": "",
    "sn35.137:1.13": "",
    "sn35.137:1.14": "",
    "sn35.137:1.15": "",
    "sn35.137:1.16": ""
  },
