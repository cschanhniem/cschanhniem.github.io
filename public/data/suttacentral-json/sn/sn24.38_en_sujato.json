  "root_text": {
    "sn24.38:0.1": "Saṁyutta Nikāya 24.38 ",
    "sn24.38:0.2": "2. Dutiyagamanavagga ",
    "sn24.38:0.3": "Arūpīattāsutta ",
    "sn24.38:1.1": "Sāvatthinidānaṁ. ",
    "sn24.38:1.2": "“Kismiṁ nu kho, bhikkhave, sati, kiṁ upādāya, kiṁ abhinivissa evaṁ diṭṭhi uppajjati: ",
    "sn24.38:1.3": "‘arūpī attā hoti arogo paraṁ maraṇā’”ti? ",
    "sn24.38:1.4": "(Peyyālo.) ",
    "sn24.38:1.5": "Vīsatimaṁ. "
  },
  "translation_text": {
    "sn24.38:0.1": "Linked Discourses 24.38 ",
    "sn24.38:0.2": "2. The Second Round ",
    "sn24.38:0.3": "The Self Is Formless ",
    "sn24.38:1.1": "At Sāvatthī. ",
    "sn24.38:1.2": "“Mendicants, when what exists, because of grasping what and insisting on what, does the view arise: ",
    "sn24.38:1.3": "‘The self is formless and healthy after death’?” … ",
    "sn24.38:1.4": ""
  },
