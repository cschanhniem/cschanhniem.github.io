  "root_text": {
    "sn56.76:0.1": "Saṁyutta Nikāya 56.76 ",
    "sn56.76:0.2": "8. Dutiyaāmakadhaññapeyyālavagga ",
    "sn56.76:0.3": "Pharusavācāsutta ",
    "sn56.76:1.1": "… “Evameva kho, bhikkhave, appakā te sattā ye pharusāya vācāya paṭiviratā; atha kho eteva bahutarā sattā ye pharusāya vācāya appaṭiviratā …pe…. ",
    "sn56.76:1.2": "Chaṭṭhaṁ. "
  },
  "translation_text": {
    "sn56.76:0.1": "Linked Discourses 56.76 ",
    "sn56.76:0.2": "8. Abbreviated Texts on Raw Grain ",
    "sn56.76:0.3": "Harsh Speech ",
    "sn56.76:1.1": "“… the sentient beings who refrain from harsh speech are few, while those who don’t refrain are many. …” "
  },
  "variant_text": {
    "sn56.76:0.3": "Pharusavācāsutta → pharusaṁ (pts1ed) "
  },
