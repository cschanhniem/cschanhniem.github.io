  "root_text": {
    "sn1.19:0.1": "Saṁyutta Nikāya 1.19 ",
    "sn1.19:0.2": "2. Nandanavagga ",
    "sn1.19:0.3": "Kuṭikāsutta ",
    "sn1.19:1.1": "“Kacci te kuṭikā natthi, ",
    "sn1.19:1.2": "kacci natthi kulāvakā; ",
    "sn1.19:1.3": "Kacci santānakā natthi, ",
    "sn1.19:1.4": "kacci muttosi bandhanā”ti. ",
    "sn1.19:2.1": "“Taggha me kuṭikā natthi, ",
    "sn1.19:2.2": "taggha natthi kulāvakā; ",
    "sn1.19:2.3": "Taggha santānakā natthi, ",
    "sn1.19:2.4": "taggha muttomhi bandhanā”ti. ",
    "sn1.19:3.1": "“Kintāhaṁ kuṭikaṁ brūmi, ",
    "sn1.19:3.2": "kiṁ te brūmi kulāvakaṁ; ",
    "sn1.19:3.3": "Kiṁ te santānakaṁ brūmi, ",
    "sn1.19:3.4": "kintāhaṁ brūmi bandhanan”ti. ",
    "sn1.19:4.1": "“Mātaraṁ kuṭikaṁ brūsi, ",
    "sn1.19:4.2": "bhariyaṁ brūsi kulāvakaṁ; ",
    "sn1.19:4.3": "Putte santānake brūsi, ",
    "sn1.19:4.4": "taṇhaṁ me brūsi bandhanan”ti. ",
    "sn1.19:5.1": "“Sāhu te kuṭikā natthi, ",
    "sn1.19:5.2": "sāhu natthi kulāvakā; ",
    "sn1.19:5.3": "Sāhu santānakā natthi, ",
    "sn1.19:5.4": "sāhu muttosi bandhanā”ti. "
  },
  "translation_text": {
    "sn1.19:0.1": "Linked Discourses 1.19 ",
    "sn1.19:0.2": "2. The Garden of Delight ",
    "sn1.19:0.3": "Little Hut ",
    "sn1.19:1.1": "“Don’t you have a little hut? ",
    "sn1.19:1.2": "Don’t you have a little nest? ",
    "sn1.19:1.3": "Don’t you have any networks? ",
    "sn1.19:1.4": "Aren’t you free of shackles?” ",
    "sn1.19:2.1": "“Indeed I have no little hut. ",
    "sn1.19:2.2": "Indeed I have no little nest. ",
    "sn1.19:2.3": "Indeed I have no networks. ",
    "sn1.19:2.4": "Indeed I’m free from shackles.” ",
    "sn1.19:3.1": "“What do you think I call your little hut? ",
    "sn1.19:3.2": "What do I call your little nest? ",
    "sn1.19:3.3": "What do I call your network? ",
    "sn1.19:3.4": "And what do I call your shackle?” ",
    "sn1.19:4.1": "“You call mother a little hut; ",
    "sn1.19:4.2": "and wife a little nest. ",
    "sn1.19:4.3": "You call children a network, ",
    "sn1.19:4.4": "and you call my craving a shackle.” ",
    "sn1.19:5.1": "“It’s good you have no little hut! ",
    "sn1.19:5.2": "It’s good you have no little nest! ",
    "sn1.19:5.3": "It’s good you have no networks! ",
    "sn1.19:5.4": "And good that you’re free from shackles.” "
  },
