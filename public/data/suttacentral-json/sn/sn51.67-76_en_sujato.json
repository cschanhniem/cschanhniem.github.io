  "root_text": {
    "sn51.67-76:0.1": "Saṁyutta Nikāya 51.67 ",
    "sn51.67-76:0.2": "7. Esanāvagga ",
    "sn51.67-76:0.3": "Esanāvagga ",
    "sn51.67-76:1.1": "(Esanāvaggo vitthāretabbo.) ",
    "sn51.67-76:2.0": "Tassuddānaṁ ",
    "sn51.67-76:2.1": "Esanā vidhā āsavo, ",
    "sn51.67-76:2.2": "Bhavo ca dukkhatā tisso; ",
    "sn51.67-76:2.3": "Khilaṁ malañca nīgho ca, ",
    "sn51.67-76:2.4": "Vedanā taṇhā tasinā cāti. "
  },
  "translation_text": {
    "sn51.67-76:0.1": "Linked Discourses 51.67–76 ",
    "sn51.67-76:0.2": "7. Searches ",
    "sn51.67-76:0.3": "Searches ",
    "sn51.67-76:1.1": "(Tell in full as in the chapter on searches at SN 45.161–170.) ",
    "sn51.67-76:2.1": "Searches, discriminations, defilements, ",
    "sn51.67-76:2.2": "states of existence, three kinds of suffering, ",
    "sn51.67-76:2.3": "barrenness, stains, and troubles, ",
    "sn51.67-76:2.4": "feelings, craving, and thirst. "
  },
