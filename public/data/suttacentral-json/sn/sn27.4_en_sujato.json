  "root_text": {
    "sn27.4:0.1": "Saṁyutta Nikāya 27.4 ",
    "sn27.4:0.2": "1. Kilesavagga ",
    "sn27.4:0.3": "Samphassasutta ",
    "sn27.4:1.1": "Sāvatthinidānaṁ. ",
    "sn27.4:1.2": "“Yo, bhikkhave, cakkhusamphassasmiṁ chandarāgo, cittasseso upakkileso. ",
    "sn27.4:1.3": "Yo sotasamphassasmiṁ … ",
    "sn27.4:1.4": "yo ghānasamphassasmiṁ … ",
    "sn27.4:1.5": "yo jivhāsamphassasmiṁ … ",
    "sn27.4:1.6": "yo kāyasamphassasmiṁ … ",
    "sn27.4:1.7": "yo manosamphassasmiṁ chandarāgo, cittasseso upakkileso. ",
    "sn27.4:1.8": "Yato kho, bhikkhave, bhikkhuno …pe… ",
    "sn27.4:1.9": "abhiññā sacchikaraṇīyesu dhammesū”ti. ",
    "sn27.4:1.10": "Catutthaṁ. "
  },
  "translation_text": {
    "sn27.4:0.1": "Linked Discourses 27.4 ",
    "sn27.4:0.2": "1. Corruptions ",
    "sn27.4:0.3": "Contact ",
    "sn27.4:1.1": "At Sāvatthī. ",
    "sn27.4:1.2": "“Mendicants, desire and greed for eye contact, ",
    "sn27.4:1.3": "ear contact, ",
    "sn27.4:1.4": "nose contact, ",
    "sn27.4:1.5": "tongue contact, ",
    "sn27.4:1.6": "body contact, ",
    "sn27.4:1.7": "or mind contact is a corruption of the mind. …” ",
    "sn27.4:1.8": "",
    "sn27.4:1.9": ""
  },
  "variant_text": {
    "sn27.4:0.3": "Samphassasutta → phassasuttaṁ (bj); phasso (pts1ed) "
  },
