  "root_text": {
    "sn45.64-68:0.1": "Saṁyutta Nikāya 45.64–68 ",
    "sn45.64-68:0.2": "7. Ekadhammapeyyālavagga ",
    "sn45.64-68:0.3": "Sīlasampadādisuttapañcaka ",
    "sn45.64-68:1.1": "“Ekadhammo, bhikkhave, bahūpakāro ariyassa aṭṭhaṅgikassa maggassa uppādāya. ",
    "sn45.64-68:1.2": "Katamo ekadhammo? ",
    "sn45.64-68:1.3": "Yadidaṁ—sīlasampadā …pe… ",
    "sn45.64-68:1.4": "yadidaṁ—chandasampadā …pe… ",
    "sn45.64-68:1.5": "yadidaṁ—attasampadā …pe… ",
    "sn45.64-68:1.6": "yadidaṁ—diṭṭhisampadā …pe… ",
    "sn45.64-68:1.7": "yadidaṁ—appamādasampadā …pe…. ",
    "sn45.64-68:1.8": "Chaṭṭhaṁ. "
  },
  "translation_text": {
    "sn45.64-68:0.1": "Linked Discourses 45.64–68 ",
    "sn45.64-68:0.2": "7. Abbreviated Texts on One Thing ",
    "sn45.64-68:0.3": "Five Discourses on Accomplishment in Ethics, Etc. (1st) ",
    "sn45.64-68:1.1": "“Mendicants, one thing helps give rise to the noble eightfold path. ",
    "sn45.64-68:1.2": "What one thing? ",
    "sn45.64-68:1.3": "It’s accomplishment in ethics. …” ",
    "sn45.64-68:1.4": "“… accomplishment in enthusiasm …” ",
    "sn45.64-68:1.5": "“… accomplishment in self-development …” ",
    "sn45.64-68:1.6": "“… accomplishment in view …” ",
    "sn45.64-68:1.7": "“… accomplishment in diligence …” "
  },
