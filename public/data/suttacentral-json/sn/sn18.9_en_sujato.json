  "root_text": {
    "sn18.9:0.1": "Saṁyutta Nikāya 18.9 ",
    "sn18.9:0.2": "1. Paṭhamavagga ",
    "sn18.9:0.3": "Dhātusutta ",
    "sn18.9:1.1": "Sāvatthiyaṁ viharati. ",
    "sn18.9:1.2": "“Taṁ kiṁ maññasi, rāhula, ",
    "sn18.9:1.3": "pathavīdhātu niccā vā aniccā vā”ti? ",
    "sn18.9:1.4": "“Aniccā, bhante” … ",
    "sn18.9:1.5": "“āpodhātu …pe… ",
    "sn18.9:1.6": "tejodhātu … ",
    "sn18.9:1.7": "vāyodhātu … ",
    "sn18.9:1.8": "ākāsadhātu … ",
    "sn18.9:1.9": "viññāṇadhātu niccā vā aniccā vā”ti? ",
    "sn18.9:1.10": "“Aniccā, bhante” … ",
    "sn18.9:1.11": "“evaṁ passaṁ, rāhula, sutavā ariyasāvako pathavīdhātuyāpi nibbindati …pe… āpodhātuyāpi nibbindati … tejodhātuyāpi nibbindati … vāyodhātuyāpi nibbindati … ākāsadhātuyāpi nibbindati … viññāṇadhātuyāpi nibbindati …pe… ",
    "sn18.9:1.12": "pajānātī”ti. ",
    "sn18.9:1.13": "Navamaṁ. "
  },
  "translation_text": {
    "sn18.9:0.1": "Linked Discourses 18.9 ",
    "sn18.9:0.2": "Chapter One ",
    "sn18.9:0.3": "Elements ",
    "sn18.9:1.1": "At Sāvatthī. ",
    "sn18.9:1.2": "“What do you think, Rāhula? ",
    "sn18.9:1.3": "Is the earth element permanent or impermanent?” ",
    "sn18.9:1.4": "“Impermanent, sir.” … ",
    "sn18.9:1.5": "“… the water element … ",
    "sn18.9:1.6": "the fire element … ",
    "sn18.9:1.7": "the air element … ",
    "sn18.9:1.8": "the space element … ",
    "sn18.9:1.9": "Is the consciousness element permanent or impermanent?” ",
    "sn18.9:1.10": "“Impermanent, sir.” … ",
    "sn18.9:1.11": "“Seeing this, a learned noble disciple grows disillusioned with the earth element, water element, fire element, air element, space element, and consciousness element …” ",
    "sn18.9:1.12": ""
  },
