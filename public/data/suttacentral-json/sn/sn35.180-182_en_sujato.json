  "root_text": {
    "sn35.180-182:0.1": "Saṁyutta Nikāya 35.180–182 ",
    "sn35.180-182:0.2": "17. Saṭṭhipeyyālavagga ",
    "sn35.180-182:0.3": "Bāhiradukkhachandādisutta ",
    "sn35.180-182:1.1": "“Yaṁ, bhikkhave, dukkhaṁ, tatra vo chando pahātabbo, rāgo pahātabbo, chandarāgo pahātabbo. ",
    "sn35.180-182:1.2": "Kiñca, bhikkhave, dukkhaṁ? ",
    "sn35.180-182:1.3": "Rūpā, bhikkhave, dukkhā; tatra vo chando pahātabbo, rāgo pahātabbo, chandarāgo pahātabbo. ",
    "sn35.180-182:1.4": "Saddā … ",
    "sn35.180-182:1.5": "gandhā … ",
    "sn35.180-182:1.6": "rasā … ",
    "sn35.180-182:1.7": "phoṭṭhabbā … ",
    "sn35.180-182:1.8": "dhammā dukkhā; tatra vo chando pahātabbo, rāgo pahātabbo, chandarāgo pahātabbo. ",
    "sn35.180-182:1.9": "Yaṁ, bhikkhave, dukkhaṁ, tatra vo chando pahātabbo, rāgo pahātabbo, chandarāgo pahātabbo”ti. "
  },
  "translation_text": {
    "sn35.180-182:0.1": "Linked Discourses 35.180–182 ",
    "sn35.180-182:0.2": "17. Sixty Abbreviated Texts ",
    "sn35.180-182:0.3": "Desire, Etc. for the Suffering Exterior ",
    "sn35.180-182:1.1": "“Mendicants, you should give up desire … greed … desire and greed for what is suffering. ",
    "sn35.180-182:1.2": "And what is suffering? ",
    "sn35.180-182:1.3": "Sights, ",
    "sn35.180-182:1.4": "sounds, ",
    "sn35.180-182:1.5": "smells, ",
    "sn35.180-182:1.6": "tastes, ",
    "sn35.180-182:1.7": "touches, ",
    "sn35.180-182:1.8": "and ideas are suffering …” "
  },
