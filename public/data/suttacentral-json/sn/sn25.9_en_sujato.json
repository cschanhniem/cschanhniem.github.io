  "root_text": {
    "sn25.9:0.1": "Saṁyutta Nikāya 25.9 ",
    "sn25.9:0.2": "1. Cakkhuvagga ",
    "sn25.9:0.3": "Pathavīdhātusutta ",
    "sn25.9:1.1": "Sāvatthinidānaṁ. ",
    "sn25.9:1.2": "“Pathavīdhātu, bhikkhave, aniccā vipariṇāmī aññathābhāvī; ",
    "sn25.9:1.3": "āpodhātu … ",
    "sn25.9:1.4": "tejodhātu … ",
    "sn25.9:1.5": "vāyodhātu … ",
    "sn25.9:1.6": "ākāsadhātu … ",
    "sn25.9:1.7": "viññāṇadhātu aniccā vipariṇāmī aññathābhāvī. ",
    "sn25.9:1.8": "Yo, bhikkhave, ime dhamme evaṁ saddahati adhimuccati, ayaṁ vuccati ‘saddhānusārī …pe… ",
    "sn25.9:1.9": "sambodhiparāyano’”ti. ",
    "sn25.9:1.10": "Navamaṁ. "
  },
  "translation_text": {
    "sn25.9:0.1": "Linked Discourses 25.9 ",
    "sn25.9:0.2": "1. The Eye ",
    "sn25.9:0.3": "Elements ",
    "sn25.9:1.1": "At Sāvatthī. ",
    "sn25.9:1.2": "“Mendicants, the earth element is impermanent, decaying, and perishing. ",
    "sn25.9:1.3": "The water element, ",
    "sn25.9:1.4": "the fire element, ",
    "sn25.9:1.5": "the air element, ",
    "sn25.9:1.6": "the space element, ",
    "sn25.9:1.7": "and the consciousness element are impermanent, decaying, and perishing. ",
    "sn25.9:1.8": "Someone who has faith and confidence in these teachings is called a follower by faith. …” ",
    "sn25.9:1.9": ""
  },
  "variant_text": {
    "sn25.9:0.3": "Pathavīdhātusutta → dhātusuttaṁ (bj); dhātu (pts1ed) "
  },
