  "root_text": {
    "sn45.23:0.1": "Saṁyutta Nikāya 45.23 ",
    "sn45.23:0.2": "3. Micchattavagga ",
    "sn45.23:0.3": "Paṭhamapaṭipadāsutta ",
    "sn45.23:1.1": "Sāvatthinidānaṁ. ",
    "sn45.23:1.2": "“Micchāpaṭipadañca vo, bhikkhave, desessāmi, sammāpaṭipadañca. ",
    "sn45.23:1.3": "Taṁ suṇātha. ",
    "sn45.23:1.4": "Katamā ca, bhikkhave, micchāpaṭipadā? ",
    "sn45.23:1.5": "Seyyathidaṁ—micchādiṭṭhi …pe… micchāsamādhi. ",
    "sn45.23:1.6": "Ayaṁ vuccati, bhikkhave, micchāpaṭipadā. ",
    "sn45.23:1.7": "Katamā ca, bhikkhave, sammāpaṭipadā? ",
    "sn45.23:1.8": "Seyyathidaṁ—sammādiṭṭhi …pe… sammāsamādhi. ",
    "sn45.23:1.9": "Ayaṁ vuccati, bhikkhave, sammāpaṭipadā”ti. ",
    "sn45.23:1.10": "Tatiyaṁ. "
  },
  "translation_text": {
    "sn45.23:0.1": "Linked Discourses 45.23 ",
    "sn45.23:0.2": "3. The Wrong Way ",
    "sn45.23:0.3": "Practice (1st) ",
    "sn45.23:1.1": "At Sāvatthī. ",
    "sn45.23:1.2": "“Mendicants, I will teach you the wrong practice and the right practice. ",
    "sn45.23:1.3": "Listen … ",
    "sn45.23:1.4": "And what’s the wrong practice? ",
    "sn45.23:1.5": "It is wrong view, wrong thought, wrong speech, wrong action, wrong livelihood, wrong effort, wrong mindfulness, and wrong immersion. ",
    "sn45.23:1.6": "This is called the wrong practice. ",
    "sn45.23:1.7": "And what’s the right practice? ",
    "sn45.23:1.8": "It is right view, right thought, right speech, right action, right livelihood, right effort, right mindfulness, and right immersion. ",
    "sn45.23:1.9": "This is called the right practice.” "
  },
