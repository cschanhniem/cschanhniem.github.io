  "root_text": {
    "sn35.112:0.1": "Saṁyutta Nikāya 35.112 ",
    "sn35.112:0.2": "11. Yogakkhemivagga ",
    "sn35.112:0.3": "Bāhirāyatanaparijānanasutta ",
    "sn35.112:1.1": "“Rūpe, bhikkhave, anabhijānaṁ aparijānaṁ avirājayaṁ appajahaṁ abhabbo dukkhakkhayāya. ",
    "sn35.112:1.2": "Sadde … ",
    "sn35.112:1.3": "gandhe … ",
    "sn35.112:1.4": "rase … ",
    "sn35.112:1.5": "phoṭṭhabbe … ",
    "sn35.112:1.6": "dhamme anabhijānaṁ aparijānaṁ avirājayaṁ appajahaṁ abhabbo dukkhakkhayāya. ",
    "sn35.112:1.7": "Rūpe ca kho, bhikkhave, abhijānaṁ parijānaṁ virājayaṁ pajahaṁ bhabbo dukkhakkhayāya. ",
    "sn35.112:1.8": "Sadde … ",
    "sn35.112:1.9": "gandhe … ",
    "sn35.112:1.10": "rase … ",
    "sn35.112:1.11": "phoṭṭhabbe … ",
    "sn35.112:1.12": "dhamme abhijānaṁ parijānaṁ virājayaṁ pajahaṁ bhabbo dukkhakkhayāyā”ti. ",
    "sn35.112:1.13": "Navamaṁ. "
  },
  "translation_text": {
    "sn35.112:0.1": "Linked Discourses 35.112 ",
    "sn35.112:0.2": "11. Sanctuary from the Yoke ",
    "sn35.112:0.3": "Complete Understanding of the Exterior ",
    "sn35.112:1.1": "“Mendicants, without directly knowing and completely understanding sights … ",
    "sn35.112:1.2": "sounds … ",
    "sn35.112:1.3": "smells … ",
    "sn35.112:1.4": "tastes … ",
    "sn35.112:1.5": "touches … ",
    "sn35.112:1.6": "ideas, without dispassion for them and giving them up, you can’t end suffering. ",
    "sn35.112:1.7": "By directly knowing and completely understanding sights … ",
    "sn35.112:1.8": "sounds … ",
    "sn35.112:1.9": "smells … ",
    "sn35.112:1.10": "tastes … ",
    "sn35.112:1.11": "touches … ",
    "sn35.112:1.12": "ideas, having dispassion for them and giving them up, you can end suffering.” "
  },
  "variant_text": {
    "sn35.112:0.3": "Bāhirāyatanaparijānanasutta → dutiyaparijānanasuttaṁ (bj); pajānaṁ 2 (pts1ed) "
  },
