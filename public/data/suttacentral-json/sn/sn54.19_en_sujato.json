  "root_text": {
    "sn54.19:0.1": "Saṁyutta Nikāya 54.19 ",
    "sn54.19:0.2": "2. Dutiyavagga ",
    "sn54.19:0.3": "Addhānapariññāsutta ",
    "sn54.19:1.1": "“… Addhānapariññāya saṁvattati …. ",
    "sn54.19:1.2": "Navamaṁ. "
  },
  "translation_text": {
    "sn54.19:0.1": "Linked Discourses 54.19 ",
    "sn54.19:0.2": "Chapter Two ",
    "sn54.19:0.3": "Completely Understanding the Course of Time ",
    "sn54.19:1.1": "“Mendicants, when immersion due to mindfulness of breathing is developed and cultivated it leads to completely understanding the course of time …” "
  },
  "variant_text": {
    "sn54.19:0.3": "Addhānapariññāsutta → addhānasuttaṁ (bj); addhānaṁ (pts1ed) "
