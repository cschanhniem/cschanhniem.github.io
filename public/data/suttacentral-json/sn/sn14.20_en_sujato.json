  "root_text": {
    "sn14.20:0.1": "Saṁyutta Nikāya 14.20 ",
    "sn14.20:0.2": "2. Dutiyavagga ",
    "sn14.20:0.3": "Anottappamūlakasutta ",
    "sn14.20:1.1": "Sāvatthiyaṁ viharati. ",
    "sn14.20:1.2": "“Dhātusova, bhikkhave, sattā saṁsandanti samenti. ",
    "sn14.20:1.3": "Anottappino anottappīhi saddhiṁ saṁsandanti samenti; ",
    "sn14.20:1.4": "appassutā appassutehi saddhiṁ saṁsandanti samenti; ",
    "sn14.20:1.5": "duppaññā duppaññehi saddhiṁ saṁsandanti samenti; ",
    "sn14.20:1.6": "ottappino ottappīhi saddhiṁ saṁsandanti samenti; ",
    "sn14.20:1.7": "bahussutā bahussutehi saddhiṁ saṁsandanti samenti; paññavanto paññavantehi saddhiṁ saṁsandanti samenti …pe…. ",
    "sn14.20:2.1": "Anottappino anottappīhi saddhiṁ saṁsandanti samenti; ",
    "sn14.20:2.2": "kusītā kusītehi saddhiṁ saṁsandanti samenti; ",
    "sn14.20:2.3": "duppaññā duppaññehi saddhiṁ saṁsandanti samenti; ",
    "sn14.20:2.4": "ottappino ottappīhi saddhiṁ saṁsandanti samenti; ",
    "sn14.20:2.5": "āraddhavīriyā āraddhavīriyehi saddhiṁ saṁsandanti samenti; paññavanto paññavantehi saddhiṁ saṁsandanti samenti …pe…. ",
    "sn14.20:3.1": "Anottappino anottappīhi saddhiṁ saṁsandanti samenti; ",
    "sn14.20:3.2": "muṭṭhassatino muṭṭhassatīhi saddhiṁ saṁsandanti samenti; ",
    "sn14.20:3.3": "duppaññā duppaññehi saddhiṁ saṁsandanti samenti; ",
    "sn14.20:3.4": "ottappino ottappīhi saddhiṁ saṁsandanti samenti; ",
    "sn14.20:3.5": "upaṭṭhitassatino upaṭṭhitassatīhi saddhiṁ saṁsandanti samenti; paññavanto paññavantehi saddhiṁ saṁsandanti samentī”ti …pe…. ",
    "sn14.20:3.6": "Dasamaṁ. "
  },
  "translation_text": {
    "sn14.20:0.1": "Linked Discourses 14.20 ",
    "sn14.20:0.2": "Chapter Two ",
    "sn14.20:0.3": "Beginning With Imprudence ",
    "sn14.20:1.1": "At Sāvatthī. ",
    "sn14.20:1.2": "“Mendicants, sentient beings join together and converge because of an element: ",
    "sn14.20:1.3": "the imprudent with the imprudent … ",
    "sn14.20:1.4": "unlearned … ",
    "sn14.20:1.5": "witless. ",
    "sn14.20:1.6": "The prudent with the prudent … ",
    "sn14.20:1.7": "learned … wise. ",
    "sn14.20:2.1": "… the imprudent with the imprudent … ",
    "sn14.20:2.2": "lazy … ",
    "sn14.20:2.3": "witless. ",
    "sn14.20:2.4": "The prudent with the prudent … ",
    "sn14.20:2.5": "energetic … wise. ",
    "sn14.20:3.1": "… the imprudent with the imprudent … ",
    "sn14.20:3.2": "unmindful … ",
    "sn14.20:3.3": "witless. ",
    "sn14.20:3.4": "The prudent with the prudent … ",
    "sn14.20:3.5": "mindful … wise.” "
  },
  "variant_text": {
    "sn14.20:0.3": "Anottappamūlakasutta → anottāpamūlakatikattayasuttaṁ (bj) "
  },
