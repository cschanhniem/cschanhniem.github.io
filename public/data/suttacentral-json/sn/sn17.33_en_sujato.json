  "root_text": {
    "sn17.33:0.1": "Saṁyutta Nikāya 17.33 ",
    "sn17.33:0.2": "4. Catutthavagga ",
    "sn17.33:0.3": "Kusaladhammasutta ",
    "sn17.33:1.1": "Sāvatthiyaṁ viharati. ",
    "sn17.33:1.2": "“Dāruṇo, bhikkhave, lābhasakkārasiloko. ",
    "sn17.33:1.3": "Lābhasakkārasilokena abhibhūtassa pariyādiṇṇacittassa, bhikkhave, devadattassa kusalo dhammo samucchedamagamā. ",
    "sn17.33:1.4": "Evaṁ dāruṇo kho, bhikkhave, lābhasakkārasiloko …pe… ",
    "sn17.33:1.5": "sikkhitabban”ti. ",
    "sn17.33:1.6": "Tatiyaṁ. "
  },
  "translation_text": {
    "sn17.33:0.1": "Linked Discourses 17.33 ",
    "sn17.33:0.2": "Chapter Four ",
    "sn17.33:0.3": "Skillful Quality ",
    "sn17.33:1.1": "At Sāvatthī. ",
    "sn17.33:1.2": "“Possessions, honor, and popularity are grim … ",
    "sn17.33:1.3": "Devadatta cut off his skillful quality because his mind was overcome and overwhelmed by possessions, honor, and popularity. ",
    "sn17.33:1.4": "So grim are possessions, honor, and popularity. …” ",
    "sn17.33:1.5": ""
  },
  "variant_text": {
    "sn17.33:0.3": "Kusaladhammasutta → kusaladhammasamucchedasuttaṁ (bj); dhammo (pts1ed, pts2ed) "
  },
