  "root_text": {
    "sn22.132:0.1": "Saṁyutta Nikāya 22.132 ",
    "sn22.132:0.2": "13. Avijjāvagga ",
    "sn22.132:0.3": "Dutiyasamudayasutta ",
    "sn22.132:1.1": "Bārāṇasiyaṁ viharanti isipatane migadāye …pe… ",
    "sn22.132:1.2": "ekamantaṁ nisinno kho āyasmā mahākoṭṭhiko āyasmantaṁ sāriputtaṁ etadavoca: ",
    "sn22.132:1.3": "“‘vijjā, vijjā’ti, āvuso sāriputta, vuccati. ",
    "sn22.132:1.4": "Katamā nu kho, āvuso, vijjā; ",
    "sn22.132:1.5": "kittāvatā ca vijjāgato hotī”ti? ",
    "sn22.132:2.1": "“Idhāvuso, sutavā ariyasāvako rūpassa samudayañca atthaṅgamañca assādañca ādīnavañca nissaraṇañca yathābhūtaṁ pajānāti. ",
    "sn22.132:2.2": "Vedanāya …pe… ",
    "sn22.132:2.3": "saññāya … ",
    "sn22.132:2.4": "saṅkhārānaṁ … ",
    "sn22.132:2.5": "viññāṇassa samudayañca atthaṅgamañca assādañca ādīnavañca nissaraṇañca yathābhūtaṁ pajānāti. ",
    "sn22.132:2.6": "Ayaṁ vuccatāvuso, vijjā; ",
    "sn22.132:2.7": "ettāvatā ca vijjāgato hotī”ti. ",
    "sn22.132:2.8": "Sattamaṁ. "
  },
  "translation_text": {
    "sn22.132:0.1": "Linked Discourses 22.132 ",
    "sn22.132:0.2": "13. Ignorance ",
    "sn22.132:0.3": "Origin (2nd) ",
    "sn22.132:1.1": "At Varanasi. ",
    "sn22.132:1.2": "Mahākoṭṭhita said to Sāriputta: ",
    "sn22.132:1.3": "“Reverend Sāriputta, they speak of this thing called ‘knowledge’. ",
    "sn22.132:1.4": "What is knowledge? ",
    "sn22.132:1.5": "And how is a knowledgeable person defined?” ",
    "sn22.132:2.1": "“Reverend, a learned noble disciple truly understands the origin, the disappearance, the gratification, the drawback, and the escape when it comes to form, ",
    "sn22.132:2.2": "feeling, ",
    "sn22.132:2.3": "perception, ",
    "sn22.132:2.4": "choices, ",
    "sn22.132:2.5": "and consciousness. ",
    "sn22.132:2.6": "This is called knowledge. ",
    "sn22.132:2.7": "And this is how a knowledgeable person is defined.” "
  },
