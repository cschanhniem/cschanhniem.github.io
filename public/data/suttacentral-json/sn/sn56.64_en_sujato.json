  "root_text": {
    "sn56.64:0.1": "Saṁyutta Nikāya 56.64 ",
    "sn56.64:0.2": "7. Paṭhamaāmakadhaññapeyyālavagga ",
    "sn56.64:0.3": "Surāmerayasutta ",
    "sn56.64:1.1": "… “Evameva kho, bhikkhave, appakā te sattā ye surāmerayamajjappamādaṭṭhānā paṭiviratā; atha kho eteva bahutarā sattā ye surāmerayamajjappamādaṭṭhānā apaṭiviratā …pe…. ",
    "sn56.64:1.2": "Catutthaṁ. "
  },
  "translation_text": {
    "sn56.64:0.1": "Linked Discourses 56.64 ",
    "sn56.64:0.2": "7. Abbreviated Texts on Raw Grain ",
    "sn56.64:0.3": "Beer and Wine ",
    "sn56.64:1.1": "“… the sentient beings who refrain from beer, wine, and liquor intoxicants, are few, while those who don’t refrain are many. …” "
  },
