  "root_text": {
    "sn22.73:0.1": "Saṁyutta Nikāya 22.73 ",
    "sn22.73:0.2": "8. Khajjanīyavagga ",
    "sn22.73:0.3": "Assādasutta ",
    "sn22.73:1.1": "Sāvatthinidānaṁ. ",
    "sn22.73:1.2": "“Assutavā, bhikkhave, puthujjano rūpassa assādañca ādīnavañca nissaraṇañca yathābhūtaṁ nappajānāti. ",
    "sn22.73:1.3": "Vedanāya … ",
    "sn22.73:1.4": "saññāya … ",
    "sn22.73:1.5": "saṅkhārānaṁ … ",
    "sn22.73:1.6": "viññāṇassa assādañca ādīnavañca nissaraṇañca yathābhūtaṁ nappajānāti. ",
    "sn22.73:1.7": "Sutavā ca kho, bhikkhave, ariyasāvako rūpassa assādañca ādīnavañca nissaraṇañca yathābhūtaṁ pajānāti. ",
    "sn22.73:1.8": "Vedanāya … ",
    "sn22.73:1.9": "saññāya … ",
    "sn22.73:1.10": "saṅkhārānaṁ … ",
    "sn22.73:1.11": "viññāṇassa assādañca ādīnavañca nissaraṇañca yathābhūtaṁ pajānātī”ti. ",
    "sn22.73:1.12": "Paṭhamaṁ. "
  },
  "translation_text": {
    "sn22.73:0.1": "Linked Discourses 22.73 ",
    "sn22.73:0.2": "8. Bitable ",
    "sn22.73:0.3": "Gratification ",
    "sn22.73:1.1": "At Sāvatthī. ",
    "sn22.73:1.2": "“Mendicants, an unlearned ordinary person doesn’t truly understand the gratification, the drawback, and the escape when it comes to form, ",
    "sn22.73:1.3": "feeling, ",
    "sn22.73:1.4": "perception, ",
    "sn22.73:1.5": "choices, ",
    "sn22.73:1.6": "and consciousness. ",
    "sn22.73:1.7": "A learned noble disciple does truly understand the gratification, the drawback, and the escape when it comes to form, ",
    "sn22.73:1.8": "feeling, ",
    "sn22.73:1.9": "perception, ",
    "sn22.73:1.10": "choices, ",
    "sn22.73:1.11": "and consciousness.” "
  },
  "variant_text": {
    "sn22.73:0.2": "Khajjanīyavagga → khajjaniyavaggo (pts1ed) "
  },
