  "root_text": {
    "sn17.26:0.1": "Saṁyutta Nikāya 17.26 ",
    "sn17.26:0.2": "3. Tatiyavagga ",
    "sn17.26:0.3": "Dutiyasamaṇabrāhmaṇasutta ",
    "sn17.26:1.1": "Sāvatthiyaṁ viharati. ",
    "sn17.26:1.2": "“Ye hi keci, bhikkhave, samaṇā vā brāhmaṇā vā lābhasakkārasilokassa samudayañca atthaṅgamañca assādañca ādīnavañca nissaraṇañca yathābhūtaṁ nappajānanti …pe… ",
    "sn17.26:1.3": "pajānanti …pe… ",
    "sn17.26:1.4": "sayaṁ abhiññā sacchikatvā upasampajja viharantī”ti. ",
    "sn17.26:1.5": "Chaṭṭhaṁ. "
  },
  "translation_text": {
    "sn17.26:0.1": "Linked Discourses 17.26 ",
    "sn17.26:0.2": "Chapter Three ",
    "sn17.26:0.3": "Ascetics and Brahmins (2nd) ",
    "sn17.26:1.1": "At Sāvatthī. ",
    "sn17.26:1.2": "“There are ascetics and brahmins who don’t truly understand the origin, disappearance, gratification, drawback, and escape when it comes to possessions, honor, and popularity … ",
    "sn17.26:1.3": "There are ascetics and brahmins who do truly understand …” ",
    "sn17.26:1.4": ""
  },
