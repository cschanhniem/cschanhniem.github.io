  "root_text": {
    "sn47.85-94:0.1": "Saṁyutta Nikāya 47.85–94 ",
    "sn47.85-94:0.2": "9. Esanāvagga ",
    "sn47.85-94:0.3": "Esanādisutta ",
    "sn47.85-94:1.1": "“Tisso imā, bhikkhave, esanā. ",
    "sn47.85-94:1.2": "Katamā tisso? ",
    "sn47.85-94:1.3": "Kāmesanā, bhavesanā, brahmacariyesanā”ti ",
    "sn47.85-94:1.4": "vitthāretabbaṁ. ",
    "sn47.85-94:1.5": "Esanāvaggo navamo. ",
    "sn47.85-94:2.0": "Tassuddānaṁ ",
    "sn47.85-94:2.1": "Esanā vidhā āsavo, ",
    "sn47.85-94:2.2": "Bhavo ca dukkhatā tisso; ",
    "sn47.85-94:2.3": "Khilaṁ malañca nīgho ca, ",
    "sn47.85-94:2.4": "Vedanā taṇhā tasināya cāti. "
  },
  "translation_text": {
    "sn47.85-94:0.1": "Linked Discourses 47.85–94 ",
    "sn47.85-94:0.2": "9. Searches ",
    "sn47.85-94:0.3": "Searches, Etc. ",
    "sn47.85-94:1.1": "“Mendicants, there are these three searches. ",
    "sn47.85-94:1.2": "What three? ",
    "sn47.85-94:1.3": "The search for sensual pleasures, the search for continued existence, and the search for a spiritual path. …” ",
    "sn47.85-94:1.4": "(Tell in full as in SN 45.161–170.) ",
    "sn47.85-94:2.1": "Searches, discriminations, defilements, ",
    "sn47.85-94:2.2": "states of existence, three kinds of suffering, ",
    "sn47.85-94:2.3": "barrenness, stains, and troubles, ",
    "sn47.85-94:2.4": "feelings, craving, and thirst. "
  },
