  "root_text": {
    "sn22.131:0.1": "Saṁyutta Nikāya 22.131 ",
    "sn22.131:0.2": "13. Avijjāvagga ",
    "sn22.131:0.3": "Samudayasutta ",
    "sn22.131:1.1": "Bārāṇasiyaṁ viharanti isipatane migadāye …pe… ",
    "sn22.131:1.2": "“‘avijjā, avijjā’ti, āvuso sāriputta, vuccati. ",
    "sn22.131:1.3": "Katamā nu kho, āvuso, avijjā; ",
    "sn22.131:1.4": "kittāvatā ca avijjāgato hotī”ti? ",
    "sn22.131:2.1": "“Idhāvuso, assutavā puthujjano rūpassa samudayañca atthaṅgamañca assādañca ādīnavañca nissaraṇañca yathābhūtaṁ nappajānāti. ",
    "sn22.131:2.2": "Vedanāya …pe… ",
    "sn22.131:2.3": "saññāya … ",
    "sn22.131:2.4": "saṅkhārānaṁ … ",
    "sn22.131:2.5": "viññāṇassa samudayañca atthaṅgamañca assādañca ādīnavañca nissaraṇañca yathābhūtaṁ nappajānāti. ",
    "sn22.131:2.6": "Ayaṁ vuccatāvuso, avijjā; ",
    "sn22.131:2.7": "ettāvatā ca avijjāgato hotī”ti. ",
    "sn22.131:2.8": "Chaṭṭhaṁ. "
  },
  "translation_text": {
    "sn22.131:0.1": "Linked Discourses 22.131 ",
    "sn22.131:0.2": "13. Ignorance ",
    "sn22.131:0.3": "Origin ",
    "sn22.131:1.1": "At Varanasi. ",
    "sn22.131:1.2": "“Reverend Sāriputta, they speak of this thing called ‘ignorance’. ",
    "sn22.131:1.3": "What is ignorance? ",
    "sn22.131:1.4": "And how is an ignorant person defined?” ",
    "sn22.131:2.1": "“Reverend, an unlearned ordinary person doesn’t truly understand the origin, the disappearance, the gratification, the drawback, and the escape when it comes to form, ",
    "sn22.131:2.2": "feeling, ",
    "sn22.131:2.3": "perception, ",
    "sn22.131:2.4": "choices, ",
    "sn22.131:2.5": "and consciousness. ",
    "sn22.131:2.6": "This is called ignorance. ",
    "sn22.131:2.7": "And this is how an ignorant person is defined.” "
  },
