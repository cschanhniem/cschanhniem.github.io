  "root_text": {
    "sn56.71:0.1": "Saṁyutta Nikāya 56.71 ",
    "sn56.71:0.2": "8. Dutiyaāmakadhaññapeyyālavagga ",
    "sn56.71:0.3": "Pāṇātipātasutta ",
    "sn56.71:1.1": "… “Evameva kho, bhikkhave, appakā te sattā ye pāṇātipātā paṭiviratā; atha kho eteva bahutarā sattā ye pāṇātipātā appaṭiviratā. ",
    "sn56.71:1.2": "Taṁ kissa hetu? …pe…. ",
    "sn56.71:1.3": "Paṭhamaṁ. "
  },
  "translation_text": {
    "sn56.71:0.1": "Linked Discourses 56.71 ",
    "sn56.71:0.2": "8. Abbreviated Texts on Raw Grain ",
    "sn56.71:0.3": "Killing Living Creatures ",
    "sn56.71:1.1": "“… the sentient beings who refrain from killing living creatures are few, while those who don’t refrain are many. …” ",
    "sn56.71:1.2": ""
  },
  "variant_text": {
    "sn56.71:0.2": "Dutiyaāmakadhaññapeyyālavagga → appakā-virataṁ (pts1ed) ",
    "sn56.71:0.3": "Pāṇātipātasutta → pāṇa (pts1ed) "
  },
