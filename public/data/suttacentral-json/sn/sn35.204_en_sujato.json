  "root_text": {
    "sn35.204:0.1": "Saṁyutta Nikāya 35.204 ",
    "sn35.204:0.2": "17. Saṭṭhipeyyālavagga ",
    "sn35.204:0.3": "Ajjhattātītayadaniccasutta ",
    "sn35.204:1.1": "“Cakkhu, bhikkhave, aniccaṁ atītaṁ. ",
    "sn35.204:1.2": "Yadaniccaṁ, taṁ dukkhaṁ. ",
    "sn35.204:1.3": "Yaṁ dukkhaṁ, tadanattā. ",
    "sn35.204:1.4": "Yadanattā, taṁ ‘netaṁ mama, nesohamasmi, na meso attā’ti evametaṁ yathābhūtaṁ sammappaññāya daṭṭhabbaṁ …pe… ",
    "sn35.204:1.5": "jivhā aniccā atītā. ",
    "sn35.204:1.6": "Yadaniccaṁ, taṁ dukkhaṁ. ",
    "sn35.204:1.7": "Yaṁ dukkhaṁ, tadanattā. ",
    "sn35.204:1.8": "Yadanattā, taṁ ‘netaṁ mama, nesohamasmi, na meso attā’ti evametaṁ yathābhūtaṁ sammappaññāya daṭṭhabbaṁ …pe… ",
    "sn35.204:1.9": "mano anicco atīto. ",
    "sn35.204:1.10": "Yadaniccaṁ, taṁ dukkhaṁ. ",
    "sn35.204:1.11": "Yaṁ dukkhaṁ, tadanattā. ",
    "sn35.204:1.12": "Yadanattā, taṁ ‘netaṁ mama, nesohamasmi, na meso attā’ti evametaṁ yathābhūtaṁ sammappaññāya daṭṭhabbaṁ. ",
    "sn35.204:1.13": "Evaṁ passaṁ …pe… ",
    "sn35.204:1.14": "nāparaṁ itthattāyāti pajānātī”ti. "
  },
  "translation_text": {
    "sn35.204:0.1": "Linked Discourses 35.204 ",
    "sn35.204:0.2": "17. Sixty Abbreviated Texts ",
    "sn35.204:0.3": "The Interior and What’s Impermanent in the Past ",
    "sn35.204:1.1": "“Mendicants, in the past the eye, ear, nose, tongue, body, and mind were impermanent. ",
    "sn35.204:1.2": "What’s impermanent is suffering. ",
    "sn35.204:1.3": "What’s suffering is not-self. ",
    "sn35.204:1.4": "And what’s not-self should be truly seen with right understanding like this: ‘This is not mine, I am not this, this is not my self.’ …” ",
