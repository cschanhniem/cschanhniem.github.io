  "root_text": {
    "sn24.12:0.1": "Saṁyutta Nikāya 24.12 ",
    "sn24.12:0.2": "1. Sotāpattivagga ",
    "sn24.12:0.3": "Anantavāsutta ",
    "sn24.12:1.1": "Sāvatthinidānaṁ. ",
    "sn24.12:1.2": "“Kismiṁ nu kho, bhikkhave, sati, kiṁ upādāya, kiṁ abhinivissa evaṁ diṭṭhi uppajjati: ",
    "sn24.12:1.3": "‘anantavā loko’”ti? ",
    "sn24.12:1.4": "“Bhagavaṁmūlakā no, bhante, dhammā …pe… ",
    "sn24.12:1.5": "niyato sambodhiparāyano”ti. ",
    "sn24.12:1.6": "Dvādasamaṁ. "
  },
  "translation_text": {
    "sn24.12:0.1": "Linked Discourses 24.12 ",
    "sn24.12:0.2": "1. Stream-Entry ",
    "sn24.12:0.3": "The Cosmos is Infinite ",
    "sn24.12:1.1": "At Sāvatthī. ",
    "sn24.12:1.2": "“Mendicants, when what exists, because of grasping what and insisting on what, does the view arise: ",
    "sn24.12:1.3": "‘The cosmos is infinite’?” … ",
    "sn24.12:1.4": "",
    "sn24.12:1.5": ""
  },
