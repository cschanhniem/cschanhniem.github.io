  "root_text": {
    "sn49.13-22:0.1": "Saṁyutta Nikāya 49.13 ",
    "sn49.13-22:0.2": "2. Appamādavagga ",
    "sn49.13-22:0.3": "Appamādavagga ",
    "sn49.13-22:1.1": "(Appamādavaggo sammappadhānavasena vitthāretabbo.) ",
    "sn49.13-22:2.0": "Tassuddānaṁ ",
    "sn49.13-22:2.1": "Tathāgataṁ padaṁ kūṭaṁ, ",
    "sn49.13-22:2.2": "mūlaṁ sārena vassikaṁ; ",
    "sn49.13-22:2.3": "Rājā candimasūriyā, ",
    "sn49.13-22:2.4": "vatthena dasamaṁ padanti. "
  },
  "translation_text": {
    "sn49.13-22:0.1": "Linked Discourses 49.13–22 ",
    "sn49.13-22:0.2": "2. Diligence ",
    "sn49.13-22:0.3": "Diligence ",
    "sn49.13-22:1.1": "(Tell in full as in SN 45.139–148.) ",
    "sn49.13-22:2.1": "The Realized One, footprint, roof peak, ",
    "sn49.13-22:2.2": "roots, heartwood, jasmine, ",
    "sn49.13-22:2.3": "monarch, sun and moon, ",
    "sn49.13-22:2.4": "and cloth is the tenth. "
  },
