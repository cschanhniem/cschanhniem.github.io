  "root_text": {
    "sn37.23:0.1": "Saṁyutta Nikāya 37.23 ",
    "sn37.23:0.2": "2. Dutiyapeyyālavagga ",
    "sn37.23:0.3": "Upaṭṭhitassatisutta ",
    "sn37.23:1.1": "“Upaṭṭhitassati ca hoti, paññavā ca hoti …pe… ",
    "sn37.23:1.2": "imehi kho, anuruddha, pañcahi dhammehi samannāgato mātugāmo kāyassa bhedā paraṁ maraṇā sugatiṁ saggaṁ lokaṁ upapajjatī”ti. ",
    "sn37.23:1.3": "Navamaṁ. ",
    "sn37.23:2.1": "Ime aṭṭha suttantasaṅkhepā. "
  },
  "translation_text": {
    "sn37.23:0.1": "Linked Discourses 37.23 ",
    "sn37.23:0.2": "2. Abbreviated Texts ",
    "sn37.23:0.3": "Mindful ",
    "sn37.23:1.1": "“… They’re faithful, conscientious, prudent, mindful, and wise. …” ",
    "sn37.23:1.2": "",
    "sn37.23:1.3": ""
  },
