  "root_text": {
    "sn45.38:0.1": "Saṁyutta Nikāya 45.38 ",
    "sn45.38:0.2": "4. Paṭipattivagga ",
    "sn45.38:0.3": "Dutiyabrahmaññasutta ",
    "sn45.38:1.1": "Sāvatthinidānaṁ. ",
    "sn45.38:1.2": "“Brahmaññañca vo, bhikkhave, desessāmi, brahmaññatthañca. ",
    "sn45.38:1.3": "Taṁ suṇātha. ",
    "sn45.38:1.4": "Katamañca, bhikkhave, brahmaññaṁ? ",
    "sn45.38:1.5": "Ayameva ariyo aṭṭhaṅgiko maggo, seyyathidaṁ—",
    "sn45.38:1.6": "sammādiṭṭhi …pe… sammāsamādhi. ",
    "sn45.38:1.7": "Idaṁ vuccati, bhikkhave, brahmaññaṁ. ",
    "sn45.38:1.8": "Katamo ca, bhikkhave, brahmaññattho? ",
    "sn45.38:1.9": "Yo kho, bhikkhave, rāgakkhayo dosakkhayo mohakkhayo—",
    "sn45.38:1.10": "ayaṁ vuccati, bhikkhave, brahmaññattho”ti. ",
    "sn45.38:1.11": "Aṭṭhamaṁ. "
  },
  "translation_text": {
    "sn45.38:0.1": "Linked Discourses 45.38 ",
    "sn45.38:0.2": "4. Practice ",
    "sn45.38:0.3": "The Brahmin Life (2nd) ",
    "sn45.38:1.1": "At Sāvatthī. ",
    "sn45.38:1.2": "“Mendicants, I will teach you life as a brahmin and the goal of life as a brahmin. ",
    "sn45.38:1.3": "Listen … ",
    "sn45.38:1.4": "And what is life as a brahmin? ",
    "sn45.38:1.5": "It is simply this noble eightfold path, that is: ",
    "sn45.38:1.6": "right view, right thought, right speech, right action, right livelihood, right effort, right mindfulness, and right immersion. ",
    "sn45.38:1.7": "This is called life as a brahmin. ",
    "sn45.38:1.8": "And what is the goal of life as a brahmin? ",
    "sn45.38:1.9": "The ending of greed, hate, and delusion. ",
    "sn45.38:1.10": "This is called the goal of life as a brahmin.” "
  },
