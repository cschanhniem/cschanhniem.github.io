  "root_text": {
    "sn1.12:0.1": "Saṁyutta Nikāya 1.12 ",
    "sn1.12:0.2": "2. Nandanavagga ",
    "sn1.12:0.3": "Nandatisutta ",
    "sn1.12:1.1": "Sāvatthinidānaṁ. ",
    "sn1.12:1.2": "Ekamantaṁ ṭhitā kho sā devatā bhagavato santike imaṁ gāthaṁ abhāsi: ",
    "sn1.12:2.1": "“Nandati puttehi puttimā, ",
    "sn1.12:2.2": "Gomā gohi tatheva nandati; ",
    "sn1.12:2.3": "Upadhīhi narassa nandanā, ",
    "sn1.12:2.4": "Na hi so nandati yo nirūpadhī”ti. ",
    "sn1.12:3.1": "“Socati puttehi puttimā, ",
    "sn1.12:3.2": "Gomā gohi tatheva socati; ",
    "sn1.12:3.3": "Upadhīhi narassa socanā, ",
    "sn1.12:3.4": "Na hi so socati yo nirūpadhī”ti. "
  },
  "translation_text": {
    "sn1.12:0.1": "Linked Discourses 1.12 ",
    "sn1.12:0.2": "2. The Garden of Delight ",
    "sn1.12:0.3": "Delight ",
    "sn1.12:1.1": "At Sāvatthī. ",
    "sn1.12:1.2": "Standing to one side, that deity spoke this verse in the Buddha’s presence: ",
    "sn1.12:2.1": "“Children bring you delight! ",
    "sn1.12:2.2": "Cattle also bring you delight! ",
    "sn1.12:2.3": "For attachments are a man’s delight; ",
    "sn1.12:2.4": "without attachments there’s no delight.” ",
    "sn1.12:3.1": "“Children bring you sorrow. ",
    "sn1.12:3.2": "Cattle also bring you sorrow. ",
    "sn1.12:3.3": "For attachments are a man’s sorrow; ",
    "sn1.12:3.4": "without attachments there are no sorrows.” "
  },
  "variant_text": {
    "sn1.12:2.2": "Gomā → gomiko (bj, sya-all, km, pts1ed, pts2ed) "
  },
