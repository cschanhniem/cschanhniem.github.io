  "root_text": {
    "sn1.73:0.1": "Saṁyutta Nikāya 1.73 ",
    "sn1.73:0.2": "8. Chetvāvagga ",
    "sn1.73:0.3": "Vittasutta ",
    "sn1.73:1.1": "“Kiṁsūdha vittaṁ purisassa seṭṭhaṁ, ",
    "sn1.73:1.2": "Kiṁsu suciṇṇo sukhamāvahati; ",
    "sn1.73:1.3": "Kiṁsu have sādutaraṁ rasānaṁ, ",
    "sn1.73:1.4": "Kathaṁjīviṁ jīvitamāhu seṭṭhan”ti. ",
    "sn1.73:2.1": "“Saddhīdha vittaṁ purisassa seṭṭhaṁ, ",
    "sn1.73:2.2": "Dhammo suciṇṇo sukhamāvahati; ",
    "sn1.73:2.3": "Saccaṁ have sādutaraṁ rasānaṁ, ",
    "sn1.73:2.4": "Paññājīviṁ jīvitamāhu seṭṭhan”ti. "
  },
  "translation_text": {
    "sn1.73:0.1": "Linked Discourses 1.73 ",
    "sn1.73:0.2": "8. Slain ",
    "sn1.73:0.3": "Wealth ",
    "sn1.73:1.1": "“What’s a person’s best wealth? ",
    "sn1.73:1.2": "What brings happiness when practiced well? ",
    "sn1.73:1.3": "What’s the sweetest taste of all? ",
    "sn1.73:1.4": "The one they say has the best life: how do they live?” ",
    "sn1.73:2.1": "“Faith here is a person’s best wealth. ",
    "sn1.73:2.2": "The teaching brings happiness when practiced well. ",
    "sn1.73:2.3": "Truth is the sweetest taste of all. ",
    "sn1.73:2.4": "The one they say has the best life lives by wisdom.” "
  },
  "variant_text": {
    "sn1.73:1.3": "sādutaraṁ → sādhutaraṁ (sya-all, mr) ",
    "sn1.73:1.4": "Kathaṁjīviṁ → kathaṁjīvī (sya1ed, sya2ed); kiṁsujīviṁ (mr) "
  },
