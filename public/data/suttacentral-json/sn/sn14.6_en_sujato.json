  "root_text": {
    "sn14.6:0.1": "Saṁyutta Nikāya 14.6 ",
    "sn14.6:0.2": "1. Nānattavagga ",
    "sn14.6:0.3": "Bāhiradhātunānattasutta ",
    "sn14.6:1.1": "Sāvatthiyaṁ viharati. ",
    "sn14.6:1.2": "“Dhātunānattaṁ vo, bhikkhave, desessāmi. ",
    "sn14.6:1.3": "Taṁ suṇātha …pe… ",
    "sn14.6:1.4": "katamañca, bhikkhave, dhātunānattaṁ? ",
    "sn14.6:1.5": "Rūpadhātu saddadhātu gandhadhātu rasadhātu phoṭṭhabbadhātu dhammadhātu—",
    "sn14.6:1.6": "idaṁ vuccati, bhikkhave, dhātunānattan”ti. ",
    "sn14.6:1.7": "Chaṭṭhaṁ. "
  },
  "translation_text": {
    "sn14.6:0.1": "Linked Discourses 14.6 ",
    "sn14.6:0.2": "1. Diversity ",
    "sn14.6:0.3": "External Diversity of Elements ",
    "sn14.6:1.1": "At Sāvatthī. ",
    "sn14.6:1.2": "“Mendicants, I will teach you the diversity of elements. ",
    "sn14.6:1.3": "",
    "sn14.6:1.4": "And what is the diversity of elements? ",
    "sn14.6:1.5": "The sight element, the sound element, the smell element, the taste element, the touch element, and the idea element. ",
    "sn14.6:1.6": "This is called the diversity of elements.” "
  },
