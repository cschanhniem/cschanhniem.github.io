  "root_text": {
    "sn23.12:0.1": "Saṁyutta Nikāya 23.12 ",
    "sn23.12:0.2": "2. Dutiyamāravagga ",
    "sn23.12:0.3": "Māradhammasutta ",
    "sn23.12:1.1": "Sāvatthinidānaṁ. ",
    "sn23.12:1.2": "Ekamantaṁ nisinno kho āyasmā rādho bhagavantaṁ etadavoca: ",
    "sn23.12:1.3": "“‘māradhammo, māradhammo’ti, bhante, vuccati. ",
    "sn23.12:1.4": "Katamo nu kho, bhante, māradhammo”ti? ",
    "sn23.12:1.5": "“Rūpaṁ kho, rādha, māradhammo, vedanā māradhammo, saññā māradhammo, saṅkhārā māradhammo, viññāṇaṁ māradhammo. ",
    "sn23.12:1.6": "Evaṁ passaṁ …pe… ",
    "sn23.12:1.7": "nāparaṁ itthattāyāti pajānātī”ti. ",
    "sn23.12:1.8": "Dutiyaṁ. "
  },
  "translation_text": {
    "sn23.12:0.1": "Linked Discourses 23.12 ",
    "sn23.12:0.2": "2. About Māra (2nd) ",
    "sn23.12:0.3": "Subject to Māra ",
    "sn23.12:1.1": "At Sāvatthī. ",
    "sn23.12:1.2": "Seated to one side, Venerable Rādha said to the Buddha: ",
    "sn23.12:1.3": "“Sir, they speak of this thing called ‘subject to Māra’. ",
    "sn23.12:1.4": "What is subject to Māra?” ",
    "sn23.12:1.5": "“Rādha, form is subject to Māra. Feeling, perception, choices, and consciousness are subject to Māra. ",
    "sn23.12:1.6": "Seeing this … ",
    "sn23.12:1.7": "They understand: ‘… there is nothing further for this place.’” "
  },
