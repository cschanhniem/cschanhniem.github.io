  "root_text": {
    "sn37.10:0.1": "Saṁyutta Nikāya 37.10 ",
    "sn37.10:0.2": "1. Paṭhamapeyyālavagga ",
    "sn37.10:0.3": "Dussīlasutta ",
    "sn37.10:1.1": "“Pañcahi, anuruddha, dhammehi samannāgato mātugāmo …pe… nirayaṁ upapajjati. ",
    "sn37.10:1.2": "Katamehi pañcahi? ",
    "sn37.10:1.3": "Assaddho ca hoti, ahiriko ca hoti, anottappī ca hoti, dussīlo ca hoti, duppañño ca hoti—",
    "sn37.10:1.4": "imehi kho, anuruddha, pañcahi dhammehi samannāgato mātugāmo …pe… nirayaṁ upapajjatī”ti. ",
    "sn37.10:1.5": "Dasamaṁ. "
  },
  "translation_text": {
    "sn37.10:0.1": "Linked Discourses 37.10 ",
    "sn37.10:0.2": "1. Abbreviated Texts ",
    "sn37.10:0.3": "Unethical ",
    "sn37.10:1.1": "",
    "sn37.10:1.2": "",
    "sn37.10:1.3": "“… They’re faithless, shameless, imprudent, unethical, and witless. …” ",
    "sn37.10:1.4": ""
  },
