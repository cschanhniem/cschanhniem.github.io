  "root_text": {
    "sn47.42:0.1": "Saṁyutta Nikāya 47.42 ",
    "sn47.42:0.2": "5. Amatavagga ",
    "sn47.42:0.3": "Samudayasutta ",
    "sn47.42:1.1": "“Catunnaṁ, bhikkhave, satipaṭṭhānānaṁ samudayañca atthaṅgamañca desessāmi. ",
    "sn47.42:1.2": "Taṁ suṇātha. ",
    "sn47.42:1.3": "Ko ca, bhikkhave, kāyassa samudayo? ",
    "sn47.42:1.4": "Āhārasamudayā kāyassa samudayo; ",
    "sn47.42:1.5": "āhāranirodhā kāyassa atthaṅgamo. ",
    "sn47.42:1.6": "Phassasamudayā vedanānaṁ samudayo; ",
    "sn47.42:1.7": "phassanirodhā vedanānaṁ atthaṅgamo. ",
    "sn47.42:1.8": "Nāmarūpasamudayā cittassa samudayo; ",
    "sn47.42:1.9": "nāmarūpanirodhā cittassa atthaṅgamo. ",
    "sn47.42:1.10": "Manasikārasamudayā dhammānaṁ samudayo; ",
    "sn47.42:1.11": "manasikāranirodhā dhammānaṁ atthaṅgamo”ti. ",
    "sn47.42:1.12": "Dutiyaṁ. "
  },
  "translation_text": {
    "sn47.42:0.1": "Linked Discourses 47.42 ",
    "sn47.42:0.2": "5. Freedom From Death ",
    "sn47.42:0.3": "Origin ",
    "sn47.42:1.1": "“Mendicants, I will teach you the origin and the ending of the four kinds of mindfulness meditation. ",
    "sn47.42:1.2": "Listen … ",
    "sn47.42:1.3": "And what is the origin of the body? ",
    "sn47.42:1.4": "The body originates from fuel. ",
    "sn47.42:1.5": "When fuel ceases, the body ends. ",
    "sn47.42:1.6": "Feelings originate from contact. ",
    "sn47.42:1.7": "When contact ceases, feelings end. ",
    "sn47.42:1.8": "The mind originates from name and form. ",
    "sn47.42:1.9": "When name and form cease, the mind ends. ",
    "sn47.42:1.10": "Principles originate from application of mind. ",
    "sn47.42:1.11": "When application of mind ends, principles end.” "
  },
