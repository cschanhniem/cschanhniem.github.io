  "root_text": {
    "sn1.62:0.1": "Saṁyutta Nikāya 1.62 ",
    "sn1.62:0.2": "7. Addhavagga ",
    "sn1.62:0.3": "Cittasutta ",
    "sn1.62:1.1": "“Kenassu nīyati loko, ",
    "sn1.62:1.2": "kenassu parikassati; ",
    "sn1.62:1.3": "Kissassu ekadhammassa, ",
    "sn1.62:1.4": "sabbeva vasamanvagū”ti. ",
    "sn1.62:2.1": "“Cittena nīyati loko, ",
    "sn1.62:2.2": "cittena parikassati; ",
    "sn1.62:2.3": "Cittassa ekadhammassa, ",
    "sn1.62:2.4": "sabbeva vasamanvagū”ti. "
  },
  "translation_text": {
    "sn1.62:0.1": "Linked Discourses 1.62 ",
    "sn1.62:0.2": "7. Overcome ",
    "sn1.62:0.3": "Mind ",
    "sn1.62:1.1": "“What leads the world on? ",
    "sn1.62:1.2": "What drags it around? ",
    "sn1.62:1.3": "What is the one thing ",
    "sn1.62:1.4": "that has everything under its sway?” ",
    "sn1.62:2.1": "“The mind leads the world on. ",
    "sn1.62:2.2": "The mind drags it around. ",
    "sn1.62:2.3": "Mind is the one thing ",
    "sn1.62:2.4": "that has everything under its sway.” "
  },
