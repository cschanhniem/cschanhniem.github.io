  "root_text": {
    "sn22.20:0.1": "Saṁyutta Nikāya 22.20 ",
    "sn22.20:0.2": "2. Aniccavagga ",
    "sn22.20:0.3": "Sahetuanattasutta ",
    "sn22.20:1.1": "Sāvatthinidānaṁ. ",
    "sn22.20:1.2": "“Rūpaṁ, bhikkhave, anattā. ",
    "sn22.20:1.3": "Yopi hetu yopi paccayo rūpassa uppādāya, sopi anattā. ",
    "sn22.20:1.4": "Anattasambhūtaṁ, bhikkhave, rūpaṁ kuto attā bhavissati. ",
    "sn22.20:1.5": "Vedanā anattā … ",
    "sn22.20:1.6": "saññā anattā … ",
    "sn22.20:1.7": "saṅkhārā anattā … ",
    "sn22.20:1.8": "viññāṇaṁ anattā. ",
    "sn22.20:1.9": "Yopi hetu yopi paccayo viññāṇassa uppādāya, sopi anattā. ",
    "sn22.20:1.10": "Anattasambhūtaṁ, bhikkhave, viññāṇaṁ kuto attā bhavissati. ",
    "sn22.20:1.11": "Evaṁ passaṁ …pe… ",
    "sn22.20:1.12": "nāparaṁ itthattāyā’ti pajānātī”ti. ",
    "sn22.20:1.13": "Navamaṁ. "
  },
  "translation_text": {
    "sn22.20:0.1": "Linked Discourses 22.20 ",
    "sn22.20:0.2": "2. Impermanence ",
    "sn22.20:0.3": "Not-Self With Its Cause ",
    "sn22.20:1.1": "At Sāvatthī. ",
    "sn22.20:1.2": "“Mendicants, form is not-self. ",
    "sn22.20:1.3": "The cause and reason that gives rise to form is also not-self. ",
    "sn22.20:1.4": "Since form is produced by what is not-self, how could it be self? ",
    "sn22.20:1.5": "Feeling is not-self … ",
    "sn22.20:1.6": "Perception is not-self … ",
    "sn22.20:1.7": "Choices are not-self … ",
    "sn22.20:1.8": "Consciousness is not-self. ",
    "sn22.20:1.9": "The cause and reason that gives rise to consciousness is also not-self. ",
    "sn22.20:1.10": "Since consciousness is produced by what is not-self, how could it be self? ",
    "sn22.20:1.11": "Seeing this … ",
    "sn22.20:1.12": "They understand: ‘… there is nothing further for this place.’” "
  },
  "variant_text": {
    "sn22.20:0.3": "Sahetuanattasutta → tatiyahetusuttaṁ (bj); hetu 3 (pts1ed) "
  },
