  "root_text": {
    "sn46.72:0.1": "Saṁyutta Nikāya 46.72 ",
    "sn46.72:0.2": "8. Nirodhavagga ",
    "sn46.72:0.3": "Dukkhasutta ",
    "sn46.72:1.1": "“Anicce dukkhasaññā, bhikkhave …pe…” ",
    "sn46.72:1.2": "chaṭṭhaṁ. "
  },
  "translation_text": {
    "sn46.72:0.1": "Linked Discourses 46.72 ",
    "sn46.72:0.2": "8. Cessation ",
    "sn46.72:0.3": "Suffering in Impermanence ",
    "sn46.72:1.1": "“Mendicants, when the perception of suffering in impermanence is developed and cultivated it’s very fruitful and beneficial. …” "
  },
  "variant_text": {
    "sn46.72:0.3": "Dukkhasutta → anicce dukkhasuttāni (bj) "
  },
