  "root_text": {
    "sn28.8:0.1": "Saṁyutta Nikāya 28.8 ",
    "sn28.8:0.2": "1. Sāriputtavagga ",
    "sn28.8:0.3": "Nevasaññānāsaññāyatanasutta ",
    "sn28.8:1.1": "Sāvatthinidānaṁ. ",
    "sn28.8:1.2": "Atha kho āyasmā sāriputto …pe… ",
    "sn28.8:1.3": "“idhāhaṁ, āvuso, ākiñcaññāyatanaṁ samatikkamma nevasaññānāsaññāyatanaṁ upasampajja viharāmi …pe… ",
    "sn28.8:1.4": "vuṭṭhitoti vā”ti. ",
    "sn28.8:1.5": "Aṭṭhamaṁ. "
  },
  "translation_text": {
    "sn28.8:0.1": "Linked Discourses 28.8 ",
    "sn28.8:0.2": "1. With Sāriputta ",
    "sn28.8:0.3": "The Dimension of Neither Perception Nor Non-Perception ",
    "sn28.8:1.1": "At Sāvatthī. ",
    "sn28.8:1.2": "Venerable Ānanda saw Venerable Sāriputta … ",
    "sn28.8:1.3": "“Reverend, going totally beyond the dimension of nothingness, I entered and remained in the dimension of neither perception nor non-perception. …” … ",
    "sn28.8:1.4": ""
  },
  "variant_text": {
    "sn28.8:0.3": "Nevasaññānāsaññāyatanasutta → saññī (pts1ed) "
  },
