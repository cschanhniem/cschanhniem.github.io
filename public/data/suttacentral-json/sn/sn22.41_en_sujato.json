  "root_text": {
    "sn22.41:0.1": "Saṁyutta Nikāya 22.41 ",
    "sn22.41:0.2": "4. Natumhākavagga ",
    "sn22.41:0.3": "Tatiyaanudhammasutta ",
    "sn22.41:1.1": "Sāvatthinidānaṁ. ",
    "sn22.41:1.2": "“Dhammānudhammappaṭipannassa, bhikkhave, bhikkhuno ayamanudhammo hoti yaṁ rūpe dukkhānupassī vihareyya …pe… ",
    "sn22.41:1.3": "‘parimuccati dukkhasmā’ti vadāmī”ti. ",
    "sn22.41:1.4": "Navamaṁ. "
  },
  "translation_text": {
    "sn22.41:0.1": "Linked Discourses 22.41 ",
    "sn22.41:0.2": "4. It’s Not Yours ",
    "sn22.41:0.3": "In Line With the Teaching (3rd) ",
    "sn22.41:1.1": "At Sāvatthī. ",
    "sn22.41:1.2": "“Mendicants, when a mendicant is practicing in line with the teaching, this is what’s in line with the teaching. They should meditate observing suffering in form, feeling, perception, choices, and consciousness. … ",
    "sn22.41:1.3": "They’re freed from suffering, I say.” "
  },
