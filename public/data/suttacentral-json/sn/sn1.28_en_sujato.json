  "root_text": {
    "sn1.28:0.1": "Saṁyutta Nikāya 1.28 ",
    "sn1.28:0.2": "3. Sattivagga ",
    "sn1.28:0.3": "Mahaddhanasutta ",
    "sn1.28:1.1": "“Mahaddhanā mahābhogā, ",
    "sn1.28:1.2": "raṭṭhavantopi khattiyā; ",
    "sn1.28:1.3": "Aññamaññābhigijjhanti, ",
    "sn1.28:1.4": "kāmesu analaṅkatā. ",
    "sn1.28:2.1": "Tesu ussukkajātesu, ",
    "sn1.28:2.2": "bhavasotānusārisu; ",
    "sn1.28:2.3": "Kedha taṇhaṁ pajahiṁsu, ",
    "sn1.28:2.4": "ke lokasmiṁ anussukā”ti. ",
    "sn1.28:3.1": "“Hitvā agāraṁ pabbajitā, ",
    "sn1.28:3.2": "hitvā puttaṁ pasuṁ piyaṁ; ",
    "sn1.28:3.3": "Hitvā rāgañca dosañca, ",
    "sn1.28:3.4": "avijjañca virājiya; ",
    "sn1.28:3.5": "Khīṇāsavā arahanto, ",
    "sn1.28:3.6": "te lokasmiṁ anussukā”ti. "
  },
  "translation_text": {
    "sn1.28:0.1": "Linked Discourses 1.28 ",
    "sn1.28:0.2": "3. A Sword ",
    "sn1.28:0.3": "Affluent ",
    "sn1.28:1.1": "“The affluent and the wealthy, ",
    "sn1.28:1.2": "even the aristocrats who rule the land, ",
    "sn1.28:1.3": "are jealous of each other, ",
    "sn1.28:1.4": "insatiable in sensual pleasures. ",
    "sn1.28:2.1": "Among those of such an avid nature, ",
    "sn1.28:2.2": "flowing along the stream of lives, ",
    "sn1.28:2.3": "who here has given up craving? ",
    "sn1.28:2.4": "Who in the world is not avid?” ",
    "sn1.28:3.1": "“Having given up their home, their child, their cattle, ",
    "sn1.28:3.2": "and all that they love, they went forth. ",
    "sn1.28:3.3": "Having given up desire and hate, ",
    "sn1.28:3.4": "having dispelled ignorance, ",
    "sn1.28:3.5": "the perfected ones with defilements ended—",
    "sn1.28:3.6": "they in the world are not avid.” "
  },
  "variant_text": {
    "sn1.28:2.3": "Kedha taṇhaṁ → rodhataṇhaṁ (sya-all, km); gedhataṇhaṁ (pts1ed, pts2ed, mr) | pajahiṁsu → pavāhiṁsu (sya-all, km, mr) "
  },
