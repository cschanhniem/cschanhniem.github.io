  "root_text": {
    "sn25.5:0.1": "Saṁyutta Nikāya 25.5 ",
    "sn25.5:0.2": "1. Cakkhuvagga ",
    "sn25.5:0.3": "Samphassajasutta ",
    "sn25.5:1.1": "Sāvatthinidānaṁ. ",
    "sn25.5:1.2": "“Cakkhusamphassajā, bhikkhave, vedanā aniccā vipariṇāmī aññathābhāvī; ",
    "sn25.5:1.3": "sotasamphassajā vedanā …pe… ",
    "sn25.5:1.4": "ghānasamphassajā vedanā …pe… ",
    "sn25.5:1.5": "jivhāsamphassajā vedanā …pe… ",
    "sn25.5:1.6": "kāyasamphassajā vedanā …pe… ",
    "sn25.5:1.7": "manosamphassajā vedanā aniccā vipariṇāmī aññathābhāvī. ",
    "sn25.5:1.8": "Yo, bhikkhave, ime dhamme evaṁ saddahati adhimuccati, ayaṁ vuccati ‘saddhānusārī …pe… ",
    "sn25.5:1.9": "sambodhiparāyano’”ti. ",
    "sn25.5:1.10": "Pañcamaṁ. "
  },
  "translation_text": {
    "sn25.5:0.1": "Linked Discourses 25.5 ",
    "sn25.5:0.2": "1. The Eye ",
    "sn25.5:0.3": "Feeling ",
    "sn25.5:1.1": "At Sāvatthī. ",
    "sn25.5:1.2": "“Mendicants, feeling born of eye contact is impermanent, decaying, and perishing. ",
    "sn25.5:1.3": "Feeling born of ear contact, ",
    "sn25.5:1.4": "feeling born of nose contact, ",
    "sn25.5:1.5": "feeling born of tongue contact, ",
    "sn25.5:1.6": "feeling born of body contact, ",
    "sn25.5:1.7": "and feeling born of mind contact are impermanent, decaying, and perishing. ",
    "sn25.5:1.8": "Someone who has faith and confidence in these teachings is called a follower by faith. …” ",
    "sn25.5:1.9": ""
  },
  "variant_text": {
    "sn25.5:0.3": "Samphassajasutta → vedanāsuttaṁ (bj); vedanāya (pts1ed); samphassajāsutta (csp1ed, csp2ed) "
  },
