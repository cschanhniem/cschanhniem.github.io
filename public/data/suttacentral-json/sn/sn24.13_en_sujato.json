  "root_text": {
    "sn24.13:0.1": "Saṁyutta Nikāya 24.13 ",
    "sn24.13:0.2": "1. Sotāpattivagga ",
    "sn24.13:0.3": "Taṁjīvaṁtaṁsarīraṁsutta ",
    "sn24.13:1.1": "Sāvatthinidānaṁ. ",
    "sn24.13:1.2": "“Kismiṁ nu kho, bhikkhave, sati, kiṁ upādāya, kiṁ abhinivissa evaṁ diṭṭhi uppajjati: ",
    "sn24.13:1.3": "‘taṁ jīvaṁ taṁ sarīran’”ti? ",
    "sn24.13:1.4": "“Bhagavaṁmūlakā no, bhante, dhammā …pe… ",
    "sn24.13:1.5": "niyato sambodhiparāyano”ti. ",
    "sn24.13:1.6": "Terasamaṁ. "
  },
  "translation_text": {
    "sn24.13:0.1": "Linked Discourses 24.13 ",
    "sn24.13:0.2": "1. Stream-Entry ",
    "sn24.13:0.3": "The Soul and the Body are One and the Same ",
    "sn24.13:1.1": "At Sāvatthī. ",
    "sn24.13:1.2": "“Mendicants, when what exists, because of grasping what and insisting on what, does the view arise: ",
    "sn24.13:1.3": "‘The soul and the body are one and the same’?” … ",
    "sn24.13:1.4": "",
    "sn24.13:1.5": ""
  },
  "variant_text": {
    "sn24.13:0.3": "Taṁjīvaṁtaṁsarīraṁsutta → taṁjīvaṁtaṁsarīrasuttaṁ (bj) "
  },
