  "root_text": {
    "sn45.36:0.1": "Saṁyutta Nikāya 45.36 ",
    "sn45.36:0.2": "4. Paṭipattivagga ",
    "sn45.36:0.3": "Dutiyasāmaññasutta ",
    "sn45.36:1.1": "Sāvatthinidānaṁ. ",
    "sn45.36:1.2": "“Sāmaññañca vo, bhikkhave, desessāmi, sāmaññatthañca. ",
    "sn45.36:1.3": "Taṁ suṇātha. ",
    "sn45.36:1.4": "Katamañca kho, bhikkhave, sāmaññaṁ? ",
    "sn45.36:1.5": "Ayameva ariyo aṭṭhaṅgiko maggo, seyyathidaṁ—",
    "sn45.36:1.6": "sammādiṭṭhi …pe… sammāsamādhi. ",
    "sn45.36:1.7": "Idaṁ vuccati, bhikkhave, sāmaññaṁ. ",
    "sn45.36:1.8": "Katamo ca, bhikkhave, sāmaññattho? ",
    "sn45.36:1.9": "Yo kho, bhikkhave, rāgakkhayo dosakkhayo mohakkhayo—",
    "sn45.36:1.10": "ayaṁ vuccati, bhikkhave, sāmaññattho”ti. ",
    "sn45.36:1.11": "Chaṭṭhaṁ. "
  },
  "translation_text": {
    "sn45.36:0.1": "Linked Discourses 45.36 ",
    "sn45.36:0.2": "4. Practice ",
    "sn45.36:0.3": "The Ascetic Life (2nd) ",
    "sn45.36:1.1": "At Sāvatthī. ",
    "sn45.36:1.2": "“Mendicants, I will teach you the ascetic life and the goal of the ascetic life. ",
    "sn45.36:1.3": "Listen … ",
    "sn45.36:1.4": "And what is the ascetic life? ",
    "sn45.36:1.5": "It is simply this noble eightfold path, that is: ",
    "sn45.36:1.6": "right view, right thought, right speech, right action, right livelihood, right effort, right mindfulness, and right immersion. ",
    "sn45.36:1.7": "This is called the ascetic life. ",
    "sn45.36:1.8": "And what is the goal of the ascetic life? ",
    "sn45.36:1.9": "The ending of greed, hate, and delusion. ",
    "sn45.36:1.10": "This is called the goal of the ascetic life.” "
  },
