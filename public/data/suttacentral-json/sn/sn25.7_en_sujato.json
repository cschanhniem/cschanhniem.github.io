  "root_text": {
    "sn25.7:0.1": "Saṁyutta Nikāya 25.7 ",
    "sn25.7:0.2": "1. Cakkhuvagga ",
    "sn25.7:0.3": "Rūpasañcetanāsutta ",
    "sn25.7:1.1": "Sāvatthinidānaṁ. ",
    "sn25.7:1.2": "“Rūpasañcetanā, bhikkhave, aniccā vipariṇāmī aññathābhāvī; ",
    "sn25.7:1.3": "saddasañcetanā … ",
    "sn25.7:1.4": "gandhasañcetanā … ",
    "sn25.7:1.5": "rasasañcetanā … ",
    "sn25.7:1.6": "phoṭṭhabbasañcetanā … ",
    "sn25.7:1.7": "dhammasañcetanā aniccā vipariṇāmī aññathābhāvī. ",
    "sn25.7:1.8": "Yo, bhikkhave, ime dhamme evaṁ saddahati adhimuccati, ayaṁ vuccati ‘saddhānusārī …pe… ",
    "sn25.7:1.9": "sambodhiparāyano’”ti. ",
    "sn25.7:1.10": "Sattamaṁ. "
  },
  "translation_text": {
    "sn25.7:0.1": "Linked Discourses 25.7 ",
    "sn25.7:0.2": "1. The Eye ",
    "sn25.7:0.3": "Intention ",
    "sn25.7:1.1": "At Sāvatthī. ",
    "sn25.7:1.2": "“Mendicants, intention regarding sights is impermanent, decaying, and perishing. ",
    "sn25.7:1.3": "Intention regarding sounds, ",
    "sn25.7:1.4": "intention regarding smells, ",
    "sn25.7:1.5": "intention regarding tastes, ",
    "sn25.7:1.6": "intention regarding touches, ",
    "sn25.7:1.7": "and intentions regarding ideas are impermanent, decaying, and perishing. ",
    "sn25.7:1.8": "Someone who has faith and confidence in these teachings is called a follower by faith. …” ",
    "sn25.7:1.9": ""
  },
  "variant_text": {
    "sn25.7:0.3": "Rūpasañcetanāsutta → cetanāsuttaṁ (bj); cetanā (pts1ed) "
  },
