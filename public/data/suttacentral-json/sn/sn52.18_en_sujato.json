  "root_text": {
    "sn52.18:0.1": "Saṁyutta Nikāya 52.18 ",
    "sn52.18:0.2": "2. Dutiyavagga ",
    "sn52.18:0.3": "Nānādhātusutta ",
    "sn52.18:1.1": "“Imesañca panāhaṁ, āvuso, catunnaṁ satipaṭṭhānānaṁ bhāvitattā bahulīkatattā anekadhātunānādhātulokaṁ yathābhūtaṁ pajānāmī”ti. ",
    "sn52.18:1.2": "Aṭṭhamaṁ. "
  },
  "translation_text": {
    "sn52.18:0.1": "Linked Discourses 52.18 ",
    "sn52.18:0.2": "2. A Thousand ",
    "sn52.18:0.3": "Diverse Elements ",
    "sn52.18:1.1": "“… And it’s because of developing and cultivating these four kinds of mindfulness meditation that I truly understand the world with its many and diverse elements.” "
  },
  "variant_text": {
    "sn52.18:0.3": "Nānādhātusutta → anekadhātusuttaṁ (bj); loka (pts1ed) "
  },
