  "root_text": {
    "sn35.207-209:0.1": "Saṁyutta Nikāya 35.207–209 ",
    "sn35.207-209:0.2": "17. Saṭṭhipeyyālavagga ",
    "sn35.207-209:0.3": "Ajjhattātītādiyaṁdukkhasutta ",
    "sn35.207-209:1.1": "“Cakkhu, bhikkhave, dukkhaṁ atītaṁ anāgataṁ paccuppannaṁ. ",
    "sn35.207-209:1.2": "Yaṁ dukkhaṁ, tadanattā. ",
    "sn35.207-209:1.3": "Yadanattā, taṁ ‘netaṁ mama, nesohamasmi, na meso attā’ti evametaṁ yathābhūtaṁ sammappaññāya daṭṭhabbaṁ …pe… ",
    "sn35.207-209:1.4": "jivhā dukkhā …pe… ",
    "sn35.207-209:1.5": "mano dukkho atīto anāgato paccuppanno. ",
    "sn35.207-209:1.6": "Yaṁ dukkhaṁ, tadanattā. ",
    "sn35.207-209:1.7": "Yadanattā, taṁ ‘netaṁ mama, nesohamasmi, na meso attā’ti evametaṁ yathābhūtaṁ sammappaññāya daṭṭhabbaṁ. ",
    "sn35.207-209:1.8": "Evaṁ passaṁ …pe… ",
    "sn35.207-209:1.9": "nāparaṁ itthattāyāti pajānātī”ti. "
  },
  "translation_text": {
    "sn35.207-209:0.1": "Linked Discourses 35.207–209 ",
    "sn35.207-209:0.2": "17. Sixty Abbreviated Texts ",
    "sn35.207-209:0.3": "The Interior and What’s Suffering in the Three Times ",
    "sn35.207-209:1.1": "“Mendicants, in the past … future … present the eye, ear, nose, tongue, body, and mind are suffering. ",
    "sn35.207-209:1.2": "What’s suffering is not-self …” ",
