  "root_text": {
    "sn27.3:0.1": "Saṁyutta Nikāya 27.3 ",
    "sn27.3:0.2": "1. Kilesavagga ",
    "sn27.3:0.3": "Viññāṇasutta ",
    "sn27.3:1.1": "Sāvatthinidānaṁ. ",
    "sn27.3:1.2": "“Yo, bhikkhave, cakkhuviññāṇasmiṁ chandarāgo, cittasseso upakkileso. ",
    "sn27.3:1.3": "Yo sotaviññāṇasmiṁ … ",
    "sn27.3:1.4": "yo ghānaviññāṇasmiṁ … ",
    "sn27.3:1.5": "yo jivhāviññāṇasmiṁ … ",
    "sn27.3:1.6": "yo kāyaviññāṇasmiṁ … ",
    "sn27.3:1.7": "yo manoviññāṇasmiṁ chandarāgo, cittasseso upakkileso. ",
    "sn27.3:1.8": "Yato kho, bhikkhave, bhikkhuno imesu chasu ṭhānesu cetaso upakkileso pahīno hoti, nekkhammaninnañcassa cittaṁ hoti. ",
    "sn27.3:1.9": "Nekkhammaparibhāvitaṁ cittaṁ kammaniyaṁ khāyati, abhiññā sacchikaraṇīyesu dhammesū”ti. ",
    "sn27.3:1.10": "Tatiyaṁ. "
  },
  "translation_text": {
    "sn27.3:0.1": "Linked Discourses 27.3 ",
    "sn27.3:0.2": "1. Corruptions ",
    "sn27.3:0.3": "Consciousness ",
    "sn27.3:1.1": "At Sāvatthī. ",
    "sn27.3:1.2": "“Mendicants, desire and greed for eye consciousness, ",
    "sn27.3:1.3": "ear consciousness, ",
    "sn27.3:1.4": "nose consciousness, ",
    "sn27.3:1.5": "tongue consciousness, ",
    "sn27.3:1.6": "body consciousness, ",
    "sn27.3:1.7": "or mind consciousness is a corruption of the mind. ",
    "sn27.3:1.8": "When a mendicant has given up mental corruption in these six cases, their mind inclines to renunciation. ",
    "sn27.3:1.9": "A mind imbued with renunciation is said to be fit for work regarding anything that can be realized by insight.” "
  },
