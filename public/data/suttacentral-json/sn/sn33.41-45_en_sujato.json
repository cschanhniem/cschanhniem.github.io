  "root_text": {
    "sn33.41-45:0.1": "Saṁyutta Nikāya 33.41–45 ",
    "sn33.41-45:0.2": "1. Vacchagottavagga ",
    "sn33.41-45:0.3": "Rūpaasamapekkhaṇādisuttapañcaka ",
    "sn33.41-45:1.1": "Sāvatthinidānaṁ. ",
    "sn33.41-45:1.2": "“Rūpe kho, vaccha, asamapekkhaṇā …pe… viññāṇe kho, vaccha, asamapekkhaṇā …pe…. ",
    "sn33.41-45:1.3": "Pañcacattālīsamaṁ. "
  },
  "translation_text": {
    "sn33.41-45:0.1": "Linked Discourses 33.41–45 ",
    "sn33.41-45:0.2": "1. With Vacchagotta ",
    "sn33.41-45:0.3": "Five Discourses on Not Examining Form, Etc. ",
    "sn33.41-45:1.1": "At Sāvatthī. ",
    "sn33.41-45:1.2": "“Vaccha, it is because of not examining form …” "
  },
