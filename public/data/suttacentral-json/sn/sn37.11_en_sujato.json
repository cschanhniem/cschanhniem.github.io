  "root_text": {
    "sn37.11:0.1": "Saṁyutta Nikāya 37.11 ",
    "sn37.11:0.2": "1. Paṭhamapeyyālavagga ",
    "sn37.11:0.3": "Appassutasutta ",
    "sn37.11:1.1": "“Pañcahi, anuruddha, dhammehi samannāgato mātugāmo …pe… nirayaṁ upapajjati. ",
    "sn37.11:1.2": "Katamehi pañcahi? ",
    "sn37.11:1.3": "Assaddho ca hoti, ahiriko ca hoti, anottappī ca hoti, appassuto ca hoti, duppañño ca hoti—",
    "sn37.11:1.4": "imehi kho, anuruddha, pañcahi dhammehi samannāgato mātugāmo …pe… nirayaṁ upapajjatī”ti. ",
    "sn37.11:1.5": "Ekādasamaṁ. "
  },
  "translation_text": {
    "sn37.11:0.1": "Linked Discourses 37.11 ",
    "sn37.11:0.2": "1. Abbreviated Texts ",
    "sn37.11:0.3": "Unlearned ",
    "sn37.11:1.1": "",
    "sn37.11:1.2": "",
    "sn37.11:1.3": "“… They’re faithless, shameless, imprudent, unlearned, and witless. …” ",
    "sn37.11:1.4": ""
  },
