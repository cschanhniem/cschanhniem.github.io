  "root_text": {
    "sn45.172:0.1": "Saṁyutta Nikāya 45.172 ",
    "sn45.172:0.2": "14. Oghavagga ",
    "sn45.172:0.3": "Yogasutta ",
    "sn45.172:1.1": "“Cattārome, bhikkhave, yogā. ",
    "sn45.172:1.2": "Katame cattāro? ",
    "sn45.172:1.3": "Kāmayogo, bhavayogo, diṭṭhiyogo avijjāyogo—",
    "sn45.172:1.4": "ime kho, bhikkhave, cattāro yogā. ",
    "sn45.172:1.5": "Imesaṁ kho, bhikkhave, catunnaṁ yogānaṁ abhiññāya pariññāya parikkhayāya pahānāya …pe… ayaṁ ariyo aṭṭhaṅgiko maggo bhāvetabbo”ti. ",
    "sn45.172:1.6": "Dutiyaṁ. "
  },
  "translation_text": {
    "sn45.172:0.1": "Linked Discourses 45.172 ",
    "sn45.172:0.2": "14. Floods ",
    "sn45.172:0.3": "Yokes ",
    "sn45.172:1.1": "“Mendicants, there are these four yokes. ",
    "sn45.172:1.2": "What four? ",
    "sn45.172:1.3": "The yokes of sensual pleasures, future lives, views, and ignorance. ",
    "sn45.172:1.4": "These are the four yokes. ",
    "sn45.172:1.5": "The noble eightfold path should be developed for the direct knowledge, complete understanding, finishing, and giving up of these four yokes.” "
  },
