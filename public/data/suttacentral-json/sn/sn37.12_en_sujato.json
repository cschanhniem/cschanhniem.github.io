  "root_text": {
    "sn37.12:0.1": "Saṁyutta Nikāya 37.12 ",
    "sn37.12:0.2": "1. Paṭhamapeyyālavagga ",
    "sn37.12:0.3": "Kusītasutta ",
    "sn37.12:1.1": "“Pañcahi, anuruddha, dhammehi samannāgato mātugāmo …pe… nirayaṁ upapajjati. ",
    "sn37.12:1.2": "Katamehi pañcahi? ",
    "sn37.12:1.3": "Assaddho ca hoti, ahiriko ca hoti, anottappī ca hoti, kusīto ca hoti, duppañño ca hoti—",
    "sn37.12:1.4": "imehi kho, anuruddha, pañcahi dhammehi samannāgato mātugāmo …pe… apāyaṁ duggatiṁ vinipātaṁ nirayaṁ upapajjatī”ti. ",
    "sn37.12:1.5": "Dvādasamaṁ. "
  },
  "translation_text": {
    "sn37.12:0.1": "Linked Discourses 37.12 ",
    "sn37.12:0.2": "1. Abbreviated Texts ",
    "sn37.12:0.3": "Lazy ",
    "sn37.12:1.1": "",
    "sn37.12:1.2": "",
    "sn37.12:1.3": "“… They’re faithless, shameless, imprudent, lazy, and witless. …” ",
    "sn37.12:1.4": ""
  },
