  "root_text": {
    "sn22.148:0.1": "Saṁyutta Nikāya 22.148 ",
    "sn22.148:0.2": "14. Kukkuḷavagga ",
    "sn22.148:0.3": "Dukkhānupassīsutta ",
    "sn22.148:1.1": "Sāvatthinidānaṁ. ",
    "sn22.148:1.2": "“Saddhāpabbajitassa, bhikkhave, kulaputtassa ayamanudhammo hoti—",
    "sn22.148:1.3": "yaṁ rūpe dukkhānupassī vihareyya. ",
    "sn22.148:1.4": "Vedanāya … ",
    "sn22.148:1.5": "saññāya … ",
    "sn22.148:1.6": "saṅkhāresu … ",
    "sn22.148:1.7": "viññāṇe dukkhānupassī vihareyya …pe… ",
    "sn22.148:1.8": "‘parimuccati dukkhasmā’ti vadāmī”ti. ",
    "sn22.148:1.9": "Terasamaṁ. "
  },
  "translation_text": {
    "sn22.148:0.1": "Linked Discourses 22.148 ",
    "sn22.148:0.2": "14. Burning Chaff ",
    "sn22.148:0.3": "Observing Suffering ",
    "sn22.148:1.1": "At Sāvatthī. ",
    "sn22.148:1.2": "“Mendicants, when a gentleman has gone forth out of faith, this is what’s in line with the teaching. ",
    "sn22.148:1.3": "They should meditate observing suffering in form, ",
    "sn22.148:1.4": "feeling, ",
    "sn22.148:1.5": "perception, ",
    "sn22.148:1.6": "choices, ",
    "sn22.148:1.7": "and consciousness. … ",
    "sn22.148:1.8": "They’re freed from suffering, I say.” "
  },
