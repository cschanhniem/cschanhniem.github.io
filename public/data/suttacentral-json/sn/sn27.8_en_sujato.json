  "root_text": {
    "sn27.8:0.1": "Saṁyutta Nikāya 27.8 ",
    "sn27.8:0.2": "1. Kilesavagga ",
    "sn27.8:0.3": "Taṇhāsutta ",
    "sn27.8:1.1": "Sāvatthinidānaṁ. ",
    "sn27.8:1.2": "“Yo, bhikkhave, rūpataṇhāya chandarāgo, cittasseso upakkileso. ",
    "sn27.8:1.3": "Yo saddataṇhāya … ",
    "sn27.8:1.4": "yo gandhataṇhāya … ",
    "sn27.8:1.5": "yo rasataṇhāya … ",
    "sn27.8:1.6": "yo phoṭṭhabbataṇhāya … ",
    "sn27.8:1.7": "yo dhammataṇhāya chandarāgo, cittasseso upakkileso. ",
    "sn27.8:1.8": "Yato kho, bhikkhave, bhikkhuno …pe… ",
    "sn27.8:1.9": "abhiññā sacchikaraṇīyesu dhammesū”ti. ",
    "sn27.8:1.10": "Aṭṭhamaṁ. "
  },
  "translation_text": {
    "sn27.8:0.1": "Linked Discourses 27.8 ",
    "sn27.8:0.2": "1. Corruptions ",
    "sn27.8:0.3": "Craving ",
    "sn27.8:1.1": "At Sāvatthī. ",
    "sn27.8:1.2": "“Mendicants, desire and greed for craving for sights, ",
    "sn27.8:1.3": "craving for sounds, ",
    "sn27.8:1.4": "craving for smells, ",
    "sn27.8:1.5": "craving for tastes, ",
    "sn27.8:1.6": "craving for touches, ",
    "sn27.8:1.7": "or craving for ideas is a corruption of the mind. …” ",
    "sn27.8:1.8": "",
    "sn27.8:1.9": ""
  },
