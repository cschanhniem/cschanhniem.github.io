  "root_text": {
    "sn56.70:0.1": "Saṁyutta Nikāya 56.70 ",
    "sn56.70:0.2": "7. Paṭhamaāmakadhaññapeyyālavagga ",
    "sn56.70:0.3": "Pacāyikasutta ",
    "sn56.70:1.1": "… “Evameva kho, bhikkhave, appakā te sattā ye kule jeṭṭhāpacāyino; atha kho eteva bahutarā sattā ye kule ajeṭṭhāpacāyinoti …pe…. ",
    "sn56.70:1.2": "Dasamaṁ. ",
    "sn56.70:1.3": "Paṭhamaāmakadhaññapeyyālavaggo sattamo. ",
    "sn56.70:2.0": "Tassuddānaṁ ",
    "sn56.70:2.1": "Aññatra paccantaṁ paññā, ",
    "sn56.70:2.2": "Surāmerayaodakā; ",
    "sn56.70:2.3": "Matteyya petteyyā cāpi, ",
    "sn56.70:2.4": "Sāmaññaṁ brahmapacāyikanti. "
  },
  "translation_text": {
    "sn56.70:0.1": "Linked Discourses 56.70 ",
    "sn56.70:0.2": "7. Abbreviated Texts on Raw Grain ",
    "sn56.70:0.3": "Honor the Elders ",
    "sn56.70:1.1": "“… the sentient beings who honor the elders in the family are few, while those who don’t are many. …” ",
