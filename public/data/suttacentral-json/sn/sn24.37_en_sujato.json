  "root_text": {
    "sn24.37:0.1": "Saṁyutta Nikāya 24.37 ",
    "sn24.37:0.2": "2. Dutiyagamanavagga ",
    "sn24.37:0.3": "Rūpīattāsutta ",
    "sn24.37:1.1": "Sāvatthinidānaṁ. ",
    "sn24.37:1.2": "“Kismiṁ nu kho, bhikkhave, sati, kiṁ upādāya, kiṁ abhinivissa evaṁ diṭṭhi uppajjati: ",
    "sn24.37:1.3": "‘rūpī attā hoti arogo paraṁ maraṇā’”ti? ",
    "sn24.37:1.4": "“Bhagavaṁmūlakā no, bhante, dhammā …pe… ",
    "sn24.37:2.1": "“Rūpe kho, bhikkhave, sati, rūpaṁ upādāya, rūpaṁ abhinivissa evaṁ diṭṭhi uppajjati: ",
    "sn24.37:2.2": "‘rūpī attā hoti arogo paraṁ maraṇā’ti. ",
    "sn24.37:2.3": "Vedanāya sati …pe… ",
    "sn24.37:2.4": "saññāya sati … ",
    "sn24.37:2.5": "saṅkhāresu sati … ",
    "sn24.37:2.6": "viññāṇe sati, viññāṇaṁ upādāya, viññāṇaṁ abhinivissa evaṁ diṭṭhi uppajjati: ",
    "sn24.37:2.7": "‘rūpī attā hoti arogo paraṁ maraṇā’ti. ",
    "sn24.37:3.1": "Taṁ kiṁ maññatha, bhikkhave, rūpaṁ niccaṁ vā aniccaṁ vā”ti? ",
    "sn24.37:3.2": "“Aniccaṁ, bhante” …pe… ",
    "sn24.37:3.3": "vipariṇāmadhammaṁ, api nu taṁ anupādāya evaṁ diṭṭhi uppajjeyya: ",
    "sn24.37:3.4": "‘rūpī attā hoti arogo paraṁ maraṇā’”ti? ",
    "sn24.37:3.5": "“No hetaṁ, bhante”. ",
    "sn24.37:3.6": "“Iti kho, bhikkhave, dukkhe sati, dukkhaṁ upādāya, dukkhaṁ abhinivissa evaṁ diṭṭhi uppajjati: ",
    "sn24.37:3.7": "‘rūpī attā hoti arogo paraṁ maraṇā’”ti? ",
    "sn24.37:3.8": "“Vedanā …pe… ",
    "sn24.37:3.9": "“no hetaṁ, bhante”. ",
    "sn24.37:3.10": "“Iti kho, bhikkhave, dukkhe sati, dukkhaṁ upādāya, dukkhaṁ abhinivissa evaṁ diṭṭhi uppajjati: ",
    "sn24.37:3.11": "‘rūpī attā hoti arogo paraṁ maraṇā’”ti. ",
    "sn24.37:3.12": "Ekūnavīsatimaṁ. "
  },
  "translation_text": {
    "sn24.37:0.1": "Linked Discourses 24.37 ",
    "sn24.37:0.2": "2. The Second Round ",
    "sn24.37:0.3": "The Self is Formed ",
    "sn24.37:1.1": "At Sāvatthī. ",
    "sn24.37:1.2": "“Mendicants, when what exists, because of grasping what and insisting on what, does the view arise: ",
    "sn24.37:1.3": "‘The self is formed and is free of disease after death’?” … ",
