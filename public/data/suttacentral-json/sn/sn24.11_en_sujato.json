  "root_text": {
    "sn24.11:0.1": "Saṁyutta Nikāya 24.11 ",
    "sn24.11:0.2": "1. Sotāpattivagga ",
    "sn24.11:0.3": "Antavāsutta ",
    "sn24.11:1.1": "Sāvatthinidānaṁ. ",
    "sn24.11:1.2": "“Kismiṁ nu kho, bhikkhave, sati, kiṁ upādāya, kiṁ abhinivissa evaṁ diṭṭhi uppajjati: ",
    "sn24.11:1.3": "‘antavā loko’”ti? ",
    "sn24.11:1.4": "“Bhagavaṁmūlakā no, bhante, dhammā …pe… ",
    "sn24.11:1.5": "niyato sambodhiparāyano”ti. ",
    "sn24.11:1.6": "Ekādasamaṁ. "
  },
  "translation_text": {
    "sn24.11:0.1": "Linked Discourses 24.11 ",
    "sn24.11:0.2": "1. Stream-Entry ",
    "sn24.11:0.3": "The Cosmos is Finite ",
    "sn24.11:1.1": "At Sāvatthī. ",
    "sn24.11:1.2": "“Mendicants, when what exists, because of grasping what and insisting on what, does the view arise: ",
    "sn24.11:1.3": "‘The cosmos is finite’?” … ",
    "sn24.11:1.4": "",
    "sn24.11:1.5": ""
  },
