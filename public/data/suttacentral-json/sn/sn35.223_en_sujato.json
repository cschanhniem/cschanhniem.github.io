  "root_text": {
    "sn35.223:0.1": "Saṁyutta Nikāya 35.223 ",
    "sn35.223:0.2": "17. Saṭṭhipeyyālavagga ",
    "sn35.223:0.3": "Ajjhattāyatanadukkhasutta ",
    "sn35.223:1.1": "“Cakkhu, bhikkhave, dukkhaṁ …pe… jivhā dukkhā …pe… mano dukkho. ",
    "sn35.223:1.2": "Evaṁ passaṁ …pe… ",
    "sn35.223:1.3": "nāparaṁ itthattāyāti pajānātī”ti. "
  },
  "translation_text": {
    "sn35.223:0.1": "Linked Discourses 35.223 ",
    "sn35.223:0.2": "17. Sixty Abbreviated Texts ",
    "sn35.223:0.3": "The Interior as Suffering ",
    "sn35.223:1.1": "“Mendicants, the eye, ear, nose, tongue, body, and mind are suffering. ",
    "sn35.223:1.2": "Seeing this … ",
    "sn35.223:1.3": "They understand: ‘… there is nothing further for this place.’” "
  },
