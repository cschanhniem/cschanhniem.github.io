  "root_text": {
    "sn43.8:0.1": "Saṁyutta Nikāya 43.8 ",
    "sn43.8:0.2": "1. Paṭhamavagga ",
    "sn43.8:0.3": "Indriyasutta ",
    "sn43.8:1.1": "“Katamo ca, bhikkhave, asaṅkhatagāmimaggo? ",
    "sn43.8:1.2": "Pañcindriyāni. Ayaṁ vuccati, bhikkhave, asaṅkhatagāmimaggo …pe…. ",
    "sn43.8:1.3": "Aṭṭhamaṁ. "
  },
  "translation_text": {
    "sn43.8:0.1": "Linked Discourses 43.8 ",
    "sn43.8:0.2": "Chapter One ",
    "sn43.8:0.3": "Faculties ",
    "sn43.8:1.1": "“And what is the path that leads to the unconditioned? ",
    "sn43.8:1.2": "The five faculties. …” "
  },
