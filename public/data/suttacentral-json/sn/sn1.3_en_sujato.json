  "root_text": {
    "sn1.3:0.1": "Saṁyutta Nikāya 1.3 ",
    "sn1.3:0.2": "1. Naḷavagga ",
    "sn1.3:0.3": "Upanīyasutta ",
    "sn1.3:1.1": "Sāvatthinidānaṁ. ",
    "sn1.3:1.2": "Ekamantaṁ ṭhitā kho sā devatā bhagavato santike imaṁ gāthaṁ abhāsi: ",
    "sn1.3:2.1": "“Upanīyati jīvitamappamāyu, ",
    "sn1.3:2.2": "Jarūpanītassa na santi tāṇā; ",
    "sn1.3:2.3": "Etaṁ bhayaṁ maraṇe pekkhamāno, ",
    "sn1.3:2.4": "Puññāni kayirātha sukhāvahānī”ti. ",
    "sn1.3:3.1": "“Upanīyati jīvitamappamāyu, ",
    "sn1.3:3.2": "Jarūpanītassa na santi tāṇā; ",
    "sn1.3:3.3": "Etaṁ bhayaṁ maraṇe pekkhamāno, ",
    "sn1.3:3.4": "Lokāmisaṁ pajahe santipekkho”ti. "
  },
  "translation_text": {
    "sn1.3:0.1": "Linked Discourses 1.3 ",
    "sn1.3:0.2": "1. A Reed ",
    "sn1.3:0.3": "Led On ",
    "sn1.3:1.1": "At Sāvatthī. ",
    "sn1.3:1.2": "Standing to one side, that deity spoke this verse in the Buddha’s presence: ",
    "sn1.3:2.1": "“This life, so very short, is led onward. ",
    "sn1.3:2.2": "One led on to old age has no shelter. ",
    "sn1.3:2.3": "Seeing this peril in death, ",
    "sn1.3:2.4": "do good deeds that bring you joy.” ",
    "sn1.3:3.1": "“This life, so very short, is led onward; ",
    "sn1.3:3.2": "one led on to old age has no shelter. ",
    "sn1.3:3.3": "Seeing this peril in death, ",
    "sn1.3:3.4": "a seeker of peace would drop the world’s bait.” "
  },
