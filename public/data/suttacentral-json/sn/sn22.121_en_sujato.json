  "root_text": {
    "sn22.121:0.1": "Saṁyutta Nikāya 22.121 ",
    "sn22.121:0.2": "12. Dhammakathikavagga ",
    "sn22.121:0.3": "Upādāniyasutta ",
    "sn22.121:1.1": "Sāvatthinidānaṁ. ",
    "sn22.121:1.2": "“Upādāniye ca, bhikkhave, dhamme desessāmi upādānañca. ",
    "sn22.121:1.3": "Taṁ suṇātha. ",
    "sn22.121:1.4": "Katame ca, bhikkhave, upādāniyā dhammā, katamaṁ upādānaṁ? ",
    "sn22.121:1.5": "Rūpaṁ, bhikkhave, upādāniyo dhammo, ",
    "sn22.121:1.6": "yo tattha chandarāgo, taṁ tattha upādānaṁ. ",
    "sn22.121:1.7": "Vedanā …pe… ",
    "sn22.121:1.8": "saññā … ",
    "sn22.121:1.9": "saṅkhārā … ",
    "sn22.121:1.10": "viññāṇaṁ upādāniyo dhammo; ",
    "sn22.121:1.11": "yo tattha chandarāgo, taṁ tattha upādānaṁ. ",
    "sn22.121:1.12": "Ime vuccanti, bhikkhave, upādāniyā dhammā, idaṁ upādānan”ti. ",
    "sn22.121:1.13": "Navamaṁ. "
  },
  "translation_text": {
    "sn22.121:0.1": "Linked Discourses 22.121 ",
    "sn22.121:0.2": "12. A Dhamma speaker ",
    "sn22.121:0.3": "Things That Fuel Grasping ",
    "sn22.121:1.1": "At Sāvatthī. ",
    "sn22.121:1.2": "“Mendicants, I will teach you the things that fuel grasping, and the grasping. ",
    "sn22.121:1.3": "Listen … ",
    "sn22.121:1.4": "What are the things that fuel grasping? And what is the grasping? ",
    "sn22.121:1.5": "Form is something that fuels grasping. ",
    "sn22.121:1.6": "The desire and greed for it is the grasping. ",
    "sn22.121:1.7": "Feeling … ",
    "sn22.121:1.8": "Perception … ",
    "sn22.121:1.9": "Choices … ",
    "sn22.121:1.10": "Consciousness is something that fuels grasping. ",
    "sn22.121:1.11": "The desire and greed for it is the grasping. ",
    "sn22.121:1.12": "These are called the things that fuel grasping, and this is the grasping.” "
  },
  "variant_text": {
    "sn22.121:0.3": "Upādāniyasutta → upādānam (pts1ed) "
  },
