  "root_text": {
    "sn55.48:0.1": "Saṁyutta Nikāya 55.48 ",
    "sn55.48:0.2": "5. Sagāthakapuññābhisandavagga ",
    "sn55.48:0.3": "Bhaddiyasutta ",
    "sn55.48:1.1": "Kapilavatthunidānaṁ. ",
    "sn55.48:1.2": "Ekamantaṁ nisinnaṁ kho bhaddiyaṁ sakkaṁ bhagavā etadavoca: ",
    "sn55.48:1.3": "“catūhi kho, bhaddiya, dhammehi samannāgato ariyasāvako sotāpanno hoti avinipātadhammo niyato sambodhiparāyaṇo. ",
    "sn55.48:2.1": "Katamehi catūhi? ",
    "sn55.48:2.2": "Idha, bhaddiya, ariyasāvako buddhe …pe… ",
    "sn55.48:2.3": "dhamme …pe… ",
    "sn55.48:2.4": "saṅghe …pe… ",
    "sn55.48:2.5": "ariyakantehi sīlehi samannāgato hoti akhaṇḍehi …pe… samādhisaṁvattanikehi. ",
    "sn55.48:2.6": "Imehi kho, bhaddiya, catūhi dhammehi samannāgato ariyasāvako sotāpanno hoti avinipātadhammo niyato sambodhiparāyaṇo”ti. ",
    "sn55.48:2.7": "Aṭṭhamaṁ. "
  },
  "translation_text": {
    "sn55.48:0.1": "Linked Discourses 55.48 ",
    "sn55.48:0.2": "5. Overflowing Merit, With Verses ",
    "sn55.48:0.3": "With Bhaddiya ",
    "sn55.48:1.1": "At Kapilavatthu. ",
    "sn55.48:1.2": "Seated to one side, the Buddha said to Bhaddiya the Sakyan: ",
    "sn55.48:1.3": "“Bhaddiya, a noble disciple who has four things is a stream-enterer …” ",
