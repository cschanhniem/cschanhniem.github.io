  "root_text": {
    "sn23.16:0.1": "Saṁyutta Nikāya 23.16 ",
    "sn23.16:0.2": "2. Dutiyamāravagga ",
    "sn23.16:0.3": "Dukkhadhammasutta ",
    "sn23.16:1.1": "Sāvatthinidānaṁ. ",
    "sn23.16:1.2": "Ekamantaṁ nisinno kho āyasmā rādho bhagavantaṁ etadavoca: ",
    "sn23.16:1.3": "“‘dukkhadhammo, dukkhadhammo’ti, bhante, vuccati. ",
    "sn23.16:1.4": "Katamo nu kho, bhante, dukkhadhammo”ti? ",
    "sn23.16:1.5": "“Rūpaṁ kho, rādha, dukkhadhammo, vedanā dukkhadhammo, saññā dukkhadhammo, saṅkhārā dukkhadhammo, viññāṇaṁ dukkhadhammo. ",
    "sn23.16:1.6": "Evaṁ passaṁ …pe… ",
    "sn23.16:1.7": "nāparaṁ itthattāyāti pajānātī”ti. ",
    "sn23.16:1.8": "Chaṭṭhaṁ. "
  },
  "translation_text": {
    "sn23.16:0.1": "Linked Discourses 23.16 ",
    "sn23.16:0.2": "2. About Māra (2nd) ",
    "sn23.16:0.3": "Liable to Suffering ",
    "sn23.16:1.1": "At Sāvatthī. ",
    "sn23.16:1.2": "Seated to one side, Venerable Rādha said to the Buddha: ",
    "sn23.16:1.3": "“Sir, they speak of ‘liable to suffering’. ",
    "sn23.16:1.4": "What is liable to suffering?” ",
    "sn23.16:1.5": "“Rādha, form, feeling, perception, choices, and consciousness are liable to suffering. ",
    "sn23.16:1.6": "Seeing this … ",
    "sn23.16:1.7": "They understand: ‘… there is nothing further for this place.’” "
  },
  "variant_text": {
    "sn23.16:0.3": "Dukkhadhammasutta → dukkha 2 (pts1ed) "
  },
