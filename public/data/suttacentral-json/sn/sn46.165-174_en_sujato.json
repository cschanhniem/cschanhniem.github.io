  "root_text": {
    "sn46.165-174:0.1": "Saṁyutta Nikāya 46.165–174 ",
    "sn46.165-174:0.2": "17. Punaesanāvagga ",
    "sn46.165-174:0.3": "Punaesanādisutta ",
    "sn46.165-174:1.1": "…pe… ",
    "sn46.165-174:1.2": "Punaesanāvaggo sattarasamo. ",
    "sn46.165-174:2.0": "Uddānaṁ ",
    "sn46.165-174:2.1": "Esanā vidhā āsavo, ",
    "sn46.165-174:2.2": "Bhavo ca dukkhatā tisso; ",
    "sn46.165-174:2.3": "Khilaṁ malañca nīgho ca, ",
    "sn46.165-174:2.4": "Vedanātaṇhā tasināya cāti. "
  },
