  "root_text": {
    "sn22.129:0.1": "Saṁyutta Nikāya 22.129 ",
    "sn22.129:0.2": "13. Avijjāvagga ",
    "sn22.129:0.3": "Assādasutta ",
    "sn22.129:1.1": "Bārāṇasiyaṁ viharanti isipatane migadāye …pe… ",
    "sn22.129:1.2": "ekamantaṁ nisinno kho āyasmā mahākoṭṭhiko āyasmantaṁ sāriputtaṁ etadavoca: ",
    "sn22.129:1.3": "“‘avijjā, avijjā’ti, āvuso sāriputta, vuccati. ",
    "sn22.129:1.4": "Katamā nu kho, āvuso, avijjā; ",
    "sn22.129:1.5": "kittāvatā ca avijjāgato hotī”ti? ",
    "sn22.129:2.1": "“Idhāvuso assutavā puthujjano rūpassa assādañca ādīnavañca nissaraṇañca yathābhūtaṁ nappajānāti. ",
    "sn22.129:2.2": "Vedanāya …pe… ",
    "sn22.129:2.3": "saññāya … ",
    "sn22.129:2.4": "saṅkhārānaṁ … ",
    "sn22.129:2.5": "viññāṇassa assādañca ādīnavañca nissaraṇañca yathābhūtaṁ nappajānāti. ",
    "sn22.129:2.6": "Ayaṁ vuccatāvuso, avijjā; ",
    "sn22.129:2.7": "ettāvatā ca avijjāgato hotī”ti. ",
    "sn22.129:2.8": "Catutthaṁ. "
  },
  "translation_text": {
    "sn22.129:0.1": "Linked Discourses 22.129 ",
    "sn22.129:0.2": "13. Ignorance ",
    "sn22.129:0.3": "Gratification ",
    "sn22.129:1.1": "At Varanasi. ",
    "sn22.129:1.2": "Mahākoṭṭhita said to Sāriputta: ",
    "sn22.129:1.3": "“Reverend Sāriputta, they speak of this thing called ‘ignorance’. ",
    "sn22.129:1.4": "What is ignorance? ",
    "sn22.129:1.5": "And how is an ignorant person defined?” ",
    "sn22.129:2.1": "“Reverend, an unlearned ordinary person doesn’t truly understand the gratification, the drawback, and the escape when it comes to form, ",
    "sn22.129:2.2": "feeling, ",
    "sn22.129:2.3": "perception, ",
    "sn22.129:2.4": "choices, ",
    "sn22.129:2.5": "and consciousness. ",
    "sn22.129:2.6": "This is called ignorance. ",
    "sn22.129:2.7": "And this is how an ignorant person is defined.” "
  },
