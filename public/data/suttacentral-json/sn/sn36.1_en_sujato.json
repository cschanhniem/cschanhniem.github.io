  "root_text": {
    "sn36.1:0.1": "Saṁyutta Nikāya 36.1 ",
    "sn36.1:0.2": "1. Sagāthāvagga ",
    "sn36.1:0.3": "Samādhisutta ",
    "sn36.1:1.1": "“Tisso imā, bhikkhave, vedanā. ",
    "sn36.1:1.2": "Katamā tisso? ",
    "sn36.1:1.3": "Sukhā vedanā, dukkhā vedanā, adukkhamasukhā vedanā—",
    "sn36.1:1.4": "imā kho, bhikkhave, tisso vedanāti. ",
    "sn36.1:2.1": "Samāhito sampajāno, ",
    "sn36.1:2.2": "sato buddhassa sāvako; ",
    "sn36.1:2.3": "Vedanā ca pajānāti, ",
    "sn36.1:2.4": "vedanānañca sambhavaṁ. ",
    "sn36.1:3.1": "Yattha cetā nirujjhanti, ",
    "sn36.1:3.2": "maggañca khayagāminaṁ; ",
    "sn36.1:3.3": "Vedanānaṁ khayā bhikkhu, ",
    "sn36.1:3.4": "nicchāto parinibbuto”ti. ",
    "sn36.1:3.5": "Paṭhamaṁ. "
  },
  "translation_text": {
    "sn36.1:0.1": "Linked Discourses 36.1 ",
    "sn36.1:0.2": "1. With Verses ",
    "sn36.1:0.3": "Immersion ",
    "sn36.1:1.1": "“Mendicants, there are these three feelings. ",
    "sn36.1:1.2": "What three? ",
    "sn36.1:1.3": "Pleasant, painful, and neutral feeling. ",
    "sn36.1:1.4": "These are the three feelings. ",
    "sn36.1:2.1": "Stilled, aware, ",
    "sn36.1:2.2": "a mindful disciple of the Buddha ",
    "sn36.1:2.3": "understands feelings, ",
    "sn36.1:2.4": "the cause of feelings, ",
    "sn36.1:3.1": "where they cease, ",
    "sn36.1:3.2": "and the path that leads to their ending. ",
    "sn36.1:3.3": "With the ending of feelings, a mendicant ",
    "sn36.1:3.4": "is hungerless, quenched.” "
  },
  "variant_text": {
    "sn36.1:0.2": "Sagāthāvagga → paṭhamakasagāthavaggo (sya-all); paṭhamasagāthavaggo (pts1ed) "
  },
