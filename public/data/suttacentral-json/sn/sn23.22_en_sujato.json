  "root_text": {
    "sn23.22:0.1": "Saṁyutta Nikāya 23.22 ",
    "sn23.22:0.2": "2. Dutiyamāravagga ",
    "sn23.22:0.3": "Nirodhadhammasutta ",
    "sn23.22:1.1": "Sāvatthinidānaṁ. ",
    "sn23.22:1.2": "Ekamantaṁ nisinno kho āyasmā rādho bhagavantaṁ etadavoca: ",
    "sn23.22:1.3": "“‘nirodhadhammo, nirodhadhammo’ti, bhante, vuccati. ",
    "sn23.22:1.4": "Katamo nu kho, bhante, nirodhadhammo”ti? ",
    "sn23.22:1.5": "“Rūpaṁ kho, rādha, nirodhadhammo, vedanā nirodhadhammo, saññā nirodhadhammo, saṅkhārā nirodhadhammo, viññāṇaṁ nirodhadhammo. ",
    "sn23.22:1.6": "Evaṁ passaṁ …pe… ",
    "sn23.22:1.7": "nāparaṁ itthattāyāti pajānātī”ti. ",
    "sn23.22:1.8": "Dvādasamaṁ. ",
    "sn23.22:1.9": "Dutiyamāravaggo. ",
    "sn23.22:2.0": "Tassuddānaṁ ",
    "sn23.22:2.1": "Māro ca māradhammo ca, ",
    "sn23.22:2.2": "Aniccena apare duve; ",
    "sn23.22:2.3": "Dukkhena ca duve vuttā, ",
    "sn23.22:2.4": "Anattena tatheva ca; ",
    "sn23.22:2.5": "Khayavayasamudayaṁ, ",
    "sn23.22:2.6": "Nirodhadhammena dvādasāti. "
  },
  "translation_text": {
    "sn23.22:0.1": "Linked Discourses 23.22 ",
    "sn23.22:0.2": "2. About Māra (2nd) ",
    "sn23.22:0.3": "Liable To Cease ",
    "sn23.22:1.1": "At Sāvatthī. ",
    "sn23.22:1.2": "Seated to one side, Venerable Rādha said to the Buddha: ",
    "sn23.22:1.3": "“Sir, they speak of ‘liable to cease’. ",
    "sn23.22:1.4": "What is liable to cease?” ",
    "sn23.22:1.5": "“Rādha, form, feeling, perception, choices, and consciousness are liable to cease. ",
    "sn23.22:1.6": "Seeing this … ",
    "sn23.22:1.7": "They understand: ‘… there is nothing further for this place.’” ",
