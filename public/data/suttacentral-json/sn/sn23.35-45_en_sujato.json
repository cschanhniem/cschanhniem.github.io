  "root_text": {
    "sn23.35:0.1": "Saṁyutta Nikāya 23.35–45 ",
    "sn23.35:0.2": "4. Upanisinnavagga ",
    "sn23.35:0.3": "Mārādisuttaekādasaka ",
    "sn23.35:1.1": "Sāvatthinidānaṁ. ",
    "sn23.35:1.2": "Ekamantaṁ nisinnaṁ kho āyasmantaṁ rādhaṁ bhagavā etadavoca: ",
    "sn23.35:1.3": "“yo kho, rādha, māro; tatra te chando pahātabbo, rāgo pahātabbo, chandarāgo pahātabbo. ",
    "sn23.35:1.4": "Ko ca, rādha, māro? ",
    "sn23.35:1.5": "Rūpaṁ kho, rādha, māro; tatra te chando pahātabbo …pe… ",
    "sn23.35:1.6": "viññāṇaṁ māro; tatra te chando pahātabbo …pe… ",
    "sn23.35:1.7": "yo kho, rādha, māro; tatra te chando pahātabbo, rāgo pahātabbo, chandarāgo pahātabbo”ti. ",
    "sn23.36:1.1": "“Yo kho, rādha, māradhammo; tatra te chando pahātabbo, rāgo pahātabbo, chandarāgo pahātabbo …pe…. ",
    "sn23.37:1.1": "“Yaṁ kho, rādha, aniccaṁ …pe…. ",
    "sn23.38:1.1": "“Yo kho, rādha, aniccadhammo …pe…. ",
    "sn23.39:1.1": "“Yaṁ kho, rādha, dukkhaṁ …pe…. ",
    "sn23.40:1.1": "“Yo kho, rādha, dukkhadhammo …pe…. ",
    "sn23.41:1.1": "“Yo kho, rādha, anattā …pe…. ",
    "sn23.42:1.1": "“Yo kho, rādha, anattadhammo …pe…. ",
    "sn23.43:1.1": "“Yo kho, rādha, khayadhammo …pe…. ",
    "sn23.44:1.1": "“Yo kho, rādha, vayadhammo …pe…. ",
    "sn23.45:1.1": "“Yo kho, rādha, samudayadhammo; tatra te chando pahātabbo, rāgo pahātabbo, chandarāgo pahātabbo …pe…. "
  },
  "translation_text": {
    "sn23.35:0.1": "Linked Discourses 23.35 ",
    "sn23.35:0.2": "4. Sitting Close ",
    "sn23.35:0.3": "Eleven Discourses on Māra, Etc. ",
    "sn23.35:1.1": "At Sāvatthī. ",
    "sn23.35:1.2": "When Venerable Rādha was seated to one side, the Buddha said to him: ",
    "sn23.35:1.3": "“Rādha, you should give up any desire, any greed, any desire and greed for whatever is Māra. ",
    "sn23.35:1.4": "And what is Māra? ",
    "sn23.35:1.5": "Form is Māra. You should give up any desire, any greed, any desire and greed for it. … ",
    "sn23.35:1.6": "Consciousness is Māra. You should give up any desire, any greed, any desire and greed for it. ",
    "sn23.35:1.7": "You should give up any desire, any greed, any desire and greed for whatever is Māra.” ",
    "sn23.36:1.1": "“You should give up any desire, any greed, any desire and greed for whatever is subject to Māra …” ",
    "sn23.37:1.1": "“… impermanent …” ",
    "sn23.38:1.1": "“… liable to impermanence …” ",
    "sn23.39:1.1": "“… suffering …” ",
    "sn23.40:1.1": "“… liable to suffering …” ",
    "sn23.41:1.1": "“… not-self …” ",
    "sn23.42:1.1": "“… liable to not-self …” ",
    "sn23.43:1.1": "“… liable to end …” ",
    "sn23.44:1.1": "“… liable to fall …” ",
    "sn23.45:1.1": "“… liable to originate …” "
  },
