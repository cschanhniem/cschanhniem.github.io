  "root_text": {
    "sn37.24:0.1": "Saṁyutta Nikāya 37.24 ",
    "sn37.24:0.2": "2. Dutiyapeyyālavagga ",
    "sn37.24:0.3": "Pañcasīlasutta ",
    "sn37.24:1.1": "“Pañcahi, anuruddha, dhammehi samannāgato mātugāmo kāyassa bhedā paraṁ maraṇā sugatiṁ saggaṁ lokaṁ upapajjati. ",
    "sn37.24:1.2": "Katamehi pañcahi? ",
    "sn37.24:1.3": "Pāṇātipātā paṭivirato ca hoti, adinnādānā paṭivirato ca hoti, kāmesumicchācārā paṭivirato ca hoti, musāvādā paṭivirato ca hoti, surāmerayamajjappamādaṭṭhānā paṭivirato ca hoti—",
    "sn37.24:1.4": "imehi kho, anuruddha, pañcahi dhammehi samannāgato mātugāmo kāyassa bhedā paraṁ maraṇā sugatiṁ saggaṁ lokaṁ upapajjatī”ti. ",
    "sn37.24:1.5": "Dasamaṁ. ",
    "sn37.24:1.6": "Dutiyapeyyālavaggo. ",
    "sn37.24:2.0": "Tassuddānaṁ ",
    "sn37.24:2.1": "Dutiye ca akkodhano, ",
    "sn37.24:2.2": "anupanāhī anissukī; ",
    "sn37.24:2.3": "Amaccharī anaticārī, ",
    "sn37.24:2.4": "sīlavā ca bahussuto; ",
    "sn37.24:2.5": "Vīriyaṁ sati sīlañca, ",
    "sn37.24:2.6": "sukkapakkhe pakāsito. "
  },
  "translation_text": {
    "sn37.24:0.1": "Linked Discourses 37.24 ",
    "sn37.24:0.2": "2. Abbreviated Texts ",
    "sn37.24:0.3": "Five Precepts ",
    "sn37.24:1.1": "“Anuruddha, when ladies have five qualities, when their body breaks up, after death, they are reborn in a good place, a heavenly realm. ",
    "sn37.24:1.2": "What five? ",
    "sn37.24:1.3": "They don’t kill living creatures, steal, commit sexual misconduct, lie, or consume beer, wine, and liquor intoxicants. ",
    "sn37.24:1.4": "When ladies possess these five qualities, when their body breaks up, after death, they are reborn in a good place, a heavenly realm.” ",
