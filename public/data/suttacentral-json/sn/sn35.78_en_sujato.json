  "root_text": {
    "sn35.78:0.1": "Saṁyutta Nikāya 35.78 ",
    "sn35.78:0.2": "8. Gilānavagga ",
    "sn35.78:0.3": "Rādhaanattasutta ",
    "sn35.78:1.1": "“Yo kho, rādha, anattā tatra te chando pahātabbo. ",
    "sn35.78:1.2": "Ko ca, rādha, anattā? ",
    "sn35.78:1.3": "Cakkhu kho, rādha, anattā. Tatra te chando pahātabbo. ",
    "sn35.78:1.4": "Rūpā … ",
    "sn35.78:1.5": "cakkhuviññāṇaṁ … ",
    "sn35.78:1.6": "cakkhusamphasso … ",
    "sn35.78:1.7": "yampidaṁ cakkhusamphassapaccayā …pe… ",
    "sn35.78:1.8": "mano anattā … ",
    "sn35.78:1.9": "dhammā … ",
    "sn35.78:1.10": "manoviññāṇaṁ … ",
    "sn35.78:1.11": "manosamphasso … ",
    "sn35.78:1.12": "yampidaṁ manosamphassapaccayā uppajjati vedayitaṁ sukhaṁ vā dukkhaṁ vā adukkhamasukhaṁ vā tampi anattā. Tatra te chando pahātabbo. ",
    "sn35.78:1.13": "Yo kho, rādha, anattā tatra te chando pahātabbo”ti. ",
    "sn35.78:1.14": "Pañcamaṁ. "
  },
  "translation_text": {
    "sn35.78:0.1": "Linked Discourses 35.78 ",
    "sn35.78:0.2": "8. Sick ",
    "sn35.78:0.3": "With Rādha on Not-Self ",
    "sn35.78:1.1": "“Rādha, you should give up desire for what is not-self. …” ",
