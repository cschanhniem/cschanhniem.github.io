  "root_text": {
    "sn48.23:0.1": "Saṁyutta Nikāya 48.23 ",
    "sn48.23:0.2": "3. Chaḷindriyavagga ",
    "sn48.23:0.3": "Aññindriyasutta ",
    "sn48.23:1.1": "“Tīṇimāni, bhikkhave, indriyāni. ",
    "sn48.23:1.2": "Katamāni tīṇi? ",
    "sn48.23:1.3": "Anaññātaññassāmītindriyaṁ, aññindriyaṁ, aññātāvindriyaṁ—",
    "sn48.23:1.4": "imāni kho, bhikkhave, tīṇi indriyānī”ti. ",
    "sn48.23:1.5": "Tatiyaṁ. "
  },
  "translation_text": {
    "sn48.23:0.1": "Linked Discourses 48.23 ",
    "sn48.23:0.2": "3. The Six Faculties ",
    "sn48.23:0.3": "The Faculty of Enlightenment ",
    "sn48.23:1.1": "“Mendicants, there are these three faculties. ",
    "sn48.23:1.2": "What three? ",
    "sn48.23:1.3": "The faculty of understanding that one’s enlightenment is imminent. The faculty of enlightenment. The faculty of one who is enlightened. ",
    "sn48.23:1.4": "These are the three faculties.” "
  },
  "variant_text": {
    "sn48.23:0.3": "Aññindriyasutta → ñāya (pts1ed) "
  },
