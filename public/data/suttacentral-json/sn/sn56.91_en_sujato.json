  "root_text": {
    "sn56.91:0.1": "Saṁyutta Nikāya 56.91 ",
    "sn56.91:0.2": "10. Catutthaāmakadhaññapeyyālavagga ",
    "sn56.91:0.3": "Khettavatthusutta ",
    "sn56.91:1.1": "… “Evameva kho, bhikkhave, appakā te sattā ye khettavatthupaṭiggahaṇā paṭiviratā; atha kho eteva bahutarā sattā ye khettavatthupaṭiggahaṇā appaṭiviratā …pe…. ",
    "sn56.91:1.2": "Paṭhamaṁ. "
  },
  "translation_text": {
    "sn56.91:0.1": "Linked Discourses 56.91 ",
    "sn56.91:0.2": "10. Abbreviated Texts on Raw Grain ",
    "sn56.91:0.3": "Fields and Land ",
    "sn56.91:1.1": "“… the sentient beings who refrain from receiving fields and land are few, while those who don’t refrain are many. …” "
  },
  "variant_text": {
    "sn56.91:0.2": "Catutthaāmakadhaññapeyyālavagga → bahuttarā sattā (pts1ed) ",
    "sn56.91:0.3": "Khettavatthusutta → khetta (pts1ed) "
  },
