  "root_text": {
    "sn35.3:0.1": "Saṁyutta Nikāya 35.3 ",
    "sn35.3:0.2": "1. Aniccavagga ",
    "sn35.3:0.3": "Ajjhattānattasutta ",
    "sn35.3:1.1": "“Cakkhuṁ, bhikkhave, anattā. ",
    "sn35.3:1.2": "Yadanattā taṁ ‘netaṁ mama, nesohamasmi, na meso attā’ti evametaṁ yathābhūtaṁ sammappaññāya daṭṭhabbaṁ. ",
    "sn35.3:1.3": "Sotaṁ anattā …pe… ",
    "sn35.3:1.4": "ghānaṁ anattā … ",
    "sn35.3:1.5": "jivhā anattā … ",
    "sn35.3:1.6": "kāyo anattā … ",
    "sn35.3:1.7": "mano anattā. ",
    "sn35.3:1.8": "Yadanattā taṁ ‘netaṁ mama, nesohamasmi, na meso attā’ti evametaṁ yathābhūtaṁ sammappaññāya daṭṭhabbaṁ. ",
    "sn35.3:1.9": "Evaṁ passaṁ …pe… ",
    "sn35.3:1.10": "nāparaṁ itthattāyāti pajānātī”ti. ",
    "sn35.3:1.11": "Tatiyaṁ. "
  },
  "translation_text": {
    "sn35.3:0.1": "Linked Discourses 35.3 ",
    "sn35.3:0.2": "1. Impermanence ",
    "sn35.3:0.3": "The Interior as Not-Self ",
    "sn35.3:1.1": "“Mendicants, the eye is not-self. ",
    "sn35.3:1.2": "And what’s not-self should be truly seen with right understanding like this: ‘This is not mine, I am not this, this is not my self.’ ",
    "sn35.3:1.3": "The ear, ",
    "sn35.3:1.4": "nose, ",
    "sn35.3:1.5": "tongue, ",
    "sn35.3:1.6": "body, ",
    "sn35.3:1.7": "and mind are not-self. ",
    "sn35.3:1.8": "And what’s not-self should be truly seen with right understanding like this: ‘This is not mine, I am not this, this is not my self.’ ",
    "sn35.3:1.9": "Seeing this … ",
    "sn35.3:1.10": "They understand: ‘… there is nothing further for this place.’” "
  },
  "variant_text": {
    "sn35.3:0.3": "Ajjhattānattasutta → anattā 1; ajjhattaṁ (pts1ed) "
  },
