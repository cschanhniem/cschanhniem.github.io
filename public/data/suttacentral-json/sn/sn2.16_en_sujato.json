  "root_text": {
    "sn2.16:0.1": "Saṁyutta Nikāya 2.16 ",
    "sn2.16:0.2": "2. Anāthapiṇḍikavagga ",
    "sn2.16:0.3": "Vāsudattasutta ",
    "sn2.16:1.1": "Ekamantaṁ ṭhito kho vāsudatto devaputto bhagavato santike imaṁ gāthaṁ abhāsi: ",
    "sn2.16:2.1": "“Sattiyā viya omaṭṭho, ",
    "sn2.16:2.2": "ḍayhamānova matthake; ",
    "sn2.16:2.3": "Kāmarāgappahānāya, ",
    "sn2.16:2.4": "sato bhikkhu paribbaje”ti. ",
    "sn2.16:3.1": "“Sattiyā viya omaṭṭho, ",
    "sn2.16:3.2": "ḍayhamānova matthake; ",
    "sn2.16:3.3": "Sakkāyadiṭṭhippahānāya, ",
    "sn2.16:3.4": "sato bhikkhu paribbaje”ti. "
  },
  "translation_text": {
    "sn2.16:0.1": "Linked Discourses 2.16 ",
    "sn2.16:0.2": "2. With Anāthapiṇḍika ",
    "sn2.16:0.3": "With Vāsudatta ",
    "sn2.16:1.1": "Standing to one side, the godling Vāsudatta spoke this verse in the Buddha’s presence: ",
    "sn2.16:2.1": "“Like they’re struck by a sword, ",
    "sn2.16:2.2": "like their head was on fire, ",
    "sn2.16:2.3": "a mendicant should wander mindful, ",
    "sn2.16:2.4": "to give up sensual desire.” ",
    "sn2.16:3.1": "“Like they’re struck by a sword, ",
    "sn2.16:3.2": "like their head was on fire, ",
    "sn2.16:3.3": "a mendicant should wander mindful, ",
    "sn2.16:3.4": "to give up substantialist view.” "
  },
  "variant_text": {
    "sn2.16:2.2": "ḍayhamānova → ḍayhamāneva (sya-all, km) "
  },
