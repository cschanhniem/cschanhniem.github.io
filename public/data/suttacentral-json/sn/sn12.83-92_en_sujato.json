  "root_text": {
    "sn12.83:0.1": "Saṁyutta Nikāya 12.83–92 ",
    "sn12.83:0.2": "9. Antarapeyyāla ",
    "sn12.83:0.3": "Dutiyasatthusuttādidasaka ",
    "sn12.83:1.1": "“Jātiṁ, bhikkhave, ajānatā apassatā yathābhūtaṁ …pe…. ",
    "sn12.84:1.1": "“Bhavaṁ, bhikkhave, ajānatā apassatā yathābhūtaṁ …pe…. ",
    "sn12.85:1.1": "“Upādānaṁ, bhikkhave, ajānatā apassatā yathābhūtaṁ …pe…. ",
    "sn12.86:1.1": "“Taṇhaṁ, bhikkhave, ajānatā apassatā yathābhūtaṁ …pe…. ",
    "sn12.87:1.1": "“Vedanaṁ, bhikkhave, ajānatā apassatā yathābhūtaṁ …pe…. ",
    "sn12.88:1.1": "“Phassaṁ, bhikkhave, ajānatā apassatā yathābhūtaṁ …pe…. ",
    "sn12.89:1.1": "“Saḷāyatanaṁ, bhikkhave, ajānatā apassatā yathābhūtaṁ …pe…. ",
    "sn12.90:1.1": "“Nāmarūpaṁ, bhikkhave, ajānatā apassatā yathābhūtaṁ …pe…. ",
    "sn12.91:1.1": "“Viññāṇaṁ, bhikkhave, ajānatā apassatā yathābhūtaṁ …pe…. ",
    "sn12.92:1.1": "“Saṅkhāre, bhikkhave, ajānatā apassatā yathābhūtaṁ saṅkhāresu yathābhūtaṁ ñāṇāya satthā pariyesitabbo; ",
    "sn12.92:1.2": "saṅkhārasamudayaṁ ajānatā apassatā yathābhūtaṁ saṅkhārasamudaye yathābhūtaṁ ñāṇāya satthā pariyesitabbo; ",
    "sn12.92:1.3": "saṅkhāranirodhaṁ ajānatā apassatā yathābhūtaṁ saṅkhāranirodhe yathābhūtaṁ ñāṇāya satthā pariyesitabbo; ",
    "sn12.92:1.4": "saṅkhāranirodhagāminiṁ paṭipadaṁ ajānatā apassatā yathābhūtaṁ saṅkhāranirodhagāminiyā paṭipadāya yathābhūtaṁ ñāṇāya satthā pariyesitabbo”ti. ",
    "sn12.92:1.5": "Ekādasamaṁ. ",
    "sn12.92:1.6": "(Sabbesaṁ catusaccikaṁ kātabbaṁ.) "
  },
  "translation_text": {
    "sn12.83:0.1": "Linked Discourses 12.83–92 ",
    "sn12.83:0.2": "9. Incorporated Abbreviation Series ",
    "sn12.83:0.3": "The Teacher (2nd) ",
    "sn12.83:1.1": "“Mendicants, one who does not truly know or see rebirth …” ",
    "sn12.84:1.1": "“… continued existence …” ",
    "sn12.85:1.1": "“… grasping …” ",
    "sn12.86:1.1": "“… craving …” ",
    "sn12.87:1.1": "“… feeling …” ",
    "sn12.88:1.1": "“… contact …” ",
    "sn12.89:1.1": "“… the six sense fields …” ",
    "sn12.90:1.1": "“… name and form …” ",
    "sn12.91:1.1": "“… consciousness …” ",
    "sn12.92:1.1": "“… choices …” ",
    "sn12.92:1.2": "",
    "sn12.92:1.3": "",
    "sn12.92:1.4": "",
    "sn12.92:1.5": "",
    "sn12.92:1.6": "(All should be treated according to the four truths.) "
  },
