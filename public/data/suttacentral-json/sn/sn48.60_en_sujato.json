  "root_text": {
    "sn48.60:0.1": "Saṁyutta Nikāya 48.60 ",
    "sn48.60:0.2": "6. Sūkarakhatavagga ",
    "sn48.60:0.3": "Dutiyauppādasutta ",
    "sn48.60:1.1": "“Pañcimāni, bhikkhave, indriyāni bhāvitāni bahulīkatāni anuppannāni uppajjanti, nāññatra sugatavinayā. ",
    "sn48.60:1.2": "Katamāni pañca? ",
    "sn48.60:1.3": "Saddhindriyaṁ, vīriyindriyaṁ, satindriyaṁ, samādhindriyaṁ, paññindriyaṁ—",
    "sn48.60:1.4": "imāni kho, bhikkhave, pañcindriyāni bhāvitāni bahulīkatāni anuppannāni uppajjanti, nāññatra sugatavinayā”ti. ",
    "sn48.60:1.5": "Dasamaṁ. ",
    "sn48.60:1.6": "Sūkarakhatavaggo chaṭṭho. ",
    "sn48.60:2.0": "Tassuddānaṁ ",
    "sn48.60:2.1": "Sālaṁ mallikaṁ sekho ca, ",
    "sn48.60:2.2": "padaṁ sāraṁ patiṭṭhitaṁ; ",
    "sn48.60:2.3": "Brahmasūkarakhatāyo, ",
    "sn48.60:2.4": "uppādā apare duveti. "
  },
  "translation_text": {
    "sn48.60:0.1": "Linked Discourses 48.60 ",
    "sn48.60:0.2": "6. The Boar’s Cave ",
    "sn48.60:0.3": "Arising (2nd) ",
    "sn48.60:1.1": "“Mendicants, these five faculties don’t arise to be developed and cultivated apart from the Holy One’s training. ",
    "sn48.60:1.2": "What five? ",
    "sn48.60:1.3": "The faculties of faith, energy, mindfulness, immersion, and wisdom. ",
    "sn48.60:1.4": "These five faculties don’t arise to be developed and cultivated apart from the Holy One’s training.” ",
