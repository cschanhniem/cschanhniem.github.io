  "root_text": {
    "sn46.121-129:0.1": "Saṁyutta Nikāya 46.121–129 ",
    "sn46.121-129:0.2": "13. Oghavagga ",
    "sn46.121-129:0.3": "Oghādisutta ",
    "sn46.121-129:1.1": "“Cattārome, bhikkhave, oghā. ",
    "sn46.121-129:1.2": "Katame cattāro? ",
    "sn46.121-129:1.3": "Kāmogho, bhavogho, diṭṭhogho, avijjogho”ti. ",
    "sn46.121-129:1.4": "vitthāretabbaṁ. "
  },
  "translation_text": {
    "sn46.121-129:0.1": "Linked Discourses 46.121–129 ",
    "sn46.121-129:0.2": "13. Floods ",
    "sn46.121-129:0.3": "Floods ",
    "sn46.121-129:1.1": "“Mendicants, there are these four floods. ",
    "sn46.121-129:1.2": "What four? ",
    "sn46.121-129:1.3": "The floods of sensuality, desire to be reborn, views, and ignorance.” ",
    "sn46.121-129:1.4": "(Tell in full as in SN 45.171–179.) "
  },
