  "root_text": {
    "sn55.61:0.1": "Saṁyutta Nikāya 55.61 ",
    "sn55.61:0.2": "6. Sappaññavagga ",
    "sn55.61:0.3": "Paññāvepullasutta ",
    "sn55.61:1.1": "“…. Paññāvepullāya … saṁvattantī”ti. ",
    "sn55.61:1.2": "Ekādasamaṁ. ",
    "sn55.61:1.3": "Sappaññavaggo chaṭṭho. ",
    "sn55.61:2.0": "Tassuddānaṁ ",
    "sn55.61:2.1": "Sagāthakaṁ vassaṁvutthaṁ, ",
    "sn55.61:2.2": "dhammadinnañca gilānaṁ; ",
    "sn55.61:2.3": "Caturo phalā paṭilābho, ",
    "sn55.61:2.4": "vuddhi vepullatāya cāti. "
  },
  "translation_text": {
    "sn55.61:0.1": "Linked Discourses 55.61 ",
    "sn55.61:0.2": "6. A Wise Person ",
    "sn55.61:0.3": "The Increase of Wisdom ",
    "sn55.61:1.1": "“Mendicants, when four things are developed and cultivated they lead to the increase of wisdom. …” ",
