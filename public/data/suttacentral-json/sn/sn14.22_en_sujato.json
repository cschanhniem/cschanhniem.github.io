  "root_text": {
    "sn14.22:0.1": "Saṁyutta Nikāya 14.22 ",
    "sn14.22:0.2": "2. Dutiyavagga ",
    "sn14.22:0.3": "Kusītamūlakasutta ",
    "sn14.22:1.1": "Sāvatthiyaṁ viharati. ",
    "sn14.22:1.2": "“Dhātusova, bhikkhave, sattā saṁsandanti samenti. ",
    "sn14.22:1.3": "Kusītā kusītehi saddhiṁ saṁsandanti samenti; ",
    "sn14.22:1.4": "muṭṭhassatino muṭṭhassatīhi saddhiṁ saṁsandanti samenti; ",
    "sn14.22:1.5": "duppaññā duppaññehi saddhiṁ saṁsandanti samenti; ",
    "sn14.22:1.6": "āraddhavīriyā āraddhavīriyehi saddhiṁ saṁsandanti samenti; ",
    "sn14.22:1.7": "upaṭṭhitassatino upaṭṭhitassatīhi saddhiṁ saṁsandanti samenti; paññavanto paññavantehi saddhiṁ saṁsandanti samentī”ti …pe…. ",
    "sn14.22:1.8": "Dvādasamaṁ. ",
    "sn14.22:1.9": "(Sabbattha atītānāgatapaccuppannaṁ kātabbaṁ.) ",
    "sn14.22:1.10": "Dutiyo vaggo. ",
    "sn14.22:2.0": "Tassuddānaṁ ",
    "sn14.22:2.1": "Sattimā sanidānañca, ",
    "sn14.22:2.2": "giñjakāvasathena ca; ",
    "sn14.22:2.3": "Hīnādhimutti caṅkamaṁ, ",
    "sn14.22:2.4": "sagāthā assaddhasattamaṁ. ",
    "sn14.22:3.1": "Assaddhamūlakā pañca, ",
    "sn14.22:3.2": "Cattāro ahirikamūlakā; ",
    "sn14.22:3.3": "Anottappamūlakā tīṇi, ",
    "sn14.22:3.4": "Duve appassutena ca. ",
    "sn14.22:4.1": "Kusītaṁ ekakaṁ vuttaṁ, ",
    "sn14.22:4.2": "Suttantā tīṇi pañcakā; ",
    "sn14.22:4.3": "Bāvīsati vuttā suttā, ",
    "sn14.22:4.4": "Dutiyo vaggo pavuccatīti. "
  },
  "translation_text": {
    "sn14.22:0.1": "Linked Discourses 14.22 ",
    "sn14.22:0.2": "Chapter Two ",
    "sn14.22:0.3": "Beginning With the Lazy ",
    "sn14.22:1.1": "At Sāvatthī. ",
    "sn14.22:1.2": "“Mendicants, sentient beings join together and converge because of an element: ",
    "sn14.22:1.3": "the lazy with the lazy … ",
    "sn14.22:1.4": "unmindful … ",
    "sn14.22:1.5": "witless … ",
    "sn14.22:1.6": "energetic … ",
    "sn14.22:1.7": "mindful … wise …” ",
    "sn14.22:1.8": "",
    "sn14.22:1.9": "(Tell all in full for the past, future, and present.) ",
