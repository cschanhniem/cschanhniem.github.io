  "root_text": {
    "sn1.64:0.1": "Saṁyutta Nikāya 1.64 ",
    "sn1.64:0.2": "7. Addhavagga ",
    "sn1.64:0.3": "Saṁyojanasutta ",
    "sn1.64:1.1": "“Kiṁsu saṁyojano loko, ",
    "sn1.64:1.2": "kiṁsu tassa vicāraṇaṁ; ",
    "sn1.64:1.3": "Kissassu vippahānena, ",
    "sn1.64:1.4": "nibbānaṁ iti vuccatī”ti. ",
    "sn1.64:2.1": "“Nandīsaṁyojano loko, ",
    "sn1.64:2.2": "vitakkassa vicāraṇaṁ; ",
    "sn1.64:2.3": "Taṇhāya vippahānena, ",
    "sn1.64:2.4": "nibbānaṁ iti vuccatī”ti. "
  },
  "translation_text": {
    "sn1.64:0.1": "Linked Discourses 1.64 ",
    "sn1.64:0.2": "7. Overcome ",
    "sn1.64:0.3": "Fetter ",
    "sn1.64:1.1": "“What fetters the world? ",
    "sn1.64:1.2": "How does it travel about? ",
    "sn1.64:1.3": "With the giving up of what ",
    "sn1.64:1.4": "is extinguishment spoken of?” ",
    "sn1.64:2.1": "“Delight fetters the world. ",
    "sn1.64:2.2": "It travels about by means of thought. ",
    "sn1.64:2.3": "With the giving up of craving ",
    "sn1.64:2.4": "extinguishment is spoken of.” "
  },
  "variant_text": {
    "sn1.64:2.1": "Nandīsaṁyojano → nandi saṁyojano (bj); nandisaññojano (sya-all, km); nandisaṁyojano (pts2ed) "
  },
