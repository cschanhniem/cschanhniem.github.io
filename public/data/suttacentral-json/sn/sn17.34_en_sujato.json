  "root_text": {
    "sn17.34:0.1": "Saṁyutta Nikāya 17.34 ",
    "sn17.34:0.2": "4. Catutthavagga ",
    "sn17.34:0.3": "Sukkadhammasutta ",
    "sn17.34:1.1": "Sāvatthiyaṁ viharati. ",
    "sn17.34:1.2": "“Dāruṇo, bhikkhave, lābhasakkārasiloko. ",
    "sn17.34:1.3": "Lābhasakkārasilokena abhibhūtassa pariyādiṇṇacittassa, bhikkhave, devadattassa sukko dhammo samucchedamagamā. ",
    "sn17.34:1.4": "Evaṁ dāruṇo kho, bhikkhave, lābhasakkārasiloko …pe… ",
    "sn17.34:1.5": "sikkhitabban”ti. ",
    "sn17.34:1.6": "Catutthaṁ. "
  },
  "translation_text": {
    "sn17.34:0.1": "Linked Discourses 17.34 ",
    "sn17.34:0.2": "Chapter Four ",
    "sn17.34:0.3": "Bright Quality ",
    "sn17.34:1.1": "At Sāvatthī. ",
    "sn17.34:1.2": "“Possessions, honor, and popularity are grim … ",
    "sn17.34:1.3": "Devadatta cut off his bright quality because his mind was overcome and overwhelmed by possessions, honor, and popularity. ",
    "sn17.34:1.4": "So grim are possessions, honor, and popularity. …” ",
    "sn17.34:1.5": ""
  },
  "variant_text": {
    "sn17.34:0.3": "Sukkadhammasutta → sukkadhammasamucchedasuttaṁ (bj); sukko (pts1ed, pts2ed) "
  },
