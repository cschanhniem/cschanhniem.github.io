  "root_text": {
    "sn45.78-82:0.1": "Saṁyutta Nikāya 45.78–82 ",
    "sn45.78-82:0.2": "8. Dutiyaekadhammapeyyālavagga ",
    "sn45.78-82:0.3": "Sīlasampadādisuttapañcaka ",
    "sn45.78-82:1.1": "“Nāhaṁ, bhikkhave, aññaṁ ekadhammampi samanupassāmi, yena anuppanno vā ariyo aṭṭhaṅgiko maggo uppajjati, uppanno vā ariyo aṭṭhaṅgiko maggo bhāvanāpāripūriṁ gacchati, yathayidaṁ, bhikkhave, sīlasampadā …pe… ",
    "sn45.78-82:1.2": "yathayidaṁ, bhikkhave, chandasampadā …pe… ",
    "sn45.78-82:1.3": "yathayidaṁ, bhikkhave, attasampadā …pe… ",
    "sn45.78-82:1.4": "yathayidaṁ, bhikkhave, diṭṭhisampadā …pe… ",
    "sn45.78-82:1.5": "yathayidaṁ, bhikkhave, appamādasampadā …pe…. ",
    "sn45.78-82:1.6": "Chaṭṭhaṁ. "
  },
  "translation_text": {
    "sn45.78-82:0.1": "Linked Discourses 45.78–82 ",
    "sn45.78-82:0.2": "8. Abbreviated Texts on One Thing ",
    "sn45.78-82:0.3": "Five Discourses on Accomplishment in Ethics, Etc. ",
    "sn45.78-82:1.1": "“Mendicants, I do not see a single thing that gives rise to the noble eightfold path, or, if it’s already arisen, fully develops it like accomplishment in ethics. …” ",
    "sn45.78-82:1.2": "“… accomplishment in enthusiasm …” ",
    "sn45.78-82:1.3": "“… accomplishment in self-development …” ",
    "sn45.78-82:1.4": "“… accomplishment in view …” ",
    "sn45.78-82:1.5": "“… accomplishment in diligence …” "
  },
