  "root_text": {
    "sn18.10:0.1": "Saṁyutta Nikāya 18.10 ",
    "sn18.10:0.2": "1. Paṭhamavagga ",
    "sn18.10:0.3": "Khandhasutta ",
    "sn18.10:1.1": "Sāvatthiyaṁ viharati. ",
    "sn18.10:1.2": "“Taṁ kiṁ maññasi, rāhula, ",
    "sn18.10:1.3": "rūpaṁ niccaṁ vā aniccaṁ vā”ti? ",
    "sn18.10:1.4": "“Aniccaṁ, bhante” … ",
    "sn18.10:1.5": "“vedanā …pe… ",
    "sn18.10:1.6": "saññā … ",
    "sn18.10:1.7": "saṅkhārā … ",
    "sn18.10:1.8": "viññāṇaṁ niccaṁ vā aniccaṁ vā”ti? ",
    "sn18.10:1.9": "“Aniccaṁ, bhante” … ",
    "sn18.10:1.10": "“evaṁ passaṁ, rāhula, sutavā ariyasāvako rūpasmimpi nibbindati …pe… vedanāyapi nibbindati … saññāyapi nibbindati … saṅkhāresupi nibbindati … viññāṇasmimpi nibbindati; ",
    "sn18.10:1.11": "nibbindaṁ virajjati; virāgā vimuccati; vimuttasmiṁ vimuttamiti ñāṇaṁ hoti. ",
    "sn18.10:1.12": "‘Khīṇā jāti, vusitaṁ brahmacariyaṁ, kataṁ karaṇīyaṁ, nāparaṁ itthattāyā’ti pajānātī”ti. ",
    "sn18.10:1.13": "Dasamaṁ. ",
    "sn18.10:1.14": "Paṭhamo vaggo. ",
    "sn18.10:2.0": "Tassuddānaṁ ",
    "sn18.10:2.1": "Cakkhu rūpañca viññāṇaṁ, ",
    "sn18.10:2.2": "samphasso vedanāya ca; ",
    "sn18.10:2.3": "Saññā sañcetanā taṇhā, ",
    "sn18.10:2.4": "dhātu khandhena te dasāti. "
  },
  "translation_text": {
    "sn18.10:0.1": "Linked Discourses 18.10 ",
    "sn18.10:0.2": "Chapter One ",
    "sn18.10:0.3": "The Aggregates ",
    "sn18.10:1.1": "At Sāvatthī. ",
    "sn18.10:1.2": "“What do you think, Rāhula? ",
    "sn18.10:1.3": "Is form permanent or impermanent?” ",
    "sn18.10:1.4": "“Impermanent, sir.” … ",
    "sn18.10:1.5": "“… feeling … ",
    "sn18.10:1.6": "perception … ",
    "sn18.10:1.7": "choices … ",
    "sn18.10:1.8": "Is consciousness permanent or impermanent?” ",
    "sn18.10:1.9": "“Impermanent, sir.” … ",
    "sn18.10:1.10": "“Seeing this, a learned noble disciple grows disillusioned with form, feeling, perception, choices, and consciousness. ",
    "sn18.10:1.11": "Being disillusioned, desire fades away. When desire fades away they’re freed. When they’re freed, they know they’re freed. ",
    "sn18.10:1.12": "They understand: ‘Rebirth is ended, the spiritual journey has been completed, what had to be done has been done, there is nothing further for this place.’” ",
