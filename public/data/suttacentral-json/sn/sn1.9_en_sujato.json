  "root_text": {
    "sn1.9:0.1": "Saṁyutta Nikāya 1.9 ",
    "sn1.9:0.2": "1. Naḷavagga ",
    "sn1.9:0.3": "Mānakāmasutta ",
    "sn1.9:1.1": "Sāvatthinidānaṁ. ",
    "sn1.9:1.2": "Ekamantaṁ ṭhitā kho sā devatā bhagavato santike imaṁ gāthaṁ abhāsi: ",
    "sn1.9:2.1": "“Na mānakāmassa damo idhatthi, ",
    "sn1.9:2.2": "Na monamatthi asamāhitassa; ",
    "sn1.9:2.3": "Eko araññe viharaṁ pamatto, ",
    "sn1.9:2.4": "Na maccudheyyassa tareyya pāran”ti. ",
    "sn1.9:3.1": "“Mānaṁ pahāya susamāhitatto, ",
    "sn1.9:3.2": "Sucetaso sabbadhi vippamutto; ",
    "sn1.9:3.3": "Eko araññe viharaṁ appamatto, ",
    "sn1.9:3.4": "Sa maccudheyyassa tareyya pāran”ti. "
  },
  "translation_text": {
    "sn1.9:0.1": "Linked Discourses 1.9 ",
    "sn1.9:0.2": "1. A Reed ",
    "sn1.9:0.3": "Fond of Conceit ",
    "sn1.9:1.1": "At Sāvatthī. ",
    "sn1.9:1.2": "Standing to one side, that deity spoke this verse in the Buddha’s presence: ",
    "sn1.9:2.1": "“One fond of conceit can’t be tamed, ",
    "sn1.9:2.2": "no sage is lacking immersion. ",
    "sn1.9:2.3": "Living negligent alone in the wilderness, ",
    "sn1.9:2.4": "they can’t cross beyond Death’s dominion.” ",
    "sn1.9:3.1": "“Having given up conceit, serene within oneself, ",
    "sn1.9:3.2": "with a good heart, everywhere free; ",
    "sn1.9:3.3": "living diligent alone in the wilderness, ",
    "sn1.9:3.4": "they cross beyond Death’s dominion.” "
  },
  "variant_text": {
    "sn1.9:0.3": "Mānakāmasutta → namānakāmasuttaṁ (bj) "
  },
