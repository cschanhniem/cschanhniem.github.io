  "root_text": {
    "sn51.45-54:0.1": "Saṁyutta Nikāya 51.45 ",
    "sn51.45-54:0.2": "5. Appamādavagga ",
    "sn51.45-54:0.3": "Appamādavagga ",
    "sn51.45-54:1.1": "(Appamādavaggo vitthāretabbo.) ",
    "sn51.45-54:2.0": "Tassuddānaṁ ",
    "sn51.45-54:2.1": "Tathāgataṁ padaṁ kūṭaṁ, ",
    "sn51.45-54:2.2": "mūlaṁ sāro ca vassikaṁ; ",
    "sn51.45-54:2.3": "Rājā candimasūriyā, ",
    "sn51.45-54:2.4": "vatthena dasamaṁ padanti. "
  },
  "translation_text": {
    "sn51.45-54:0.1": "Linked Discourses 51.45–54 ",
    "sn51.45-54:0.2": "5. Diligence ",
    "sn51.45-54:0.3": "Diligence ",
    "sn51.45-54:1.1": "(Tell in full as in the chapter on diligence at SN 45.139–148.) ",
    "sn51.45-54:2.1": "The Realized One, footprint, roof peak, ",
    "sn51.45-54:2.2": "roots, heartwood, jasmine, ",
    "sn51.45-54:2.3": "monarch, sun and moon, ",
    "sn51.45-54:2.4": "and cloth is the tenth. "
  },
