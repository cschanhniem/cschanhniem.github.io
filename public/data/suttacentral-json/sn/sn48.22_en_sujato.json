  "root_text": {
    "sn48.22:0.1": "Saṁyutta Nikāya 48.22 ",
    "sn48.22:0.2": "3. Chaḷindriyavagga ",
    "sn48.22:0.3": "Jīvitindriyasutta ",
    "sn48.22:1.1": "“Tīṇimāni, bhikkhave, indriyāni. ",
    "sn48.22:1.2": "Katamāni tīṇi? ",
    "sn48.22:1.3": "Itthindriyaṁ, purisindriyaṁ, jīvitindriyaṁ—",
    "sn48.22:1.4": "imāni kho, bhikkhave, tīṇi indriyānī”ti. ",
    "sn48.22:1.5": "Dutiyaṁ. "
  },
  "translation_text": {
    "sn48.22:0.1": "Linked Discourses 48.22 ",
    "sn48.22:0.2": "3. The Six Faculties ",
    "sn48.22:0.3": "The Life Faculty ",
    "sn48.22:1.1": "“Mendicants, there are these three faculties. ",
    "sn48.22:1.2": "What three? ",
    "sn48.22:1.3": "The faculties of femininity, masculinity, and life. ",
    "sn48.22:1.4": "These are the three faculties.” "
  },
  "variant_text": {
    "sn48.22:0.3": "Jīvitindriyasutta → jīvita (pts1ed) "
  },
