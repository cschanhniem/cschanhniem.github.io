  "root_text": {
    "sn43.2:0.1": "Saṁyutta Nikāya 43.2 ",
    "sn43.2:0.2": "1. Paṭhamavagga ",
    "sn43.2:0.3": "Samathavipassanāsutta ",
    "sn43.2:1.1": "“Asaṅkhatañca vo, bhikkhave, desessāmi asaṅkhatagāmiñca maggaṁ. ",
    "sn43.2:1.2": "Taṁ suṇātha. ",
    "sn43.2:1.3": "Katamañca, bhikkhave, asaṅkhataṁ? ",
    "sn43.2:1.4": "Yo, bhikkhave, rāgakkhayo dosakkhayo mohakkhayo—",
    "sn43.2:1.5": "idaṁ vuccati, bhikkhave, asaṅkhataṁ. ",
    "sn43.2:1.6": "Katamo ca, bhikkhave, asaṅkhatagāmimaggo? ",
    "sn43.2:1.7": "Samatho ca vipassanā ca. ",
    "sn43.2:1.8": "Ayaṁ vuccati, bhikkhave, asaṅkhatagāmimaggo …pe…. ",
    "sn43.2:1.9": "Dutiyaṁ. "
  },
  "translation_text": {
    "sn43.2:0.1": "Linked Discourses 43.2 ",
    "sn43.2:0.2": "Chapter One ",
    "sn43.2:0.3": "Serenity and Discernment ",
    "sn43.2:1.1": "“Mendicants, I will teach you the unconditioned and the path that leads to the unconditioned. ",
    "sn43.2:1.2": "Listen … ",
    "sn43.2:1.3": "And what is the unconditioned? ",
    "sn43.2:1.4": "The ending of greed, hate, and delusion. ",
    "sn43.2:1.5": "This is called the unconditioned. ",
    "sn43.2:1.6": "And what is the path that leads to the unconditioned? ",
    "sn43.2:1.7": "Serenity and discernment. ",
    "sn43.2:1.8": "This is called the path that leads to the unconditioned. …” "
  },
  "variant_text": {
    "sn43.2:0.3": "Samathavipassanāsutta → samatho (pts1ed) "
  },
