  "root_text": {
    "sn22.138:0.1": "Saṁyutta Nikāya 22.138 ",
    "sn22.138:0.2": "14. Kukkuḷavagga ",
    "sn22.138:0.3": "Dutiyaaniccasutta ",
    "sn22.138:1.1": "Sāvatthinidānaṁ. ",
    "sn22.138:1.2": "“Yaṁ, bhikkhave, aniccaṁ; tatra vo rāgo pahātabbo. ",
    "sn22.138:1.3": "Kiñca, bhikkhave, aniccaṁ? ",
    "sn22.138:1.4": "Rūpaṁ, bhikkhave, aniccaṁ; tatra vo rāgo pahātabbo. ",
    "sn22.138:1.5": "Vedanā aniccā … ",
    "sn22.138:1.6": "saññā … ",
    "sn22.138:1.7": "saṅkhārā … ",
    "sn22.138:1.8": "viññāṇaṁ aniccaṁ; tatra vo rāgo pahātabbo. ",
    "sn22.138:1.9": "Yaṁ, bhikkhave, aniccaṁ; tatra vo rāgo pahātabbo”ti. ",
    "sn22.138:1.10": "Tatiyaṁ. "
  },
  "translation_text": {
    "sn22.138:0.1": "Linked Discourses 22.138 ",
    "sn22.138:0.2": "14. Burning Chaff ",
    "sn22.138:0.3": "Impermanence (2nd) ",
    "sn22.138:1.1": "At Sāvatthī. ",
    "sn22.138:1.2": "“Mendicants, you should give up greed for what is impermanent. ",
    "sn22.138:1.3": "And what is impermanent? ",
    "sn22.138:1.4": "Form is impermanent; you should give up greed for it. ",
    "sn22.138:1.5": "Feeling … ",
    "sn22.138:1.6": "Perception … ",
    "sn22.138:1.7": "Choices … ",
    "sn22.138:1.8": "Consciousness is impermanent; you should give up greed for it. ",
    "sn22.138:1.9": "You should give up greed for what is impermanent.” "
  },
