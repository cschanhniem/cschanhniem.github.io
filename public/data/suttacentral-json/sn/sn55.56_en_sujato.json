  "root_text": {
    "sn55.56:0.1": "Saṁyutta Nikāya 55.56 ",
    "sn55.56:0.2": "6. Sappaññavagga ",
    "sn55.56:0.3": "Sakadāgāmiphalasutta ",
    "sn55.56:1.1": "“Cattārome, bhikkhave, dhammā bhāvitā bahulīkatā sakadāgāmiphalasacchikiriyāya saṁvattanti. ",
    "sn55.56:1.2": "Katame cattāro? ",
    "sn55.56:1.3": "… pe Saṁvattantī”ti. ",
    "sn55.56:1.4": "Chaṭṭhaṁ. "
  },
  "translation_text": {
    "sn55.56:0.1": "Linked Discourses 55.56 ",
    "sn55.56:0.2": "6. A Wise Person ",
    "sn55.56:0.3": "The Fruit of Once-Return ",
    "sn55.56:1.1": "“Mendicants, when four things are developed and cultivated they lead to the realization of the fruit of once-return. …” ",
    "sn55.56:1.2": "",
    "sn55.56:1.3": ""
  },
  "variant_text": {
    "sn55.56:0.3": "Sakadāgāmiphalasutta → dutiyaphalasuttaṁ (bj); caturo phalā 2 (pts1ed) "
  },
