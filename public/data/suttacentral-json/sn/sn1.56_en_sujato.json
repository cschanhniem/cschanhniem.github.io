  "root_text": {
    "sn1.56:0.1": "Saṁyutta Nikāya 1.56 ",
    "sn1.56:0.2": "6. Jarāvagga ",
    "sn1.56:0.3": "Dutiyajanasutta ",
    "sn1.56:1.1": "“Kiṁsu janeti purisaṁ, ",
    "sn1.56:1.2": "kiṁsu tassa vidhāvati; ",
    "sn1.56:1.3": "Kiṁsu saṁsāramāpādi, ",
    "sn1.56:1.4": "kismā na parimuccatī”ti. ",
    "sn1.56:2.1": "“Taṇhā janeti purisaṁ, ",
    "sn1.56:2.2": "cittamassa vidhāvati; ",
    "sn1.56:2.3": "Satto saṁsāramāpādi, ",
    "sn1.56:2.4": "dukkhā na parimuccatī”ti. "
  },
  "translation_text": {
    "sn1.56:0.1": "Linked Discourses 1.56 ",
    "sn1.56:0.2": "6. Old Age ",
    "sn1.56:0.3": "Gives Birth (2nd) ",
    "sn1.56:1.1": "“What gives birth to a person? ",
    "sn1.56:1.2": "What do they have that runs about? ",
    "sn1.56:1.3": "What enters transmigration? ",
    "sn1.56:1.4": "From what are they not free?” ",
    "sn1.56:2.1": "“Craving gives birth to a person. ",
    "sn1.56:2.2": "Their mind is what runs about. ",
    "sn1.56:2.3": "A sentient being enters transmigration. ",
    "sn1.56:2.4": "From suffering they are not free.” "
  },
  "variant_text": {
    "sn1.56:0.3": "Dutiyajanasutta → dutiyajanetisuttaṁ (bj) "
  },
