  "root_text": {
    "sn28.5:0.1": "Saṁyutta Nikāya 28.5 ",
    "sn28.5:0.2": "1. Sāriputtavagga ",
    "sn28.5:0.3": "Ākāsānañcāyatanasutta ",
    "sn28.5:1.1": "Sāvatthinidānaṁ. ",
    "sn28.5:1.2": "Addasā kho āyasmā ānando …pe… ",
    "sn28.5:1.3": "“idhāhaṁ, āvuso, sabbaso rūpasaññānaṁ samatikkamā paṭighasaññānaṁ atthaṅgamā nānattasaññānaṁ amanasikārā ananto ākāsoti ākāsānañcāyatanaṁ upasampajja viharāmi …pe… ",
    "sn28.5:1.4": "vuṭṭhitoti vā”ti. ",
    "sn28.5:1.5": "Pañcamaṁ. "
  },
  "translation_text": {
    "sn28.5:0.1": "Linked Discourses 28.5 ",
    "sn28.5:0.2": "1. With Sāriputta ",
    "sn28.5:0.3": "The Dimension of Infinite Space ",
    "sn28.5:1.1": "At Sāvatthī. ",
    "sn28.5:1.2": "Venerable Ānanda saw Venerable Sāriputta … ",
    "sn28.5:1.3": "“Reverend, going totally beyond perceptions of form, with the disappearance of perceptions of impingement, not focusing on perceptions of diversity, aware that ‘space is infinite’, I entered and remained in the dimension of infinite space. …” … ",
    "sn28.5:1.4": ""
  },
  "variant_text": {
    "sn28.5:0.3": "Ākāsānañcāyatanasutta → ākāsa (pts1ed) "
  },
