    "sn30.17-46:1.15": "",
    "sn30.17-46:1.16": "",
    "sn30.17-46:1.17": "(Tell all in full.) ",
    "sn30.17-46:1.18": "",
    "sn30.17-46:2.1": "",
    "sn30.17-46:2.2": "",
    "sn30.17-46:2.3": "",
    "sn30.17-46:2.4": "",
    "sn30.17-46:2.5": "The Linked Discourses on phoenixes are complete. "
  },
