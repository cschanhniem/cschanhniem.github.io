  "root_text": {
    "sn45.167:0.1": "Saṁyutta Nikāya 45.167 ",
    "sn45.167:0.2": "13. Esanāvagga ",
    "sn45.167:0.3": "Malasutta ",
    "sn45.167:1.1": "“Tīṇimāni, bhikkhave, malāni. ",
    "sn45.167:1.2": "Katamāni tīṇi? ",
    "sn45.167:1.3": "Rāgo malaṁ, doso malaṁ, moho malaṁ—",
    "sn45.167:1.4": "imāni kho, bhikkhave, tīṇi malāni. ",
    "sn45.167:1.5": "Imesaṁ kho, bhikkhave, tiṇṇannaṁ malānaṁ abhiññāya pariññāya parikkhayāya pahānāya …pe… ayaṁ ariyo aṭṭhaṅgiko maggo bhāvetabbo”ti. ",
    "sn45.167:1.6": "Sattamaṁ. "
  },
  "translation_text": {
    "sn45.167:0.1": "Linked Discourses 45.167 ",
    "sn45.167:0.2": "13. Searches ",
    "sn45.167:0.3": "Stains ",
    "sn45.167:1.1": "“Mendicants, there are these three stains. ",
    "sn45.167:1.2": "What three? ",
    "sn45.167:1.3": "Greed, hate, and delusion. ",
    "sn45.167:1.4": "These are the three stains. ",
    "sn45.167:1.5": "The noble eightfold path should be developed for the direct knowledge, complete understanding, finishing, and giving up of these three stains.” "
  },
