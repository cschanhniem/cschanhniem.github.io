  "root_text": {
    "sn1.72:0.1": "Saṁyutta Nikāya 1.72 ",
    "sn1.72:0.2": "8. Chetvāvagga ",
    "sn1.72:0.3": "Rathasutta ",
    "sn1.72:1.1": "“Kiṁsu rathassa paññāṇaṁ, ",
    "sn1.72:1.2": "kiṁsu paññāṇamaggino; ",
    "sn1.72:1.3": "Kiṁsu raṭṭhassa paññāṇaṁ, ",
    "sn1.72:1.4": "kiṁsu paññāṇamitthiyā”ti. ",
    "sn1.72:2.1": "“Dhajo rathassa paññāṇaṁ, ",
    "sn1.72:2.2": "dhūmo paññāṇamaggino; ",
    "sn1.72:2.3": "Rājā raṭṭhassa paññāṇaṁ, ",
    "sn1.72:2.4": "bhattā paññāṇamitthiyā”ti. "
  },
  "translation_text": {
    "sn1.72:0.1": "Linked Discourses 1.72 ",
    "sn1.72:0.2": "8. Slain ",
    "sn1.72:0.3": "A Chariot ",
    "sn1.72:1.1": "“What is a chariot known by? ",
    "sn1.72:1.2": "What is fire known by? ",
    "sn1.72:1.3": "What is a nation known by? ",
    "sn1.72:1.4": "What is a woman known by?” ",
    "sn1.72:2.1": "“A chariot is known by a banner. ",
    "sn1.72:2.2": "Fire is known by smoke. ",
    "sn1.72:2.3": "A nation is known by its ruler. ",
    "sn1.72:2.4": "A woman is known by her husband.” "
  },
