  "root_text": {
    "sn37.9:0.1": "Saṁyutta Nikāya 37.9 ",
    "sn37.9:0.2": "1. Paṭhamapeyyālavagga ",
    "sn37.9:0.3": "Aticārīsutta ",
    "sn37.9:1.1": "“Pañcahi, anuruddha, dhammehi samannāgato mātugāmo …pe… apāyaṁ duggatiṁ vinipātaṁ nirayaṁ upapajjati. ",
    "sn37.9:1.2": "Katamehi pañcahi? ",
    "sn37.9:1.3": "Assaddho ca hoti, ahiriko ca hoti, anottappī ca hoti, aticārī ca hoti, duppañño ca hoti—",
    "sn37.9:1.4": "imehi kho, anuruddha, pañcahi dhammehi samannāgato mātugāmo …pe… upapajjatī”ti. ",
    "sn37.9:1.5": "Navamaṁ. "
  },
  "translation_text": {
    "sn37.9:0.1": "Linked Discourses 37.9 ",
    "sn37.9:0.2": "1. Abbreviated Texts ",
    "sn37.9:0.3": "Adultery ",
    "sn37.9:1.1": "",
    "sn37.9:1.2": "",
    "sn37.9:1.3": "“… They’re faithless, shameless, imprudent, adulterous, and witless. …” ",
    "sn37.9:1.4": ""
  },
