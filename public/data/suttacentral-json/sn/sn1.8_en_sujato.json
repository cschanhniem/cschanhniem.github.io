  "root_text": {
    "sn1.8:0.1": "Saṁyutta Nikāya 1.8 ",
    "sn1.8:0.2": "1. Naḷavagga ",
    "sn1.8:0.3": "Susammuṭṭhasutta ",
    "sn1.8:1.1": "Sāvatthinidānaṁ. ",
    "sn1.8:1.2": "Ekamantaṁ ṭhitā kho sā devatā bhagavato santike imaṁ gāthaṁ abhāsi: ",
    "sn1.8:2.1": "“Yesaṁ dhammā susammuṭṭhā, ",
    "sn1.8:2.2": "paravādesu nīyare; ",
    "sn1.8:2.3": "Suttā te nappabujjhanti, ",
    "sn1.8:2.4": "kālo tesaṁ pabujjhitun”ti. ",
    "sn1.8:3.1": "“Yesaṁ dhammā asammuṭṭhā, ",
    "sn1.8:3.2": "paravādesu na nīyare; ",
    "sn1.8:3.3": "Te sambuddhā sammadaññā, ",
    "sn1.8:3.4": "caranti visame saman”ti. "
  },
  "translation_text": {
    "sn1.8:0.1": "Linked Discourses 1.8 ",
    "sn1.8:0.2": "1. A Reed ",
    "sn1.8:0.3": "Very Confused ",
    "sn1.8:1.1": "At Sāvatthī. ",
    "sn1.8:1.2": "Standing to one side, that deity spoke this verse in the Buddha’s presence: ",
    "sn1.8:2.1": "“Those who are very confused about the teachings ",
    "sn1.8:2.2": "may be led astray by the doctrines of others. ",
    "sn1.8:2.3": "Asleep, they have not woken up: ",
    "sn1.8:2.4": "it is time for them to wake!” ",
    "sn1.8:3.1": "“Those who are unconfused about the teachings, ",
    "sn1.8:3.2": "won’t be led astray by the doctrines of others. ",
    "sn1.8:3.3": "They have woken up, they rightly know, ",
    "sn1.8:3.4": "smoothly they walk in the rough.” "
  },
