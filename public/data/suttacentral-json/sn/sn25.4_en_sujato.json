  "root_text": {
    "sn25.4:0.1": "Saṁyutta Nikāya 25.4 ",
    "sn25.4:0.2": "1. Cakkhuvagga ",
    "sn25.4:0.3": "Samphassasutta ",
    "sn25.4:1.1": "Sāvatthinidānaṁ. ",
    "sn25.4:1.2": "“Cakkhusamphasso, bhikkhave, anicco vipariṇāmī aññathābhāvī; ",
    "sn25.4:1.3": "sotasamphasso … ",
    "sn25.4:1.4": "ghānasamphasso … ",
    "sn25.4:1.5": "jivhāsamphasso … ",
    "sn25.4:1.6": "kāyasamphasso … ",
    "sn25.4:1.7": "manosamphasso anicco vipariṇāmī aññathābhāvī. ",
    "sn25.4:1.8": "Yo, bhikkhave, ime dhamme evaṁ saddahati adhimuccati, ayaṁ vuccati ‘saddhānusārī …pe… ",
    "sn25.4:1.9": "sambodhiparāyano’”ti. ",
    "sn25.4:1.10": "Catutthaṁ. "
  },
  "translation_text": {
    "sn25.4:0.1": "Linked Discourses 25.4 ",
    "sn25.4:0.2": "1. The Eye ",
    "sn25.4:0.3": "Contact ",
    "sn25.4:1.1": "At Sāvatthī. ",
    "sn25.4:1.2": "“Mendicants, eye contact is impermanent, decaying, and perishing. ",
    "sn25.4:1.3": "Ear contact, ",
    "sn25.4:1.4": "nose contact, ",
    "sn25.4:1.5": "tongue contact, ",
    "sn25.4:1.6": "body contact, ",
    "sn25.4:1.7": "and mind contact are impermanent, decaying, and perishing. ",
    "sn25.4:1.8": "Someone who has faith and confidence in these teachings is called a follower by faith. …” ",
    "sn25.4:1.9": ""
  },
  "variant_text": {
    "sn25.4:0.3": "Samphassasutta → phassasuttaṁ (bj); phasso (pts1ed) "
  },
