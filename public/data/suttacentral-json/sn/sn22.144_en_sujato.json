  "root_text": {
    "sn22.144:0.1": "Saṁyutta Nikāya 22.144 ",
    "sn22.144:0.2": "14. Kukkuḷavagga ",
    "sn22.144:0.3": "Dutiyaanattasutta ",
    "sn22.144:1.1": "Sāvatthinidānaṁ. ",
    "sn22.144:1.2": "“Yo, bhikkhave, anattā; tatra vo rāgo pahātabbo. ",
    "sn22.144:1.3": "Ko ca, bhikkhave, anattā? ",
    "sn22.144:1.4": "Rūpaṁ, bhikkhave, anattā; tatra vo rāgo pahātabbo. ",
    "sn22.144:1.5": "Vedanā anattā … ",
    "sn22.144:1.6": "saññā … ",
    "sn22.144:1.7": "saṅkhārā … ",
    "sn22.144:1.8": "viññāṇaṁ anattā; tatra vo rāgo pahātabbo. ",
    "sn22.144:1.9": "Yo, bhikkhave, anattā; tatra vo rāgo pahātabbo”ti. ",
    "sn22.144:1.10": "Navamaṁ. "
  },
  "translation_text": {
    "sn22.144:0.1": "Linked Discourses 22.144 ",
    "sn22.144:0.2": "14. Burning Chaff ",
    "sn22.144:0.3": "Not-Self (2nd) ",
    "sn22.144:1.1": "At Sāvatthī. ",
    "sn22.144:1.2": "“Mendicants, you should give up greed for what is not-self. …” ",
