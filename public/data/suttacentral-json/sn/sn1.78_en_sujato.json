  "root_text": {
    "sn1.78:0.1": "Saṁyutta Nikāya 1.78 ",
    "sn1.78:0.2": "8. Chetvāvagga ",
    "sn1.78:0.3": "Kāmasutta ",
    "sn1.78:1.1": "“Kimatthakāmo na dade, ",
    "sn1.78:1.2": "kiṁ macco na pariccaje; ",
    "sn1.78:1.3": "Kiṁsu muñceyya kalyāṇaṁ, ",
    "sn1.78:1.4": "pāpikaṁ na ca mocaye”ti. ",
    "sn1.78:2.1": "“Attānaṁ na dade poso, ",
    "sn1.78:2.2": "attānaṁ na pariccaje; ",
    "sn1.78:2.3": "Vācaṁ muñceyya kalyāṇaṁ, ",
    "sn1.78:2.4": "pāpikañca na mocaye”ti. "
  },
  "translation_text": {
    "sn1.78:0.1": "Linked Discourses 1.78 ",
    "sn1.78:0.2": "8. Slain ",
    "sn1.78:0.3": "Desire ",
    "sn1.78:1.1": "“What should one who wants what’s best <j>not give away? ",
    "sn1.78:1.2": "What should a mortal not forsake? ",
    "sn1.78:1.3": "What should be released when it’s good, ",
    "sn1.78:1.4": "but not when it’s bad?” ",
    "sn1.78:2.1": "“A man shouldn’t give away himself. ",
    "sn1.78:2.2": "He shouldn’t forsake himself. ",
    "sn1.78:2.3": "Speech should be released when it’s good, ",
    "sn1.78:2.4": "but not when it’s bad.” "
  },
