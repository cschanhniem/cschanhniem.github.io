  "root_text": {
    "sn35.169:0.1": "Saṁyutta Nikāya 35.169 ",
    "sn35.169:0.2": "17. Saṭṭhipeyyālavagga ",
    "sn35.169:0.3": "Ajjhattaaniccarāgasutta ",
    "sn35.169:1.1": "“Yaṁ, bhikkhave, aniccaṁ, tatra vo rāgo pahātabbo. ",
    "sn35.169:1.2": "Kiñca, bhikkhave, aniccaṁ? ",
    "sn35.169:1.3": "Cakkhu, bhikkhave, aniccaṁ; ",
    "sn35.169:1.4": "tatra vo rāgo pahātabbo …pe… ",
    "sn35.169:1.5": "jivhā aniccā; ",
    "sn35.169:1.6": "tatra vo rāgo pahātabbo …pe… ",
    "sn35.169:1.7": "mano anicco; ",
    "sn35.169:1.8": "tatra vo rāgo pahātabbo. ",
    "sn35.169:1.9": "Yaṁ, bhikkhave, aniccaṁ, tatra vo rāgo pahātabbo”ti. "
  },
  "translation_text": {
    "sn35.169:0.1": "Linked Discourses 35.169 ",
    "sn35.169:0.2": "17. Sixty Abbreviated Texts ",
    "sn35.169:0.3": "Greed for the Impermanent Interior ",
    "sn35.169:1.1": "“Mendicants, you should give up greed for what is impermanent. ",
    "sn35.169:1.2": "And what is impermanent? ",
    "sn35.169:1.3": "The eye, ear, nose, tongue, body, and mind are impermanent …” ",
