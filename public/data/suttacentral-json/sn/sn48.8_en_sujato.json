  "root_text": {
    "sn48.8:0.1": "Saṁyutta Nikāya 48.8 ",
    "sn48.8:0.2": "1. Suddhikavagga ",
    "sn48.8:0.3": "Daṭṭhabbasutta ",
    "sn48.8:1.1": "“Pañcimāni, bhikkhave, indriyāni. ",
    "sn48.8:1.2": "Katamāni pañca? ",
    "sn48.8:1.3": "Saddhindriyaṁ …pe… paññindriyaṁ. ",
    "sn48.8:1.4": "Kattha ca, bhikkhave, saddhindriyaṁ daṭṭhabbaṁ? ",
    "sn48.8:1.5": "Catūsu sotāpattiyaṅgesu—",
    "sn48.8:1.6": "ettha saddhindriyaṁ daṭṭhabbaṁ. ",
    "sn48.8:1.7": "Kattha ca, bhikkhave, vīriyindriyaṁ daṭṭhabbaṁ? ",
    "sn48.8:1.8": "Catūsu sammappadhānesu—",
    "sn48.8:1.9": "ettha vīriyindriyaṁ daṭṭhabbaṁ. ",
    "sn48.8:1.10": "Kattha ca, bhikkhave, satindriyaṁ daṭṭhabbaṁ? ",
    "sn48.8:1.11": "Catūsu satipaṭṭhānesu—",
    "sn48.8:1.12": "ettha satindriyaṁ daṭṭhabbaṁ. ",
    "sn48.8:1.13": "Kattha ca, bhikkhave, samādhindriyaṁ daṭṭhabbaṁ? ",
    "sn48.8:1.14": "Catūsu jhānesu—",
    "sn48.8:1.15": "ettha samādhindriyaṁ daṭṭhabbaṁ. ",
    "sn48.8:1.16": "Kattha ca, bhikkhave, paññindriyaṁ daṭṭhabbaṁ? ",
    "sn48.8:1.17": "Catūsu ariyasaccesu—",
    "sn48.8:1.18": "ettha paññindriyaṁ daṭṭhabbaṁ. ",
    "sn48.8:1.19": "Imāni kho, bhikkhave, pañcindriyānī”ti. ",
    "sn48.8:1.20": "Aṭṭhamaṁ. "
  },
  "translation_text": {
    "sn48.8:0.1": "Linked Discourses 48.8 ",
    "sn48.8:0.2": "1. Plain Version ",
    "sn48.8:0.3": "Should Be Seen ",
    "sn48.8:1.1": "“Mendicants, there are these five faculties. ",
    "sn48.8:1.2": "What five? ",
    "sn48.8:1.3": "The faculties of faith, energy, mindfulness, immersion, and wisdom. ",
    "sn48.8:1.4": "And where should the faculty of faith be seen? ",
    "sn48.8:1.5": "In the four factors of stream-entry. ",
    "sn48.8:1.6": "",
    "sn48.8:1.7": "And where should the faculty of energy be seen? ",
    "sn48.8:1.8": "In the four right efforts. ",
    "sn48.8:1.9": "",
    "sn48.8:1.10": "And where should the faculty of mindfulness be seen? ",
    "sn48.8:1.11": "In the four kinds of mindfulness meditation. ",
    "sn48.8:1.12": "",
    "sn48.8:1.13": "And where should the faculty of immersion be seen? ",
    "sn48.8:1.14": "In the four absorptions. ",
    "sn48.8:1.15": "",
    "sn48.8:1.16": "And where should the faculty of wisdom be seen? ",
    "sn48.8:1.17": "In the four noble truths. ",
    "sn48.8:1.18": "",
    "sn48.8:1.19": "These are the five faculties.” "
  },
