{
  "comment_text": {
    "sn9.2:0.3": "",
    "sn9.2:1.2": "A midday nap in the heat was common (<a href='https://suttacentral.net/dn23/en/sujato#15.2'>DN 23:15.2</a>), but was considered a vice in excess (<a href='https://suttacentral.net/dn31/en/sujato#14.14'>DN 31:14.14</a>). The Buddha defended the practice, saying that he took a nap on occasion (<a href='https://suttacentral.net/mn36/en/sujato#45.8'>MN 36:45.8</a>). ",
    "sn9.2:5.3": ""
  },
