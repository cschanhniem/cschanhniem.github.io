  "root_text": {
    "sn36.30:0.1": "Saṁyutta Nikāya 36.30 ",
    "sn36.30:0.2": "3. Aṭṭhasatapariyāyavagga ",
    "sn36.30:0.3": "Suddhikasutta ",
    "sn36.30:1.1": "“Tisso imā, bhikkhave, vedanā. ",
    "sn36.30:1.2": "Katamā tisso? ",
    "sn36.30:1.3": "Sukhā vedanā, dukkhā vedanā, adukkhamasukhā vedanā—",
    "sn36.30:1.4": "imā kho, bhikkhave, tisso vedanā”ti. ",
    "sn36.30:1.5": "Dasamaṁ. "
  },
  "translation_text": {
    "sn36.30:0.1": "Linked Discourses 36.30 ",
    "sn36.30:0.2": "3. The Explanation of the Hundred and Eight ",
    "sn36.30:0.3": "Plain Version ",
    "sn36.30:1.1": "“Mendicants, there are these three feelings. ",
    "sn36.30:1.2": "What three? ",
    "sn36.30:1.3": "Pleasant, painful, and neutral feelings. ",
    "sn36.30:1.4": "These are the three feelings.” "
  },
  "variant_text": {
    "sn36.30:0.3": "Suddhikasutta → suddhikavedanāsuttaṁ (bj); suddhikaṁ nirāmisaṁ (pts1ed) "
  },
