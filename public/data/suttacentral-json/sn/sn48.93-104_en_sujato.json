  "root_text": {
    "sn48.93-104:0.1": "Saṁyutta Nikāya 48.93 ",
    "sn48.93-104:0.2": "10. Balakaraṇīyavagga ",
    "sn48.93-104:0.3": "Balakaraṇīyavagga ",
    "sn48.93-104:1.1": "(Balakaraṇīyavaggo vitthāretabbo.) ",
    "sn48.93-104:2.0": "Tassuddānaṁ ",
    "sn48.93-104:2.1": "Balaṁ bījañca nāgo ca, ",
    "sn48.93-104:2.2": "rukkho kumbhena sūkiyā; ",
    "sn48.93-104:2.3": "Ākāsena ca dve meghā, ",
    "sn48.93-104:2.4": "nāvā āgantukā nadīti. "
  },
  "translation_text": {
    "sn48.93-104:0.1": "Linked Discourses 48.93–104 ",
    "sn48.93-104:0.2": "10. The Chapter on Hard Work ",
    "sn48.93-104:0.3": "The Chapter on Hard Work ",
    "sn48.93-104:1.1": "(Tell in full as in the chapter on hard work at SN 45.149–160.) ",
    "sn48.93-104:2.1": "Hard work, seeds, and dragons, ",
    "sn48.93-104:2.2": "a tree, a pot, and a spike, ",
    "sn48.93-104:2.3": "the atmosphere, and two on clouds, ",
    "sn48.93-104:2.4": "a ship, a guest house, and a river. "
  },
