  "root_text": {
    "sn35.144:0.1": "Saṁyutta Nikāya 35.144 ",
    "sn35.144:0.2": "14. Devadahavagga ",
    "sn35.144:0.3": "Bāhiradukkhahetusutta ",
    "sn35.144:1.1": "“Rūpā, bhikkhave, dukkhā. ",
    "sn35.144:1.2": "Yopi hetu, yopi paccayo rūpānaṁ uppādāya, sopi dukkho. ",
    "sn35.144:1.3": "Dukkhasambhūtā, bhikkhave, rūpā kuto sukhā bhavissanti. ",
    "sn35.144:1.4": "Saddā … ",
    "sn35.144:1.5": "gandhā … ",
    "sn35.144:1.6": "rasā … ",
    "sn35.144:1.7": "phoṭṭhabbā … ",
    "sn35.144:1.8": "dhammā dukkhā. ",
    "sn35.144:1.9": "Yopi hetu, yopi paccayo dhammānaṁ uppādāya, sopi dukkho. ",
    "sn35.144:1.10": "Dukkhasambhūtā, bhikkhave, dhammā kuto sukhā bhavissanti. ",
    "sn35.144:1.11": "Evaṁ passaṁ …pe… ",
    "sn35.144:1.12": "nāparaṁ itthattāyā’ti pajānātī”ti. ",
    "sn35.144:1.13": "Ekādasamaṁ. "
  },
  "translation_text": {
    "sn35.144:0.1": "Linked Discourses 35.144 ",
    "sn35.144:0.2": "14. At Devadaha ",
    "sn35.144:0.3": "Exterior and Cause Are Suffering ",
    "sn35.144:1.1": "“Mendicants, sights are suffering. ",
    "sn35.144:1.2": "The cause and reason that gives rise to sights is also suffering. ",
    "sn35.144:1.3": "Since sights are produced by what is suffering, how could they be happiness? ",
    "sn35.144:1.4": "Sounds … ",
    "sn35.144:1.5": "Smells … ",
    "sn35.144:1.6": "Tastes … ",
    "sn35.144:1.7": "Touches … ",
    "sn35.144:1.8": "Ideas are suffering. ",
    "sn35.144:1.9": "The cause and reason that gives rise to ideas is also suffering. ",
    "sn35.144:1.10": "Since ideas are produced by what is suffering, how could they be happiness? ",
    "sn35.144:1.11": "Seeing this … ",
    "sn35.144:1.12": "They understand: ‘… there is nothing further for this place.’” "
  },
  "variant_text": {
    "sn35.144:0.3": "Bāhiradukkhahetusutta → bāhiradukkhasuttaṁ (bj); hetunā bāhira 2 (pts1ed) "
  },
