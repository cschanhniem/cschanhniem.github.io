  "root_text": {
    "sn46.131-142:0.1": "Saṁyutta Nikāya 46.131–142 ",
    "sn46.131-142:0.2": "14. Punagaṅgāpeyyālavagga ",
    "sn46.131-142:0.3": "Punagaṅgānadīādisutta ",
    "sn46.131-142:1.1": "…pe… ",
    "sn46.131-142:1.2": "vaggo cuddasamo. ",
    "sn46.131-142:2.0": "Uddānaṁ ",
    "sn46.131-142:2.1": "Cha pācīnato ninnā, ",
    "sn46.131-142:2.2": "cha ninnā ca samuddato; ",
    "sn46.131-142:2.3": "Dvete cha dvādasa honti, ",
    "sn46.131-142:2.4": "vaggo tena pavuccatīti. ",
    "sn46.131-142:3.1": "(Bojjhaṅgasaṁyuttassa gaṅgāpeyyālaṁ rāgavasena vitthāretabbaṁ.) "
  },
  "translation_text": {
    "sn46.131-142:0.1": "Linked Discourses 46.131–142 ",
    "sn46.131-142:0.2": "14. Another Chapter of Abbreviated Texts on the Ganges ",
    "sn46.131-142:0.3": "More on the Ganges River, Etc. ",
