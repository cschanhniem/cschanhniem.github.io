  "root_text": {
    "sn35.195-197:0.1": "Saṁyutta Nikāya 35.195–197 ",
    "sn35.195-197:0.2": "17. Saṭṭhipeyyālavagga ",
    "sn35.195-197:0.3": "Bāhirātītādianiccasutta ",
    "sn35.195-197:1.1": "“Rūpā, bhikkhave, aniccā atītā anāgatā paccuppannā. Saddā … gandhā … rasā … phoṭṭhabbā … dhammā aniccā atītā anāgatā paccuppannā. ",
    "sn35.195-197:1.2": "Evaṁ passaṁ …pe… ",
    "sn35.195-197:1.3": "nāparaṁ itthattāyāti pajānātī”ti. "
  },
  "translation_text": {
    "sn35.195-197:0.1": "Linked Discourses 35.195–197 ",
    "sn35.195-197:0.2": "17. Sixty Abbreviated Texts ",
    "sn35.195-197:0.3": "The Exterior as Impermanent in the Three Times ",
    "sn35.195-197:1.1": "“Mendicants, in the past … future … present sights, sounds, smells, tastes, touches, and ideas are impermanent …” ",
    "sn35.195-197:1.2": ""
  },
