  "root_text": {
    "sn35.66:0.1": "Saṁyutta Nikāya 35.66 ",
    "sn35.66:0.2": "7. Migajālavagga ",
    "sn35.66:0.3": "Samiddhisattapañhāsutta ",
    "sn35.66:1.1": "“‘Satto, satto’ti, bhante, vuccati. ",
    "sn35.66:1.2": "Kittāvatā nu kho, bhante, satto vā assa sattapaññatti vā”ti …pe…. ",
    "sn35.66:1.3": "Catutthaṁ. "
  },
  "translation_text": {
    "sn35.66:0.1": "Linked Discourses 35.66 ",
    "sn35.66:0.2": "7. With Migajāla ",
    "sn35.66:0.3": "Samiddhi’s Question About a Sentient Being ",
    "sn35.66:1.1": "“Sir, they speak of this thing called a ‘sentient being’. ",
    "sn35.66:1.2": "How do we define a sentient being or what is known as a sentient being?” … "
  },
