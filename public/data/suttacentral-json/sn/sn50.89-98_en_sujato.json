  "root_text": {
    "sn50.89-98:0.1": "Saṁyutta Nikāya 50.89–98 ",
    "sn50.89-98:0.2": "8. Punaesanāvagga ",
    "sn50.89-98:0.3": "Punaesanādisutta ",
    "sn50.89-98:1.1": "(Evaṁ esanāpāḷi vitthāretabbā—rāgavinayapariyosānaṁ dosavinayapariyosānaṁ mohavinayapariyosānaṁ.) ",
    "sn50.89-98:1.2": "Esanāvaggo navamo. ",
    "sn50.89-98:2.0": "Tassuddānaṁ ",
    "sn50.89-98:2.1": "Esanā vidhā āsavo, ",
    "sn50.89-98:2.2": "Bhavo ca dukkhatā tisso; ",
    "sn50.89-98:2.3": "Khilaṁ malañca nīgho ca, ",
    "sn50.89-98:2.4": "Vedanā taṇhā tasinā cāti. "
  },
  "translation_text": {
    "sn50.89-98:0.1": "Linked Discourses 50.89–98 ",
    "sn50.89-98:0.2": "8. Another Chapter on Searches ",
    "sn50.89-98:0.3": "Another Series on Searches, Etc. ",
    "sn50.89-98:1.1": "(Tell in full as in SN 45.161–170, removal of greed version.) ",
    "sn50.89-98:1.2": "",
    "sn50.89-98:2.1": "Searches, discriminations, defilements, ",
    "sn50.89-98:2.2": "states of existence, three kinds of suffering, ",
    "sn50.89-98:2.3": "barrenness, stains, and troubles, ",
    "sn50.89-98:2.4": "feelings, craving, and thirst. "
  },
