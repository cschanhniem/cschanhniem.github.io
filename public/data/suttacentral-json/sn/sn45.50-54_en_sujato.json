  "root_text": {
    "sn45.50-54:0.1": "Saṁyutta Nikāya 45.50–54 ",
    "sn45.50-54:0.2": "6. Sūriyapeyyālavagga ",
    "sn45.50-54:0.3": "Sīlasampadādisuttapañcaka ",
    "sn45.50-54:1.1": "“Sūriyassa, bhikkhave, udayato etaṁ pubbaṅgamaṁ etaṁ pubbanimittaṁ, yadidaṁ—aruṇuggaṁ; ",
    "sn45.50-54:1.2": "evameva kho, bhikkhave, bhikkhuno ariyassa aṭṭhaṅgikassa maggassa uppādāya etaṁ pubbaṅgamaṁ etaṁ pubbanimittaṁ, yadidaṁ—sīlasampadā. ",
    "sn45.50-54:1.3": "Sīlasampannassetaṁ, bhikkhave, bhikkhuno pāṭikaṅkhaṁ …pe… ",
    "sn45.50-54:1.4": "yadidaṁ—chandasampadā …pe… ",
    "sn45.50-54:1.5": "yadidaṁ—attasampadā …pe… ",
    "sn45.50-54:1.6": "yadidaṁ—diṭṭhisampadā …pe… ",
    "sn45.50-54:1.7": "yadidaṁ—appamādasampadā …pe…. ",
    "sn45.50-54:1.8": "Chaṭṭhaṁ. "
  },
  "translation_text": {
    "sn45.50-54:0.1": "Linked Discourses 45.50–54 ",
    "sn45.50-54:0.2": "6. Abbreviated Texts on the Sun ",
    "sn45.50-54:0.3": "Five Discourses on Accomplishment in Ethics, Etc. (1st) ",
    "sn45.50-54:1.1": "“Mendicants, the dawn is the forerunner and precursor of the sunrise. ",
    "sn45.50-54:1.2": "In the same way accomplishment in ethics is the forerunner and precursor of the noble eightfold path for a mendicant. ",
    "sn45.50-54:1.3": "A mendicant accomplished in ethics can expect …” … ",
    "sn45.50-54:1.4": "“… accomplished in enthusiasm …” ",
    "sn45.50-54:1.5": "“… accomplished in self-development …” ",
    "sn45.50-54:1.6": "“… accomplished in view …” ",
    "sn45.50-54:1.7": "“… accomplished in diligence …” "
  },
  "variant_text": {
    "sn45.50-54:0.3": "Sīlasampadādisuttapañcaka → appamādasuttaṁ (bj); appamāda (pts1ed) "
  },
