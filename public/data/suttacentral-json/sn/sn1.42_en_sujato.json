  "root_text": {
    "sn1.42:0.1": "Saṁyutta Nikāya 1.42 ",
    "sn1.42:0.2": "5. Ādittavagga ",
    "sn1.42:0.3": "Kiṁdadasutta ",
    "sn1.42:1.1": "“Kiṁdado balado hoti, ",
    "sn1.42:1.2": "kiṁdado hoti vaṇṇado; ",
    "sn1.42:1.3": "Kiṁdado sukhado hoti, ",
    "sn1.42:1.4": "kiṁdado hoti cakkhudo; ",
    "sn1.42:1.5": "Ko ca sabbadado hoti, ",
    "sn1.42:1.6": "taṁ me akkhāhi pucchito”ti. ",
    "sn1.42:2.1": "“Annado balado hoti, ",
    "sn1.42:2.2": "vatthado hoti vaṇṇado; ",
    "sn1.42:2.3": "Yānado sukhado hoti, ",
    "sn1.42:2.4": "dīpado hoti cakkhudo. ",
    "sn1.42:3.1": "So ca sabbadado hoti, ",
    "sn1.42:3.2": "yo dadāti upassayaṁ; ",
    "sn1.42:3.3": "Amataṁ dado ca so hoti, ",
    "sn1.42:3.4": "yo dhammamanusāsatī”ti. "
  },
  "translation_text": {
    "sn1.42:0.1": "Linked Discourses 1.42 ",
    "sn1.42:0.2": "5. On Fire ",
    "sn1.42:0.3": "Giving What? ",
    "sn1.42:1.1": "“Giving what do you give strength? ",
    "sn1.42:1.2": "Giving what do you give beauty? ",
    "sn1.42:1.3": "Giving what do you give happiness? ",
    "sn1.42:1.4": "Giving what do you give vision? ",
    "sn1.42:1.5": "And who is the giver of all? ",
    "sn1.42:1.6": "Please answer my question.” ",
    "sn1.42:2.1": "“Giving food you give strength. ",
    "sn1.42:2.2": "Giving clothes you give beauty. ",
    "sn1.42:2.3": "Giving a vehicle you give happiness. ",
    "sn1.42:2.4": "Giving a lamp you give vision. ",
    "sn1.42:3.1": "And the giver of all ",
    "sn1.42:3.2": "is the one who gives monastic quarters. ",
    "sn1.42:3.3": "But one who teaches the Dhamma ",
    "sn1.42:3.4": "gives the gift of freedom from death.” "
  },
