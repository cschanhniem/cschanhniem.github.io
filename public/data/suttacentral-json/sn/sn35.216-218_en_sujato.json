  "root_text": {
    "sn35.216-218:0.1": "Saṁyutta Nikāya 35.216–218 ",
    "sn35.216-218:0.2": "17. Saṭṭhipeyyālavagga ",
    "sn35.216-218:0.3": "Bāhirātītādiyaṁdukkhasutta ",
    "sn35.216-218:1.1": "“Rūpā, bhikkhave, dukkhā atītā anāgatā paccuppannā. ",
    "sn35.216-218:1.2": "Yaṁ dukkhaṁ, tadanattā. ",
    "sn35.216-218:1.3": "Yadanattā, taṁ ‘netaṁ mama, nesohamasmi, na meso attā’ti evametaṁ yathābhūtaṁ sammappaññāya daṭṭhabbaṁ. ",
    "sn35.216-218:1.4": "Saddā … ",
    "sn35.216-218:1.5": "gandhā … ",
    "sn35.216-218:1.6": "rasā … ",
    "sn35.216-218:1.7": "phoṭṭhabbā … ",
    "sn35.216-218:1.8": "dhammā dukkhā atītā anāgatā paccuppannā. ",
    "sn35.216-218:1.9": "Yaṁ dukkhaṁ, tadanattā. ",
    "sn35.216-218:1.10": "Yadanattā, taṁ ‘netaṁ mama, nesohamasmi, na meso attā’ti evametaṁ yathābhūtaṁ sammappaññāya daṭṭhabbaṁ. ",
    "sn35.216-218:1.11": "Evaṁ passaṁ …pe… ",
    "sn35.216-218:1.12": "nāparaṁ itthattāyāti pajānātī”ti. "
  },
  "translation_text": {
    "sn35.216-218:0.1": "Linked Discourses 35.216–218 ",
    "sn35.216-218:0.2": "17. Sixty Abbreviated Texts ",
    "sn35.216-218:0.3": "The Exterior and What’s Suffering in the Three Times ",
    "sn35.216-218:1.1": "“Mendicants, in the past … future … present sights, sounds, smells, tastes, touches, and ideas are suffering. ",
    "sn35.216-218:1.2": "What’s suffering is not-self …” ",
