  "root_text": {
    "sn22.114:0.1": "Saṁyutta Nikāya 22.114 ",
    "sn22.114:0.2": "12. Dhammakathikavagga ",
    "sn22.114:0.3": "Vijjāsutta ",
    "sn22.114:1.1": "Sāvatthinidānaṁ. ",
    "sn22.114:1.2": "Ekamantaṁ nisinno kho so bhikkhu bhagavantaṁ etadavoca: ",
    "sn22.114:1.3": "“‘vijjā, vijjā’ti, bhante, vuccati. ",
    "sn22.114:1.4": "Katamā nu kho, bhante, vijjā; ",
    "sn22.114:1.5": "kittāvatā ca vijjāgato hotī”ti? ",
    "sn22.114:1.6": "“Idha, bhikkhu, sutavā ariyasāvako rūpaṁ pajānāti, rūpasamudayaṁ … rūpanirodhaṁ … rūpanirodhagāminiṁ paṭipadaṁ pajānāti. ",
    "sn22.114:1.7": "Vedanaṁ … ",
    "sn22.114:1.8": "saññaṁ … ",
    "sn22.114:1.9": "saṅkhāre pajānāti …pe… ",
    "sn22.114:1.10": "viññāṇanirodhagāminiṁ paṭipadaṁ pajānāti. ",
    "sn22.114:1.11": "Ayaṁ vuccati, bhikkhu, vijjā; ",
    "sn22.114:1.12": "ettāvatā ca vijjāgato hotī”ti. ",
    "sn22.114:1.13": "Dutiyaṁ. "
  },
  "translation_text": {
    "sn22.114:0.1": "Linked Discourses 22.114 ",
    "sn22.114:0.2": "12. A Dhamma speaker ",
    "sn22.114:0.3": "Knowledge ",
    "sn22.114:1.1": "At Sāvatthī. ",
    "sn22.114:1.2": "Seated to one side, that mendicant said to the Buddha: ",
    "sn22.114:1.3": "“Sir, they speak of this thing called ‘knowledge’. ",
    "sn22.114:1.4": "What is knowledge? ",
    "sn22.114:1.5": "And how is a knowledgeable person defined?” ",
    "sn22.114:1.6": "“Mendicant, it’s when a learned noble disciple understands form, its origin, its cessation, and the practice that leads to its cessation. ",
    "sn22.114:1.7": "They understand feeling … ",
    "sn22.114:1.8": "perception … ",
    "sn22.114:1.9": "choices … ",
    "sn22.114:1.10": "consciousness, its origin, its cessation, and the practice that leads to its cessation. ",
    "sn22.114:1.11": "This is called knowledge. ",
    "sn22.114:1.12": "And this is how a knowledgeable person is defined.” "
  },
  "variant_text": {
    "sn22.114:0.3": "Vijjāsutta → vijjā or bhikkhu 2 (pts1ed) "
  },
