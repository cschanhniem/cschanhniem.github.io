  "root_text": {
    "sn22.19:0.1": "Saṁyutta Nikāya 22.19 ",
    "sn22.19:0.2": "2. Aniccavagga ",
    "sn22.19:0.3": "Sahetudukkhasutta ",
    "sn22.19:1.1": "Sāvatthinidānaṁ. ",
    "sn22.19:1.2": "“Rūpaṁ, bhikkhave, dukkhaṁ. ",
    "sn22.19:1.3": "Yopi hetu yopi paccayo rūpassa uppādāya, sopi dukkho. ",
    "sn22.19:1.4": "Dukkhasambhūtaṁ, bhikkhave, rūpaṁ kuto sukhaṁ bhavissati. ",
    "sn22.19:1.5": "Vedanā dukkhā … ",
    "sn22.19:1.6": "saññā dukkhā … ",
    "sn22.19:1.7": "saṅkhārā dukkhā … ",
    "sn22.19:1.8": "viññāṇaṁ dukkhaṁ. ",
    "sn22.19:1.9": "Yopi hetu yopi paccayo viññāṇassa uppādāya, sopi dukkho. ",
    "sn22.19:1.10": "Dukkhasambhūtaṁ, bhikkhave, viññāṇaṁ kuto sukhaṁ bhavissati. ",
    "sn22.19:1.11": "Evaṁ passaṁ …pe… ",
    "sn22.19:1.12": "nāparaṁ itthattāyā’ti pajānātī”ti. ",
    "sn22.19:1.13": "Aṭṭhamaṁ. "
  },
  "translation_text": {
    "sn22.19:0.1": "Linked Discourses 22.19 ",
    "sn22.19:0.2": "2. Impermanence ",
    "sn22.19:0.3": "Suffering With Its Cause ",
    "sn22.19:1.1": "At Sāvatthī. ",
    "sn22.19:1.2": "“Mendicants, form is suffering. ",
    "sn22.19:1.3": "The cause and reason that gives rise to form is also suffering. ",
    "sn22.19:1.4": "Since form is produced by what is suffering, how could it be happiness? ",
    "sn22.19:1.5": "Feeling is suffering … ",
    "sn22.19:1.6": "Perception is suffering … ",
    "sn22.19:1.7": "Choices are suffering … ",
    "sn22.19:1.8": "Consciousness is suffering. ",
    "sn22.19:1.9": "The cause and reason that gives rise to consciousness is also suffering. ",
    "sn22.19:1.10": "Since consciousness is produced by what is suffering, how could it be happiness? ",
    "sn22.19:1.11": "Seeing this … ",
    "sn22.19:1.12": "They understand: ‘… there is nothing further for this place.’” "
  },
  "variant_text": {
    "sn22.19:0.3": "Sahetudukkhasutta → dutiyahetusuttaṁ (bj); hetu 2 (pts1ed) "
  },
