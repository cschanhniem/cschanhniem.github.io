  "root_text": {
    "sn22.149:0.1": "Saṁyutta Nikāya 22.149 ",
    "sn22.149:0.2": "14. Kukkuḷavagga ",
    "sn22.149:0.3": "Anattānupassīsutta ",
    "sn22.149:1.1": "Sāvatthinidānaṁ. ",
    "sn22.149:1.2": "“Saddhāpabbajitassa, bhikkhave, kulaputtassa ayamanudhammo hoti—",
    "sn22.149:1.3": "yaṁ rūpe anattānupassī vihareyya. ",
    "sn22.149:1.4": "Vedanāya … ",
    "sn22.149:1.5": "saññāya … ",
    "sn22.149:1.6": "saṅkhāresu … ",
    "sn22.149:1.7": "viññāṇe anattānupassī vihareyya. ",
    "sn22.149:1.8": "Anattānupassī viharanto, vedanāya … ",
    "sn22.149:1.9": "saññāya … ",
    "sn22.149:1.10": "saṅkhāresu … ",
    "sn22.149:1.11": "viññāṇe anattānupassī viharanto rūpaṁ parijānāti, vedanaṁ …pe… ",
    "sn22.149:1.12": "saññaṁ … ",
    "sn22.149:1.13": "saṅkhāre … ",
    "sn22.149:1.14": "viññāṇaṁ parijānāti. ",
    "sn22.149:1.15": "So rūpaṁ parijānaṁ vedanaṁ parijānaṁ saññaṁ parijānaṁ saṅkhāre parijānaṁ viññāṇaṁ parijānaṁ parimuccati rūpamhā, parimuccati vedanāya, parimuccati saññāya, parimuccati saṅkhārehi, parimuccati viññāṇamhā, parimuccati jātiyā jarāya maraṇena sokehi paridevehi dukkhehi domanassehi upāyāsehi; ",
    "sn22.149:1.16": "‘parimuccati dukkhasmā’ti vadāmī”ti. ",
    "sn22.149:1.17": "Cuddasamaṁ. ",
    "sn22.149:1.18": "Kukkuḷavaggo catuttho. ",
    "sn22.149:2.0": "Tassuddānaṁ ",
    "sn22.149:2.1": "Kukkuḷā tayo aniccena, ",
    "sn22.149:2.2": "dukkhena apare tayo; ",
    "sn22.149:2.3": "Anattena tayo vuttā, ",
    "sn22.149:2.4": "kulaputtena dve dukāti. "
  },
  "translation_text": {
    "sn22.149:0.1": "Linked Discourses 22.149 ",
    "sn22.149:0.2": "14. Burning Chaff ",
    "sn22.149:0.3": "Observing Not-Self ",
    "sn22.149:1.1": "At Sāvatthī. ",
    "sn22.149:1.2": "“Mendicants, when a gentleman has gone forth out of faith, this is what’s in line with the teaching. ",
    "sn22.149:1.3": "They should meditate observing not-self in form, ",
    "sn22.149:1.4": "feeling, ",
    "sn22.149:1.5": "perception, ",
    "sn22.149:1.6": "choices, ",
    "sn22.149:1.7": "and consciousness. … ",
    "sn22.149:1.8": "",
    "sn22.149:1.9": "",
    "sn22.149:1.10": "",
    "sn22.149:1.11": "",
    "sn22.149:1.12": "",
    "sn22.149:1.13": "",
    "sn22.149:1.14": "",
    "sn22.149:1.15": "",
    "sn22.149:1.16": "They’re freed from suffering, I say.” ",
    "sn22.149:1.17": "",
    "sn22.149:1.18": "",
