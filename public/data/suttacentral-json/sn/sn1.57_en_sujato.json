  "root_text": {
    "sn1.57:0.1": "Saṁyutta Nikāya 1.57 ",
    "sn1.57:0.2": "6. Jarāvagga ",
    "sn1.57:0.3": "Tatiyajanasutta ",
    "sn1.57:1.1": "“Kiṁsu janeti purisaṁ, ",
    "sn1.57:1.2": "kiṁsu tassa vidhāvati; ",
    "sn1.57:1.3": "Kiṁsu saṁsāramāpādi, ",
    "sn1.57:1.4": "kiṁsu tassa parāyanan”ti. ",
    "sn1.57:2.1": "“Taṇhā janeti purisaṁ, ",
    "sn1.57:2.2": "cittamassa vidhāvati; ",
    "sn1.57:2.3": "Satto saṁsāramāpādi, ",
    "sn1.57:2.4": "kammaṁ tassa parāyanan”ti. "
  },
  "translation_text": {
    "sn1.57:0.1": "Linked Discourses 1.57 ",
    "sn1.57:0.2": "6. Old Age ",
    "sn1.57:0.3": "Gives Birth (3rd) ",
    "sn1.57:1.1": "“What gives birth to a person? ",
    "sn1.57:1.2": "What do they have that runs about? ",
    "sn1.57:1.3": "What enters transmigration? ",
    "sn1.57:1.4": "What is their destiny?” ",
    "sn1.57:2.1": "“Craving gives birth to a person. ",
    "sn1.57:2.2": "Their mind is what runs about. ",
    "sn1.57:2.3": "A sentient being enters transmigration. ",
    "sn1.57:2.4": "Deeds are their final haven.” "
  },
  "variant_text": {
    "sn1.57:0.3": "Tatiyajanasutta → tatiyajanetisuttaṁ (bj) "
  },
