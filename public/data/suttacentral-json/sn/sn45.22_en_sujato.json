  "root_text": {
    "sn45.22:0.1": "Saṁyutta Nikāya 45.22 ",
    "sn45.22:0.2": "3. Micchattavagga ",
    "sn45.22:0.3": "Akusaladhammasutta ",
    "sn45.22:1.1": "Sāvatthinidānaṁ. ",
    "sn45.22:1.2": "“Akusale ca kho, bhikkhave, dhamme desessāmi, kusale ca dhamme. ",
    "sn45.22:1.3": "Taṁ suṇātha. ",
    "sn45.22:1.4": "Katame ca, bhikkhave, akusalā dhammā? ",
    "sn45.22:1.5": "Seyyathidaṁ—micchādiṭṭhi …pe… micchāsamādhi. ",
    "sn45.22:1.6": "Ime vuccanti, bhikkhave, akusalā dhammā. ",
    "sn45.22:1.7": "Katame ca, bhikkhave, kusalā dhammā? ",
    "sn45.22:1.8": "Seyyathidaṁ—sammādiṭṭhi …pe… sammāsamādhi. ",
    "sn45.22:1.9": "Ime vuccanti, bhikkhave, kusalā dhammā”ti. ",
    "sn45.22:1.10": "Dutiyaṁ. "
  },
  "translation_text": {
    "sn45.22:0.1": "Linked Discourses 45.22 ",
    "sn45.22:0.2": "3. The Wrong Way ",
    "sn45.22:0.3": "Unskillful Qualities ",
    "sn45.22:1.1": "At Sāvatthī. ",
    "sn45.22:1.2": "“Mendicants, I will teach you skillful and unskillful qualities. ",
    "sn45.22:1.3": "Listen … ",
    "sn45.22:1.4": "And what are unskillful qualities? ",
    "sn45.22:1.5": "They are wrong view, wrong thought, wrong speech, wrong action, wrong livelihood, wrong effort, wrong mindfulness, and wrong immersion. ",
    "sn45.22:1.6": "These are called unskillful qualities. ",
    "sn45.22:1.7": "And what are skillful qualities? ",
    "sn45.22:1.8": "They are right view, right thought, right speech, right action, right livelihood, right effort, right mindfulness, and right immersion. ",
    "sn45.22:1.9": "These are called skillful qualities.” "
  },
