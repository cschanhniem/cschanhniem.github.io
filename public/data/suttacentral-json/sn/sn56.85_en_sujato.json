  "root_text": {
    "sn56.85:0.1": "Saṁyutta Nikāya 56.85 ",
    "sn56.85:0.2": "9. Tatiyaāmakadhaññapeyyālavagga ",
    "sn56.85:0.3": "Āmakamaṁsasutta ",
    "sn56.85:1.1": "… “Evameva kho, bhikkhave, appakā te sattā ye āmakamaṁsapaṭiggahaṇā paṭiviratā; atha kho eteva bahutarā sattā ye āmakamaṁsapaṭiggahaṇā appaṭiviratā …pe…. ",
    "sn56.85:1.2": "Pañcamaṁ. "
  },
  "translation_text": {
    "sn56.85:0.1": "Linked Discourses 56.85 ",
    "sn56.85:0.2": "9. Abbreviated Texts on Raw Grain ",
    "sn56.85:0.3": "Raw Meat ",
    "sn56.85:1.1": "“… the sentient beings who refrain from receiving raw meat are few, while those who don’t refrain are many. …” "
  },
  "variant_text": {
    "sn56.85:0.3": "Āmakamaṁsasutta → maṁsaṁ (pts1ed) "
  },
