  "root_text": {
    "sn33.21-25:0.1": "Saṁyutta Nikāya 33.21–25 ",
    "sn33.21-25:0.2": "1. Vacchagottavagga ",
    "sn33.21-25:0.3": "Rūpaappaṭivedhādisuttapañcaka ",
    "sn33.21-25:1.1": "Sāvatthinidānaṁ. Ko nu kho, bho gotama, hetu, ko paccayo …pe…. ",
    "sn33.21-25:1.2": "“Rūpe kho, vaccha, appaṭivedhā …pe… viññāṇe kho, vaccha, appaṭivedhā …pe…. ",
    "sn33.21-25:1.3": "Pañcavīsatimaṁ. "
  },
  "translation_text": {
    "sn33.21-25:0.1": "Linked Discourses 33.21–25 ",
    "sn33.21-25:0.2": "1. With Vacchagotta ",
    "sn33.21-25:0.3": "Five Discourses on Not Penetrating Form, Etc. ",
    "sn33.21-25:1.1": "At Sāvatthī. ",
    "sn33.21-25:1.2": "“Vaccha, it is because of not penetrating form …” "
  },
