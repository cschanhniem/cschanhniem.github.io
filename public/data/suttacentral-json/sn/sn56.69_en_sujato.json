  "root_text": {
    "sn56.69:0.1": "Saṁyutta Nikāya 56.69 ",
    "sn56.69:0.2": "7. Paṭhamaāmakadhaññapeyyālavagga ",
    "sn56.69:0.3": "Brahmaññasutta ",
    "sn56.69:1.1": "… “Evameva kho, bhikkhave, appakā te sattā ye brahmaññā; atha kho eteva bahutarā sattā ye abrahmaññā …pe…. ",
    "sn56.69:1.2": "Navamaṁ. "
  },
  "translation_text": {
    "sn56.69:0.1": "Linked Discourses 56.69 ",
    "sn56.69:0.2": "7. Abbreviated Texts on Raw Grain ",
    "sn56.69:0.3": "Respect Brahmins ",
    "sn56.69:1.1": "“… the sentient beings who respect brahmins are few, while those who don’t are many. …” "
  },
