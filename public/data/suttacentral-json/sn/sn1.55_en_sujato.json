  "root_text": {
    "sn1.55:0.1": "Saṁyutta Nikāya 1.55 ",
    "sn1.55:0.2": "6. Jarāvagga ",
    "sn1.55:0.3": "Paṭhamajanasutta ",
    "sn1.55:1.1": "“Kiṁsu janeti purisaṁ, ",
    "sn1.55:1.2": "kiṁsu tassa vidhāvati; ",
    "sn1.55:1.3": "Kiṁsu saṁsāramāpādi, ",
    "sn1.55:1.4": "kiṁsu tassa mahabbhayan”ti. ",
    "sn1.55:2.1": "“Taṇhā janeti purisaṁ, ",
    "sn1.55:2.2": "cittamassa vidhāvati; ",
    "sn1.55:2.3": "Satto saṁsāramāpādi, ",
    "sn1.55:2.4": "dukkhamassa mahabbhayan”ti. "
  },
  "translation_text": {
    "sn1.55:0.1": "Linked Discourses 1.55 ",
    "sn1.55:0.2": "6. Old Age ",
    "sn1.55:0.3": "Gives Birth (1st) ",
    "sn1.55:1.1": "“What gives birth to a person? ",
    "sn1.55:1.2": "What do they have that runs about? ",
    "sn1.55:1.3": "What enters transmigration? ",
    "sn1.55:1.4": "What’s their greatest fear?” ",
    "sn1.55:2.1": "“Craving gives birth to a person. ",
    "sn1.55:2.2": "Their mind is what runs about. ",
    "sn1.55:2.3": "A sentient being enters transmigration. ",
    "sn1.55:2.4": "Suffering is their greatest fear.” "
  },
  "variant_text": {
    "sn1.55:0.3": "Paṭhamajanasutta → paṭhamajanetisuttaṁ (bj) "
  },
