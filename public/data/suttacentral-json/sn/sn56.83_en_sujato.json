  "root_text": {
    "sn56.83:0.1": "Saṁyutta Nikāya 56.83 ",
    "sn56.83:0.2": "9. Tatiyaāmakadhaññapeyyālavagga ",
    "sn56.83:0.3": "Jātarūparajatasutta ",
    "sn56.83:1.1": "… “Evameva kho, bhikkhave, appakā te sattā ye jātarūparajatapaṭiggahaṇā paṭiviratā; atha kho eteva bahutarā sattā ye jātarūparajatapaṭiggahaṇā appaṭiviratā …pe…. ",
    "sn56.83:1.2": "Tatiyaṁ. "
  },
  "translation_text": {
    "sn56.83:0.1": "Linked Discourses 56.83 ",
    "sn56.83:0.2": "9. Abbreviated Texts on Raw Grain ",
    "sn56.83:0.3": "Gold and Currency ",
    "sn56.83:1.1": "“… the sentient beings who refrain from receiving gold and currency are few, while those who don’t refrain are many. …” "
  },
  "variant_text": {
    "sn56.83:0.3": "Jātarūparajatasutta → jātarūpasuttaṁ (bj); rajataṁ (pts1ed) "
  },
