  "root_text": {
    "sn45.32:0.1": "Saṁyutta Nikāya 45.32 ",
    "sn45.32:0.2": "4. Paṭipattivagga ",
    "sn45.32:0.3": "Dutiyapaṭipattisutta ",
    "sn45.32:1.1": "Sāvatthinidānaṁ. ",
    "sn45.32:1.2": "“Micchāpaṭipannañca vo, bhikkhave, desessāmi, sammāpaṭipannañca. ",
    "sn45.32:1.3": "Taṁ suṇātha. ",
    "sn45.32:1.4": "Katamo ca, bhikkhave, micchāpaṭipanno? ",
    "sn45.32:1.5": "Idha, bhikkhave, ekacco micchādiṭṭhiko hoti …pe… micchāsamādhi—",
    "sn45.32:1.6": "ayaṁ vuccati, bhikkhave, micchāpaṭipanno. ",
    "sn45.32:1.7": "Katamo ca, bhikkhave, sammāpaṭipanno? ",
    "sn45.32:1.8": "Idha, bhikkhave, ekacco sammādiṭṭhiko hoti …pe… sammāsamādhi—",
    "sn45.32:1.9": "ayaṁ vuccati, bhikkhave, sammāpaṭipanno”ti. ",
    "sn45.32:1.10": "Dutiyaṁ. "
  },
  "translation_text": {
    "sn45.32:0.1": "Linked Discourses 45.32 ",
    "sn45.32:0.2": "4. Practice ",
    "sn45.32:0.3": "Practice (2nd) ",
    "sn45.32:1.1": "At Sāvatthī. ",
    "sn45.32:1.2": "“Mendicants, I will teach you one practicing wrongly and one practicing rightly. ",
    "sn45.32:1.3": "Listen … ",
    "sn45.32:1.4": "And who is practicing wrongly? ",
    "sn45.32:1.5": "It’s someone who has wrong view, wrong thought, wrong speech, wrong action, wrong livelihood, wrong effort, wrong mindfulness, and wrong immersion. ",
    "sn45.32:1.6": "This is called one practicing wrongly. ",
    "sn45.32:1.7": "And who is practicing rightly? ",
    "sn45.32:1.8": "It’s someone who has right view, right thought, right speech, right action, right livelihood, right effort, right mindfulness, and right immersion. ",
    "sn45.32:1.9": "This is called one practicing rightly.” "
  },
  "variant_text": {
    "sn45.32:0.3": "Dutiyapaṭipattisutta → paṭipanno (pts1ed) "
  },
