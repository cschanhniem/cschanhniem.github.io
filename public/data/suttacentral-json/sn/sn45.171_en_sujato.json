  "root_text": {
    "sn45.171:0.1": "Saṁyutta Nikāya 45.171 ",
    "sn45.171:0.2": "14. Oghavagga ",
    "sn45.171:0.3": "Oghasutta ",
    "sn45.171:1.1": "Sāvatthinidānaṁ. ",
    "sn45.171:1.2": "“Cattārome, bhikkhave, oghā. ",
    "sn45.171:1.3": "Katame cattāro? ",
    "sn45.171:1.4": "Kāmogho, bhavogho, diṭṭhogho, avijjogho—",
    "sn45.171:1.5": "ime kho, bhikkhave, cattāro oghā. ",
    "sn45.171:1.6": "Imesaṁ kho, bhikkhave, catunnaṁ oghānaṁ abhiññāya pariññāya parikkhayāya pahānāya …pe… ayaṁ ariyo aṭṭhaṅgiko maggo bhāvetabbo”ti. ",
    "sn45.171:1.7": "(Yathā esanā, evaṁ vitthāretabbaṁ.) ",
    "sn45.171:1.8": "Paṭhamaṁ. "
  },
  "translation_text": {
    "sn45.171:0.1": "Linked Discourses 45.171 ",
    "sn45.171:0.2": "14. Floods ",
    "sn45.171:0.3": "Floods ",
    "sn45.171:1.1": "At Sāvatthī. ",
    "sn45.171:1.2": "“Mendicants, there are these four floods. ",
    "sn45.171:1.3": "What four? ",
    "sn45.171:1.4": "The floods of sensuality, desire to be reborn, views, and ignorance. ",
    "sn45.171:1.5": "These are the four floods. ",
    "sn45.171:1.6": "The noble eightfold path should be developed for the direct knowledge, complete understanding, finishing, and giving up of these four floods.” ",
    "sn45.171:1.7": "(Tell in full as in the section on searches.) "
  },
