  "root_text": {
    "sn18.4:0.1": "Saṁyutta Nikāya 18.4 ",
    "sn18.4:0.2": "1. Paṭhamavagga ",
    "sn18.4:0.3": "Samphassasutta ",
    "sn18.4:1.1": "Sāvatthiyaṁ viharati. ",
    "sn18.4:1.2": "“Taṁ kiṁ maññasi, rāhula, ",
    "sn18.4:1.3": "cakkhusamphasso nicco vā anicco vā”ti? ",
    "sn18.4:1.4": "“Anicco, bhante” … ",
    "sn18.4:1.5": "“sotasamphasso …pe… ",
    "sn18.4:1.6": "ghānasamphasso … ",
    "sn18.4:1.7": "jivhāsamphasso … ",
    "sn18.4:1.8": "kāyasamphasso … ",
    "sn18.4:1.9": "manosamphasso nicco vā anicco vā”ti? ",
    "sn18.4:1.10": "“Anicco, bhante” … ",
    "sn18.4:1.11": "“evaṁ passaṁ, rāhula, sutavā ariyasāvako cakkhusamphassasmimpi nibbindati …pe… sotasamphassasmimpi nibbindati … ghānasamphassasmimpi nibbindati … jivhāsamphassasmimpi nibbindati … kāyasamphassasmimpi nibbindati … manosamphassasmimpi nibbindati; ",
    "sn18.4:1.12": "nibbindaṁ virajjati …pe… ",
    "sn18.4:1.13": "pajānātī”ti. ",
    "sn18.4:1.14": "Catutthaṁ. "
  },
  "translation_text": {
    "sn18.4:0.1": "Linked Discourses 18.4 ",
    "sn18.4:0.2": "Chapter One ",
    "sn18.4:0.3": "Contact ",
    "sn18.4:1.1": "At Sāvatthī. ",
    "sn18.4:1.2": "“What do you think, Rāhula? ",
    "sn18.4:1.3": "Is eye contact permanent or impermanent?” ",
    "sn18.4:1.4": "“Impermanent, sir.” … ",
    "sn18.4:1.5": "“… ear contact … ",
    "sn18.4:1.6": "nose contact … ",
    "sn18.4:1.7": "tongue contact … ",
    "sn18.4:1.8": "body contact … ",
    "sn18.4:1.9": "Is mind contact permanent or impermanent?” ",
    "sn18.4:1.10": "“Impermanent, sir.” … ",
    "sn18.4:1.11": "“Seeing this, a learned noble disciple grows disillusioned with eye contact, ear contact, nose contact, tongue contact, body contact, and mind contact. ",
    "sn18.4:1.12": "Being disillusioned, desire fades away. …” ",
    "sn18.4:1.13": ""
  },
