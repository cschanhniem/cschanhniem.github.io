  "root_text": {
    "sn34.35-40:0.1": "Saṁyutta Nikāya 34.35–40 ",
    "sn34.35-40:0.2": "1. Jhānavagga ",
    "sn34.35-40:0.3": "Kallitamūlakaārammaṇasuttādichakka ",
    "sn34.35-40:1.1": "Sāvatthinidānaṁ … ",
    "sn34.35-40:1.2": "“samādhismiṁ kallitakusalo hoti, na samādhismiṁ ārammaṇakusalo … ",
    "sn34.35-40:1.3": "samādhismiṁ ārammaṇakusalo hoti, na samādhismiṁ kallitakusalo … ",
    "sn34.35-40:1.4": "neva samādhismiṁ kallitakusalo hoti, na ca samādhismiṁ ārammaṇakusalo … ",
    "sn34.35-40:1.5": "samādhismiṁ kallitakusalo ca hoti, samādhismiṁ ārammaṇakusalo ca. ",
    "sn34.35-40:1.6": "Tatra, bhikkhave, yvāyaṁ jhāyī …pe… ",
    "sn34.35-40:1.7": "uttamo ca pavaro cā”ti. ",
    "sn34.35-40:1.8": "Pañcatiṁsatimaṁ. ",
    "sn34.35-40:1.9": "(Purimamūlakāni viya yāva cattālīsamā kallitamūlakasappāyakārīsuttā cha suttāni pūretabbāni.) ",
    "sn34.35-40:1.10": "(Kallitamūlakaṁ.) "
  },
  "translation_text": {
    "sn34.35-40:0.1": "Linked Discourses 34.35–40 ",
    "sn34.35-40:0.2": "1. Absorption ",
    "sn34.35-40:0.3": "Six on Gladdening and Support, Etc. ",
    "sn34.35-40:1.1": "At Sāvatthī. ",
    "sn34.35-40:1.2": "“One meditator is skilled in positivity for immersion but not in the supports for immersion. …” ",
    "sn34.35-40:1.9": "(These six discourses should be told in full as the previous set.) "
  },
