  "root_text": {
    "sn20.12:0.1": "Saṁyutta Nikāya 20.12 ",
    "sn20.12:0.2": "1. Opammavagga ",
    "sn20.12:0.3": "Dutiyasiṅgālasutta ",
    "sn20.12:1.1": "Sāvatthiyaṁ viharati. ",
    "sn20.12:1.2": "“Assuttha no tumhe, bhikkhave, rattiyā paccūsasamayaṁ jarasiṅgālassa vassamānassā”ti? ",
    "sn20.12:1.3": "“Evaṁ, bhante”. ",
    "sn20.12:1.4": "“Siyā kho, bhikkhave, tasmiṁ jarasiṅgāle yā kāci kataññutā kataveditā, na tveva idhekacce sakyaputtiyapaṭiññe siyā yā kāci kataññutā kataveditā. ",
    "sn20.12:1.5": "Tasmātiha, bhikkhave, evaṁ sikkhitabbaṁ: ",
    "sn20.12:1.6": "‘kataññuno bhavissāma katavedino; ",
    "sn20.12:1.7": "na ca no amhesu appakampi kataṁ nassissatī’ti. ",
    "sn20.12:1.8": "Evañhi vo, bhikkhave, sikkhitabban”ti. ",
    "sn20.12:1.9": "Dvādasamaṁ. ",
    "sn20.12:1.10": "Opammavaggo paṭhamo. ",
    "sn20.12:2.0": "Tassuddānaṁ ",
    "sn20.12:2.1": "Kūṭaṁ nakhasikhaṁ kulaṁ, ",
    "sn20.12:2.2": "okkhā satti dhanuggaho; ",
    "sn20.12:2.3": "Āṇi kaliṅgaro nāgo, ",
    "sn20.12:2.4": "biḷāro dve siṅgālakāti. ",
    "sn20.12:2.5": "Opammasaṁyuttaṁ samattaṁ. "
  },
  "translation_text": {
    "sn20.12:0.1": "Linked Discourses 20.12 ",
    "sn20.12:0.2": "1. Similes ",
    "sn20.12:0.3": "A Jackal (2nd) ",
    "sn20.12:1.1": "At Sāvatthī. ",
    "sn20.12:1.2": "“Mendicants, did you hear an old jackal howling at the crack of dawn?” ",
    "sn20.12:1.3": "“Yes, sir.” ",
    "sn20.12:1.4": "“There might be some gratitude and thankfulness in that old jackal, but there is none in a certain person here who claims to follow the Sakyan. ",
    "sn20.12:1.5": "So you should train like this: ",
    "sn20.12:1.6": "‘We will be grateful and thankful. ",
    "sn20.12:1.7": "We won’t forget even a small thing done for us.’ ",
    "sn20.12:1.8": "That’s how you should train.” ",
    "sn20.12:1.9": "",
    "sn20.12:1.10": "",
    "sn20.12:2.1": "",
    "sn20.12:2.2": "",
    "sn20.12:2.3": "",
    "sn20.12:2.4": "",
    "sn20.12:2.5": "The Linked Discourses with similes are complete. "
  },
