  "root_text": {
    "sn1.59:0.1": "Saṁyutta Nikāya 1.59 ",
    "sn1.59:0.2": "6. Jarāvagga ",
    "sn1.59:0.3": "Dutiyasutta ",
    "sn1.59:1.1": "“Kiṁsu dutiyā purisassa hoti, ",
    "sn1.59:1.2": "Kiṁsu cenaṁ pasāsati; ",
    "sn1.59:1.3": "Kissa cābhirato macco, ",
    "sn1.59:1.4": "Sabbadukkhā pamuccatī”ti. ",
    "sn1.59:2.1": "“Saddhā dutiyā purisassa hoti, ",
    "sn1.59:2.2": "Paññā cenaṁ pasāsati; ",
    "sn1.59:2.3": "Nibbānābhirato macco, ",
    "sn1.59:2.4": "Sabbadukkhā pamuccatī”ti. "
  },
  "translation_text": {
    "sn1.59:0.1": "Linked Discourses 1.59 ",
    "sn1.59:0.2": "6. Old Age ",
    "sn1.59:0.3": "A Partner ",
    "sn1.59:1.1": "“What is a person’s partner? ",
    "sn1.59:1.2": "What instructs them? ",
    "sn1.59:1.3": "Enjoying what is a mortal ",
    "sn1.59:1.4": "released from all suffering?” ",
    "sn1.59:2.1": "“Faith is a person’s partner. ",
    "sn1.59:2.2": "Wisdom instructs them. ",
    "sn1.59:2.3": "Delighting in extinguishment a mortal ",
    "sn1.59:2.4": "is released from all suffering.” "
  },
  "variant_text": {
    "sn1.59:0.3": "Dutiyasutta → dutiyāsuttaṁ (bj, pts2ed); dutiyauppathasuttaṁ (bj) ",
    "sn1.59:1.1": "dutiyā → dutiyaṁ (sya-all, km, pts1ed, pts2ed) "
  },
