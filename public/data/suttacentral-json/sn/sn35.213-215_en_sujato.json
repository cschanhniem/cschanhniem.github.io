  "root_text": {
    "sn35.213-215:0.1": "Saṁyutta Nikāya 35.213–215 ",
    "sn35.213-215:0.2": "17. Saṭṭhipeyyālavagga ",
    "sn35.213-215:0.3": "Bāhirātītādiyadaniccasutta ",
    "sn35.213-215:1.1": "“Rūpā, bhikkhave, aniccā atītā anāgatā paccuppannā. ",
    "sn35.213-215:1.2": "Yadaniccaṁ, taṁ dukkhaṁ. ",
    "sn35.213-215:1.3": "Yaṁ dukkhaṁ, tadanattā. ",
    "sn35.213-215:1.4": "Yadanattā, taṁ ‘netaṁ mama, nesohamasmi, na meso attā’ti evametaṁ yathābhūtaṁ sammappaññāya daṭṭhabbaṁ. ",
    "sn35.213-215:1.5": "Saddā … ",
    "sn35.213-215:1.6": "gandhā … ",
    "sn35.213-215:1.7": "rasā … ",
    "sn35.213-215:1.8": "phoṭṭhabbā … ",
    "sn35.213-215:1.9": "dhammā aniccā atītā anāgatā paccuppannā. ",
    "sn35.213-215:1.10": "Yadaniccaṁ taṁ dukkhaṁ. ",
    "sn35.213-215:1.11": "Yaṁ dukkhaṁ tadanattā. ",
    "sn35.213-215:1.12": "Yadanattā taṁ ‘netaṁ mama, nesohamasmi, na meso attā’ti evametaṁ yathābhūtaṁ sammappaññāya daṭṭhabbaṁ. ",
    "sn35.213-215:1.13": "Evaṁ passaṁ …pe… ",
    "sn35.213-215:1.14": "nāparaṁ itthattāyāti pajānātī”ti. "
  },
  "translation_text": {
    "sn35.213-215:0.1": "Linked Discourses 35.213–215 ",
    "sn35.213-215:0.2": "17. Sixty Abbreviated Texts ",
    "sn35.213-215:0.3": "The Exterior and What’s Impermanent in the Three Times ",
    "sn35.213-215:1.1": "“Mendicants, in the past … future … present sights, sounds, smells, tastes, touches, and ideas are impermanent. ",
    "sn35.213-215:1.2": "What’s impermanent is suffering …” ",
