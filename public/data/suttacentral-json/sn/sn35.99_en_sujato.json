  "root_text": {
    "sn35.99:0.1": "Saṁyutta Nikāya 35.99 ",
    "sn35.99:0.2": "10. Saḷavagga ",
    "sn35.99:0.3": "Samādhisutta ",
    "sn35.99:1.1": "“Samādhiṁ, bhikkhave, bhāvetha. ",
    "sn35.99:1.2": "Samāhito, bhikkhave, bhikkhu yathābhūtaṁ pajānāti. ",
    "sn35.99:1.3": "Kiñca yathābhūtaṁ pajānāti? ",
    "sn35.99:1.4": "‘Cakkhu aniccan’ti yathābhūtaṁ pajānāti; ",
    "sn35.99:1.5": "‘rūpā aniccā’ti yathābhūtaṁ pajānāti; ",
    "sn35.99:1.6": "‘cakkhuviññāṇaṁ aniccan’ti yathābhūtaṁ pajānāti; ",
    "sn35.99:1.7": "‘cakkhusamphasso anicco’ti yathābhūtaṁ pajānāti. ",
    "sn35.99:1.8": "‘Yampidaṁ cakkhusamphassapaccayā uppajjati vedayitaṁ sukhaṁ vā dukkhaṁ vā adukkhamasukhaṁ vā tampi aniccan’ti yathābhūtaṁ pajānāti …pe… ",
    "sn35.99:1.9": "‘mano aniccan’ti yathābhūtaṁ pajānāti. ",
    "sn35.99:1.10": "Dhammā … ",
    "sn35.99:1.11": "manoviññāṇaṁ … ",
    "sn35.99:1.12": "manosamphasso … ",
    "sn35.99:1.13": "‘yampidaṁ manosamphassapaccayā uppajjati vedayitaṁ sukhaṁ vā dukkhaṁ vā adukkhamasukhaṁ vā tampi aniccan’ti yathābhūtaṁ pajānāti. ",
    "sn35.99:1.14": "Samādhiṁ, bhikkhave, bhāvetha. ",
    "sn35.99:1.15": "Samāhito, bhikkhave, bhikkhu yathābhūtaṁ pajānātī”ti. ",
    "sn35.99:1.16": "Chaṭṭhaṁ. "
  },
  "translation_text": {
    "sn35.99:0.1": "Linked Discourses 35.99 ",
    "sn35.99:0.2": "10. The Sixes ",
    "sn35.99:0.3": "Immersion ",
    "sn35.99:1.1": "“Mendicants, develop immersion. ",
    "sn35.99:1.2": "A mendicant who has immersion truly understands. ",
    "sn35.99:1.3": "What do they truly understand? ",
    "sn35.99:1.4": "They truly understand that the eye is impermanent. ",
    "sn35.99:1.5": "They truly understand that sights … ",
    "sn35.99:1.6": "eye consciousness … ",
    "sn35.99:1.7": "eye contact … ",
    "sn35.99:1.8": "the pleasant, painful, or neutral feeling that arises dependent on eye contact is impermanent. … ",
    "sn35.99:1.9": "They truly understand that the mind is impermanent. ",
    "sn35.99:1.10": "They truly understand that ideas … ",
    "sn35.99:1.11": "mind consciousness … ",
    "sn35.99:1.12": "mind contact … ",
    "sn35.99:1.13": "the pleasant, painful, or neutral feeling that arises dependent on mind contact is impermanent. ",
    "sn35.99:1.14": "Mendicants, develop immersion. ",
    "sn35.99:1.15": "A mendicant who has immersion truly understands.” "
  },
