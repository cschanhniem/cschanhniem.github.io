  "root_text": {
    "sn14.30:0.1": "Saṁyutta Nikāya 14.30 ",
    "sn14.30:0.2": "4. Catutthavagga ",
    "sn14.30:0.3": "Catudhātusutta ",
    "sn14.30:1.1": "Ekaṁ samayaṁ bhagavā sāvatthiyaṁ viharati jetavane anāthapiṇḍikassa ārāme … ",
    "sn14.30:1.2": "“catasso imā, bhikkhave, dhātuyo. ",
    "sn14.30:1.3": "Katamā catasso? ",
    "sn14.30:1.4": "Pathavīdhātu, āpodhātu, tejodhātu, vāyodhātu—",
    "sn14.30:1.5": "imā kho, bhikkhave, catasso dhātuyo”ti. ",
    "sn14.30:1.6": "Paṭhamaṁ. "
  },
  "translation_text": {
    "sn14.30:0.1": "Linked Discourses 14.30 ",
    "sn14.30:0.2": "4. Chapter Four ",
    "sn14.30:0.3": "Four Elements ",
    "sn14.30:1.1": "At one time the Buddha was staying near Sāvatthī in Jeta’s Grove, Anāthapiṇḍika’s monastery. … ",
    "sn14.30:1.2": "“Mendicants, there are these four elements. ",
    "sn14.30:1.3": "What four? ",
    "sn14.30:1.4": "The elements of earth, water, fire, and air. ",
    "sn14.30:1.5": "These are the four elements.” "
  },
  "variant_text": {
    "sn14.30:0.3": "Catudhātusutta → catasso (pts1ed, pts2ed) "
  },
