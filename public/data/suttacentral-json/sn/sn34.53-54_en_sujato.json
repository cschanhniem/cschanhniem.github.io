  "root_text": {
    "sn34.53:0.1": "Saṁyutta Nikāya 34.53–54 ",
    "sn34.53:0.2": "1. Jhānavagga ",
    "sn34.53:0.3": "Sakkaccamūlakasātaccakārīsuttadukādi ",
    "sn34.53:1.1": "Sāvatthinidānaṁ … ",
    "sn34.53:1.2": "“samādhismiṁ sakkaccakārī hoti, na samādhismiṁ sātaccakārī … ",
    "sn34.53:1.3": "samādhismiṁ sātaccakārī hoti, na samādhismiṁ sakkaccakārī … ",
    "sn34.53:1.4": "neva samādhismiṁ sakkaccakārī hoti, na ca samādhismiṁ sātaccakārī … ",
    "sn34.53:1.5": "samādhismiṁ sakkaccakārī ca hoti, samādhismiṁ sātaccakārī ca. ",
    "sn34.53:1.6": "Tatra, bhikkhave, yvāyaṁ …pe… ",
    "sn34.53:1.7": "uttamo ca pavaro cā”ti. ",
    "sn34.53:1.8": "Tepaññāsamaṁ. ",
    "sn34.54:1.1": "“Samādhismiṁ sakkaccakārī hoti, na samādhismiṁ sappāyakārī …pe…. ",
    "sn34.54:1.2": "Catupaññāsamaṁ. "
  },
  "translation_text": {
    "sn34.53:0.1": "Linked Discourses 34.53–54 ",
    "sn34.53:0.2": "1. Absorption ",
    "sn34.53:0.3": "Two on Carefulness and Persistence ",
    "sn34.53:1.1": "At Sāvatthī. ",
    "sn34.53:1.2": "“One meditator is skilled in practicing carefully for immersion but not in practicing persistently for it. …” ",
    "sn34.54:1.1": "“One meditator is skilled in practicing carefully for immersion but not in doing what’s conducive to it. …” "
  },
