  "root_text": {
    "sn35.143:0.1": "Saṁyutta Nikāya 35.143 ",
    "sn35.143:0.2": "14. Devadahavagga ",
    "sn35.143:0.3": "Bāhirāniccahetusutta ",
    "sn35.143:1.1": "“Rūpā, bhikkhave, aniccā. ",
    "sn35.143:1.2": "Yopi hetu, yopi paccayo rūpānaṁ uppādāya, sopi anicco. ",
    "sn35.143:1.3": "Aniccasambhūtā, bhikkhave, rūpā kuto niccā bhavissanti. ",
    "sn35.143:1.4": "Saddā … ",
    "sn35.143:1.5": "gandhā … ",
    "sn35.143:1.6": "rasā … ",
    "sn35.143:1.7": "phoṭṭhabbā … ",
    "sn35.143:1.8": "dhammā aniccā. ",
    "sn35.143:1.9": "Yopi hetu, yopi paccayo dhammānaṁ uppādāya, sopi anicco. ",
    "sn35.143:1.10": "Aniccasambhūtā, bhikkhave, dhammā kuto niccā bhavissanti. ",
    "sn35.143:1.11": "Evaṁ passaṁ …pe… ",
    "sn35.143:1.12": "nāparaṁ itthattāyā’ti pajānātī”ti. ",
    "sn35.143:1.13": "Dasamaṁ. "
  },
  "translation_text": {
    "sn35.143:0.1": "Linked Discourses 35.143 ",
    "sn35.143:0.2": "14. At Devadaha ",
    "sn35.143:0.3": "Exterior and Cause Are Impermanent ",
    "sn35.143:1.1": "“Mendicants, sights are impermanent. ",
    "sn35.143:1.2": "The cause and reason that gives rise to sights is also impermanent. ",
    "sn35.143:1.3": "Since sights are produced by what is impermanent, how could they be permanent? ",
    "sn35.143:1.4": "Sounds … ",
    "sn35.143:1.5": "Smells … ",
    "sn35.143:1.6": "Tastes … ",
    "sn35.143:1.7": "Touches … ",
    "sn35.143:1.8": "Ideas are impermanent. ",
    "sn35.143:1.9": "The cause and reason that gives rise to ideas is also impermanent. ",
    "sn35.143:1.10": "Since ideas are produced by what is impermanent, how could they be permanent? ",
    "sn35.143:1.11": "Seeing this … ",
    "sn35.143:1.12": "They understand: ‘… there is nothing further for this place.’” "
  },
  "variant_text": {
    "sn35.143:0.3": "Bāhirāniccahetusutta → bāhiraaniccasuttaṁ (bj); hetunā bāhira 1 (pts1ed) "
  },
