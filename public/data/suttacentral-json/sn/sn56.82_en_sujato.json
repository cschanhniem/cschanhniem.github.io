  "root_text": {
    "sn56.82:0.1": "Saṁyutta Nikāya 56.82 ",
    "sn56.82:0.2": "9. Tatiyaāmakadhaññapeyyālavagga ",
    "sn56.82:0.3": "Uccāsayanasutta ",
    "sn56.82:1.1": "… “Evameva kho, bhikkhave, appakā te sattā ye uccāsayanamahāsayanā paṭiviratā; atha kho eteva bahutarā sattā ye uccāsayanamahāsayanā appaṭiviratā …pe…. ",
    "sn56.82:1.2": "Dutiyaṁ. "
  },
  "translation_text": {
    "sn56.82:0.1": "Linked Discourses 56.82 ",
    "sn56.82:0.2": "9. Abbreviated Texts on Raw Grain ",
    "sn56.82:0.3": "High Beds ",
    "sn56.82:1.1": "“… the sentient beings who refrain from high and luxurious beds are few, while those who don’t refrain are many. …” "
  },
  "variant_text": {
    "sn56.82:0.3": "Uccāsayanasutta → sayanaṁ (pts1ed) "
  },
