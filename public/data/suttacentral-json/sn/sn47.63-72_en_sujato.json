  "root_text": {
    "sn47.63-72:0.1": "Saṁyutta Nikāya 47.63–72 ",
    "sn47.63-72:0.2": "7. Appamādavagga ",
    "sn47.63-72:0.3": "Tathāgatādisutta ",
    "sn47.63-72:1.1": "“Yāvatā, bhikkhave, sattā apadā vā dvipadā vā catuppadā vā bahuppadā vā”ti  ",
    "sn47.63-72:1.2": "vitthāretabbaṁ.",
    "sn47.63-72:1.3": "Appamādavaggo sattamo. ",
    "sn47.63-72:2.0": "Tassuddānaṁ ",
    "sn47.63-72:2.1": "Tathāgataṁ padaṁ kūṭaṁ, ",
    "sn47.63-72:2.2": "mūlaṁ sāro ca vassikaṁ; ",
    "sn47.63-72:2.3": "Rājā candimasūriyā, ",
    "sn47.63-72:2.4": "vatthena dasamaṁ padanti. "
  },
  "translation_text": {
    "sn47.63-72:0.1": "Linked Discourses 47.63–72 ",
    "sn47.63-72:0.2": "7. Diligence ",
    "sn47.63-72:0.3": "The Realized One ",
    "sn47.63-72:1.1": "“Mendicants, the Realized One, the perfected one, the fully awakened Buddha, is said to be the best of all sentient beings—be they footless, with two feet, four feet, or many feet …” ",
    "sn47.63-72:1.2": "(Tell in full as in SN 45.139–148.) ",
    "sn47.63-72:2.1": "The Realized One, footprint, roof peak, ",
    "sn47.63-72:2.2": "roots, heartwood, jasmine, ",
    "sn47.63-72:2.3": "monarch, sun and moon, ",
    "sn47.63-72:2.4": "and cloth is the tenth. "
  },
