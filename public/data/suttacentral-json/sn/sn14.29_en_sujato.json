  "root_text": {
    "sn14.29:0.1": "Saṁyutta Nikāya 14.29 ",
    "sn14.29:0.2": "3. Kammapathavagga ",
    "sn14.29:0.3": "Dasaṅgasutta ",
    "sn14.29:1.1": "Sāvatthiyaṁ viharati. ",
    "sn14.29:1.2": "“Dhātusova, bhikkhave, sattā saṁsandanti samenti. ",
    "sn14.29:1.3": "Micchādiṭṭhikā micchādiṭṭhikehi saddhiṁ saṁsandanti samenti; ",
    "sn14.29:1.4": "micchāsaṅkappā …pe… ",
    "sn14.29:1.5": "micchāvācā … ",
    "sn14.29:1.6": "micchākammantā … ",
    "sn14.29:1.7": "micchāājīvā … ",
    "sn14.29:1.8": "micchāvāyāmā … ",
    "sn14.29:1.9": "micchāsatino … ",
    "sn14.29:1.10": "micchāsamādhino micchāsamādhīhi saddhiṁ saṁsandanti samenti; ",
    "sn14.29:1.11": "micchāñāṇino micchāñāṇīhi saddhiṁ saṁsandanti samenti; ",
    "sn14.29:1.12": "micchāvimuttino micchāvimuttīhi saddhiṁ saṁsandanti samenti. ",
    "sn14.29:2.1": "Sammādiṭṭhikā sammādiṭṭhikehi saddhiṁ saṁsandanti samenti; ",
    "sn14.29:2.2": "sammāsaṅkappā …pe… ",
    "sn14.29:2.3": "sammāvācā … ",
    "sn14.29:2.4": "sammākammantā … ",
    "sn14.29:2.5": "sammāājīvā … ",
    "sn14.29:2.6": "sammāvāyāmā … ",
    "sn14.29:2.7": "sammāsatino … ",
    "sn14.29:2.8": "sammāsamādhino … ",
    "sn14.29:2.9": "sammāñāṇino sammāñāṇīhi saddhiṁ saṁsandanti samenti; ",
    "sn14.29:2.10": "sammāvimuttino sammāvimuttīhi saddhiṁ saṁsandanti samentī”ti. ",
    "sn14.29:2.11": "Sattamaṁ. ",
    "sn14.29:2.12": "(Sabbattha atītānāgatapaccuppannaṁ kātabbaṁ.) ",
    "sn14.29:3.0": "Sattannaṁ suttantānaṁ uddānaṁ ",
    "sn14.29:3.1": "Asamāhitaṁ dussīlaṁ, ",
    "sn14.29:3.2": "pañca sikkhāpadāni ca; ",
    "sn14.29:3.3": "Satta kammapathā vuttā, ",
    "sn14.29:3.4": "dasakammapathena ca; ",
    "sn14.29:3.5": "Chaṭṭhaṁ aṭṭhaṅgiko vutto, ",
    "sn14.29:3.6": "dasaṅgena ca sattamaṁ. ",
    "sn14.29:3.7": "Kammapathavaggo tatiyo. "
  },
  "translation_text": {
    "sn14.29:0.1": "Linked Discourses 14.29 ",
    "sn14.29:0.2": "3. Ways of Performing Deeds ",
    "sn14.29:0.3": "Ten Factored Path ",
    "sn14.29:1.1": "At Sāvatthī. ",
    "sn14.29:1.2": "“Mendicants, sentient beings come together and converge because of an element: ",
    "sn14.29:1.3": "those of wrong view with those of wrong view … ",
    "sn14.29:1.4": "wrong thought … ",
    "sn14.29:1.5": "wrong speech … ",
    "sn14.29:1.6": "wrong action … ",
    "sn14.29:1.7": "wrong livelihood … ",
    "sn14.29:1.8": "wrong effort … ",
    "sn14.29:1.9": "wrong mindfulness … ",
    "sn14.29:1.10": "wrong immersion … ",
    "sn14.29:1.11": "wrong knowledge … ",
    "sn14.29:1.12": "wrong freedom … ",
    "sn14.29:2.1": "Those who have right view … ",
    "sn14.29:2.2": "right thought … ",
    "sn14.29:2.3": "right speech … ",
    "sn14.29:2.4": "right action … ",
    "sn14.29:2.5": "right livelihood … ",
    "sn14.29:2.6": "right effort … ",
    "sn14.29:2.7": "right mindfulness … ",
    "sn14.29:2.8": "right immersion … ",
    "sn14.29:2.9": "right knowledge … ",
    "sn14.29:2.10": "right freedom with those who have right freedom.” ",
    "sn14.29:2.11": "",
    "sn14.29:2.12": "(Tell all in full for the past, future, and present.) ",
