  "root_text": {
    "sn25.8:0.1": "Saṁyutta Nikāya 25.8 ",
    "sn25.8:0.2": "1. Cakkhuvagga ",
    "sn25.8:0.3": "Rūpataṇhāsutta ",
    "sn25.8:1.1": "Sāvatthinidānaṁ. ",
    "sn25.8:1.2": "“Rūpataṇhā, bhikkhave, aniccā vipariṇāmī aññathābhāvī; ",
    "sn25.8:1.3": "saddataṇhā … ",
    "sn25.8:1.4": "gandhataṇhā … ",
    "sn25.8:1.5": "rasataṇhā … ",
    "sn25.8:1.6": "phoṭṭhabbataṇhā … ",
    "sn25.8:1.7": "dhammataṇhā aniccā vipariṇāmī aññathābhāvī. ",
    "sn25.8:1.8": "Yo, bhikkhave, ime dhamme evaṁ saddahati adhimuccati, ayaṁ vuccati ‘saddhānusārī …pe… ",
    "sn25.8:1.9": "sambodhiparāyano’”ti. ",
    "sn25.8:1.10": "Aṭṭhamaṁ. "
  },
  "translation_text": {
    "sn25.8:0.1": "Linked Discourses 25.8 ",
    "sn25.8:0.2": "1. The Eye ",
    "sn25.8:0.3": "Craving For Sights ",
    "sn25.8:1.1": "At Sāvatthī. ",
    "sn25.8:1.2": "“Mendicants, craving for sights is impermanent, decaying, and perishing. ",
    "sn25.8:1.3": "Craving for sounds, ",
    "sn25.8:1.4": "craving for smells, ",
    "sn25.8:1.5": "craving for tastes, ",
    "sn25.8:1.6": "craving for touches, ",
    "sn25.8:1.7": "and craving for ideas are impermanent, decaying, and perishing. ",
    "sn25.8:1.8": "Someone who has faith and confidence in these teachings is called a follower by faith. …” ",
    "sn25.8:1.9": ""
  },
  "variant_text": {
    "sn25.8:0.3": "Rūpataṇhāsutta → taṇhāsuttaṁ (bj); taṇhā (pts1ed) "
  },
