  "root_text": {
    "sn45.35:0.1": "Saṁyutta Nikāya 45.35 ",
    "sn45.35:0.2": "4. Paṭipattivagga ",
    "sn45.35:0.3": "Paṭhamasāmaññasutta ",
    "sn45.35:1.1": "Sāvatthinidānaṁ. ",
    "sn45.35:1.2": "“Sāmaññañca vo, bhikkhave, desessāmi, sāmaññaphalāni ca. ",
    "sn45.35:1.3": "Taṁ suṇātha. ",
    "sn45.35:1.4": "Katamañca, bhikkhave, sāmaññaṁ? ",
    "sn45.35:1.5": "Ayameva ariyo aṭṭhaṅgiko maggo, seyyathidaṁ—",
    "sn45.35:1.6": "sammādiṭṭhi …pe… sammāsamādhi. ",
    "sn45.35:1.7": "Idaṁ vuccati, bhikkhave, sāmaññaṁ. ",
    "sn45.35:1.8": "Katamāni ca, bhikkhave, sāmaññaphalāni? ",
    "sn45.35:1.9": "Sotāpattiphalaṁ, sakadāgāmiphalaṁ, anāgāmiphalaṁ, arahattaphalaṁ—",
    "sn45.35:1.10": "imāni vuccanti, bhikkhave, sāmaññaphalānī”ti. ",
    "sn45.35:1.11": "Pañcamaṁ. "
  },
  "translation_text": {
    "sn45.35:0.1": "Linked Discourses 45.35 ",
    "sn45.35:0.2": "4. Practice ",
    "sn45.35:0.3": "The Ascetic Life (1st) ",
    "sn45.35:1.1": "At Sāvatthī. ",
    "sn45.35:1.2": "“Mendicants, I will teach you the ascetic life and the fruits of the ascetic life. ",
    "sn45.35:1.3": "Listen … ",
    "sn45.35:1.4": "And what is the ascetic life? ",
    "sn45.35:1.5": "It is simply this noble eightfold path, that is: ",
    "sn45.35:1.6": "right view, right thought, right speech, right action, right livelihood, right effort, right mindfulness, and right immersion. ",
    "sn45.35:1.7": "This is called the ascetic life. ",
    "sn45.35:1.8": "And what are the fruits of the ascetic life? ",
    "sn45.35:1.9": "The fruits of stream-entry, once-return, non-return, and perfection. ",
    "sn45.35:1.10": "These are called the fruits of the ascetic life.” "
  },
