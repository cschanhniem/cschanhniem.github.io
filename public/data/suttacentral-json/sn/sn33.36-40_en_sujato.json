  "root_text": {
    "sn33.36-40:0.1": "Saṁyutta Nikāya 33.36–40 ",
    "sn33.36-40:0.2": "1. Vacchagottavagga ",
    "sn33.36-40:0.3": "Rūpaappaccupalakkhaṇādisuttapañcaka ",
    "sn33.36-40:1.1": "Sāvatthinidānaṁ. ",
    "sn33.36-40:1.2": "“Rūpe kho, vaccha, appaccupalakkhaṇā …pe… viññāṇe kho, vaccha, appaccupalakkhaṇā …pe…. ",
    "sn33.36-40:1.3": "Cattālīsamaṁ. "
  },
  "translation_text": {
    "sn33.36-40:0.1": "Linked Discourses 33.36–40 ",
    "sn33.36-40:0.2": "1. With Vacchagotta ",
    "sn33.36-40:0.3": "Five Discourses on Not Differentiating Form, Etc. ",
    "sn33.36-40:1.1": "At Sāvatthī. ",
    "sn33.36-40:1.2": "“Vaccha, it is because of not differentiating form …” "
  },
