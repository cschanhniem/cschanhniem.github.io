  "root_text": {
    "sn46.66:0.1": "Saṁyutta Nikāya 46.66 ",
    "sn46.66:0.2": "7. Ānāpānavagga ",
    "sn46.66:0.3": "Ānāpānasutta ",
    "sn46.66:1.1": "“Ānāpānassati, bhikkhave, bhāvitā …pe…” ",
    "sn46.66:1.2": "dasamaṁ. ",
    "sn46.66:1.3": "Ānāpānavaggo sattamo. ",
    "sn46.66:2.0": "Tassuddānaṁ ",
    "sn46.66:2.1": "Aṭṭhikapuḷavakaṁ vinīlakaṁ, ",
    "sn46.66:2.2": "Vicchiddakaṁ uddhumātena pañcamaṁ; ",
    "sn46.66:2.3": "Mettā karuṇā muditā, ",
    "sn46.66:2.4": "Upekkhā ānāpānena te dasāti. "
  },
  "translation_text": {
    "sn46.66:0.1": "Linked Discourses 46.66 ",
    "sn46.66:0.2": "7. Breathing ",
    "sn46.66:0.3": "Breathing ",
    "sn46.66:1.1": "“Mendicants, when mindfulness of breathing is developed and cultivated it’s very fruitful and beneficial. …” ",
