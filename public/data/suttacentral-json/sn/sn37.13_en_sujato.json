  "root_text": {
    "sn37.13:0.1": "Saṁyutta Nikāya 37.13 ",
    "sn37.13:0.2": "1. Paṭhamapeyyālavagga ",
    "sn37.13:0.3": "Muṭṭhassatisutta ",
    "sn37.13:1.1": "“Pañcahi, anuruddha, dhammehi samannāgato mātugāmo …pe… nirayaṁ upapajjati. ",
    "sn37.13:1.2": "Katamehi pañcahi? ",
    "sn37.13:1.3": "Assaddho ca hoti, ahiriko ca hoti, anottappī ca hoti, muṭṭhassati ca hoti, duppañño ca hoti—",
    "sn37.13:1.4": "imehi kho, anuruddha, pañcahi dhammehi samannāgato mātugāmo …pe… nirayaṁ upapajjatī”ti. ",
    "sn37.13:1.5": "Terasamaṁ. "
  },
  "translation_text": {
    "sn37.13:0.1": "Linked Discourses 37.13 ",
    "sn37.13:0.2": "1. Abbreviated Texts ",
    "sn37.13:0.3": "Unmindful ",
    "sn37.13:1.1": "",
    "sn37.13:1.2": "",
    "sn37.13:1.3": "“… They’re faithless, shameless, imprudent, unmindful, and witless. …” ",
    "sn37.13:1.4": ""
  },
