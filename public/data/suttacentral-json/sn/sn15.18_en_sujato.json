  "root_text": {
    "sn15.18:0.1": "Saṁyutta Nikāya 15.18 ",
    "sn15.18:0.2": "2. Dutiyavagga ",
    "sn15.18:0.3": "Puttasutta ",
    "sn15.18:1.1": "Sāvatthiyaṁ viharati …pe… ",
    "sn15.18:1.2": "“na so, bhikkhave, satto sulabharūpo yo naputtabhūtapubbo …pe… ",
    "sn15.18:1.3": "alaṁ vimuccitun”ti. ",
    "sn15.18:1.4": "Aṭṭhamaṁ. "
  },
  "translation_text": {
    "sn15.18:0.1": "Linked Discourses 15.18 ",
    "sn15.18:0.2": "Chapter Two ",
    "sn15.18:0.3": "Son ",
    "sn15.18:1.1": "At Sāvatthī. ",
    "sn15.18:1.2": "“It’s not easy to find a sentient being who in all this long time has not previously been your son. … ",
    "sn15.18:1.3": "This is quite enough for you to become disillusioned, dispassionate, and freed regarding all conditions.” "
  },
