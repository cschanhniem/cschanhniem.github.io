  "root_text": {
    "sn56.67:0.1": "Saṁyutta Nikāya 56.67 ",
    "sn56.67:0.2": "7. Paṭhamaāmakadhaññapeyyālavagga ",
    "sn56.67:0.3": "Petteyyasutta ",
    "sn56.67:1.1": "… “Evameva kho, bhikkhave, appakā te sattā ye petteyyā; atha kho eteva bahutarā sattā ye apetteyyā …pe…. ",
    "sn56.67:1.2": "Sattamaṁ. "
  },
  "translation_text": {
    "sn56.67:0.1": "Linked Discourses 56.67 ",
    "sn56.67:0.2": "7. Abbreviated Texts on Raw Grain ",
    "sn56.67:0.3": "Respect Father ",
    "sn56.67:1.1": "“… the sentient beings who respect their fathers are few, while those who don’t are many. …” "
  },
