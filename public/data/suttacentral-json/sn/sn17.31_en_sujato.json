  "root_text": {
    "sn17.31:0.1": "Saṁyutta Nikāya 17.31 ",
    "sn17.31:0.2": "4. Catutthavagga ",
    "sn17.31:0.3": "Bhindisutta ",
    "sn17.31:1.1": "Sāvatthiyaṁ viharati. ",
    "sn17.31:1.2": "“Dāruṇo, bhikkhave, lābhasakkārasiloko. ",
    "sn17.31:1.3": "Lābhasakkārasilokena abhibhūto pariyādiṇṇacitto, bhikkhave, devadatto saṅghaṁ bhindi. ",
    "sn17.31:1.4": "Evaṁ dāruṇo kho, bhikkhave, lābhasakkārasiloko …pe… ",
    "sn17.31:1.5": "sikkhitabban”ti. ",
    "sn17.31:1.6": "Paṭhamaṁ. "
  },
  "translation_text": {
    "sn17.31:0.1": "Linked Discourses 17.31 ",
    "sn17.31:0.2": "Chapter Four ",
    "sn17.31:0.3": "Schism ",
    "sn17.31:1.1": "At Sāvatthī. ",
    "sn17.31:1.2": "“Possessions, honor, and popularity are grim … ",
    "sn17.31:1.3": "Devadatta split the Saṅgha because his mind was overcome and overwhelmed by possessions, honor, and popularity. ",
    "sn17.31:1.4": "So grim are possessions, honor, and popularity. …” ",
    "sn17.31:1.5": ""
  },
  "variant_text": {
    "sn17.31:0.2": "Catutthavagga → saṅghabhedavaggo (bj) ",
    "sn17.31:0.3": "Bhindisutta → saṅghabhedasuttaṁ (bj); chindi (pts1ed, pts2ed) "
  },
