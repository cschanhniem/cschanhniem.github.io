  "root_text": {
    "sn34.12:0.1": "Saṁyutta Nikāya 34.12 ",
    "sn34.12:0.2": "1. Jhānavagga ",
    "sn34.12:0.3": "Samāpattimūlakavuṭṭhānasutta ",
    "sn34.12:1.1": "Sāvatthinidānaṁ. ",
    "sn34.12:1.2": "“Cattārome, bhikkhave, jhāyī. ",
    "sn34.12:1.3": "Katame cattāro? ",
    "sn34.12:1.4": "Idha, bhikkhave, ekacco jhāyī samādhismiṁ samāpattikusalo hoti, na samādhismiṁ vuṭṭhānakusalo. ",
    "sn34.12:1.5": "Idha pana, bhikkhave, ekacco jhāyī samādhismiṁ vuṭṭhānakusalo hoti, na samādhismiṁ samāpattikusalo. ",
    "sn34.12:1.6": "Idha pana, bhikkhave, ekacco jhāyī neva samādhismiṁ samāpattikusalo hoti, na ca samādhismiṁ vuṭṭhānakusalo. ",
    "sn34.12:1.7": "Idha pana, bhikkhave, ekacco jhāyī samādhismiṁ samāpattikusalo ca hoti, samādhismiṁ vuṭṭhānakusalo ca. ",
    "sn34.12:1.8": "Tatra, bhikkhave, yvāyaṁ jhāyī …pe… ",
    "sn34.12:1.9": "pavaro cā”ti. ",
    "sn34.12:1.10": "Dvādasamaṁ. "
  },
  "translation_text": {
    "sn34.12:0.1": "Linked Discourses 34.12 ",
    "sn34.12:0.2": "1. Absorption ",
    "sn34.12:0.3": "Entering and Emerging ",
    "sn34.12:1.1": "At Sāvatthī. ",
    "sn34.12:1.2": "“Mendicants, there are these four meditators. ",
    "sn34.12:1.3": "What four? ",
    "sn34.12:1.4": "One meditator is skilled in entering immersion but not in emerging from it. …” "
  },
  "variant_text": {
    "sn34.12:0.3": "Samāpattimūlakavuṭṭhānasutta → samāpattivuṭṭhānakusalasuttaṁ (bj); samāpatti-vuṭṭhāna (pts1ed) "
  },
