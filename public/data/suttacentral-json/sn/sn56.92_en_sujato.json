  "root_text": {
    "sn56.92:0.1": "Saṁyutta Nikāya 56.92 ",
    "sn56.92:0.2": "10. Catutthaāmakadhaññapeyyālavagga ",
    "sn56.92:0.3": "Kayavikkayasutta ",
    "sn56.92:1.1": "… “Evameva kho, bhikkhave, appakā te sattā ye kayavikkayā paṭiviratā; atha kho eteva bahutarā sattā ye kayavikkayā appaṭiviratā …pe…. ",
    "sn56.92:1.2": "Dutiyaṁ. "
  },
  "translation_text": {
    "sn56.92:0.1": "Linked Discourses 56.92 ",
    "sn56.92:0.2": "10. Abbreviated Texts on Raw Grain ",
    "sn56.92:0.3": "Buying and Selling ",
    "sn56.92:1.1": "“… the sentient beings who refrain from buying and selling are few, while those who don’t refrain are many. …” "
  },
