  "root_text": {
    "sn35.77:0.1": "Saṁyutta Nikāya 35.77 ",
    "sn35.77:0.2": "8. Gilānavagga ",
    "sn35.77:0.3": "Rādhadukkhasutta ",
    "sn35.77:1.1": "“Yaṁ kho, rādha, dukkhaṁ tatra te chando pahātabbo. ",
    "sn35.77:1.2": "Kiñca, rādha, dukkhaṁ? ",
    "sn35.77:1.3": "Cakkhu kho, rādha, dukkhaṁ. Tatra te chando pahātabbo. ",
    "sn35.77:1.4": "Rūpā … ",
    "sn35.77:1.5": "cakkhuviññāṇaṁ … ",
    "sn35.77:1.6": "cakkhusamphasso … ",
    "sn35.77:1.7": "yampidaṁ cakkhusamphassa …pe… adukkhamasukhaṁ vā tampi dukkhaṁ. Tatra te chando pahātabbo …pe… ",
    "sn35.77:1.8": "mano dukkho … ",
    "sn35.77:1.9": "dhammā … ",
    "sn35.77:1.10": "manoviññāṇaṁ … ",
    "sn35.77:1.11": "manosamphasso … ",
    "sn35.77:1.12": "yampidaṁ manosamphassapaccayā uppajjati vedayitaṁ sukhaṁ vā dukkhaṁ vā adukkhamasukhaṁ vā tampi dukkhaṁ. Tatra te chando pahātabbo. ",
    "sn35.77:1.13": "Yaṁ kho, rādha, dukkhaṁ tatra te chando pahātabbo”ti. ",
    "sn35.77:1.14": "Catutthaṁ. "
  },
  "translation_text": {
    "sn35.77:0.1": "Linked Discourses 35.77 ",
    "sn35.77:0.2": "8. Sick ",
    "sn35.77:0.3": "With Rādha on Suffering ",
    "sn35.77:1.1": "“Rādha, you should give up desire for what is suffering. …” ",
