  "root_text": {
    "sn22.156:0.1": "Saṁyutta Nikāya 22.156 ",
    "sn22.156:0.2": "15. Diṭṭhivagga ",
    "sn22.156:0.3": "Attānudiṭṭhisutta ",
    "sn22.156:1.1": "Sāvatthinidānaṁ. ",
    "sn22.156:1.2": "“Kismiṁ nu kho, bhikkhave, sati, kiṁ upādāya, kiṁ abhinivissa attānudiṭṭhi uppajjatī”ti? ",
    "sn22.156:1.3": "Bhagavaṁmūlakā no, bhante, dhammā …pe… ",
    "sn22.156:1.4": "“rūpe kho, bhikkhave, sati, rūpaṁ upādāya, rūpaṁ abhinivissa attānudiṭṭhi uppajjati. ",
    "sn22.156:1.5": "Vedanāya sati … ",
    "sn22.156:1.6": "saññāya sati … ",
    "sn22.156:1.7": "saṅkhāresu sati … ",
    "sn22.156:1.8": "viññāṇe sati, viññāṇaṁ upādāya, viññāṇaṁ abhinivissa attānudiṭṭhi uppajjati. ",
    "sn22.156:1.9": "Taṁ kiṁ maññatha, bhikkhave, ",
    "sn22.156:1.10": "rūpaṁ niccaṁ vā aniccaṁ vā”ti? ",
    "sn22.156:1.11": "“Aniccaṁ, bhante”. ",
    "sn22.156:1.12": "“Yaṁ panāniccaṁ …pe… ",
    "sn22.156:1.13": "api nu taṁ anupādāya attānudiṭṭhi uppajjeyyā”ti? ",
    "sn22.156:1.14": "“No hetaṁ, bhante”. ",
    "sn22.156:1.15": "“Vedanā … ",
    "sn22.156:1.16": "saññā … ",
    "sn22.156:1.17": "saṅkhārā … ",
    "sn22.156:1.18": "viññāṇaṁ niccaṁ vā aniccaṁ vā”ti? ",
    "sn22.156:1.19": "“Aniccaṁ, bhante”. ",
    "sn22.156:1.20": "“Yaṁ panāniccaṁ …pe… ",
    "sn22.156:1.21": "api nu taṁ anupādāya attānudiṭṭhi uppajjeyyā”ti? ",
    "sn22.156:1.22": "“No hetaṁ, bhante”. ",
    "sn22.156:1.23": "“Evaṁ passaṁ …pe… ",
    "sn22.156:1.24": "nāparaṁ itthattāyāti pajānātī”ti. ",
    "sn22.156:1.25": "Sattamaṁ. "
  },
  "translation_text": {
    "sn22.156:0.1": "Linked Discourses 22.156 ",
    "sn22.156:0.2": "15. Views ",
    "sn22.156:0.3": "Theory of Self ",
    "sn22.156:1.1": "At Sāvatthī. ",
    "sn22.156:1.2": "“Mendicants, when what exists, because of grasping what and insisting on what, does theory of self arise?” ",
    "sn22.156:1.3": "“Our teachings are rooted in the Buddha. …” ",
    "sn22.156:1.4": "“When form exists, because of grasping form and insisting on form, theory of self arises. ",
    "sn22.156:1.5": "When feeling … ",
    "sn22.156:1.6": "perception … ",
    "sn22.156:1.7": "choices … ",
    "sn22.156:1.8": "consciousness exists, because of grasping consciousness and insisting on consciousness, theory of self arises. ",
    "sn22.156:1.9": "What do you think, mendicants? ",
    "sn22.156:1.10": "Is form permanent or impermanent?” ",
    "sn22.156:1.11": "“Impermanent, sir.” … ",
    "sn22.156:1.12": "",
    "sn22.156:1.13": "“But by not grasping what’s impermanent, suffering, and perishable, would theory of self arise?” ",
    "sn22.156:1.14": "“No, sir.” ",
    "sn22.156:1.15": "“Is feeling … ",
    "sn22.156:1.16": "perception … ",
    "sn22.156:1.17": "choices … ",
    "sn22.156:1.18": "consciousness permanent or impermanent?” ",
    "sn22.156:1.19": "“Impermanent, sir.” … ",
    "sn22.156:1.20": "",
    "sn22.156:1.21": "“But by not grasping what’s impermanent, suffering, and perishable, would theory of self arise?” ",
    "sn22.156:1.22": "“No, sir.” ",
    "sn22.156:1.23": "“Seeing this … ",
    "sn22.156:1.24": "They understand: ‘… there is nothing further for this place.’” "
  },
  "variant_text": {
    "sn22.156:0.3": "Attānudiṭṭhisutta → attānu (pts1ed) "
  },
