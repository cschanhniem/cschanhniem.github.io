  "root_text": {
    "sn1.18:0.1": "Saṁyutta Nikāya 1.18 ",
    "sn1.18:0.2": "2. Nandanavagga ",
    "sn1.18:0.3": "Hirīsutta ",
    "sn1.18:1.1": "“Hirīnisedho puriso, ",
    "sn1.18:1.2": "koci lokasmiṁ vijjati; ",
    "sn1.18:1.3": "Yo nindaṁ apabodhati, ",
    "sn1.18:1.4": "asso bhadro kasāmivā”ti. ",
    "sn1.18:2.1": "“Hirīnisedhā tanuyā, ",
    "sn1.18:2.2": "ye caranti sadā satā; ",
    "sn1.18:2.3": "Antaṁ dukkhassa pappuyya, ",
    "sn1.18:2.4": "caranti visame saman”ti. "
  },
  "translation_text": {
    "sn1.18:0.1": "Linked Discourses 1.18 ",
    "sn1.18:0.2": "2. The Garden of Delight ",
    "sn1.18:0.3": "Conscience ",
    "sn1.18:1.1": "“Can a person constrained by conscience ",
    "sn1.18:1.2": "be found in the world, ",
    "sn1.18:1.3": "who is cognizant of blame, ",
    "sn1.18:1.4": "like a fine horse of the whip?” ",
    "sn1.18:2.1": "“Few are those constrained by conscience, ",
    "sn1.18:2.2": "who live always mindful. ",
    "sn1.18:2.3": "Having reached the end of suffering, ",
    "sn1.18:2.4": "smoothly they walk in the rough.” "
  },
  "variant_text": {
    "sn1.18:0.3": "Hirīsutta → hirisuttaṁ (bj, sya1ed, sya2ed, pts2ed) ",
    "sn1.18:1.1": "Hirīnisedho → hirinisedho (bj, sya1ed, sya2ed) "
  },
