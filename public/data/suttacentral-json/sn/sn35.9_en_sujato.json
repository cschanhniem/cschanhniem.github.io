  "root_text": {
    "sn35.9:0.1": "Saṁyutta Nikāya 35.9 ",
    "sn35.9:0.2": "1. Aniccavagga ",
    "sn35.9:0.3": "Ajjhattānattātītānāgatasutta ",
    "sn35.9:1.1": "“Cakkhuṁ, bhikkhave, anattā atītānāgataṁ; ",
    "sn35.9:1.2": "ko pana vādo paccuppannassa. ",
    "sn35.9:1.3": "Evaṁ passaṁ, bhikkhave, sutavā ariyasāvako atītasmiṁ cakkhusmiṁ anapekkho hoti; ",
    "sn35.9:1.4": "anāgataṁ cakkhuṁ nābhinandati; ",
    "sn35.9:1.5": "paccuppannassa cakkhussa nibbidāya virāgāya nirodhāya paṭipanno hoti. ",
    "sn35.9:1.6": "Sotaṁ anattā …pe… ",
    "sn35.9:1.7": "ghānaṁ anattā …pe… ",
    "sn35.9:1.8": "jivhā anattā atītānāgatā; ",
    "sn35.9:1.9": "ko pana vādo paccuppannāya. ",
    "sn35.9:1.10": "Evaṁ passaṁ, bhikkhave, sutavā ariyasāvako atītāya jivhāya anapekkho hoti; ",
    "sn35.9:1.11": "anāgataṁ jivhaṁ nābhinandati; ",
    "sn35.9:1.12": "paccuppannāya jivhāya nibbidāya virāgāya nirodhāya paṭipanno hoti. ",
    "sn35.9:1.13": "Kāyo anattā …pe… ",
    "sn35.9:1.14": "mano anattā atītānāgato; ",
    "sn35.9:1.15": "ko pana vādo paccuppannassa. ",
    "sn35.9:1.16": "Evaṁ passaṁ, bhikkhave, sutavā ariyasāvako atītasmiṁ manasmiṁ anapekkho hoti; ",
    "sn35.9:1.17": "anāgataṁ manaṁ nābhinandati; ",
    "sn35.9:1.18": "paccuppannassa manassa nibbidāya virāgāya nirodhāya paṭipanno hotī”ti. ",
    "sn35.9:1.19": "Navamaṁ. "
  },
  "translation_text": {
    "sn35.9:0.1": "Linked Discourses 35.9 ",
    "sn35.9:0.2": "1. Impermanence ",
    "sn35.9:0.3": "The Interior as Not-Self in the Three Times ",
    "sn35.9:1.1": "“Mendicants, the eye of the past and future is not-self, ",
    "sn35.9:1.2": "let alone the present. ",
    "sn35.9:1.3": "Seeing this, a learned noble disciple is not concerned with the eye of the past, ",
    "sn35.9:1.4": "they don’t look forward to enjoying the eye in the future, ",
    "sn35.9:1.5": "and they practice for disillusionment, dispassion, and cessation regarding the eye in the present. …” ",
