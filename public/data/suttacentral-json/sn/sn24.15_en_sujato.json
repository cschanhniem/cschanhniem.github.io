  "root_text": {
    "sn24.15:0.1": "Saṁyutta Nikāya 24.15 ",
    "sn24.15:0.2": "1. Sotāpattivagga ",
    "sn24.15:0.3": "Hotitathāgatosutta ",
    "sn24.15:1.1": "Sāvatthinidānaṁ. ",
    "sn24.15:1.2": "“Kismiṁ nu kho, bhikkhave, sati, kiṁ upādāya, kiṁ abhinivissa evaṁ diṭṭhi uppajjati: ",
    "sn24.15:1.3": "‘hoti tathāgato paraṁ maraṇā’”ti? ",
    "sn24.15:1.4": "“Bhagavaṁmūlakā no, bhante, dhammā …pe… ",
    "sn24.15:1.5": "niyato sambodhiparāyano”ti. ",
    "sn24.15:1.6": "Pannarasamaṁ. "
  },
  "translation_text": {
    "sn24.15:0.1": "Linked Discourses 24.15 ",
    "sn24.15:0.2": "1. Stream-Entry ",
    "sn24.15:0.3": "A Realized One Still Exists ",
    "sn24.15:1.1": "At Sāvatthī. ",
    "sn24.15:1.2": "“Mendicants, when what exists, because of grasping what and insisting on what, does the view arise: ",
    "sn24.15:1.3": "‘A realized one still exists after death’?” … ",
    "sn24.15:1.4": "",
    "sn24.15:1.5": ""
  },
  "variant_text": {
    "sn24.15:0.3": "Hotitathāgatosutta → hotitathāgatasuttaṁ (bj) "
  },
