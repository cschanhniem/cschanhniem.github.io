  "root_text": {
    "sn48.31:0.1": "Saṁyutta Nikāya 48.31 ",
    "sn48.31:0.2": "4. Sukhindriyavagga ",
    "sn48.31:0.3": "Suddhikasutta ",
    "sn48.31:1.1": "“Pañcimāni, bhikkhave, indriyāni. ",
    "sn48.31:1.2": "Katamāni pañca? ",
    "sn48.31:1.3": "Sukhindriyaṁ, dukkhindriyaṁ, somanassindriyaṁ, domanassindriyaṁ, upekkhindriyaṁ—",
    "sn48.31:1.4": "imāni kho, bhikkhave, pañcindriyānī”ti. ",
    "sn48.31:1.5": "Paṭhamaṁ. "
  },
  "translation_text": {
    "sn48.31:0.1": "Linked Discourses 48.31 ",
    "sn48.31:0.2": "4. The Pleasure Faculty ",
    "sn48.31:0.3": "Plain Version ",
    "sn48.31:1.1": "“Mendicants, there are these five faculties. ",
    "sn48.31:1.2": "What five? ",
    "sn48.31:1.3": "The faculties of pleasure, pain, happiness, sadness, and equanimity. ",
    "sn48.31:1.4": "These are the five faculties.” "
  },
  "variant_text": {
    "sn48.31:0.3": "Suddhikasutta → suddhakasuttaṁ (bj) "
  },
