  "root_text": {
    "sn17.21:0.1": "Saṁyutta Nikāya 17.21 ",
    "sn17.21:0.2": "3. Tatiyavagga ",
    "sn17.21:0.3": "Mātugāmasutta ",
    "sn17.21:1.1": "Sāvatthiyaṁ viharati. ",
    "sn17.21:1.2": "“Dāruṇo, bhikkhave, lābhasakkārasiloko …pe… ",
    "sn17.21:1.3": "na tassa, bhikkhave, mātugāmo eko ekassa cittaṁ pariyādāya tiṭṭhati yassa lābhasakkārasiloko cittaṁ pariyādāya tiṭṭhati. ",
    "sn17.21:1.4": "Evaṁ dāruṇo kho, bhikkhave, lābhasakkārasiloko …pe… ",
    "sn17.21:1.5": "evañhi vo, bhikkhave, sikkhitabban”ti. ",
    "sn17.21:1.6": "Paṭhamaṁ. "
  },
  "translation_text": {
    "sn17.21:0.1": "Linked Discourses 17.21 ",
    "sn17.21:0.2": "Chapter Three ",
    "sn17.21:0.3": "A Female ",
    "sn17.21:1.1": "At Sāvatthī. ",
    "sn17.21:1.2": "“Possessions, honor, and popularity are grim … ",
    "sn17.21:1.3": "Even if you’re alone with a lady she might not occupy your mind, but possessions, honor and popularity would still occupy your mind. ",
    "sn17.21:1.4": "So grim are possessions, honor, and popularity. …” ",
    "sn17.21:1.5": ""
  },
  "variant_text": {
    "sn17.21:0.2": "Tatiyavagga → mātugāmavaggo (bj) "
  },
