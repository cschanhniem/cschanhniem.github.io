  "root_text": {
    "sn35.226:0.1": "Saṁyutta Nikāya 35.226 ",
    "sn35.226:0.2": "17. Saṭṭhipeyyālavagga ",
    "sn35.226:0.3": "Bāhirāyatanadukkhasutta ",
    "sn35.226:1.1": "“Rūpā, bhikkhave, dukkhā. Saddā … gandhā … rasā … phoṭṭhabbā … dhammā dukkhā. ",
    "sn35.226:1.2": "Evaṁ passaṁ …pe… ",
    "sn35.226:1.3": "nāparaṁ itthattāyāti pajānātī”ti. "
  },
  "translation_text": {
    "sn35.226:0.1": "Linked Discourses 35.226 ",
    "sn35.226:0.2": "17. Sixty Abbreviated Texts ",
    "sn35.226:0.3": "The Exterior as Suffering ",
    "sn35.226:1.1": "“Mendicants, sights, sounds, smells, tastes, touches, and ideas are suffering. ",
    "sn35.226:1.2": "Seeing this … ",
    "sn35.226:1.3": "They understand: ‘… there is nothing further for this place.’” "
  },
