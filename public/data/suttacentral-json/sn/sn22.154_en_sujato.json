  "root_text": {
    "sn22.154:0.1": "Saṁyutta Nikāya 22.154 ",
    "sn22.154:0.2": "15. Diṭṭhivagga ",
    "sn22.154:0.3": "Micchādiṭṭhisutta ",
    "sn22.154:1.1": "Sāvatthinidānaṁ. ",
    "sn22.154:1.2": "“Kismiṁ nu kho, bhikkhave, sati, kiṁ upādāya, kiṁ abhinivissa micchādiṭṭhi uppajjatī”ti? ",
    "sn22.154:1.3": "Bhagavaṁmūlakā no, bhante, dhammā …pe… ",
    "sn22.154:1.4": "“rūpe kho, bhikkhave, sati, rūpaṁ upādāya, rūpaṁ abhinivissa micchādiṭṭhi uppajjati. ",
    "sn22.154:1.5": "Vedanāya sati … ",
    "sn22.154:1.6": "saññāya sati … ",
    "sn22.154:1.7": "saṅkhāresu sati … ",
    "sn22.154:1.8": "viññāṇe sati, viññāṇaṁ upādāya, viññāṇaṁ abhinivissa micchādiṭṭhi uppajjati. ",
    "sn22.154:1.9": "Taṁ kiṁ maññatha, bhikkhave, ",
    "sn22.154:1.10": "rūpaṁ niccaṁ vā aniccaṁ vā”ti? ",
    "sn22.154:1.11": "“Aniccaṁ, bhante”. ",
    "sn22.154:1.12": "“Yaṁ panāniccaṁ …pe… ",
    "sn22.154:1.13": "api nu taṁ anupādāya micchādiṭṭhi uppajjeyyā”ti? ",
    "sn22.154:1.14": "“No hetaṁ, bhante”. ",
    "sn22.154:1.15": "“Vedanā … ",
    "sn22.154:1.16": "saññā … ",
    "sn22.154:1.17": "saṅkhārā … ",
    "sn22.154:1.18": "viññāṇaṁ niccaṁ vā aniccaṁ vā”ti? ",
    "sn22.154:1.19": "“Aniccaṁ, bhante”. ",
    "sn22.154:1.20": "“Yaṁ panāniccaṁ dukkhaṁ vā taṁ sukhaṁ vā”ti? ",
    "sn22.154:1.21": "“Dukkhaṁ, bhante”. ",
    "sn22.154:1.22": "“Yaṁ panāniccaṁ dukkhaṁ vipariṇāmadhammaṁ, api nu taṁ anupādāya micchādiṭṭhi uppajjeyyā”ti? ",
    "sn22.154:1.23": "“No hetaṁ, bhante”. ",
    "sn22.154:1.24": "“Evaṁ passaṁ …pe… ",
    "sn22.154:1.25": "nāparaṁ itthattāyāti pajānātī”ti. ",
    "sn22.154:1.26": "Pañcamaṁ. "
  },
  "translation_text": {
    "sn22.154:0.1": "Linked Discourses 22.154 ",
    "sn22.154:0.2": "15. Views ",
    "sn22.154:0.3": "Wrong View ",
    "sn22.154:1.1": "At Sāvatthī. ",
    "sn22.154:1.2": "“Mendicants, when what exists, because of grasping what and insisting on what, does wrong view arise?” ",
    "sn22.154:1.3": "“Our teachings are rooted in the Buddha. …” ",
    "sn22.154:1.4": "“When form exists, because of grasping form and insisting on form, wrong view arises. ",
    "sn22.154:1.5": "When feeling … ",
    "sn22.154:1.6": "perception … ",
    "sn22.154:1.7": "choices … ",
    "sn22.154:1.8": "consciousness exists, because of grasping consciousness and insisting on consciousness, wrong view arises. ",
    "sn22.154:1.9": "What do you think, mendicants? ",
    "sn22.154:1.10": "Is form permanent or impermanent?” ",
    "sn22.154:1.11": "“Impermanent, sir.” … ",
    "sn22.154:1.12": "",
    "sn22.154:1.13": "“But by not grasping what’s impermanent, suffering, and perishable, would wrong view arise?” ",
    "sn22.154:1.14": "“No, sir.” ",
    "sn22.154:1.15": "“Is feeling … ",
    "sn22.154:1.16": "perception … ",
    "sn22.154:1.17": "choices … ",
    "sn22.154:1.18": "consciousness permanent or impermanent?” ",
    "sn22.154:1.19": "“Impermanent, sir.” ",
    "sn22.154:1.20": "“But if it’s impermanent, is it suffering or happiness?” ",
    "sn22.154:1.21": "“Suffering, sir.” ",
    "sn22.154:1.22": "“But by not grasping what’s impermanent, suffering, and perishable, would wrong view arise?” ",
    "sn22.154:1.23": "“No, sir.” ",
    "sn22.154:1.24": "“Seeing this … ",
    "sn22.154:1.25": "They understand: ‘… there is nothing further for this place.’” "
  },
