  "root_text": {
    "sn17.28:0.1": "Saṁyutta Nikāya 17.28 ",
    "sn17.28:0.2": "3. Tatiyavagga ",
    "sn17.28:0.3": "Chavisutta ",
    "sn17.28:1.1": "Sāvatthiyaṁ viharati. ",
    "sn17.28:1.2": "“Dāruṇo, bhikkhave, lābhasakkārasiloko. ",
    "sn17.28:1.3": "Lābhasakkārasiloko, bhikkhave, chaviṁ chindati, chaviṁ chetvā cammaṁ chindati, cammaṁ chetvā maṁsaṁ chindati, maṁsaṁ chetvā nhāruṁ chindati, nhāruṁ chetvā aṭṭhiṁ chindati, aṭṭhiṁ chetvā aṭṭhimiñjaṁ āhacca tiṭṭhati. ",
    "sn17.28:1.4": "Evaṁ dāruṇo kho, bhikkhave, lābhasakkārasiloko …pe… ",
    "sn17.28:1.5": "evañhi vo bhikkhave, sikkhitabban”ti. ",
    "sn17.28:1.6": "Aṭṭhamaṁ. "
  },
  "translation_text": {
    "sn17.28:0.1": "Linked Discourses 17.28 ",
    "sn17.28:0.2": "Chapter Three ",
    "sn17.28:0.3": "Skin ",
    "sn17.28:1.1": "At Sāvatthī. ",
    "sn17.28:1.2": "“Possessions, honor, and popularity are grim … ",
    "sn17.28:1.3": "They cut through the outer skin, the inner skin, the flesh, sinews, and bones, until they reach the marrow and keep pressing. ",
    "sn17.28:1.4": "So grim are possessions, honor, and popularity. …” ",
    "sn17.28:1.5": ""
  },
