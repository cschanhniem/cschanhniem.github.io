  "root_text": {
    "sn19.18:0.1": "Saṁyutta Nikāya 19.18 ",
    "sn19.18:0.2": "2. Dutiyavagga ",
    "sn19.18:0.3": "Pāpabhikkhunīsutta ",
    "sn19.18:1.1": "“Addasaṁ bhikkhuniṁ vehāsaṁ gacchantiṁ. ",
    "sn19.18:1.2": "Tassā saṅghāṭipi ādittā …pe… ",
    "sn19.18:1.3": "pāpabhikkhunī ahosi …pe…. ",
    "sn19.18:1.4": "Aṭṭhamaṁ. "
  },
  "translation_text": {
    "sn19.18:0.1": "Linked Discourses 19.18 ",
    "sn19.18:0.2": "Chapter Two ",
    "sn19.18:0.3": "A Bad Nun ",
    "sn19.18:1.1": "“I saw a nun flying through the air. ",
    "sn19.18:1.2": "Her outer robe was burning …” … ",
    "sn19.18:1.3": "“She used to be a bad nun …” "
  },
  "variant_text": {
    "sn19.18:0.3": "Pāpabhikkhunīsutta → bhikkhunīsuttaṁ (bj); bhikkhunī (pts1ed, pts2ed) "
