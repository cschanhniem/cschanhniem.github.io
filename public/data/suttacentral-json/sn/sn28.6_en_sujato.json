  "root_text": {
    "sn28.6:0.1": "Saṁyutta Nikāya 28.6 ",
    "sn28.6:0.2": "1. Sāriputtavagga ",
    "sn28.6:0.3": "Viññāṇañcāyatanasutta ",
    "sn28.6:1.1": "Sāvatthinidānaṁ. ",
    "sn28.6:1.2": "Addasā kho āyasmā ānando …pe… ",
    "sn28.6:1.3": "“idhāhaṁ, āvuso, sabbaso ākāsānañcāyatanaṁ samatikkamma anantaṁ viññāṇanti viññāṇañcāyatanaṁ upasampajja viharāmi …pe… ",
    "sn28.6:1.4": "vuṭṭhitoti vā”ti. ",
    "sn28.6:1.5": "Chaṭṭhaṁ. "
  },
  "translation_text": {
    "sn28.6:0.1": "Linked Discourses 28.6 ",
    "sn28.6:0.2": "1. With Sāriputta ",
    "sn28.6:0.3": "The Dimension of Infinite Consciousness ",
    "sn28.6:1.1": "At Sāvatthī. ",
    "sn28.6:1.2": "Venerable Ānanda saw Venerable Sāriputta … ",
    "sn28.6:1.3": "“Reverend, going totally beyond the dimension of infinite space, aware that ‘consciousness is infinite’, I entered and remained in the dimension of infinite consciousness. …” … ",
    "sn28.6:1.4": ""
  },
  "variant_text": {
    "sn28.6:0.3": "Viññāṇañcāyatanasutta → viññāṇaṁ (pts1ed) "
  },
