  "root_text": {
    "sn46.43:0.1": "Saṁyutta Nikāya 46.43 ",
    "sn46.43:0.2": "5. Cakkavattivagga ",
    "sn46.43:0.3": "Mārasutta ",
    "sn46.43:1.1": "“Mārasenappamaddanaṁ vo, bhikkhave, maggaṁ desessāmi; ",
    "sn46.43:1.2": "taṁ suṇātha. ",
    "sn46.43:1.3": "Katamo ca, bhikkhave, mārasenappamaddano maggo? ",
    "sn46.43:1.4": "Yadidaṁ—",
    "sn46.43:1.5": "satta bojjhaṅgā. ",
    "sn46.43:1.6": "Katame satta? ",
    "sn46.43:1.7": "Satisambojjhaṅgo …pe… upekkhāsambojjhaṅgo—",
    "sn46.43:1.8": "ayaṁ kho, bhikkhave, mārasenappamaddano maggo”ti. ",
    "sn46.43:1.9": "Tatiyaṁ. "
  },
  "translation_text": {
    "sn46.43:0.1": "Linked Discourses 46.43 ",
    "sn46.43:0.2": "5. A Wheel-Turning Monarch ",
    "sn46.43:0.3": "About Māra ",
    "sn46.43:1.1": "“Mendicants, I will teach you a path for crushing Māra’s army. ",
    "sn46.43:1.2": "Listen … ",
    "sn46.43:1.3": "And what is that path? ",
    "sn46.43:1.4": "",
    "sn46.43:1.5": "It is the seven awakening factors. ",
    "sn46.43:1.6": "What seven? ",
    "sn46.43:1.7": "The awakening factors of mindfulness, investigation of principles, energy, rapture, tranquility, immersion, and equanimity. ",
    "sn46.43:1.8": "This is the path for crushing Māra’s army.” "
  },
