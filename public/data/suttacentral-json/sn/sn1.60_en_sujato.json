  "root_text": {
    "sn1.60:0.1": "Saṁyutta Nikāya 1.60 ",
    "sn1.60:0.2": "6. Jarāvagga ",
    "sn1.60:0.3": "Kavisutta ",
    "sn1.60:1.1": "“Kiṁsu nidānaṁ gāthānaṁ, ",
    "sn1.60:1.2": "kiṁsu tāsaṁ viyañjanaṁ; ",
    "sn1.60:1.3": "Kiṁsu sannissitā gāthā, ",
    "sn1.60:1.4": "kiṁsu gāthānamāsayo”ti. ",
    "sn1.60:2.1": "“Chando nidānaṁ gāthānaṁ, ",
    "sn1.60:2.2": "akkharā tāsaṁ viyañjanaṁ; ",
    "sn1.60:2.3": "Nāmasannissitā gāthā, ",
    "sn1.60:2.4": "kavi gāthānamāsayo”ti. ",
    "sn1.60:2.5": "Jarāvaggo chaṭṭho. ",
    "sn1.60:3.0": "Tassuddānaṁ ",
    "sn1.60:3.1": "Jarā ajarasā mittaṁ, ",
    "sn1.60:3.2": "vatthu tīṇi janāni ca; ",
    "sn1.60:3.3": "Uppatho ca dutiyo ca, ",
    "sn1.60:3.4": "kavinā pūrito vaggoti. "
  },
  "translation_text": {
    "sn1.60:0.1": "Linked Discourses 1.60 ",
    "sn1.60:0.2": "6. Old Age ",
    "sn1.60:0.3": "A Poet ",
    "sn1.60:1.1": "“What’s the source of verses? ",
    "sn1.60:1.2": "What constitutes their phrasing? ",
    "sn1.60:1.3": "What do verses depend upon? ",
    "sn1.60:1.4": "What underlies verses?” ",
    "sn1.60:2.1": "“Metre is the source of verses. ",
    "sn1.60:2.2": "Syllables constitute their phrasing. ",
    "sn1.60:2.3": "Verses depend on names. ",
    "sn1.60:2.4": "A poet underlies verses.” ",
