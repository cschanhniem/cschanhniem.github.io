  "root_text": {
    "sn27.9:0.1": "Saṁyutta Nikāya 27.9 ",
    "sn27.9:0.2": "1. Kilesavagga ",
    "sn27.9:0.3": "Dhātusutta ",
    "sn27.9:1.1": "Sāvatthinidānaṁ. ",
    "sn27.9:1.2": "“Yo, bhikkhave, pathavīdhātuyā chandarāgo, cittasseso upakkileso. ",
    "sn27.9:1.3": "Yo āpodhātuyā … ",
    "sn27.9:1.4": "yo tejodhātuyā … ",
    "sn27.9:1.5": "yo vāyodhātuyā … ",
    "sn27.9:1.6": "yo ākāsadhātuyā … ",
    "sn27.9:1.7": "yo viññāṇadhātuyā chandarāgo, cittasseso upakkileso. ",
    "sn27.9:1.8": "Yato kho, bhikkhave, bhikkhuno imesu chasu ṭhānesu cetaso upakkileso pahīno hoti, nekkhammaninnañcassa cittaṁ hoti. ",
    "sn27.9:1.9": "Nekkhammaparibhāvitaṁ cittaṁ kammaniyaṁ khāyati, abhiññā sacchikaraṇīyesu dhammesū”ti. ",
    "sn27.9:1.10": "Navamaṁ. "
  },
  "translation_text": {
    "sn27.9:0.1": "Linked Discourses 27.9 ",
    "sn27.9:0.2": "1. Corruptions ",
    "sn27.9:0.3": "Elements ",
    "sn27.9:1.1": "At Sāvatthī. ",
    "sn27.9:1.2": "“Mendicants, desire and greed for the earth element, ",
    "sn27.9:1.3": "the water element, ",
    "sn27.9:1.4": "the fire element, ",
    "sn27.9:1.5": "the air element, ",
    "sn27.9:1.6": "the space element, ",
    "sn27.9:1.7": "or the consciousness element is a corruption of the mind. …” ",
    "sn27.9:1.8": "",
    "sn27.9:1.9": ""
  },
