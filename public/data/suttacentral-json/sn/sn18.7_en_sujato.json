  "root_text": {
    "sn18.7:0.1": "Saṁyutta Nikāya 18.7 ",
    "sn18.7:0.2": "1. Paṭhamavagga ",
    "sn18.7:0.3": "Sañcetanāsutta ",
    "sn18.7:1.1": "Sāvatthiyaṁ viharati. ",
    "sn18.7:1.2": "“Taṁ kiṁ maññasi, rāhula, ",
    "sn18.7:1.3": "rūpasañcetanā niccā vā aniccā vā”ti? ",
    "sn18.7:1.4": "“Aniccā, bhante” … ",
    "sn18.7:1.5": "“saddasañcetanā …pe… ",
    "sn18.7:1.6": "gandhasañcetanā … ",
    "sn18.7:1.7": "rasasañcetanā … ",
    "sn18.7:1.8": "phoṭṭhabbasañcetanā … ",
    "sn18.7:1.9": "dhammasañcetanā niccā vā aniccā vā”ti? ",
    "sn18.7:1.10": "“Aniccā, bhante” … ",
    "sn18.7:1.11": "“evaṁ passaṁ, rāhula, sutavā ariyasāvako rūpasañcetanāyapi nibbindati …pe… saddasañcetanāyapi nibbindati … gandhasañcetanāyapi nibbindati … rasasañcetanāyapi nibbindati … phoṭṭhabbasañcetanāyapi nibbindati … dhammasañcetanāyapi nibbindati …pe… ",
    "sn18.7:1.12": "pajānātī”ti. ",
    "sn18.7:1.13": "Sattamaṁ. "
  },
  "translation_text": {
    "sn18.7:0.1": "Linked Discourses 18.7 ",
    "sn18.7:0.2": "Chapter One ",
    "sn18.7:0.3": "Intention ",
    "sn18.7:1.1": "At Sāvatthī. ",
    "sn18.7:1.2": "“What do you think, Rāhula? ",
    "sn18.7:1.3": "Is intention regarding sights permanent or impermanent?” ",
    "sn18.7:1.4": "“Impermanent, sir.” … ",
    "sn18.7:1.5": "“… intention regarding sounds … ",
    "sn18.7:1.6": "intention regarding smells … ",
    "sn18.7:1.7": "intention regarding tastes … ",
    "sn18.7:1.8": "intention regarding touches … ",
    "sn18.7:1.9": "Is intention regarding ideas permanent or impermanent?” ",
    "sn18.7:1.10": "“Impermanent, sir.” … ",
    "sn18.7:1.11": "“Seeing this, a learned noble disciple grows disillusioned with intention regarding sights, sounds, smells, tastes, touches, and ideas. …” ",
    "sn18.7:1.12": ""
  },
