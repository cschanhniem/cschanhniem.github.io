  "root_text": {
    "sn28.7:0.1": "Saṁyutta Nikāya 28.7 ",
    "sn28.7:0.2": "1. Sāriputtavagga ",
    "sn28.7:0.3": "Ākiñcaññāyatanasutta ",
    "sn28.7:1.1": "Sāvatthinidānaṁ. ",
    "sn28.7:1.2": "Atha kho āyasmā sāriputto …pe… ",
    "sn28.7:1.3": "“idhāhaṁ, āvuso, sabbaso viññāṇañcāyatanaṁ samatikkamma, natthi kiñcīti ākiñcaññāyatanaṁ upasampajja viharāmi …pe… ",
    "sn28.7:1.4": "vuṭṭhitoti vā”ti. ",
    "sn28.7:1.5": "Sattamaṁ. "
  },
  "translation_text": {
    "sn28.7:0.1": "Linked Discourses 28.7 ",
    "sn28.7:0.2": "1. With Sāriputta ",
    "sn28.7:0.3": "The Dimension of Nothingness ",
    "sn28.7:1.1": "At Sāvatthī. ",
    "sn28.7:1.2": "Venerable Ānanda saw Venerable Sāriputta … ",
    "sn28.7:1.3": "“Reverend, going totally beyond the dimension of infinite consciousness, aware that ‘there is nothing at all’, I entered and remained in the dimension of nothingness. …” … ",
    "sn28.7:1.4": ""
  },
  "variant_text": {
    "sn28.7:0.3": "Ākiñcaññāyatanasutta → ākiñcañña (pts1ed) "
  },
