  "root_text": {
    "sn23.19:0.1": "Saṁyutta Nikāya 23.19 ",
    "sn23.19:0.2": "2. Dutiyamāravagga ",
    "sn23.19:0.3": "Khayadhammasutta ",
    "sn23.19:1.1": "Sāvatthinidānaṁ. ",
    "sn23.19:1.2": "Ekamantaṁ nisinno kho āyasmā rādho bhagavantaṁ etadavoca: ",
    "sn23.19:1.3": "“‘khayadhammo, khayadhammo’ti, bhante, vuccati. ",
    "sn23.19:1.4": "Katamo nu kho, bhante, khayadhammo”ti? ",
    "sn23.19:1.5": "“Rūpaṁ kho, rādha, khayadhammo, vedanā khayadhammo, saññā khayadhammo, saṅkhārā khayadhammo, viññāṇaṁ khayadhammo. ",
    "sn23.19:1.6": "Evaṁ passaṁ …pe… ",
    "sn23.19:1.7": "nāparaṁ itthattāyāti pajānātī”ti. ",
    "sn23.19:1.8": "Navamaṁ. "
  },
  "translation_text": {
    "sn23.19:0.1": "Linked Discourses 23.19 ",
    "sn23.19:0.2": "2. About Māra (2nd) ",
    "sn23.19:0.3": "Liable To End ",
    "sn23.19:1.1": "At Sāvatthī. ",
    "sn23.19:1.2": "Seated to one side, Venerable Rādha said to the Buddha: ",
    "sn23.19:1.3": "“Sir, they speak of ‘liable to end’. ",
    "sn23.19:1.4": "What is liable to end?” ",
    "sn23.19:1.5": "“Rādha, form, feeling, perception, choices, and consciousness are liable to end. ",
    "sn23.19:1.6": "Seeing this … ",
    "sn23.19:1.7": "They understand: ‘… there is nothing further for this place.’” "
  },
  "variant_text": {
    "sn23.19:0.3": "Khayadhammasutta → khaya (pts1ed) "
  },
