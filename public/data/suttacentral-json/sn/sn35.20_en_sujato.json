  "root_text": {
    "sn35.20:0.1": "Saṁyutta Nikāya 35.20 ",
    "sn35.20:0.2": "2. Yamakavagga ",
    "sn35.20:0.3": "Dutiyābhinandasutta ",
    "sn35.20:1.1": "“Yo, bhikkhave, rūpe abhinandati, dukkhaṁ so abhinandati. ",
    "sn35.20:1.2": "Yo dukkhaṁ abhinandati, ‘aparimutto so dukkhasmā’ti vadāmi. ",
    "sn35.20:1.3": "Yo sadde …pe… ",
    "sn35.20:1.4": "gandhe … ",
    "sn35.20:1.5": "rase … ",
    "sn35.20:1.6": "phoṭṭhabbe … ",
    "sn35.20:1.7": "dhamme abhinandati, dukkhaṁ so abhinandati. ",
    "sn35.20:1.8": "Yo dukkhaṁ abhinandati, ‘aparimutto so dukkhasmā’ti vadāmi. ",
    "sn35.20:2.1": "“Yo ca kho, bhikkhave, rūpe nābhinandati, dukkhaṁ so nābhinandati. ",
    "sn35.20:2.2": "Yo dukkhaṁ nābhinandati, ‘aparimutto so dukkhasmā’ti vadāmi. ",
    "sn35.20:2.3": "Yo sadde …pe… ",
    "sn35.20:2.4": "gandhe … ",
    "sn35.20:2.5": "rase … ",
    "sn35.20:2.6": "phoṭṭhabbe … ",
    "sn35.20:2.7": "dhamme nābhinandati, dukkhaṁ so nābhinandati. ",
    "sn35.20:2.8": "Yo dukkhaṁ nābhinandati, ‘aparimutto so dukkhasmā’ti vadāmi.” ",
    "sn35.20:2.9": "Aṭṭhamaṁ. "
  },
  "translation_text": {
    "sn35.20:0.1": "Linked Discourses 35.20 ",
    "sn35.20:0.2": "2. Pairs ",
    "sn35.20:0.3": "Taking Pleasure (Exterior) ",
    "sn35.20:1.1": "“Mendicants, if you take pleasure in sights, you take pleasure in suffering. ",
    "sn35.20:1.2": "If you take pleasure in suffering, you’re not free from suffering, I say. …” ",
