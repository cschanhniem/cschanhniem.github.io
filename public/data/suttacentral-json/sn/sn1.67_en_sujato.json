  "root_text": {
    "sn1.67:0.1": "Saṁyutta Nikāya 1.67 ",
    "sn1.67:0.2": "7. Addhavagga ",
    "sn1.67:0.3": "Uḍḍitasutta ",
    "sn1.67:1.1": "“Kenassu uḍḍito loko, ",
    "sn1.67:1.2": "kenassu parivārito; ",
    "sn1.67:1.3": "Kenassu pihito loko, ",
    "sn1.67:1.4": "kismiṁ loko patiṭṭhito”ti. ",
    "sn1.67:2.1": "“Taṇhāya uḍḍito loko, ",
    "sn1.67:2.2": "jarāya parivārito; ",
    "sn1.67:2.3": "Maccunā pihito loko, ",
    "sn1.67:2.4": "dukkhe loko patiṭṭhito”ti. "
  },
  "translation_text": {
    "sn1.67:0.1": "Linked Discourses 1.67 ",
    "sn1.67:0.2": "7. Overcome ",
    "sn1.67:0.3": "Ensnared ",
    "sn1.67:1.1": "“By what is the world ensnared? ",
    "sn1.67:1.2": "By what is it surrounded? ",
    "sn1.67:1.3": "By what is the world fastened shut? ",
    "sn1.67:1.4": "On what is the world grounded?” ",
    "sn1.67:2.1": "“Craving has ensnared the world. ",
    "sn1.67:2.2": "It’s surrounded by old age. ",
    "sn1.67:2.3": "The world is fastened shut by mortality. ",
    "sn1.67:2.4": "The world is grounded on suffering.” "
  },
  "variant_text": {
    "sn1.67:0.3": "Uḍḍitasutta → uddito (pts1ed) "
  },
