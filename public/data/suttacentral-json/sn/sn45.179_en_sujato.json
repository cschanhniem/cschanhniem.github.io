  "root_text": {
    "sn45.179:0.1": "Saṁyutta Nikāya 45.179 ",
    "sn45.179:0.2": "14. Oghavagga ",
    "sn45.179:0.3": "Orambhāgiyasutta ",
    "sn45.179:1.1": "“Pañcimāni, bhikkhave, orambhāgiyāni saṁyojanāni. ",
    "sn45.179:1.2": "Katamāni pañca? ",
    "sn45.179:1.3": "Sakkāyadiṭṭhi, vicikicchā, sīlabbataparāmāso, kāmacchando, byāpādo—",
    "sn45.179:1.4": "imāni kho, bhikkhave, pañcorambhāgiyāni saṁyojanāni. ",
    "sn45.179:1.5": "Imesaṁ kho, bhikkhave, pañcannaṁ orambhāgiyānaṁ saṁyojanānaṁ abhiññāya pariññāya parikkhayāya pahānāya …pe… ayaṁ ariyo aṭṭhaṅgiko maggo bhāvetabbo”ti. ",
    "sn45.179:1.6": "Navamaṁ. "
  },
  "translation_text": {
    "sn45.179:0.1": "Linked Discourses 45.179 ",
    "sn45.179:0.2": "14. Floods ",
    "sn45.179:0.3": "Lower Fetters ",
    "sn45.179:1.1": "“Mendicants, there are five lower fetters. ",
    "sn45.179:1.2": "What five? ",
    "sn45.179:1.3": "Substantialist view, doubt, misapprehension of precepts and observances, sensual desire, and ill will. ",
    "sn45.179:1.4": "These are the five lower fetters. ",
    "sn45.179:1.5": "The noble eightfold path should be developed for the direct knowledge, complete understanding, finishing, and giving up of these five lowers fetters.” "
  },
  "variant_text": {
    "sn45.179:0.3": "Orambhāgiyasutta → orambhāgiyasaṁyojanasuttāni (bj) "
  },
