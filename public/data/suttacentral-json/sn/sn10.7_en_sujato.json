  "comment_text": {
    "sn10.7:1.4": "This is another ode to the maternal love of the female <i lang='pi' translate='no'>yakkha</i>. ",
    "sn10.7:2.2": "Punabbasu is a lunar mansion or asterism, roughly equivalent to Gemini. The child is probably named after the asterism, which suggests Uttarā was too; there are three asterisms with Uttara in their names (cf. <a href='https://suttacentral.net/dn14/en/sujato#1.12.15'>DN 14:1.12.15</a>). ",
    "sn10.7:3.1": "She is referring to <a href='https://suttacentral.net/iti102/en/sujato#5.3'>Iti 102:5.3</a>. "
  },
