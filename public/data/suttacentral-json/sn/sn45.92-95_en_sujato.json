  "root_text": {
    "sn45.92-95:0.1": "Saṁyutta Nikāya 45.92–95 ",
    "sn45.92-95:0.2": "9. Gaṅgāpeyyālavagga ",
    "sn45.92-95:0.3": "Dutiyādipācīnaninnasuttacatukka ",
    "sn45.92-95:1.1": "“Seyyathāpi, bhikkhave, yamunā nadī pācīnaninnā pācīnapoṇā pācīnapabbhārā; ",
    "sn45.92-95:1.2": "evameva kho, bhikkhave …pe… ",
    "sn45.92-95:1.3": "seyyathāpi, bhikkhave, aciravatī nadī pācīnaninnā pācīnapoṇā pācīnapabbhārā; ",
    "sn45.92-95:1.4": "evameva kho, bhikkhave …pe… ",
    "sn45.92-95:1.5": "seyyathāpi, bhikkhave, sarabhū nadī pācīnaninnā pācīnapoṇā pācīnapabbhārā; ",
    "sn45.92-95:1.6": "evameva kho, bhikkhave …pe… ",
    "sn45.92-95:1.7": "seyyathāpi, bhikkhave, mahī nadī pācīnaninnā pācīnapoṇā pācīnapabbhārā; evameva kho, bhikkhave …pe…. ",
    "sn45.92-95:1.8": "Pañcamaṁ. "
  },
  "translation_text": {
    "sn45.92-95:0.1": "Linked Discourses 45.92–95 ",
    "sn45.92-95:0.2": "9. Abbreviated Texts on the Ganges ",
    "sn45.92-95:0.3": "Four Discourses on Slanting East ",
    "sn45.92-95:1.1": "“Mendicants, the Yamunā river slants, slopes, and inclines to the east. …” ",
    "sn45.92-95:1.2": "",
    "sn45.92-95:1.3": "“… the Aciravatī river …” ",
    "sn45.92-95:1.4": "",
    "sn45.92-95:1.5": "“… the Sarabhū river …” ",
    "sn45.92-95:1.6": "",
    "sn45.92-95:1.7": "“… the Mahī river …” "
  },
