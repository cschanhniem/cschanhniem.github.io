  "root_text": {
    "sn35.210-212:0.1": "Saṁyutta Nikāya 35.210–212 ",
    "sn35.210-212:0.2": "17. Saṭṭhipeyyālavagga ",
    "sn35.210-212:0.3": "Ajjhattātītādiyadanattasutta ",
    "sn35.210-212:1.1": "“Cakkhu, bhikkhave, anattā atītaṁ anāgataṁ paccuppannaṁ. ",
    "sn35.210-212:1.2": "Yadanattā, taṁ ‘netaṁ mama, nesohamasmi, na meso attā’ti evametaṁ yathābhūtaṁ sammappaññāya daṭṭhabbaṁ …pe… ",
    "sn35.210-212:1.3": "jivhā anattā …pe… ",
    "sn35.210-212:1.4": "mano anattā atīto anāgato paccuppanno. ",
    "sn35.210-212:1.5": "Yadanattā taṁ ‘netaṁ mama, nesohamasmi, na meso attā’ti evametaṁ yathābhūtaṁ sammappaññāya daṭṭhabbaṁ. ",
    "sn35.210-212:1.6": "Evaṁ passaṁ …pe… ",
    "sn35.210-212:1.7": "nāparaṁ itthattāyāti pajānātī”ti. "
  },
  "translation_text": {
    "sn35.210-212:0.1": "Linked Discourses 35.210–212 ",
    "sn35.210-212:0.2": "17. Sixty Abbreviated Texts ",
    "sn35.210-212:0.3": "The Interior and What’s Not-Self in the Three Times ",
    "sn35.210-212:1.1": "“Mendicants, in the past … future … present the eye, ear, nose, tongue, body, and mind are not-self. ",
    "sn35.210-212:1.2": "And what’s not-self should be truly seen with right understanding like this: ‘This is not mine, I am not this, this is not my self.’ …” ",
