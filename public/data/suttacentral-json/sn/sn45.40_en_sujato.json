  "root_text": {
    "sn45.40:0.1": "Saṁyutta Nikāya 45.40 ",
    "sn45.40:0.2": "4. Paṭipattivagga ",
    "sn45.40:0.3": "Dutiyabrahmacariyasutta ",
    "sn45.40:1.1": "Sāvatthinidānaṁ. ",
    "sn45.40:1.2": "“Brahmacariyañca vo, bhikkhave, desessāmi, brahmacariyatthañca. ",
    "sn45.40:1.3": "Taṁ suṇātha. ",
    "sn45.40:1.4": "Katamañca, bhikkhave, brahmacariyaṁ? ",
    "sn45.40:1.5": "Ayameva ariyo aṭṭhaṅgiko maggo, seyyathidaṁ—",
    "sn45.40:1.6": "sammādiṭṭhi …pe… sammāsamādhi. ",
    "sn45.40:1.7": "Idaṁ vuccati, bhikkhave, brahmacariyaṁ. ",
    "sn45.40:1.8": "Katamo ca, bhikkhave, brahmacariyattho? ",
    "sn45.40:1.9": "Yo kho, bhikkhave, rāgakkhayo dosakkhayo mohakkhayo—",
    "sn45.40:1.10": "ayaṁ vuccati, bhikkhave, brahmacariyattho”ti. ",
    "sn45.40:1.11": "Dasamaṁ. ",
    "sn45.40:1.12": "Paṭipattivaggo catuttho. ",
    "sn45.40:2.0": "Tassuddānaṁ ",
    "sn45.40:2.1": "Paṭipatti paṭipanno ca, ",
    "sn45.40:2.2": "viraddhañca pāraṅgamā; ",
    "sn45.40:2.3": "Sāmaññena ca dve vuttā, ",
    "sn45.40:2.4": "brahmaññā apare duve; ",
    "sn45.40:2.5": "Brahmacariyena dve vuttā, ",
    "sn45.40:2.6": "vaggo tena pavuccatīti. "
  },
  "translation_text": {
    "sn45.40:0.1": "Linked Discourses 45.40 ",
    "sn45.40:0.2": "4. Practice ",
    "sn45.40:0.3": "The Spiritual Path (2nd) ",
    "sn45.40:1.1": "At Sāvatthī. ",
    "sn45.40:1.2": "“Mendicants, I will teach you the spiritual path and the goal of the spiritual path. ",
    "sn45.40:1.3": "Listen … ",
    "sn45.40:1.4": "And what is the spiritual path? ",
    "sn45.40:1.5": "It is simply this noble eightfold path, that is: ",
    "sn45.40:1.6": "right view, right thought, right speech, right action, right livelihood, right effort, right mindfulness, and right immersion. ",
    "sn45.40:1.7": "This is called the spiritual path. ",
    "sn45.40:1.8": "And what is the goal of the spiritual path? ",
    "sn45.40:1.9": "The ending of greed, hate, and delusion. ",
    "sn45.40:1.10": "This is called the goal of the spiritual path.” ",
