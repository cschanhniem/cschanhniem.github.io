  "root_text": {
    "sn35.5:0.1": "Saṁyutta Nikāya 35.5 ",
    "sn35.5:0.2": "1. Aniccavagga ",
    "sn35.5:0.3": "Bāhiradukkhasutta ",
    "sn35.5:1.1": "“Rūpā, bhikkhave, dukkhā. ",
    "sn35.5:1.2": "Yaṁ dukkhaṁ tadanattā; ",
    "sn35.5:1.3": "yadanattā taṁ ‘netaṁ mama, nesohamasmi, na meso attā’ti evametaṁ yathābhūtaṁ sammappaññāya daṭṭhabbaṁ. ",
    "sn35.5:1.4": "Saddā … ",
    "sn35.5:1.5": "gandhā … ",
    "sn35.5:1.6": "rasā … ",
    "sn35.5:1.7": "phoṭṭhabbā … ",
    "sn35.5:1.8": "dhammā dukkhā. ",
    "sn35.5:1.9": "Yaṁ dukkhaṁ tadanattā. ",
    "sn35.5:1.10": "Yadanattā taṁ ‘netaṁ mama, nesohamasmi, na meso attā’ti evametaṁ yathābhūtaṁ sammappaññāya daṭṭhabbaṁ. ",
    "sn35.5:1.11": "Evaṁ passaṁ …pe… ",
    "sn35.5:1.12": "nāparaṁ itthattāyāti pajānātī”ti. ",
    "sn35.5:1.13": "Pañcamaṁ. "
  },
  "translation_text": {
    "sn35.5:0.1": "Linked Discourses 35.5 ",
    "sn35.5:0.2": "1. Impermanence ",
    "sn35.5:0.3": "The Exterior as Suffering ",
    "sn35.5:1.1": "“Mendicants, sights are suffering. ",
    "sn35.5:1.2": "What’s suffering is not-self. ",
    "sn35.5:1.3": "And what’s not-self should be truly seen with right understanding like this: ‘This is not mine, I am not this, this is not my self.’ …” ",
