  "root_text": {
    "sn17.22:0.1": "Saṁyutta Nikāya 17.22 ",
    "sn17.22:0.2": "3. Tatiyavagga ",
    "sn17.22:0.3": "Kalyāṇīsutta ",
    "sn17.22:1.1": "Sāvatthiyaṁ viharati. ",
    "sn17.22:1.2": "“Dāruṇo, bhikkhave, lābhasakkārasiloko …pe… ",
    "sn17.22:1.3": "na tassa, bhikkhave, janapadakalyāṇī ekā ekassa cittaṁ pariyādāya tiṭṭhati yassa lābhasakkārasiloko cittaṁ pariyādāya tiṭṭhati. ",
    "sn17.22:1.4": "Evaṁ dāruṇo kho, bhikkhave, lābhasakkārasiloko …pe… ",
    "sn17.22:1.5": "evañhi vo, bhikkhave, sikkhitabban”ti. ",
    "sn17.22:1.6": "Dutiyaṁ. "
  },
  "translation_text": {
    "sn17.22:0.1": "Linked Discourses 17.22 ",
    "sn17.22:0.2": "Chapter Three ",
    "sn17.22:0.3": "The Finest Lady in the Land ",
    "sn17.22:1.1": "At Sāvatthī. ",
    "sn17.22:1.2": "“Possessions, honor, and popularity are grim … ",
    "sn17.22:1.3": "Even if you’re alone with the finest lady in the land she might not occupy your mind, but possessions, honor and popularity would still occupy your mind. ",
    "sn17.22:1.4": "So grim are possessions, honor, and popularity. …” ",
    "sn17.22:1.5": ""
  },
  "variant_text": {
    "sn17.22:0.3": "Kalyāṇīsutta → janapadakalyāṇīsuttaṁ (bj) "
  },
