  "root_text": {
    "sn48.25:0.1": "Saṁyutta Nikāya 48.25 ",
    "sn48.25:0.2": "3. Chaḷindriyavagga ",
    "sn48.25:0.3": "Suddhakasutta ",
    "sn48.25:1.1": "“Chayimāni, bhikkhave, indriyāni. ",
    "sn48.25:1.2": "Katamāni cha? ",
    "sn48.25:1.3": "Cakkhundriyaṁ, sotindriyaṁ, ghānindriyaṁ, jivhindriyaṁ, kāyindriyaṁ, manindriyaṁ—",
    "sn48.25:1.4": "imāni kho, bhikkhave, cha indriyānī”ti. ",
    "sn48.25:1.5": "Pañcamaṁ. "
  },
  "translation_text": {
    "sn48.25:0.1": "Linked Discourses 48.25 ",
    "sn48.25:0.2": "3. The Six Faculties ",
    "sn48.25:0.3": "Plain Version ",
    "sn48.25:1.1": "“Mendicants, there are these six faculties. ",
    "sn48.25:1.2": "What six? ",
    "sn48.25:1.3": "The faculties of the eye, ear, nose, tongue, body, and mind. ",
    "sn48.25:1.4": "These are the six faculties.” "
  },
