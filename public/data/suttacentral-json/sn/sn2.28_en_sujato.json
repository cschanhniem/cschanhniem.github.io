  "root_text": {
    "sn2.28:0.1": "Saṁyutta Nikāya 2.28 ",
    "sn2.28:0.2": "3. Nānātitthiyavagga ",
    "sn2.28:0.3": "Nandivisālasutta ",
    "sn2.28:1.1": "Ekamantaṁ ṭhito kho nandivisālo devaputto bhagavantaṁ gāthāya ajjhabhāsi: ",
    "sn2.28:2.1": "“Catucakkaṁ navadvāraṁ, ",
    "sn2.28:2.2": "puṇṇaṁ lobhena saṁyutaṁ; ",
    "sn2.28:2.3": "Paṅkajātaṁ mahāvīra, ",
    "sn2.28:2.4": "kathaṁ yātrā bhavissatī”ti. ",
    "sn2.28:3.1": "“Chetvā naddhiṁ varattañca, ",
    "sn2.28:3.2": "icchālobhañca pāpakaṁ; ",
    "sn2.28:3.3": "Samūlaṁ taṇhamabbuyha, ",
    "sn2.28:3.4": "evaṁ yātrā bhavissatī”ti. "
  },
  "translation_text": {
    "sn2.28:0.1": "Linked Discourses 2.28 ",
    "sn2.28:0.2": "3. Various Sectarians ",
    "sn2.28:0.3": "With Nandivisāla ",
    "sn2.28:1.1": "Standing to one side, the godling Nandivisāla addressed the Buddha in verse: ",
    "sn2.28:2.1": "“Four are its wheels, and nine its doors; ",
    "sn2.28:2.2": "it’s stuffed full, bound with greed, ",
    "sn2.28:2.3": "and born from a bog. ",
    "sn2.28:2.4": "Great hero, how will I keep going?” ",
    "sn2.28:3.1": "“Having cut the strap and harness—",
    "sn2.28:3.2": "wicked desire and greed—",
    "sn2.28:3.3": "and having plucked out craving, root and all: ",
    "sn2.28:3.4": "that’s how you will keep going.” "
  },
