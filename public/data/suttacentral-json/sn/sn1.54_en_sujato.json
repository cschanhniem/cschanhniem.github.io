  "root_text": {
    "sn1.54:0.1": "Saṁyutta Nikāya 1.54 ",
    "sn1.54:0.2": "6. Jarāvagga ",
    "sn1.54:0.3": "Vatthusutta ",
    "sn1.54:1.1": "“Kiṁsu vatthu manussānaṁ, ",
    "sn1.54:1.2": "kiṁsūdha paramo sakhā; ",
    "sn1.54:1.3": "Kiṁsu bhūtā upajīvanti, ",
    "sn1.54:1.4": "ye pāṇā pathavissitā”ti. ",
    "sn1.54:2.1": "“Puttā vatthu manussānaṁ, ",
    "sn1.54:2.2": "bhariyā ca paramo sakhā; ",
    "sn1.54:2.3": "Vuṭṭhiṁ bhūtā upajīvanti, ",
    "sn1.54:2.4": "ye pāṇā pathavissitā”ti. "
  },
  "translation_text": {
    "sn1.54:0.1": "Linked Discourses 1.54 ",
    "sn1.54:0.2": "6. Old Age ",
    "sn1.54:0.3": "Grounds ",
    "sn1.54:1.1": "“What is the site for human beings? ",
    "sn1.54:1.2": "What is the best comrade here? ",
    "sn1.54:1.3": "By what do the creatures who live off the earth ",
    "sn1.54:1.4": "sustain their life?” ",
    "sn1.54:2.1": "“Children are the site for human beings. ",
    "sn1.54:2.2": "A wife is the best comrade. ",
    "sn1.54:2.3": "The creatures who live off the earth ",
    "sn1.54:2.4": "sustain their life by rain.” "
  },
  "variant_text": {
    "sn1.54:1.4": "pathavissitā”ti → paṭhaviṁ sitāti (bj, sya-all, km, pts2ed); pathaviṁ sitāti (pts1ed) ",
    "sn1.54:2.2": "bhariyā ca → bhariyāva (bj, pts2ed); bhariyā (sya-all, km) "
  },
