  "root_text": {
    "sn23.14:0.1": "Saṁyutta Nikāya 23.14 ",
    "sn23.14:0.2": "2. Dutiyamāravagga ",
    "sn23.14:0.3": "Aniccadhammasutta ",
    "sn23.14:1.1": "Sāvatthinidānaṁ. ",
    "sn23.14:1.2": "Ekamantaṁ nisinno kho āyasmā rādho bhagavantaṁ etadavoca: ",
    "sn23.14:1.3": "“‘aniccadhammo, aniccadhammo’ti, bhante, vuccati. ",
    "sn23.14:1.4": "Katamo nu kho, bhante, aniccadhammo”ti? ",
    "sn23.14:1.5": "“Rūpaṁ kho, rādha, aniccadhammo, vedanā aniccadhammo, saññā aniccadhammo, saṅkhārā aniccadhammo, viññāṇaṁ aniccadhammo. ",
    "sn23.14:1.6": "Evaṁ passaṁ …pe… ",
    "sn23.14:1.7": "nāparaṁ itthattāyāti pajānātī”ti. ",
    "sn23.14:1.8": "Catutthaṁ. "
  },
  "translation_text": {
    "sn23.14:0.1": "Linked Discourses 23.14 ",
    "sn23.14:0.2": "2. About Māra (2nd) ",
    "sn23.14:0.3": "Liable to Impermanence ",
    "sn23.14:1.1": "At Sāvatthī. ",
    "sn23.14:1.2": "Seated to one side, Venerable Rādha said to the Buddha: ",
    "sn23.14:1.3": "“Sir, they speak of this thing called ‘liable to impermanence’. ",
    "sn23.14:1.4": "What is liable to impermanence? ",
    "sn23.14:1.5": "“Rādha, form, feeling, perception, choices, and consciousness are liable to impermanence. ",
    "sn23.14:1.6": "Seeing this … ",
    "sn23.14:1.7": "They understand: ‘… there is nothing further for this place.’” "
  },
  "variant_text": {
    "sn23.14:0.3": "Aniccadhammasutta → anicca 2 (pts1ed) "
  },
