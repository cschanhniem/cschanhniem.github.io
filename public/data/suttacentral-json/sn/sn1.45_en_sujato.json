  "root_text": {
    "sn1.45:0.1": "Saṁyutta Nikāya 1.45 ",
    "sn1.45:0.2": "5. Ādittavagga ",
    "sn1.45:0.3": "Anomasutta ",
    "sn1.45:1.1": "“Anomanāmaṁ nipuṇatthadassiṁ, ",
    "sn1.45:1.2": "Paññādadaṁ kāmālaye asattaṁ; ",
    "sn1.45:1.3": "Taṁ passatha sabbaviduṁ sumedhaṁ, ",
    "sn1.45:1.4": "Ariye pathe kamamānaṁ mahesin”ti. "
  },
  "translation_text": {
    "sn1.45:0.1": "Linked Discourses 1.45 ",
    "sn1.45:0.2": "5. On Fire ",
    "sn1.45:0.3": "Peerless ",
    "sn1.45:1.1": "“Behold him of peerless name <j>who sees the subtle meaning, ",
    "sn1.45:1.2": "giver of wisdom, <j>unattached to the realm of sensuality: ",
    "sn1.45:1.3": "the all-knower, so very intelligent, ",
    "sn1.45:1.4": "the great seer treading the noble road.” "
  },
