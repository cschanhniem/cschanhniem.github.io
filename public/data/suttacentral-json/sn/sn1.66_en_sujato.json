  "root_text": {
    "sn1.66:0.1": "Saṁyutta Nikāya 1.66 ",
    "sn1.66:0.2": "7. Addhavagga ",
    "sn1.66:0.3": "Attahatasutta ",
    "sn1.66:1.1": "“Kenassubbhāhato loko, ",
    "sn1.66:1.2": "kenassu parivārito; ",
    "sn1.66:1.3": "Kena sallena otiṇṇo, ",
    "sn1.66:1.4": "kissa dhūpāyito sadā”ti. ",
    "sn1.66:2.1": "“Maccunābbhāhato loko, ",
    "sn1.66:2.2": "jarāya parivārito; ",
    "sn1.66:2.3": "Taṇhāsallena otiṇṇo, ",
    "sn1.66:2.4": "icchādhūpāyito sadā”ti. "
  },
  "translation_text": {
    "sn1.66:0.1": "Linked Discourses 1.66 ",
    "sn1.66:0.2": "7. Overcome ",
    "sn1.66:0.3": "Beaten Down ",
    "sn1.66:1.1": "“By what is the world beaten down? ",
    "sn1.66:1.2": "By what is it surrounded? ",
    "sn1.66:1.3": "What dart has laid it low? ",
    "sn1.66:1.4": "With what is it always fuming?” ",
    "sn1.66:2.1": "“The world is beaten down by death. ",
    "sn1.66:2.2": "It’s surrounded by old age. ",
    "sn1.66:2.3": "The dart of craving has laid it low. ",
    "sn1.66:2.4": "It’s always fuming with desire.” "
  },
  "variant_text": {
    "sn1.66:0.3": "Attahatasutta → abbhāhatasuttaṁ (bj, sya-all, pts2ed); abbhāhata (pts1ed) "
  },
