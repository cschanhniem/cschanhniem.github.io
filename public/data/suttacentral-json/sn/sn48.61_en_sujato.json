  "root_text": {
    "sn48.61:0.1": "Saṁyutta Nikāya 48.61 ",
    "sn48.61:0.2": "7. Bodhipakkhiyavagga ",
    "sn48.61:0.3": "Saṁyojanasutta ",
    "sn48.61:1.1": "Sāvatthinidānaṁ. ",
    "sn48.61:1.2": "“Pañcimāni, bhikkhave, indriyāni bhāvitāni bahulīkatāni saṁyojanappahānāya saṁvattanti. ",
    "sn48.61:1.3": "Katamāni pañca? ",
    "sn48.61:1.4": "Saddhindriyaṁ …pe… paññindriyaṁ—",
    "sn48.61:1.5": "imāni kho, bhikkhave, pañcindriyāni bhāvitāni bahulīkatāni saṁyojanappahānāya saṁvattantī”ti. ",
    "sn48.61:1.6": "Paṭhamaṁ. "
  },
  "translation_text": {
    "sn48.61:0.1": "Linked Discourses 48.61 ",
    "sn48.61:0.2": "7. Leading to Awakening ",
    "sn48.61:0.3": "Fetters ",
    "sn48.61:1.1": "At Sāvatthī. ",
    "sn48.61:1.2": "“Mendicants, when these five faculties are developed and cultivated they lead to giving up the fetters. ",
    "sn48.61:1.3": "What five? ",
    "sn48.61:1.4": "The faculties of faith, energy, mindfulness, immersion, and wisdom. ",
    "sn48.61:1.5": "When these five faculties are developed and cultivated they lead to giving up the fetters.” "
  },
  "variant_text": {
    "sn48.61:0.2": "Bodhipakkhiyavagga → sambodhivaggo (bj) ",
    "sn48.61:1.2": "saṁyojanappahānāya → saññojanānaṁ pahānāya (sya-all, pts1ed, mr) "
  },
