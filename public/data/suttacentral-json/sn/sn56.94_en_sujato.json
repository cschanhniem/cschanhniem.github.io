  "root_text": {
    "sn56.94:0.1": "Saṁyutta Nikāya 56.94 ",
    "sn56.94:0.2": "10. Catutthaāmakadhaññapeyyālavagga ",
    "sn56.94:0.3": "Tulākūṭasutta ",
    "sn56.94:1.1": "… “Evameva kho, bhikkhave, appakā te sattā ye tulākūṭakaṁsakūṭamānakūṭā paṭiviratā; atha kho eteva bahutarā sattā ye tulākūṭakaṁsakūṭamānakūṭā appaṭiviratā …pe…. ",
    "sn56.94:1.2": "Catutthaṁ. "
  },
  "translation_text": {
    "sn56.94:0.1": "Linked Discourses 56.94 ",
    "sn56.94:0.2": "10. Abbreviated Texts on Raw Grain ",
    "sn56.94:0.3": "False Weights ",
    "sn56.94:1.1": "“… the sentient beings who refrain from falsifying weights, metals, or measures are few, while those who don’t refrain are many. …” "
  },
  "variant_text": {
    "sn56.94:0.3": "Tulākūṭasutta → tulākūṭādisuttāni (bj) "
  },
