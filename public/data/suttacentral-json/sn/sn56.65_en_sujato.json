  "root_text": {
    "sn56.65:0.1": "Saṁyutta Nikāya 56.65 ",
    "sn56.65:0.2": "7. Paṭhamaāmakadhaññapeyyālavagga ",
    "sn56.65:0.3": "Odakasutta ",
    "sn56.65:1.1": "… “Evameva kho, bhikkhave, appakā te sattā ye thalajā; atha kho eteva bahutarā sattā ye udakajā. Taṁ kissa hetu …pe…. ",
    "sn56.65:1.2": "Pañcamaṁ. "
  },
  "translation_text": {
    "sn56.65:0.1": "Linked Discourses 56.65 ",
    "sn56.65:0.2": "7. Abbreviated Texts on Raw Grain ",
    "sn56.65:0.3": "Born in Water ",
    "sn56.65:1.1": "“… the sentient beings born on land are few, while those born in water are many. …” "
  },
  "variant_text": {
    "sn56.65:0.3": "Odakasutta → odakajasuttaṁ (bj) "
  },
