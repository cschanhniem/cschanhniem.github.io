  "root_text": {
    "sn18.6:0.1": "Saṁyutta Nikāya 18.6 ",
    "sn18.6:0.2": "1. Paṭhamavagga ",
    "sn18.6:0.3": "Saññāsutta ",
    "sn18.6:1.1": "Sāvatthiyaṁ viharati. ",
    "sn18.6:1.2": "“Taṁ kiṁ maññasi, rāhula, ",
    "sn18.6:1.3": "rūpasaññā niccā vā aniccā vā”ti? ",
    "sn18.6:1.4": "“Aniccā, bhante” … ",
    "sn18.6:1.5": "“saddasaññā …pe… ",
    "sn18.6:1.6": "gandhasaññā … ",
    "sn18.6:1.7": "rasasaññā … ",
    "sn18.6:1.8": "phoṭṭhabbasaññā … ",
    "sn18.6:1.9": "dhammasaññā niccā vā aniccā vā”ti? ",
    "sn18.6:1.10": "“Aniccā, bhante” … ",
    "sn18.6:1.11": "“evaṁ passaṁ, rāhula, sutavā ariyasāvako rūpasaññāyapi nibbindati …pe… saddasaññāyapi nibbindati … gandhasaññāyapi nibbindati … rasasaññāyapi nibbindati … phoṭṭhabbasaññāyapi nibbindati … dhammasaññāyapi nibbindati …pe… ",
    "sn18.6:1.12": "pajānātī”ti. ",
    "sn18.6:1.13": "Chaṭṭhaṁ. "
  },
  "translation_text": {
    "sn18.6:0.1": "Linked Discourses 18.6 ",
    "sn18.6:0.2": "Chapter One ",
    "sn18.6:0.3": "Perceptions ",
    "sn18.6:1.1": "At Sāvatthī. ",
    "sn18.6:1.2": "“What do you think, Rāhula? ",
    "sn18.6:1.3": "Is perception of sights permanent or impermanent?” ",
    "sn18.6:1.4": "“Impermanent, sir.” … ",
    "sn18.6:1.5": "“… perception of sounds … ",
    "sn18.6:1.6": "perception of smells … ",
    "sn18.6:1.7": "perception of tastes … ",
    "sn18.6:1.8": "perception of touches … ",
    "sn18.6:1.9": "Is perception of ideas permanent or impermanent?” ",
    "sn18.6:1.10": "“Impermanent, sir.” … ",
    "sn18.6:1.11": "“Seeing this, a learned noble disciple grows disillusioned with the perception of sights, sounds, smells, tastes, touches, and ideas. …” ",
    "sn18.6:1.12": ""
  },
