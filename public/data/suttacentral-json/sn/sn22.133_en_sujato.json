  "root_text": {
    "sn22.133:0.1": "Saṁyutta Nikāya 22.133 ",
    "sn22.133:0.2": "13. Avijjāvagga ",
    "sn22.133:0.3": "Koṭṭhikasutta ",
    "sn22.133:1.1": "Bārāṇasiyaṁ viharanti isipatane migadāye. ",
    "sn22.133:1.2": "Atha kho āyasmā sāriputto sāyanhasamayaṁ …pe… ",
    "sn22.133:1.3": "ekamantaṁ nisinno kho āyasmā sāriputto āyasmantaṁ mahākoṭṭhikaṁ etadavoca: ",
    "sn22.133:1.4": "“‘avijjā, avijjā’ti, āvuso koṭṭhika, vuccati. ",
    "sn22.133:1.5": "Katamā nu kho, āvuso, avijjā; ",
    "sn22.133:1.6": "kittāvatā ca avijjāgato hotī”ti? ",
    "sn22.133:2.1": "“Idhāvuso, assutavā puthujjano rūpassa assādañca ādīnavañca nissaraṇañca yathābhūtaṁ nappajānāti. ",
    "sn22.133:2.2": "Vedanāya …pe… ",
    "sn22.133:2.3": "saññāya … ",
    "sn22.133:2.4": "saṅkhārānaṁ … ",
    "sn22.133:2.5": "viññāṇassa assādañca ādīnavañca nissaraṇañca yathābhūtaṁ nappajānāti. ",
    "sn22.133:2.6": "Ayaṁ vuccatāvuso, avijjā; ",
    "sn22.133:2.7": "ettāvatā ca avijjāgato hotī”ti. ",
    "sn22.133:3.1": "Evaṁ vutte, āyasmā sāriputto āyasmantaṁ mahākoṭṭhikaṁ etadavoca: ",
    "sn22.133:3.2": "“‘vijjā, vijjā’ti, āvuso koṭṭhika, vuccati. ",
    "sn22.133:3.3": "Katamā nu kho, āvuso, vijjā; ",
    "sn22.133:3.4": "kittāvatā ca vijjāgato hotī”ti? ",
    "sn22.133:4.1": "“Idhāvuso, sutavā ariyasāvako rūpassa assādañca ādīnavañca nissaraṇañca yathābhūtaṁ pajānāti. ",
    "sn22.133:4.2": "Vedanāya …pe… ",
    "sn22.133:4.3": "saññāya … ",
    "sn22.133:4.4": "saṅkhārānaṁ … ",
    "sn22.133:4.5": "viññāṇassa assādañca ādīnavañca nissaraṇañca yathābhūtaṁ pajānāti. ",
    "sn22.133:4.6": "Ayaṁ vuccatāvuso, vijjā; ",
    "sn22.133:4.7": "ettāvatā ca vijjāgato hotī”ti. ",
    "sn22.133:4.8": "Aṭṭhamaṁ. "
  },
  "translation_text": {
    "sn22.133:0.1": "Linked Discourses 22.133 ",
    "sn22.133:0.2": "13. Ignorance ",
    "sn22.133:0.3": "With Koṭṭhita ",
    "sn22.133:1.1": "At Varanasi. ",
    "sn22.133:1.2": "",
    "sn22.133:1.3": "Sāriputta said to Mahākoṭṭhita: ",
    "sn22.133:1.4": "“Reverend Koṭṭhita, they speak of this thing called ‘ignorance’. ",
    "sn22.133:1.5": "What is ignorance? ",
    "sn22.133:1.6": "And how is an ignorant person defined?” ",
    "sn22.133:2.1": "“Reverend, an unlearned ordinary person doesn’t truly understand the gratification, the drawback, and the escape when it comes to form, ",
    "sn22.133:2.2": "feeling, ",
    "sn22.133:2.3": "perception, ",
    "sn22.133:2.4": "choices, ",
    "sn22.133:2.5": "and consciousness. ",
    "sn22.133:2.6": "This is called ignorance. ",
    "sn22.133:2.7": "And this is how an ignorant person is defined.” ",
    "sn22.133:3.1": "When he said this, Venerable Sāriputta said to him: ",
    "sn22.133:3.2": "“Reverend Koṭṭhita, they speak of this thing called ‘knowledge’. ",
    "sn22.133:3.3": "What is knowledge? ",
    "sn22.133:3.4": "And how is a knowledgeable person defined?” ",
    "sn22.133:4.1": "“Reverend, a learned noble disciple truly understands the gratification, the drawback, and the escape when it comes to form, ",
    "sn22.133:4.2": "feeling, ",
    "sn22.133:4.3": "perception, ",
    "sn22.133:4.4": "choices, ",
    "sn22.133:4.5": "and consciousness. ",
    "sn22.133:4.6": "This is called knowledge. ",
    "sn22.133:4.7": "And this is how a knowledgeable person is defined.” "
  },
