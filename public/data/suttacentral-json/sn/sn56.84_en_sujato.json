  "root_text": {
    "sn56.84:0.1": "Saṁyutta Nikāya 56.84 ",
    "sn56.84:0.2": "9. Tatiyaāmakadhaññapeyyālavagga ",
    "sn56.84:0.3": "Āmakadhaññasutta ",
    "sn56.84:1.1": "… “Evameva kho, bhikkhave, appakā te sattā ye āmakadhaññapaṭiggahaṇā paṭiviratā; atha kho eteva bahutarā sattā ye āmakadhaññapaṭiggahaṇā appaṭiviratā …pe…. ",
    "sn56.84:1.2": "Catutthaṁ. "
  },
  "translation_text": {
    "sn56.84:0.1": "Linked Discourses 56.84 ",
    "sn56.84:0.2": "9. Abbreviated Texts on Raw Grain ",
    "sn56.84:0.3": "Raw Grain ",
    "sn56.84:1.1": "“… the sentient beings who refrain from receiving raw grain are few, while those who don’t refrain are many. …” "
  },
  "variant_text": {
    "sn56.84:0.3": "Āmakadhaññasutta → dhaññaṁ (pts1ed) "
  },
