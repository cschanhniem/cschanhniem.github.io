  "root_text": {
    "sn11.15:0.1": "Saṁyutta Nikāya 11.15 ",
    "sn11.15:0.2": "2. Dutiyavagga ",
    "sn11.15:0.3": "Rāmaṇeyyakasutta ",
    "sn11.15:1.1": "Sāvatthiyaṁ jetavane. ",
    "sn11.15:1.2": "Atha kho sakko devānamindo yena bhagavā tenupasaṅkami; upasaṅkamitvā bhagavantaṁ abhivādetvā ekamantaṁ aṭṭhāsi. Ekamantaṁ ṭhito kho sakko devānamindo bhagavantaṁ etadavoca: ",
    "sn11.15:1.3": "“kiṁ nu kho, bhante, bhūmirāmaṇeyyakan”ti? ",
    "sn11.15:2.1": "“Ārāmacetyā vanacetyā, ",
    "sn11.15:2.2": "pokkharañño sunimmitā; ",
    "sn11.15:2.3": "Manussarāmaṇeyyassa, ",
    "sn11.15:2.4": "kalaṁ nāgghanti soḷasiṁ. ",
    "sn11.15:3.1": "Gāme vā yadi vāraññe, ",
    "sn11.15:3.2": "Ninne vā yadi vā thale; ",
    "sn11.15:3.3": "Yattha arahanto viharanti, ",
    "sn11.15:3.4": "Taṁ bhūmirāmaṇeyyakan”ti. "
  },
  "translation_text": {
    "sn11.15:0.1": "Linked Discourses 11.15 ",
    "sn11.15:0.2": "Chapter Two ",
    "sn11.15:0.3": "Delightful ",
    "sn11.15:1.1": "Near Sāvatthī in Jeta’s Grove. ",
    "sn11.15:1.2": "And then Sakka, lord of gods, went up to the Buddha, bowed, stood to one side, and said to him, ",
    "sn11.15:1.3": "“Sir, what is a delightful place?” ",
    "sn11.15:2.1": "“Shrines in parks and forests, ",
    "sn11.15:2.2": "well-made lotus ponds, ",
    "sn11.15:2.3": "are not worth a sixteenth part ",
    "sn11.15:2.4": "of a delightful human being. ",
    "sn11.15:3.1": "Whether in village or wilderness, ",
    "sn11.15:3.2": "in a valley or the uplands, ",
    "sn11.15:3.3": "wherever the perfected ones live ",
    "sn11.15:3.4": "is a delightful place.” "
  },
