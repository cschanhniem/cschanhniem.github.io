    "sn55.66:0.1": "Saṁyutta Nikāya 55.66 ",
    "sn55.66:0.2": "7. Mahāpaññavagga ",
    "sn55.66:0.3": "Appamattapaññāsutta ",
    "sn55.66:1.1": "“… Appamattapaññatāya saṁvattantī”ti. ",
    "sn55.66:1.2": "Pañcamaṁ. "
  },
  "translation_text": {
