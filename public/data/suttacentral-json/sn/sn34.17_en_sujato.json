  "root_text": {
    "sn34.17:0.1": "Saṁyutta Nikāya 34.17 ",
    "sn34.17:0.2": "1. Jhānavagga ",
    "sn34.17:0.3": "Samāpattimūlakasakkaccasutta ",
    "sn34.17:1.1": "Sāvatthinidānaṁ. ",
    "sn34.17:1.2": "“Cattārome, bhikkhave, jhāyī. ",
    "sn34.17:1.3": "Katame cattāro? ",
    "sn34.17:1.4": "Idha, bhikkhave, ekacco jhāyī samādhismiṁ samāpattikusalo hoti, na samādhismiṁ sakkaccakārī. ",
    "sn34.17:1.5": "Idha pana, bhikkhave, ekacco jhāyī samādhismiṁ sakkaccakārī hoti, na samādhismiṁ samāpattikusalo. ",
    "sn34.17:1.6": "Idha pana, bhikkhave, ekacco jhāyī neva samādhismiṁ samāpattikusalo hoti, na ca samādhismiṁ sakkaccakārī. ",
    "sn34.17:1.7": "Idha pana, bhikkhave, ekacco jhāyī samādhismiṁ samāpattikusalo ca hoti, samādhismiṁ sakkaccakārī ca. ",
    "sn34.17:1.8": "Tatra …pe… ",
    "sn34.17:1.9": "pavaro cā”ti. ",
    "sn34.17:1.10": "Sattarasamaṁ. "
  },
  "translation_text": {
    "sn34.17:0.1": "Linked Discourses 34.17 ",
    "sn34.17:0.2": "1. Absorption ",
    "sn34.17:0.3": "Entering and Carefulness ",
    "sn34.17:1.1": "At Sāvatthī. ",
    "sn34.17:1.2": "“Mendicants, there are these four meditators. ",
    "sn34.17:1.3": "What four? ",
    "sn34.17:1.4": "One meditator is skilled in entering immersion but not in practicing carefully for it. …” "
  },
  "variant_text": {
    "sn34.17:0.3": "Samāpattimūlakasakkaccasutta → samāpattisakkaccakārīsuttaṁ (bj); samāpatti-sakkacca (pts1ed) "
  },
