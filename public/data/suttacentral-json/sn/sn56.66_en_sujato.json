  "root_text": {
    "sn56.66:0.1": "Saṁyutta Nikāya 56.66 ",
    "sn56.66:0.2": "7. Paṭhamaāmakadhaññapeyyālavagga ",
    "sn56.66:0.3": "Matteyyasutta ",
    "sn56.66:1.1": "… “Evameva kho, bhikkhave, appakā te sattā ye matteyyā; atha kho eteva bahutarā sattā ye amatteyyā …pe…. ",
    "sn56.66:1.2": "Chaṭṭhaṁ. "
  },
  "translation_text": {
    "sn56.66:0.1": "Linked Discourses 56.66 ",
    "sn56.66:0.2": "7. Abbreviated Texts on Raw Grain ",
    "sn56.66:0.3": "Respect Mother ",
    "sn56.66:1.1": "“… the sentient beings who respect their mothers are few, while those who don’t are many. …” "
  },
