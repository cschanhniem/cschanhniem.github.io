  "root_text": {
    "sn46.10:0.1": "Saṁyutta Nikāya 46.10 ",
    "sn46.10:0.2": "1. Pabbatavagga ",
    "sn46.10:0.3": "Dutiyauppannasutta ",
    "sn46.10:1.1": "“Sattime, bhikkhave, bojjhaṅgā bhāvitā bahulīkatā anuppannā uppajjanti, nāññatra sugatavinayā. ",
    "sn46.10:1.2": "Katame satta? ",
    "sn46.10:1.3": "Satisambojjhaṅgo …pe… upekkhāsambojjhaṅgo—",
    "sn46.10:1.4": "ime kho, bhikkhave, satta bojjhaṅgā bhāvitā bahulīkatā anuppannā uppajjanti, nāññatra sugatavinayā”ti. ",
    "sn46.10:1.5": "Dasamaṁ. ",
    "sn46.10:1.6": "Pabbatavaggo paṭhamo. ",
    "sn46.10:2.0": "Tassuddānaṁ ",
    "sn46.10:2.1": "Himavantaṁ kāyaṁ sīlaṁ, ",
    "sn46.10:2.2": "vatthaṁ bhikkhu ca kuṇḍali; ",
    "sn46.10:2.3": "Kūṭañca upavānañca, ",
    "sn46.10:2.4": "uppannā apare duveti. "
  },
  "translation_text": {
    "sn46.10:0.1": "Linked Discourses 46.10 ",
    "sn46.10:0.2": "1. Mountains ",
    "sn46.10:0.3": "Arisen (2nd) ",
    "sn46.10:1.1": "“Mendicants, these seven awakening factors don’t arise to be developed and cultivated apart from the Holy One’s training. ",
    "sn46.10:1.2": "What seven? ",
    "sn46.10:1.3": "The awakening factors of mindfulness, investigation of principles, energy, rapture, tranquility, immersion, and equanimity. ",
    "sn46.10:1.4": "These seven awakening factors don’t arise to be developed and cultivated apart from the Holy One’s training.” ",
