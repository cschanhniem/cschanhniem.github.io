  "root_text": {
    "sn45.71-75:0.1": "Saṁyutta Nikāya 45.71–75 ",
    "sn45.71-75:0.2": "7. Ekadhammapeyyālavagga ",
    "sn45.71-75:0.3": "Dutiyasīlasampadādisuttapañcaka ",
    "sn45.71-75:1.1": "Sāvatthinidānaṁ. ",
    "sn45.71-75:1.2": "“Ekadhammo, bhikkhave, bahūpakāro ariyassa aṭṭhaṅgikassa maggassa uppādāya. ",
    "sn45.71-75:1.3": "Katamo ekadhammo? ",
    "sn45.71-75:1.4": "Yadidaṁ—sīlasampadā …pe… ",
    "sn45.71-75:1.5": "yadidaṁ—chandasampadā …pe… ",
    "sn45.71-75:1.6": "yadidaṁ—attasampadā …pe… ",
    "sn45.71-75:1.7": "yadidaṁ—diṭṭhisampadā …pe… ",
    "sn45.71-75:1.8": "yadidaṁ—appamādasampadā …pe…. ",
    "sn45.71-75:1.9": "Chaṭṭhaṁ. "
  },
  "translation_text": {
    "sn45.71-75:0.1": "Linked Discourses 45.71–75 ",
    "sn45.71-75:0.2": "7. Abbreviated Texts on One Thing ",
    "sn45.71-75:0.3": "Five Discourses on Accomplishment in Ethics, Etc. (2nd) ",
    "sn45.71-75:1.1": "At Sāvatthī. ",
    "sn45.71-75:1.2": "“Mendicants, one thing helps give rise to the noble eightfold path. ",
    "sn45.71-75:1.3": "What one thing? ",
    "sn45.71-75:1.4": "It’s accomplishment in ethics. …” ",
    "sn45.71-75:1.5": "“… accomplishment in enthusiasm …” ",
    "sn45.71-75:1.6": "“… accomplishment in self-development …” ",
    "sn45.71-75:1.7": "“… accomplishment in view …” ",
    "sn45.71-75:1.8": "“… accomplishment in diligence …” "
  },
