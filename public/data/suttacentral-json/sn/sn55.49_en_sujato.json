  "root_text": {
    "sn55.49:0.1": "Saṁyutta Nikāya 55.49 ",
    "sn55.49:0.2": "5. Sagāthakapuññābhisandavagga ",
    "sn55.49:0.3": "Mahānāmasutta ",
    "sn55.49:1.1": "Kapilavatthunidānaṁ. ",
    "sn55.49:1.2": "Ekamantaṁ nisinnaṁ kho mahānāmaṁ sakkaṁ bhagavā etadavoca: ",
    "sn55.49:1.3": "“catūhi kho, mahānāma, dhammehi samannāgato ariyasāvako sotāpanno hoti …pe… sambodhiparāyaṇo. ",
    "sn55.49:2.1": "Katamehi catūhi? ",
    "sn55.49:2.2": "Idha, mahānāma, ariyasāvako buddhe …pe… ",
    "sn55.49:2.3": "dhamme …pe… ",
    "sn55.49:2.4": "saṅghe …pe… ",
    "sn55.49:2.5": "ariyakantehi sīlehi samannāgato hoti akhaṇḍehi …pe… samādhisaṁvattanikehi. ",
    "sn55.49:2.6": "Imehi kho, mahānāma, catūhi dhammehi samannāgato ariyasāvako sotāpanno hoti avinipātadhammo niyato sambodhiparāyaṇo”ti. ",
    "sn55.49:2.7": "Navamaṁ. "
  },
  "translation_text": {
    "sn55.49:0.1": "Linked Discourses 55.49 ",
    "sn55.49:0.2": "5. Overflowing Merit, With Verses ",
    "sn55.49:0.3": "With Mahānāma ",
    "sn55.49:1.1": "At Kapilavatthu. ",
    "sn55.49:1.2": "Seated to one side, the Buddha said to Mahānāma the Sakyan: ",
    "sn55.49:1.3": "“Mahānāma, a noble disciple who has four things is a stream-enterer …” ",
