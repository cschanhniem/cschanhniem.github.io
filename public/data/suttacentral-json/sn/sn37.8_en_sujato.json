  "root_text": {
    "sn37.8:0.1": "Saṁyutta Nikāya 37.8 ",
    "sn37.8:0.2": "1. Paṭhamapeyyālavagga ",
    "sn37.8:0.3": "Maccharīsutta ",
    "sn37.8:1.1": "“Pañcahi, anuruddha, dhammehi samannāgato mātugāmo kāyassa bhedā paraṁ maraṇā apāyaṁ duggatiṁ vinipātaṁ nirayaṁ upapajjati. ",
    "sn37.8:1.2": "Katamehi pañcahi? ",
    "sn37.8:1.3": "Assaddho ca hoti, ahiriko ca hoti, anottappī ca hoti, maccharī ca hoti, duppañño ca hoti—",
    "sn37.8:1.4": "imehi kho, anuruddha, pañcahi dhammehi samannāgato mātugāmo …pe… ",
    "sn37.8:1.5": "apāyaṁ duggatiṁ vinipātaṁ nirayaṁ upapajjatī”ti. ",
    "sn37.8:1.6": "Aṭṭhamaṁ. "
  },
  "translation_text": {
    "sn37.8:0.1": "Linked Discourses 37.8 ",
    "sn37.8:0.2": "1. Abbreviated Texts ",
    "sn37.8:0.3": "Stingy ",
    "sn37.8:1.1": "",
    "sn37.8:1.2": "",
    "sn37.8:1.3": "“… They’re faithless, shameless, imprudent, stingy, and witless. …” ",
    "sn37.8:1.4": "",
    "sn37.8:1.5": ""
  },
