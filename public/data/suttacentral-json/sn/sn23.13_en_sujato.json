  "root_text": {
    "sn23.13:0.1": "Saṁyutta Nikāya 23.13 ",
    "sn23.13:0.2": "2. Dutiyamāravagga ",
    "sn23.13:0.3": "Aniccasutta ",
    "sn23.13:1.1": "Sāvatthinidānaṁ. ",
    "sn23.13:1.2": "Ekamantaṁ nisinno kho āyasmā rādho bhagavantaṁ etadavoca: ",
    "sn23.13:1.3": "“‘aniccaṁ, aniccan’ti, bhante, vuccati. ",
    "sn23.13:1.4": "Katamaṁ nu kho, bhante, aniccan”ti? ",
    "sn23.13:1.5": "“Rūpaṁ kho, rādha, aniccaṁ, vedanā aniccā, saññā aniccā, saṅkhārā aniccā, viññāṇaṁ aniccaṁ. ",
    "sn23.13:1.6": "Evaṁ passaṁ …pe… ",
    "sn23.13:1.7": "nāparaṁ itthattāyāti pajānātī”ti. ",
    "sn23.13:1.8": "Tatiyaṁ. "
  },
  "translation_text": {
    "sn23.13:0.1": "Linked Discourses 23.13 ",
    "sn23.13:0.2": "2. About Māra (2nd) ",
    "sn23.13:0.3": "Impermanence ",
    "sn23.13:1.1": "At Sāvatthī. ",
    "sn23.13:1.2": "Seated to one side, Venerable Rādha said to the Buddha: ",
    "sn23.13:1.3": "“Sir, they speak of this thing called ‘impermanence’. ",
    "sn23.13:1.4": "What is impermanence?” ",
    "sn23.13:1.5": "“Rādha, form, feeling, perception, choices, and consciousness are impermanent. ",
    "sn23.13:1.6": "Seeing this … ",
    "sn23.13:1.7": "They understand: ‘… there is nothing further for this place.’” "
  },
  "variant_text": {
    "sn23.13:0.3": "Aniccasutta → anicca 1 (pts1ed) "
  },
