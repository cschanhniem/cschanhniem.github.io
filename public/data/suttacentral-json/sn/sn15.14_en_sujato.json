  "root_text": {
    "sn15.14:0.1": "Saṁyutta Nikāya 15.14 ",
    "sn15.14:0.2": "2. Dutiyavagga ",
    "sn15.14:0.3": "Mātusutta ",
    "sn15.14:1.1": "Sāvatthiyaṁ viharati. ",
    "sn15.14:1.2": "“Anamataggoyaṁ, bhikkhave, saṁsāro …pe… ",
    "sn15.14:1.3": "na so, bhikkhave, satto sulabharūpo yo namātābhūtapubbo iminā dīghena addhunā. ",
    "sn15.14:1.4": "Taṁ kissa hetu? ",
    "sn15.14:1.5": "Anamataggoyaṁ, bhikkhave, saṁsāro …pe… ",
    "sn15.14:1.6": "alaṁ vimuccitun”ti. ",
    "sn15.14:1.7": "Catutthaṁ. "
  },
  "translation_text": {
    "sn15.14:0.1": "Linked Discourses 15.14 ",
    "sn15.14:0.2": "Chapter Two ",
    "sn15.14:0.3": "Mother ",
    "sn15.14:1.1": "At Sāvatthī. ",
    "sn15.14:1.2": "“Mendicants, this transmigration has no known beginning. … ",
    "sn15.14:1.3": "It’s not easy to find a sentient being who in all this long time has not previously been your mother. ",
    "sn15.14:1.4": "Why is that? ",
    "sn15.14:1.5": "This transmigration has no known beginning. … ",
    "sn15.14:1.6": "This is quite enough for you to become disillusioned, dispassionate, and freed regarding all conditions.” "
  },
