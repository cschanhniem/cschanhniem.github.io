  "root_text": {
    "sn48.20:0.1": "Saṁyutta Nikāya 48.20 ",
    "sn48.20:0.2": "2. Mudutaravagga ",
    "sn48.20:0.3": "Āsavakkhayasutta ",
    "sn48.20:1.1": "“Pañcimāni, bhikkhave, indriyāni. ",
    "sn48.20:1.2": "Katamāni pañca? ",
    "sn48.20:1.3": "Saddhindriyaṁ …pe… paññindriyaṁ—",
    "sn48.20:1.4": "imāni kho, bhikkhave, pañcindriyāni. ",
    "sn48.20:1.5": "Imesaṁ kho, bhikkhave, pañcannaṁ indriyānaṁ bhāvitattā bahulīkatattā bhikkhu āsavānaṁ khayā anāsavaṁ cetovimuttiṁ paññāvimuttiṁ diṭṭheva dhamme sayaṁ abhiññā sacchikatvā upasampajja viharatī”ti. ",
    "sn48.20:1.6": "Dasamaṁ. ",
    "sn48.20:1.7": "Mudutaravaggo dutiyo. ",
    "sn48.20:2.0": "Tassuddānaṁ ",
    "sn48.20:2.1": "Paṭilābho tayo saṅkhittā, ",
    "sn48.20:2.2": "vitthārā apare tayo; ",
    "sn48.20:2.3": "Paṭipanno ca sampanno, ",
    "sn48.20:2.4": "dasamaṁ āsavakkhayanti. "
  },
  "translation_text": {
    "sn48.20:0.1": "Linked Discourses 48.20 ",
    "sn48.20:0.2": "2. Weaker ",
    "sn48.20:0.3": "The Ending of Defilements ",
    "sn48.20:1.1": "“Mendicants, there are these five faculties. ",
    "sn48.20:1.2": "What five? ",
    "sn48.20:1.3": "The faculties of faith, energy, mindfulness, immersion, and wisdom. ",
    "sn48.20:1.4": "These are the five faculties. ",
    "sn48.20:1.5": "It’s because of developing and cultivating these five faculties that a mendicant realizes the undefiled freedom of heart and freedom by wisdom in this very life. And they live having realized it with their own insight due to the ending of defilements.” ",
    "sn48.20:1.6": "",
    "sn48.20:1.7": "",
    "sn48.20:2.1": "",
    "sn48.20:2.2": "",
    "sn48.20:2.3": ""
  },
  "variant_text": {
    "sn48.20:0.3": "Āsavakkhayasutta → āsavānaṁ khayo (pts1ed) ",
    "sn48.20:2.3": "Paṭipanno ca sampanno → paṭipanno cupasamo (sya-all, km, pts1ed, mr) "
  },
