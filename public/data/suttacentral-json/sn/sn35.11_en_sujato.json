  "root_text": {
    "sn35.11:0.1": "Saṁyutta Nikāya 35.11 ",
    "sn35.11:0.2": "1. Aniccavagga ",
    "sn35.11:0.3": "Bāhiradukkhātītānāgatasutta ",
    "sn35.11:1.1": "“Rūpā, bhikkhave, dukkhā atītānāgatā; ",
    "sn35.11:1.2": "ko pana vādo paccuppannānaṁ. ",
    "sn35.11:1.3": "Evaṁ passaṁ, bhikkhave, sutavā ariyasāvako atītesu rūpesu anapekkho hoti; ",
    "sn35.11:1.4": "anāgate rūpe nābhinandati; paccuppannānaṁ rūpānaṁ nibbidāya virāgāya nirodhāya paṭipanno hotī”ti …pe…. ",
    "sn35.11:1.5": "Ekādasamaṁ. "
  },
  "translation_text": {
    "sn35.11:0.1": "Linked Discourses 35.11 ",
    "sn35.11:0.2": "1. Impermanence ",
    "sn35.11:0.3": "The Exterior as Suffering in the Three Times ",
    "sn35.11:1.1": "“Mendicants, sights of the past and future are suffering, ",
    "sn35.11:1.2": "let alone the present. …” ",
    "sn35.11:1.3": "",
    "sn35.11:1.4": ""
  },
  "variant_text": {
    "sn35.11:0.3": "Bāhiradukkhātītānāgatasutta → dutiyabāhiradukkhasuttaṁ (bj); dukkhaṁ 4; bāhiraṁ (pts1ed) "
  },
