  "root_text": {
    "sn45.168:0.1": "Saṁyutta Nikāya 45.168 ",
    "sn45.168:0.2": "13. Esanāvagga ",
    "sn45.168:0.3": "Nīghasutta ",
    "sn45.168:1.1": "“Tayome, bhikkhave, nīghā. ",
    "sn45.168:1.2": "Katame tayo? ",
    "sn45.168:1.3": "Rāgo nīgho, doso nīgho, moho nīgho—",
    "sn45.168:1.4": "ime kho, bhikkhave, tayo nīghā. ",
    "sn45.168:1.5": "Imesaṁ kho, bhikkhave, tiṇṇannaṁ nīghānaṁ abhiññāya pariññāya parikkhayāya pahānāya …pe… ayaṁ ariyo aṭṭhaṅgiko maggo bhāvetabbo”ti. ",
    "sn45.168:1.6": "Aṭṭhamaṁ. "
  },
  "translation_text": {
    "sn45.168:0.1": "Linked Discourses 45.168 ",
    "sn45.168:0.2": "13. Searches ",
    "sn45.168:0.3": "Troubles ",
    "sn45.168:1.1": "“Mendicants, there are these three troubles. ",
    "sn45.168:1.2": "What three? ",
    "sn45.168:1.3": "Greed, hate, and delusion. ",
    "sn45.168:1.4": "These are the three troubles. ",
    "sn45.168:1.5": "The noble eightfold path should be developed for the direct knowledge, complete understanding, finishing, and giving up of these three troubles.” "
  },
