  "root_text": {
    "sn23.21:0.1": "Saṁyutta Nikāya 23.21 ",
    "sn23.21:0.2": "2. Dutiyamāravagga ",
    "sn23.21:0.3": "Samudayadhammasutta ",
    "sn23.21:1.1": "Sāvatthinidānaṁ. ",
    "sn23.21:1.2": "Ekamantaṁ nisinno kho āyasmā rādho bhagavantaṁ etadavoca: ",
    "sn23.21:1.3": "“‘samudayadhammo, samudayadhammo’ti, bhante, vuccati. ",
    "sn23.21:1.4": "Katamo nu kho, bhante, samudayadhammo”ti? ",
    "sn23.21:1.5": "“Rūpaṁ kho, rādha, samudayadhammo, vedanā samudayadhammo, saññā samudayadhammo, saṅkhārā samudayadhammo, viññāṇaṁ samudayadhammo. ",
    "sn23.21:1.6": "Evaṁ passaṁ …pe… ",
    "sn23.21:1.7": "nāparaṁ itthattāyāti pajānātī”ti. ",
    "sn23.21:1.8": "Ekādasamaṁ. "
  },
  "translation_text": {
    "sn23.21:0.1": "Linked Discourses 23.21 ",
    "sn23.21:0.2": "2. About Māra (2nd) ",
    "sn23.21:0.3": "Liable To Originate ",
    "sn23.21:1.1": "At Sāvatthī. ",
    "sn23.21:1.2": "Seated to one side, Venerable Rādha said to the Buddha: ",
    "sn23.21:1.3": "“Sir, they speak of ‘liable to originate’. ",
    "sn23.21:1.4": "What is liable to originate?” ",
    "sn23.21:1.5": "“Rādha, form, feeling, perception, choices, and consciousness are liable to originate. ",
    "sn23.21:1.6": "Seeing this … ",
    "sn23.21:1.7": "They understand: ‘… there is nothing further for this place.’” "
  },
  "variant_text": {
    "sn23.21:0.3": "Samudayadhammasutta → samudaya (pts1ed) "
  },
