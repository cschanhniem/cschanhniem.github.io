  "root_text": {
    "sn46.22:0.1": "Saṁyutta Nikāya 46.22 ",
    "sn46.22:0.2": "3. Udāyivagga ",
    "sn46.22:0.3": "Bojjhaṅgadesanāsutta ",
    "sn46.22:1.1": "“Satta vo, bhikkhave, bojjhaṅge desessāmi; ",
    "sn46.22:1.2": "taṁ suṇātha. ",
    "sn46.22:1.3": "Katame ca, bhikkhave, satta bojjhaṅgā? ",
    "sn46.22:1.4": "Satisambojjhaṅgo …pe… upekkhāsambojjhaṅgo—",
    "sn46.22:1.5": "ime kho, bhikkhave, satta bojjhaṅgā”ti. ",
    "sn46.22:1.6": "Dutiyaṁ. "
  },
  "translation_text": {
    "sn46.22:0.1": "Linked Discourses 46.22 ",
    "sn46.22:0.2": "3. With Udāyī ",
    "sn46.22:0.3": "A Teaching on the Awakening Factors ",
    "sn46.22:1.1": "“Mendicants, I will teach you the seven awakening factors. ",
    "sn46.22:1.2": "Listen … ",
    "sn46.22:1.3": "And what are the seven awakening factors? ",
    "sn46.22:1.4": "The awakening factors of mindfulness, investigation of principles, energy, rapture, tranquility, immersion, and equanimity. ",
    "sn46.22:1.5": "These are the seven awakening factors.” "
  },
  "variant_text": {
    "sn46.22:0.3": "Bojjhaṅgadesanāsutta → desanāsuttaṁ (bj); desanā (pts1ed) "
  },
