  "root_text": {
    "sn52.24:0.1": "Saṁyutta Nikāya 52.24 ",
    "sn52.24:0.2": "2. Dutiyavagga ",
    "sn52.24:0.3": "Āsavakkhayasutta ",
    "sn52.24:1.1": "“Imesañca panāhaṁ, āvuso, catunnaṁ satipaṭṭhānānaṁ bhāvitattā bahulīkatattā āsavānaṁ khayā anāsavaṁ cetovimuttiṁ paññāvimuttiṁ diṭṭheva dhamme sayaṁ abhiññā sacchikatvā upasampajja viharāmī”ti. ",
    "sn52.24:1.2": "Cuddasamaṁ. ",
    "sn52.24:1.3": "Dutiyo vaggo. ",
    "sn52.24:2.0": "Tassuddānaṁ ",
    "sn52.24:2.1": "Mahābhiññaṁ iddhi dibbaṁ, ",
    "sn52.24:2.2": "Cetopariyaṁ ṭhānaṁ kammaṁ; ",
    "sn52.24:2.3": "Sabbatthadhātudhimutti, ",
    "sn52.24:2.4": "Indriyaṁ jhānaṁ tisso vijjāti. ",
    "sn52.24:2.5": "Anuruddhasaṁyuttaṁ aṭṭhamaṁ. "
  },
  "translation_text": {
    "sn52.24:0.1": "Linked Discourses 52.24 ",
    "sn52.24:0.2": "2. A Thousand ",
    "sn52.24:0.3": "The Ending of Defilements ",
    "sn52.24:1.1": "“… And it’s because of developing and cultivating these four kinds of mindfulness meditation that I realized the undefiled freedom of heart and freedom by wisdom in this very life. And I live having realized it with my own insight due to the ending of defilements.” ",
    "sn52.24:1.2": "",
    "sn52.24:1.3": "",
    "sn52.24:2.1": "",
    "sn52.24:2.2": "",
    "sn52.24:2.3": "",
    "sn52.24:2.4": "",
    "sn52.24:2.5": "The Linked Discourses with Anuruddha are the eighth section. "
  },
  "variant_text": {
    "sn52.24:0.3": "Āsavakkhayasutta → vijjā 3 (pts1ed) "
  },
