  "root_text": {
    "sn1.30:0.1": "Saṁyutta Nikāya 1.30 ",
    "sn1.30:0.2": "3. Sattivagga ",
    "sn1.30:0.3": "Eṇijaṅghasutta ",
    "sn1.30:1.1": "“Eṇijaṅghaṁ kisaṁ vīraṁ, ",
    "sn1.30:1.2": "appāhāraṁ alolupaṁ; ",
    "sn1.30:1.3": "Sīhaṁvekacaraṁ nāgaṁ, ",
    "sn1.30:1.4": "kāmesu anapekkhinaṁ; ",
    "sn1.30:1.5": "Upasaṅkamma pucchāma, ",
    "sn1.30:1.6": "kathaṁ dukkhā pamuccatī”ti. ",
    "sn1.30:2.1": "“Pañca kāmaguṇā loke, ",
    "sn1.30:2.2": "manochaṭṭhā paveditā; ",
    "sn1.30:2.3": "Ettha chandaṁ virājetvā, ",
    "sn1.30:2.4": "evaṁ dukkhā pamuccatī”ti. ",
    "sn1.30:2.5": "Sattivaggo tatiyo. ",
    "sn1.30:3.0": "Tassuddānaṁ ",
    "sn1.30:3.1": "Sattiyā phusati ceva, ",
    "sn1.30:3.2": "jaṭā manonivāraṇā; ",
    "sn1.30:3.3": "Arahantena pajjoto, ",
    "sn1.30:3.4": "sarā mahaddhanena ca; ",
    "sn1.30:3.5": "Catucakkena navamaṁ, ",
    "sn1.30:3.6": "eṇijaṅghena te dasāti. "
  },
  "translation_text": {
    "sn1.30:0.1": "Linked Discourses 1.30 ",
    "sn1.30:0.2": "3. A Sword ",
    "sn1.30:0.3": "Antelope Calves ",
    "sn1.30:1.1": "“O hero so lean, with antelope calves, ",
    "sn1.30:1.2": "not greedy, eating little, ",
    "sn1.30:1.3": "a giant, wandering alone like a lion, ",
    "sn1.30:1.4": "you’re not concerned for sensual pleasures. ",
    "sn1.30:1.5": "We’ve come to ask a question: ",
    "sn1.30:1.6": "How is one released from all suffering?” ",
    "sn1.30:2.1": "“The world has five kinds of sensual stimulation, ",
    "sn1.30:2.2": "and the mind is said to be the sixth. ",
    "sn1.30:2.3": "When you’ve discarded desire for these, ",
    "sn1.30:2.4": "you’re released from all suffering.” ",
