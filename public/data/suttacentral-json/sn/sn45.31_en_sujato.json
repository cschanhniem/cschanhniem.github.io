  "root_text": {
    "sn45.31:0.1": "Saṁyutta Nikāya 45.31 ",
    "sn45.31:0.2": "4. Paṭipattivagga ",
    "sn45.31:0.3": "Paṭhamapaṭipattisutta ",
    "sn45.31:1.1": "Sāvatthinidānaṁ. ",
    "sn45.31:1.2": "“Micchāpaṭipattiñca vo, bhikkhave, desessāmi, sammāpaṭipattiñca. ",
    "sn45.31:1.3": "Taṁ suṇātha. ",
    "sn45.31:1.4": "Katamā ca, bhikkhave, micchāpaṭipatti? ",
    "sn45.31:1.5": "Seyyathidaṁ—micchādiṭṭhi …pe… micchāsamādhi. ",
    "sn45.31:1.6": "Ayaṁ vuccati, bhikkhave, micchāpaṭipatti. ",
    "sn45.31:1.7": "Katamā ca, bhikkhave, sammāpaṭipatti? ",
    "sn45.31:1.8": "Seyyathidaṁ—sammādiṭṭhi …pe… sammāsamādhi. ",
    "sn45.31:1.9": "Ayaṁ vuccati, bhikkhave, sammāpaṭipattī”ti. ",
    "sn45.31:1.10": "Paṭhamaṁ. "
  },
  "translation_text": {
    "sn45.31:0.1": "Linked Discourses 45.31 ",
    "sn45.31:0.2": "4. Practice ",
    "sn45.31:0.3": "Practice (1st) ",
    "sn45.31:1.1": "At Sāvatthī. ",
    "sn45.31:1.2": "“Mendicants, I will teach you the wrong practice and the right practice. ",
    "sn45.31:1.3": "Listen … ",
    "sn45.31:1.4": "And what’s the wrong practice? ",
    "sn45.31:1.5": "It is wrong view, wrong thought, wrong speech, wrong action, wrong livelihood, wrong effort, wrong mindfulness, and wrong immersion. ",
    "sn45.31:1.6": "This is called the wrong practice. ",
    "sn45.31:1.7": "And what’s the right practice? ",
    "sn45.31:1.8": "It is right view, right thought, right speech, right action, right livelihood, right effort, right mindfulness, and right immersion. ",
    "sn45.31:1.9": "This is called the right practice.” "
  },
