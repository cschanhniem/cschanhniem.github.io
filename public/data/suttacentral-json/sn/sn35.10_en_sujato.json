  "root_text": {
    "sn35.10:0.1": "Saṁyutta Nikāya 35.10 ",
    "sn35.10:0.2": "1. Aniccavagga ",
    "sn35.10:0.3": "Bāhirāniccātītānāgatasutta ",
    "sn35.10:1.1": "“Rūpā, bhikkhave, aniccā atītānāgatā; ",
    "sn35.10:1.2": "ko pana vādo paccuppannānaṁ. ",
    "sn35.10:1.3": "Evaṁ passaṁ, bhikkhave, sutavā ariyasāvako atītesu rūpesu anapekkho hoti; ",
    "sn35.10:1.4": "anāgate rūpe nābhinandati; ",
    "sn35.10:1.5": "paccuppannānaṁ rūpānaṁ nibbidāya virāgāya nirodhāya paṭipanno hoti. ",
    "sn35.10:1.6": "Saddā … ",
    "sn35.10:1.7": "gandhā … ",
    "sn35.10:1.8": "rasā … ",
    "sn35.10:1.9": "phoṭṭhabbā … ",
    "sn35.10:1.10": "dhammā aniccā atītānāgatā; ",
    "sn35.10:1.11": "ko pana vādo paccuppannānaṁ. ",
    "sn35.10:1.12": "Evaṁ passaṁ, bhikkhave, sutavā ariyasāvako atītesu dhammesu anapekkho hoti; ",
    "sn35.10:1.13": "anāgate dhamme nābhinandati; ",
    "sn35.10:1.14": "paccuppannānaṁ dhammānaṁ nibbidāya virāgāya nirodhāya paṭipanno hotī”ti. ",
    "sn35.10:1.15": "Dasamaṁ. "
  },
  "translation_text": {
    "sn35.10:0.1": "Linked Discourses 35.10 ",
    "sn35.10:0.2": "1. Impermanence ",
    "sn35.10:0.3": "The Exterior as Impermanent in the Three Times ",
    "sn35.10:1.1": "“Mendicants, sights of the past and future are impermanent, ",
    "sn35.10:1.2": "let alone the present. …” ",
