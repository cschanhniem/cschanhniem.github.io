  "root_text": {
    "sn45.177:0.1": "Saṁyutta Nikāya 45.177 ",
    "sn45.177:0.2": "14. Oghavagga ",
    "sn45.177:0.3": "Nīvaraṇasutta ",
    "sn45.177:1.1": "“Pañcimāni, bhikkhave, nīvaraṇāni. ",
    "sn45.177:1.2": "Katamāni pañca? ",
    "sn45.177:1.3": "Kāmacchandanīvaraṇaṁ, byāpādanīvaraṇaṁ, thinamiddhanīvaraṇaṁ, uddhaccakukkuccanīvaraṇaṁ, vicikicchānīvaraṇaṁ—",
    "sn45.177:1.4": "imāni kho, bhikkhave, pañca nīvaraṇāni. ",
    "sn45.177:1.5": "Imesaṁ kho, bhikkhave, pañcannaṁ nīvaraṇānaṁ abhiññāya pariññāya parikkhayāya pahānāya …pe… ayaṁ ariyo aṭṭhaṅgiko maggo bhāvetabbo”ti. ",
    "sn45.177:1.6": "Sattamaṁ. "
  },
  "translation_text": {
    "sn45.177:0.1": "Linked Discourses 45.177 ",
    "sn45.177:0.2": "14. Floods ",
    "sn45.177:0.3": "Hindrances ",
    "sn45.177:1.1": "“Mendicants, there are these five hindrances. ",
    "sn45.177:1.2": "What five? ",
    "sn45.177:1.3": "The hindrances of sensual desire, ill will, dullness and drowsiness, restlessness and remorse, and doubt. ",
    "sn45.177:1.4": "These are the five hindrances. ",
    "sn45.177:1.5": "The noble eightfold path should be developed for the direct knowledge, complete understanding, finishing, and giving up of these five hindrances.” "
  },
  "variant_text": {
    "sn45.177:0.3": "Nīvaraṇasutta → nivaraṇāni (pts1ed) "
  },
