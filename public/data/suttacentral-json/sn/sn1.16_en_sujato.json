  "root_text": {
    "sn1.16:0.1": "Saṁyutta Nikāya 1.16 ",
    "sn1.16:0.2": "2. Nandanavagga ",
    "sn1.16:0.3": "Niddātandīsutta ",
    "sn1.16:1.1": "“Niddā tandī vijambhitā, ",
    "sn1.16:1.2": "Aratī bhattasammado; ",
    "sn1.16:1.3": "Etena nappakāsati, ",
    "sn1.16:1.4": "Ariyamaggo idha pāṇinan”ti. ",
    "sn1.16:2.1": "“Niddaṁ tandiṁ vijambhitaṁ, ",
    "sn1.16:2.2": "Aratiṁ bhattasammadaṁ; ",
    "sn1.16:2.3": "Vīriyena naṁ paṇāmetvā, ",
    "sn1.16:2.4": "Ariyamaggo visujjhatī”ti. "
  },
  "translation_text": {
    "sn1.16:0.1": "Linked Discourses 1.16 ",
    "sn1.16:0.2": "2. The Garden of Delight ",
    "sn1.16:0.3": "Sleepiness and Sloth ",
    "sn1.16:1.1": "“Sleepiness, sloth, and yawning, ",
    "sn1.16:1.2": "discontent, and grogginess after eating: ",
    "sn1.16:1.3": "because of this the noble path ",
    "sn1.16:1.4": "doesn’t shine for creatures here.” ",
    "sn1.16:2.1": "“Sleepiness, sloth, and yawning, ",
    "sn1.16:2.2": "discontent, and grogginess after eating: ",
    "sn1.16:2.3": "when this is energetically fended off, ",
    "sn1.16:2.4": "the noble path is purified.” "
  },
  "variant_text": {
    "sn1.16:0.3": "Niddātandīsutta → niddātandisuttaṁ (bj, pts2ed); niddā tandi (pts1ed) ",
    "sn1.16:1.1": "tandī → niddā tandi (bj) | vijambhitā → tandi vijambhikā (bj, pts2ed); tandī vijimhitā (sya-all); tandī vijambhikā (pts1ed) ",
    "sn1.16:2.3": "Vīriyena → viriyena (bj, sya-all, km, pts1ed, pts2ed) "
  },
