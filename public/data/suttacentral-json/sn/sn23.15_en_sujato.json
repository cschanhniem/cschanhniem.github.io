  "root_text": {
    "sn23.15:0.1": "Saṁyutta Nikāya 23.15 ",
    "sn23.15:0.2": "2. Dutiyamāravagga ",
    "sn23.15:0.3": "Dukkhasutta ",
    "sn23.15:1.1": "Sāvatthinidānaṁ. ",
    "sn23.15:1.2": "Ekamantaṁ nisinno kho āyasmā rādho bhagavantaṁ etadavoca: ",
    "sn23.15:1.3": "“‘dukkhaṁ, dukkhan’ti, bhante, vuccati. ",
    "sn23.15:1.4": "Katamaṁ nu kho, bhante, dukkhan”ti? ",
    "sn23.15:1.5": "“Rūpaṁ kho, rādha, dukkhaṁ, vedanā dukkhā, saññā dukkhā, saṅkhārā dukkhā, viññāṇaṁ dukkhaṁ. ",
    "sn23.15:1.6": "Evaṁ passaṁ …pe… ",
    "sn23.15:1.7": "nāparaṁ itthattāyāti pajānātī”ti. ",
    "sn23.15:1.8": "Pañcamaṁ. "
  },
  "translation_text": {
    "sn23.15:0.1": "Linked Discourses 23.15 ",
    "sn23.15:0.2": "2. About Māra (2nd) ",
    "sn23.15:0.3": "Suffering ",
    "sn23.15:1.1": "At Sāvatthī. ",
    "sn23.15:1.2": "Seated to one side, Venerable Rādha said to the Buddha: ",
    "sn23.15:1.3": "“Sir, they speak of this thing called ‘suffering’. ",
    "sn23.15:1.4": "What is suffering?” ",
    "sn23.15:1.5": "“Rādha, form, feeling, perception, choices, and consciousness are suffering. ",
    "sn23.15:1.6": "Seeing this … ",
    "sn23.15:1.7": "They understand: ‘… there is nothing further for this place.’” "
  },
  "variant_text": {
    "sn23.15:0.3": "Dukkhasutta → dukkha 1 (pts1ed) "
  },
