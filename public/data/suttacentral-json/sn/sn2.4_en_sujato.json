  "root_text": {
    "sn2.4:0.1": "Saṁyutta Nikāya 2.4 ",
    "sn2.4:0.2": "1. Paṭhamavagga ",
    "sn2.4:0.3": "Māgadhasutta ",
    "sn2.4:1.1": "Sāvatthinidānaṁ. ",
    "sn2.4:1.2": "Ekamantaṁ ṭhito kho māgadho devaputto bhagavantaṁ gāthāya ajjhabhāsi: ",
    "sn2.4:2.1": "“Kati lokasmiṁ pajjotā, ",
    "sn2.4:2.2": "yehi loko pakāsati; ",
    "sn2.4:2.3": "Bhavantaṁ puṭṭhumāgamma, ",
    "sn2.4:2.4": "kathaṁ jānemu taṁ mayan”ti. ",
    "sn2.4:3.1": "“Cattāro loke pajjotā, ",
    "sn2.4:3.2": "pañcamettha na vijjati; ",
    "sn2.4:3.3": "Divā tapati ādicco, ",
    "sn2.4:3.4": "rattimābhāti candimā. ",
    "sn2.4:4.1": "Atha aggi divārattiṁ, ",
    "sn2.4:4.2": "tattha tattha pakāsati; ",
    "sn2.4:4.3": "Sambuddho tapataṁ seṭṭho, ",
    "sn2.4:4.4": "esā ābhā anuttarā”ti. "
  },
  "translation_text": {
    "sn2.4:0.1": "Linked Discourses 2.4 ",
    "sn2.4:0.2": "Chapter One ",
    "sn2.4:0.3": "With Maghada ",
    "sn2.4:1.1": "At Sāvatthī. ",
    "sn2.4:1.2": "Standing to one side, the godling Maghada addressed the Buddha in verse: ",
    "sn2.4:2.1": "“How many lamps are there ",
    "sn2.4:2.2": "that light up the world? ",
    "sn2.4:2.3": "We’ve come to ask the Buddha; ",
    "sn2.4:2.4": "how are we to understand this?” ",
    "sn2.4:3.1": "“There are four lamps in the world, ",
    "sn2.4:3.2": "a fifth is not found. ",
    "sn2.4:3.3": "The sun blazes by day, ",
    "sn2.4:3.4": "the moon radiates at night, ",
    "sn2.4:4.1": "while a fire illuminates both ",
    "sn2.4:4.2": "by day and by night. ",
    "sn2.4:4.3": "But a Buddha is the best of blazes: ",
    "sn2.4:4.4": "this is the supreme radiance.” "
  },
