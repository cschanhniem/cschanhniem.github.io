  "root_text": {
    "sn17.32:0.1": "Saṁyutta Nikāya 17.32 ",
    "sn17.32:0.2": "4. Catutthavagga ",
    "sn17.32:0.3": "Kusalamūlasutta ",
    "sn17.32:1.1": "Sāvatthiyaṁ viharati. ",
    "sn17.32:1.2": "“Dāruṇo, bhikkhave, lābhasakkārasiloko. ",
    "sn17.32:1.3": "Lābhasakkārasilokena abhibhūtassa pariyādiṇṇacittassa, bhikkhave, devadattassa kusalamūlaṁ samucchedamagamā. ",
    "sn17.32:1.4": "Evaṁ dāruṇo kho, bhikkhave, lābhasakkārasiloko …pe… ",
    "sn17.32:1.5": "sikkhitabban”ti. ",
    "sn17.32:1.6": "Dutiyaṁ. "
  },
  "translation_text": {
    "sn17.32:0.1": "Linked Discourses 17.32 ",
    "sn17.32:0.2": "Chapter Four ",
    "sn17.32:0.3": "Skillful Root ",
    "sn17.32:1.1": "At Sāvatthī. ",
    "sn17.32:1.2": "“Possessions, honor, and popularity are grim … ",
    "sn17.32:1.3": "Devadatta cut off his skillful root because his mind was overcome and overwhelmed by possessions, honor, and popularity. ",
    "sn17.32:1.4": "So grim are possessions, honor, and popularity. …” ",
    "sn17.32:1.5": ""
  },
  "variant_text": {
    "sn17.32:0.3": "Kusalamūlasutta → kusalamūlasamucchedasuttaṁ (bj); mūla (pts1ed, pts2ed) "
  },
