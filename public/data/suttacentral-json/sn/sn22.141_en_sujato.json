  "root_text": {
    "sn22.141:0.1": "Saṁyutta Nikāya 22.141 ",
    "sn22.141:0.2": "14. Kukkuḷavagga ",
    "sn22.141:0.3": "Dutiyadukkhasutta ",
    "sn22.141:1.1": "Sāvatthinidānaṁ. ",
    "sn22.141:1.2": "“Yaṁ, bhikkhave, dukkhaṁ; tatra vo rāgo pahātabbo …pe… ",
    "sn22.141:1.3": "yaṁ, bhikkhave, dukkhaṁ; tatra vo rāgo pahātabbo”ti. ",
    "sn22.141:1.4": "Chaṭṭhaṁ. "
  },
  "translation_text": {
    "sn22.141:0.1": "Linked Discourses 22.141 ",
    "sn22.141:0.2": "14. Burning Chaff ",
    "sn22.141:0.3": "Suffering (2nd) ",
    "sn22.141:1.1": "At Sāvatthī. ",
    "sn22.141:1.2": "“Mendicants, you should give up greed for what is suffering. …” ",
    "sn22.141:1.3": ""
  },
