  "root_text": {
    "sn22.143:0.1": "Saṁyutta Nikāya 22.143 ",
    "sn22.143:0.2": "14. Kukkuḷavagga ",
    "sn22.143:0.3": "Anattasutta ",
    "sn22.143:1.1": "Sāvatthinidānaṁ. ",
    "sn22.143:1.2": "“Yo, bhikkhave, anattā; tatra vo chando pahātabbo. ",
    "sn22.143:1.3": "Ko ca, bhikkhave, anattā? ",
    "sn22.143:1.4": "Rūpaṁ, bhikkhave, anattā; tatra vo chando pahātabbo. ",
    "sn22.143:1.5": "Vedanā anattā … ",
    "sn22.143:1.6": "saññā … ",
    "sn22.143:1.7": "saṅkhārā … ",
    "sn22.143:1.8": "viññāṇaṁ anattā; tatra vo chando pahātabbo. ",
    "sn22.143:1.9": "Yo, bhikkhave, anattā; tatra vo chando pahātabbo”ti. ",
    "sn22.143:1.10": "Aṭṭhamaṁ. "
  },
  "translation_text": {
    "sn22.143:0.1": "Linked Discourses 22.143 ",
    "sn22.143:0.2": "14. Burning Chaff ",
    "sn22.143:0.3": "Not-Self ",
    "sn22.143:1.1": "At Sāvatthī. ",
    "sn22.143:1.2": "“Mendicants, you should give up desire for what is not-self. …” ",
