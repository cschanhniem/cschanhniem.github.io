  "root_text": {
    "sn26.4:0.1": "Saṁyutta Nikāya 26.4 ",
    "sn26.4:0.2": "1. Uppādavagga ",
    "sn26.4:0.3": "Samphassasutta ",
    "sn26.4:1.1": "Sāvatthinidānaṁ. ",
    "sn26.4:1.2": "“Yo kho, bhikkhave, cakkhusamphassassa uppādo ṭhiti …pe… ",
    "sn26.4:1.3": "jarāmaraṇassa pātubhāvo …pe… ",
    "sn26.4:1.4": "yo manosamphassassa uppādo ṭhiti …pe… ",
    "sn26.4:1.5": "jarāmaraṇassa pātubhāvo. ",
    "sn26.4:1.6": "Yo ca kho, bhikkhave, cakkhusamphassassa nirodho …pe… ",
    "sn26.4:1.7": "jarāmaraṇassa atthaṅgamo …pe… ",
    "sn26.4:1.8": "yo manosamphassassa nirodho …pe… ",
    "sn26.4:1.9": "jarāmaraṇassa atthaṅgamo”ti. ",
    "sn26.4:1.10": "Catutthaṁ. "
  },
  "translation_text": {
    "sn26.4:0.1": "Linked Discourses 26.4 ",
    "sn26.4:0.2": "1. Arising ",
    "sn26.4:0.3": "Contact ",
    "sn26.4:1.1": "At Sāvatthī. ",
    "sn26.4:1.2": "“Mendicants, the arising of eye contact … ",
    "sn26.4:1.3": "",
    "sn26.4:1.4": "mind contact … ",
    "sn26.4:1.5": "is the manifestation of old age and death. ",
    "sn26.4:1.6": "The cessation of eye contact … ",
    "sn26.4:1.7": "",
    "sn26.4:1.8": "mind contact … ",
    "sn26.4:1.9": "is the disappearance of old age and death.” "
  },
  "variant_text": {
    "sn26.4:0.3": "Samphassasutta → phassasuttaṁ (bj); phasso (pts1ed) "
  },
