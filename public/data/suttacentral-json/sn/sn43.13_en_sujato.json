  "root_text": {
    "sn43.13:0.1": "Saṁyutta Nikāya 43.13 ",
    "sn43.13:0.2": "2. Dutiyavagga ",
    "sn43.13:0.3": "Anatasutta ",
    "sn43.13:1.1": "“Anatañca vo, bhikkhave, desessāmi, anatagāmiñca maggaṁ. ",
    "sn43.13:1.2": "Taṁ suṇātha. ",
    "sn43.13:1.3": "Katamañca, bhikkhave, anataṁ …pe…”. ",
    "sn43.13:1.4": "(Yathā asaṅkhataṁ tathā vitthāretabbaṁ.) ",
    "sn43.13:1.5": "Dutiyaṁ. "
  },
  "translation_text": {
    "sn43.13:0.1": "Linked Discourses 43.13 ",
    "sn43.13:0.2": "Chapter Two ",
    "sn43.13:0.3": "Uninclined ",
    "sn43.13:1.1": "“Mendicants, I will teach you the uninclined …” ",
    "sn43.13:1.2": "",
    "sn43.13:1.3": "",
    "sn43.13:1.4": "(Tell in full as in the unconditioned in the previous chapter.) "
  },
  "variant_text": {
    "sn43.13:0.3": "Anatasutta → antasuttāni (bj); antam (pts1ed) ",
    "sn43.13:1.1": "Anatañca → antañca (bj, pts1ed) "
  },
