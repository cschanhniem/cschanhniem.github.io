  "root_text": {
    "sn34.41-45:0.1": "Saṁyutta Nikāya 34.41–45 ",
    "sn34.41-45:0.2": "1. Jhānavagga ",
    "sn34.41-45:0.3": "Ārammaṇamūlakagocarasuttādipañcaka ",
    "sn34.41-45:1.1": "Sāvatthinidānaṁ … ",
    "sn34.41-45:1.2": "“samādhismiṁ ārammaṇakusalo hoti, na samādhismiṁ gocarakusalo … ",
    "sn34.41-45:1.3": "samādhismiṁ gocarakusalo hoti, na samādhismiṁ ārammaṇakusalo … ",
    "sn34.41-45:1.4": "neva samādhismiṁ ārammaṇakusalo hoti, na ca samādhismiṁ gocarakusalo … ",
    "sn34.41-45:1.5": "samādhismiṁ ārammaṇakusalo ca hoti, samādhismiṁ gocarakusalo ca. ",
    "sn34.41-45:1.6": "Tatra, bhikkhave, yvāyaṁ jhāyī …pe… ",
    "sn34.41-45:1.7": "uttamo ca pavaro cā”ti. ",
    "sn34.41-45:1.8": "Ekacattālīsamaṁ. ",
    "sn34.41-45:1.9": "(Purimamūlakāni viya yāva pañcacattālīsamā ārammaṇamūlakasappāyakārīsuttā pañca suttāni pūretabbāni.) ",
    "sn34.41-45:1.10": "(Ārammaṇamūlakaṁ.) "
  },
  "translation_text": {
    "sn34.41-45:0.1": "Linked Discourses 34.41–45 ",
    "sn34.41-45:0.2": "1. Absorption ",
    "sn34.41-45:0.3": "Five on Support and Territory, Etc. ",
    "sn34.41-45:1.1": "At Sāvatthī. ",
    "sn34.41-45:1.2": "“One meditator is skilled in the supports for immersion but not in the territory of immersion. …” ",
    "sn34.41-45:1.9": "(These five discourses should be told in full as the previous set.) "
  },
