  "root_text": {
    "sn22.118:0.1": "Saṁyutta Nikāya 22.118 ",
    "sn22.118:0.2": "12. Dhammakathikavagga ",
    "sn22.118:0.3": "Paripucchitasutta ",
    "sn22.118:1.1": "Sāvatthinidānaṁ. ",
    "sn22.118:1.2": "“Taṁ kiṁ maññatha, bhikkhave, ",
    "sn22.118:1.3": "rūpaṁ ‘etaṁ mama, esohamasmi, eso me attā’ti samanupassathā”ti? ",
    "sn22.118:1.4": "“No hetaṁ, bhante”. ",
    "sn22.118:1.5": "“Sādhu, bhikkhave. ",
    "sn22.118:1.6": "Rūpaṁ, bhikkhave, ‘netaṁ mama, nesohamasmi, na meso attā’ti evametaṁ yathābhūtaṁ sammappaññāya daṭṭhabbaṁ. ",
    "sn22.118:1.7": "Vedanaṁ … ",
    "sn22.118:1.8": "saññaṁ … ",
    "sn22.118:1.9": "saṅkhāre … ",
    "sn22.118:1.10": "viññāṇaṁ ‘etaṁ mama, esohamasmi, eso me attā’ti samanupassathā”ti? ",
    "sn22.118:1.11": "“No hetaṁ, bhante”. ",
    "sn22.118:1.12": "“Sādhu, bhikkhave. ",
    "sn22.118:1.13": "Viññāṇaṁ, bhikkhave, ‘netaṁ mama, nesohamasmi, na meso attā’ti evametaṁ yathābhūtaṁ sammappaññāya daṭṭhabbaṁ …pe… ",
    "sn22.118:1.14": "evaṁ passaṁ …pe… ",
    "sn22.118:1.15": "nāparaṁ itthattāyāti pajānātī”ti. ",
    "sn22.118:1.16": "Chaṭṭhaṁ. "
  },
  "translation_text": {
    "sn22.118:0.1": "Linked Discourses 22.118 ",
    "sn22.118:0.2": "12. A Dhamma speaker ",
    "sn22.118:0.3": "Questioning ",
    "sn22.118:1.1": "At Sāvatthī. ",
    "sn22.118:1.2": "“What do you think, mendicants? ",
    "sn22.118:1.3": "Do you regard form like this: ‘This is mine, I am this, this is my self’?” ",
    "sn22.118:1.4": "“No, sir.” ",
    "sn22.118:1.5": "“Good, mendicants! ",
    "sn22.118:1.6": "Form should be truly seen with right understanding like this: ‘This is not mine, I am not this, this is not my self.’ ",
    "sn22.118:1.7": "Do you regard feeling … ",
    "sn22.118:1.8": "perception … ",
    "sn22.118:1.9": "choices … ",
    "sn22.118:1.10": "consciousness like this: ‘This is mine, I am this, this is my self’?” ",
    "sn22.118:1.11": "“No, sir.” ",
    "sn22.118:1.12": "“Good, mendicants! ",
    "sn22.118:1.13": "Consciousness should be truly seen with right understanding like this: ‘This is not mine, I am not this, this is not my self.’ ",
    "sn22.118:1.14": "Seeing this … ",
    "sn22.118:1.15": "They understand: ‘… there is nothing further for this place.’” "
  },
  "variant_text": {
    "sn22.118:0.3": "Paripucchitasutta → parimucchita 1 (pts1ed) "
  },
