  "root_text": {
    "sn1.15:0.1": "Saṁyutta Nikāya 1.15 ",
    "sn1.15:0.2": "2. Nandanavagga ",
    "sn1.15:0.3": "Saṇamānasutta ",
    "sn1.15:1.1": "“Ṭhite majjhanhike kāle, ",
    "sn1.15:1.2": "sannisīvesu pakkhisu; ",
    "sn1.15:1.3": "Saṇateva brahāraññaṁ, ",
    "sn1.15:1.4": "taṁ bhayaṁ paṭibhāti man”ti. ",
    "sn1.15:2.1": "“Ṭhite majjhanhike kāle, ",
    "sn1.15:2.2": "sannisīvesu pakkhisu; ",
    "sn1.15:2.3": "Saṇateva brahāraññaṁ, ",
    "sn1.15:2.4": "sā rati paṭibhāti man”ti. "
  },
  "translation_text": {
    "sn1.15:0.1": "Linked Discourses 1.15 ",
    "sn1.15:0.2": "2. The Garden of Delight ",
    "sn1.15:0.3": "Whispering ",
    "sn1.15:1.1": "“In the still of high noon, ",
    "sn1.15:1.2": "when the birds have settled down, ",
    "sn1.15:1.3": "the mighty forest itself resounds—",
    "sn1.15:1.4": "that strikes me as so scary!” ",
    "sn1.15:2.1": "“In the still of high noon, ",
    "sn1.15:2.2": "when the birds have settled down, ",
    "sn1.15:2.3": "the mighty forest itself resounds—",
    "sn1.15:2.4": "that strikes me as so delightful!” "
  },
  "variant_text": {
