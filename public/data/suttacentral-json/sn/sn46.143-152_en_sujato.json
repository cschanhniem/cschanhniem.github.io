  "root_text": {
    "sn46.143-152:0.1": "Saṁyutta Nikāya 46.143–152 ",
    "sn46.143-152:0.2": "15. Punaappamādavagga ",
    "sn46.143-152:0.3": "Punatathāgatādisutta ",
    "sn46.143-152:1.1": "…pe… ",
    "sn46.143-152:1.2": "Pannarasamo. ",
    "sn46.143-152:2.0": "Uddānaṁ ",
    "sn46.143-152:2.1": "Tathāgataṁ padaṁ kūṭaṁ, ",
    "sn46.143-152:2.2": "mūlaṁ sārena vassikaṁ; ",
    "sn46.143-152:2.3": "Rājā candimasūriyā ca, ",
    "sn46.143-152:2.4": "vatthena dasamaṁ padanti. ",
    "sn46.143-152:3.1": "(Appamādavaggo rāgavasena vitthāretabbo.) "
  },
  "translation_text": {
    "sn46.143-152:0.1": "Linked Discourses 46.143–152 ",
    "sn46.143-152:0.2": "15. Another Chapter on Diligence ",
    "sn46.143-152:0.3": "Another Series on a Realized One, Etc. ",
