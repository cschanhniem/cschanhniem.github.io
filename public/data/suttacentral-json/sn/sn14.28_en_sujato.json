  "root_text": {
    "sn14.28:0.1": "Saṁyutta Nikāya 14.28 ",
    "sn14.28:0.2": "3. Kammapathavagga ",
    "sn14.28:0.3": "Aṭṭhaṅgikasutta ",
    "sn14.28:1.1": "Sāvatthiyaṁ viharati. ",
    "sn14.28:1.2": "“Dhātusova, bhikkhave, sattā saṁsandanti samenti. ",
    "sn14.28:1.3": "Micchādiṭṭhikā micchādiṭṭhikehi saddhiṁ saṁsandanti samenti; ",
    "sn14.28:1.4": "micchāsaṅkappā …pe… ",
    "sn14.28:1.5": "micchāvācā … ",
    "sn14.28:1.6": "micchākammantā … ",
    "sn14.28:1.7": "micchāājīvā … ",
    "sn14.28:1.8": "micchāvāyāmā … ",
    "sn14.28:1.9": "micchāsatino … ",
    "sn14.28:1.10": "micchāsamādhino micchāsamādhīhi saddhiṁ saṁsandanti samenti. ",
    "sn14.28:2.1": "Sammādiṭṭhikā sammādiṭṭhikehi saddhiṁ saṁsandanti samenti; ",
    "sn14.28:2.2": "sammāsaṅkappā …pe… ",
    "sn14.28:2.3": "sammāvācā … ",
    "sn14.28:2.4": "sammākammantā … ",
    "sn14.28:2.5": "sammāājīvā … ",
    "sn14.28:2.6": "sammāvāyāmā … ",
    "sn14.28:2.7": "sammāsatino … ",
    "sn14.28:2.8": "sammāsamādhino sammāsamādhīhi saddhiṁ saṁsandanti samentī”ti. ",
    "sn14.28:2.9": "Chaṭṭhaṁ. "
  },
  "translation_text": {
    "sn14.28:0.1": "Linked Discourses 14.28 ",
    "sn14.28:0.2": "3. Ways of Performing Deeds ",
    "sn14.28:0.3": "The Eightfold Path ",
    "sn14.28:1.1": "At Sāvatthī. ",
    "sn14.28:1.2": "“Mendicants, sentient beings join together and converge because of an element: ",
    "sn14.28:1.3": "those of wrong view with those of wrong view … ",
    "sn14.28:1.4": "wrong thought … ",
    "sn14.28:1.5": "wrong speech … ",
    "sn14.28:1.6": "wrong action … ",
    "sn14.28:1.7": "wrong livelihood … ",
    "sn14.28:1.8": "wrong effort … ",
    "sn14.28:1.9": "wrong mindfulness … ",
    "sn14.28:1.10": "wrong immersion … ",
    "sn14.28:2.1": "Those who have right view … ",
    "sn14.28:2.2": "right thought … ",
    "sn14.28:2.3": "right speech … ",
    "sn14.28:2.4": "right action … ",
    "sn14.28:2.5": "right livelihood … ",
    "sn14.28:2.6": "right effort … ",
    "sn14.28:2.7": "right mindfulness … ",
    "sn14.28:2.8": "right immersion with those who have right immersion.” "
  },
