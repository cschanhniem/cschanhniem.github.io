  "root_text": {
    "sn46.70:0.1": "Saṁyutta Nikāya 46.70 ",
    "sn46.70:0.2": "8. Nirodhavagga ",
    "sn46.70:0.3": "Anabhiratisutta ",
    "sn46.70:1.1": "“Sabbaloke anabhiratisaññā, bhikkhave …pe…” ",
    "sn46.70:1.2": "catutthaṁ. "
  },
  "translation_text": {
    "sn46.70:0.1": "Linked Discourses 46.70 ",
    "sn46.70:0.2": "8. Cessation ",
    "sn46.70:0.3": "Dissatisfaction ",
    "sn46.70:1.1": "“Mendicants, when the perception of dissatisfaction with the whole world is developed and cultivated it’s very fruitful and beneficial. …” "
  },
  "variant_text": {
