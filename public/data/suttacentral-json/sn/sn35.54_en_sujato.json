  "root_text": {
    "sn35.54:0.1": "Saṁyutta Nikāya 35.54 ",
    "sn35.54:0.2": "6. Avijjāvagga ",
    "sn35.54:0.3": "Saṁyojanappahānasutta ",
    "sn35.54:1.1": "“Kathaṁ nu kho, bhante, jānato, kathaṁ passato, saṁyojanā pahīyantī”ti? ",
    "sn35.54:1.2": "“Cakkhuṁ kho, bhikkhu, aniccato jānato passato saṁyojanā pahīyanti. ",
    "sn35.54:1.3": "Rūpe … ",
    "sn35.54:1.4": "cakkhuviññāṇaṁ … ",
    "sn35.54:1.5": "cakkhusamphassaṁ … ",
    "sn35.54:1.6": "yampidaṁ cakkhusamphassapaccayā uppajjati vedayitaṁ sukhaṁ vā dukkhaṁ vā adukkhamasukhaṁ vā tampi aniccato jānato passato saṁyojanā pahīyanti. ",
    "sn35.54:1.7": "Sotaṁ … ",
    "sn35.54:1.8": "ghānaṁ … ",
    "sn35.54:1.9": "jivhaṁ … ",
    "sn35.54:1.10": "kāyaṁ … ",
    "sn35.54:1.11": "manaṁ … ",
    "sn35.54:1.12": "dhamme … ",
    "sn35.54:1.13": "manoviññāṇaṁ … ",
    "sn35.54:1.14": "manosamphassaṁ … ",
    "sn35.54:1.15": "yampidaṁ manosamphassapaccayā uppajjati vedayitaṁ sukhaṁ vā dukkhaṁ vā adukkhamasukhaṁ vā tampi aniccato jānato passato saṁyojanā pahīyanti. ",
    "sn35.54:1.16": "Evaṁ kho, bhikkhu, jānato evaṁ passato saṁyojanā pahīyantī”ti. ",
    "sn35.54:1.17": "Dutiyaṁ. "
  },
  "translation_text": {
    "sn35.54:0.1": "Linked Discourses 35.54 ",
    "sn35.54:0.2": "6. Ignorance ",
    "sn35.54:0.3": "Giving Up Fetters ",
    "sn35.54:1.1": "“Sir, how does one know and see so that the fetters are given up?” ",
    "sn35.54:1.2": "“Mendicant, knowing and seeing the eye as impermanent, the fetters are given up …” ",
