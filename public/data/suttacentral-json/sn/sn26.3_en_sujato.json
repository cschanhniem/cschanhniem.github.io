  "root_text": {
    "sn26.3:0.1": "Saṁyutta Nikāya 26.3 ",
    "sn26.3:0.2": "1. Uppādavagga ",
    "sn26.3:0.3": "Viññāṇasutta ",
    "sn26.3:1.1": "Sāvatthinidānaṁ. ",
    "sn26.3:1.2": "“Yo kho, bhikkhave, cakkhuviññāṇassa uppādo ṭhiti …pe… ",
    "sn26.3:1.3": "jarāmaraṇassa pātubhāvo …pe… ",
    "sn26.3:1.4": "yo manoviññāṇassa uppādo ṭhiti …pe… ",
    "sn26.3:1.5": "jarāmaraṇassa pātubhāvo. ",
    "sn26.3:1.6": "Yo ca kho, bhikkhave, cakkhuviññāṇassa nirodho …pe… ",
    "sn26.3:1.7": "jarāmaraṇassa atthaṅgamo …pe… ",
    "sn26.3:1.8": "yo manoviññāṇassa nirodho …pe… ",
    "sn26.3:1.9": "jarāmaraṇassa atthaṅgamo”ti. ",
    "sn26.3:1.10": "Tatiyaṁ. "
  },
  "translation_text": {
    "sn26.3:0.1": "Linked Discourses 26.3 ",
    "sn26.3:0.2": "1. Arising ",
    "sn26.3:0.3": "Consciousness ",
    "sn26.3:1.1": "At Sāvatthī. ",
    "sn26.3:1.2": "“Mendicants, the arising of eye consciousness … ",
    "sn26.3:1.3": "",
    "sn26.3:1.4": "mind consciousness … ",
    "sn26.3:1.5": "is the manifestation of old age and death. ",
    "sn26.3:1.6": "The cessation of eye consciousness … ",
    "sn26.3:1.7": "",
    "sn26.3:1.8": "mind consciousness … ",
    "sn26.3:1.9": "is the disappearance of old age and death.” "
  },
