  "root_text": {
    "sn55.74:0.1": "Saṁyutta Nikāya 55.74 ",
    "sn55.74:0.2": "7. Mahāpaññavagga ",
    "sn55.74:0.3": "Nibbedhikapaññāsutta ",
    "sn55.74:1.1": "“… Nibbedhikapaññatāya saṁvattanti. ",
    "sn55.74:1.2": "Katame cattāro? ",
    "sn55.74:1.3": "Sappurisasaṁsevo, saddhammassavanaṁ, yonisomanasikāro, dhammānudhammappaṭipatti—",
    "sn55.74:1.4": "ime kho, bhikkhave, cattāro dhammā bhāvitā bahulīkatā nibbedhikapaññatāya saṁvattantī”ti. ",
    "sn55.74:1.5": "Terasamaṁ. ",
    "sn55.74:1.6": "Mahāpaññavaggo sattamo. ",
    "sn55.74:2.0": "Tassuddānaṁ ",
    "sn55.74:2.1": "Mahā puthu vipula gambhīraṁ, ",
    "sn55.74:2.2": "Appamatta bhūri bāhullaṁ; ",
    "sn55.74:2.3": "Sīgha lahu hāsa javana, ",
    "sn55.74:2.4": "Tikkha nibbedhikāya cāti. ",
    "sn55.74:2.5": "Sotāpattisaṁyuttaṁ ekādasamaṁ. "
  },
  "translation_text": {
    "sn55.74:0.1": "Linked Discourses 55.74 ",
    "sn55.74:0.2": "7. Great Wisdom ",
    "sn55.74:0.3": "Penetrating Wisdom ",
    "sn55.74:1.1": "“Mendicants, when four things are developed and cultivated they lead to penetrating wisdom. ",
    "sn55.74:1.2": "What four? ",
    "sn55.74:1.3": "Associating with true persons, listening to the true teaching, rational application of mind, and practicing in line with the teaching. ",
    "sn55.74:1.4": "When these four things are developed and cultivated they lead to penetrating wisdom.” ",
