  "root_text": {
    "sn56.75:0.1": "Saṁyutta Nikāya 56.75 ",
    "sn56.75:0.2": "8. Dutiyaāmakadhaññapeyyālavagga ",
    "sn56.75:0.3": "Pesuññasutta ",
    "sn56.75:1.1": "… “Evameva kho, bhikkhave, appakā te sattā ye pisuṇāya vācāya paṭiviratā; atha kho eteva bahutarā sattā ye pisuṇāya vācāya appaṭiviratā …pe…. ",
    "sn56.75:1.2": "Pañcamaṁ. "
  },
  "translation_text": {
    "sn56.75:0.1": "Linked Discourses 56.75 ",
    "sn56.75:0.2": "8. Abbreviated Texts on Raw Grain ",
    "sn56.75:0.3": "Divisive Speech ",
    "sn56.75:1.1": "“… the sentient beings who refrain from divisive speech are few, while those who don’t refrain are many. …” "
  },
  "variant_text": {
    "sn56.75:0.3": "Pesuññasutta → pisuṇavācāsuttaṁ (bj); pesuṇaṁ (pts1ed) "
  },
