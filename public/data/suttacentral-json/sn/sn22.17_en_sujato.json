  "root_text": {
    "sn22.17:0.1": "Saṁyutta Nikāya 22.17 ",
    "sn22.17:0.2": "2. Aniccavagga ",
    "sn22.17:0.3": "Yadanattāsutta ",
    "sn22.17:1.1": "Sāvatthinidānaṁ. ",
    "sn22.17:1.2": "“Rūpaṁ, bhikkhave, anattā. ",
    "sn22.17:1.3": "Yadanattā taṁ ‘netaṁ mama, nesohamasmi, na meso attā’ti evametaṁ yathābhūtaṁ sammappaññāya daṭṭhabbaṁ. ",
    "sn22.17:1.4": "Vedanā anattā … ",
    "sn22.17:1.5": "saññā anattā … ",
    "sn22.17:1.6": "saṅkhārā anattā … ",
    "sn22.17:1.7": "viññāṇaṁ anattā. ",
    "sn22.17:1.8": "Yadanattā taṁ ‘netaṁ mama, nesohamasmi, na meso attā’ti evametaṁ yathābhūtaṁ sammappaññāya daṭṭhabbaṁ. ",
    "sn22.17:1.9": "Evaṁ passaṁ, bhikkhave …pe… ",
    "sn22.17:1.10": "nāparaṁ itthattāyā’ti pajānātī”ti. ",
    "sn22.17:1.11": "Chaṭṭhaṁ. "
  },
  "translation_text": {
    "sn22.17:0.1": "Linked Discourses 22.17 ",
    "sn22.17:0.2": "2. Impermanence ",
    "sn22.17:0.3": "That Which is Not-Self ",
    "sn22.17:1.1": "At Sāvatthī. ",
    "sn22.17:1.2": "“Mendicants, form is not-self. ",
    "sn22.17:1.3": "And what’s not-self should be truly seen with right understanding like this: ‘This is not mine, I am not this, this is not my self.’ ",
    "sn22.17:1.4": "Feeling is not-self … ",
    "sn22.17:1.5": "Perception is not-self … ",
    "sn22.17:1.6": "Choices are not-self … ",
    "sn22.17:1.7": "Consciousness is not-self. ",
    "sn22.17:1.8": "And what’s not-self should be truly seen with right understanding like this: ‘This is not mine, I am not this, this is not my self.’ ",
    "sn22.17:1.9": "Seeing this … ",
    "sn22.17:1.10": "They understand: ‘… there is nothing further for this place.’” "
  },
  "variant_text": {
    "sn22.17:0.3": "Yadanattāsutta → yadanattasuttaṁ (bj); yad anicca 3 (pts1ed) "
  },
