  "root_text": {
    "sn53.35-44:0.1": "Saṁyutta Nikāya 53.35 ",
    "sn53.35-44:0.2": "4. Esanāvagga ",
    "sn53.35-44:0.3": "Esanāvagga ",
    "sn53.35-44:1.1": "(Esanāvaggo vitthāretabbo.) ",
    "sn53.35-44:2.0": "Tassuddānaṁ ",
    "sn53.35-44:2.1": "Esanā vidhā āsavo, ",
    "sn53.35-44:2.2": "Bhavo ca dukkhatā tisso; ",
    "sn53.35-44:2.3": "Khilaṁ malañca nīgho ca, ",
    "sn53.35-44:2.4": "Vedanā taṇhā tasinā cāti. "
  },
  "translation_text": {
    "sn53.35-44:0.1": "Linked Discourses 53.35–44 ",
    "sn53.35-44:0.2": "4. Searches ",
    "sn53.35-44:0.3": "Searches ",
    "sn53.35-44:1.1": "(Tell in full as in the chapter on searches at SN 45.161–170.) ",
    "sn53.35-44:2.1": "Searches, discriminations, defilements, ",
    "sn53.35-44:2.2": "states of existence, three kinds of suffering, ",
    "sn53.35-44:2.3": "barrenness, stains, and troubles, ",
    "sn53.35-44:2.4": "feelings, craving, and thirst. "
  },
