  "root_text": {
    "sn55.50:0.1": "Saṁyutta Nikāya 55.50 ",
    "sn55.50:0.2": "5. Sagāthakapuññābhisandavagga ",
    "sn55.50:0.3": "Aṅgasutta ",
    "sn55.50:1.1": "“Cattārimāni, bhikkhave, sotāpattiyaṅgāni. ",
    "sn55.50:1.2": "Katamāni cattāri? ",
    "sn55.50:1.3": "Sappurisasaṁsevo, saddhammassavanaṁ, yonisomanasikāro, dhammānudhammappaṭipatti—",
    "sn55.50:1.4": "imāni kho, bhikkhave, cattāri sotāpattiyaṅgānī”ti. ",
    "sn55.50:1.5": "Dasamaṁ. ",
    "sn55.50:1.6": "Sagāthakapuññābhisandavaggo pañcamo. ",
    "sn55.50:2.0": "Tassuddānaṁ ",
    "sn55.50:2.1": "Abhisandā tayo vuttā, ",
    "sn55.50:2.2": "Duve mahaddhanena ca; ",
    "sn55.50:2.3": "Suddhaṁ nandiyaṁ bhaddiyaṁ, ",
    "sn55.50:2.4": "Mahānāmaṅgena te dasāti. "
  },
  "translation_text": {
    "sn55.50:0.1": "Linked Discourses 55.50 ",
    "sn55.50:0.2": "5. Overflowing Merit, With Verses ",
    "sn55.50:0.3": "Factors ",
    "sn55.50:1.1": "“Mendicants, there are these four factors of stream-entry. ",
    "sn55.50:1.2": "What four? ",
    "sn55.50:1.3": "Associating with true persons, listening to the true teaching, rational application of mind, and practicing in line with the teaching. ",
    "sn55.50:1.4": "These are the four factors of stream-entry.” ",
