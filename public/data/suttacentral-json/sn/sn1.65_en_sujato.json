  "root_text": {
    "sn1.65:0.1": "Saṁyutta Nikāya 1.65 ",
    "sn1.65:0.2": "7. Addhavagga ",
    "sn1.65:0.3": "Bandhanasutta ",
    "sn1.65:1.1": "“Kiṁsu sambandhano loko, ",
    "sn1.65:1.2": "kiṁsu tassa vicāraṇaṁ; ",
    "sn1.65:1.3": "Kissassu vippahānena, ",
    "sn1.65:1.4": "sabbaṁ chindati bandhanan”ti. ",
    "sn1.65:2.1": "“Nandīsambandhano loko, ",
    "sn1.65:2.2": "vitakkassa vicāraṇaṁ; ",
    "sn1.65:2.3": "Taṇhāya vippahānena, ",
    "sn1.65:2.4": "sabbaṁ chindati bandhanan”ti. "
  },
  "translation_text": {
    "sn1.65:0.1": "Linked Discourses 1.65 ",
    "sn1.65:0.2": "7. Overcome ",
    "sn1.65:0.3": "Bonds ",
    "sn1.65:1.1": "“What binds the world? ",
    "sn1.65:1.2": "How does it travel about? ",
    "sn1.65:1.3": "With the giving up of what ",
    "sn1.65:1.4": "are all bonds severed?” ",
    "sn1.65:2.1": "“Delight binds the world. ",
    "sn1.65:2.2": "It travels about by means of thought. ",
    "sn1.65:2.3": "With the giving up of craving ",
    "sn1.65:2.4": "all bonds are severed.” "
  },
